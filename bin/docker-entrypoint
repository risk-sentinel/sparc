#!/usr/bin/env bash
set -euo pipefail

# Verify jemalloc is active (set via Dockerfile ENV, see issue #380)
if [ -n "${LD_PRELOAD:-}" ]; then
    echo "jemalloc: active (LD_PRELOAD=$LD_PRELOAD)"
else
    echo "WARNING: jemalloc not active — memory fragmentation may occur"
fi

# Wait for PostgreSQL (safe for all services)
# Parse DATABASE_URL for host/port if available, fallback to docker-compose defaults
DB_HOST=$(echo "${DATABASE_URL:-}" | sed 's|.*@\(.*\):.*|\1|')
DB_PORT=$(echo "${DATABASE_URL:-}" | sed 's|.*:\([0-9]*\)/.*|\1|')
echo "Waiting for PostgreSQL at ${DB_HOST:-db}:${DB_PORT:-5432}..."
until pg_isready -h "${DB_HOST:-db}" -p "${DB_PORT:-5432}" -t 1 >/dev/null 2>&1; do
    echo "Postgres is not ready yet - sleeping..."
    sleep 2
done
echo "PostgreSQL is ready!"

# Only run db:prepare + seeds when starting the Rails server (web container)
# This prevents concurrent migration errors from sidekiq/console/etc.
# CMD may be: ["./bin/rails", "server"] or ["./bin/thrust", "./bin/rails", "server"]
if [[ "$*" == *"rails"*"server"* ]]; then
    echo "Running database preparation (create/migrate all databases)..."
    bundle exec rails db:prepare
    bundle exec rails db:prepare:all 2>/dev/null || true

    # Enable Solid Queue in Puma for single-container deployments (ECS)
    export SOLID_QUEUE_IN_PUMA="${SOLID_QUEUE_IN_PUMA:-true}"

    # Admin bootstrap runs independently of seeds — always ensures admin exists.
    # Idempotent: creates if missing, fixes admin flag if unset, never resets passwords.
    echo "Bootstrapping admin account..."
    bundle exec rails sparc:bootstrap_admin || echo "WARNING: Admin bootstrap failed (non-fatal)"

    # Always run seeds — SeedRunner tracks completion and skips already-done sections.
    # Failed sections from previous deploys will automatically retry.
    echo "Running seed completeness check..."
    bundle exec rails db:seed
fi

# Explicit seed trigger for non-web containers or re-seeding
if [ "${SPARC_RUN_SEEDS:-false}" = "true" ]; then
    echo "SPARC_RUN_SEEDS=true — running database seeds..."
    bundle exec rails db:seed
fi

# Hand over to the actual command
echo "Starting: $@"
exec "$@"