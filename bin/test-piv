#!/usr/bin/env bash
# #790 — end-to-end PIV/CAC proof. Stands up an nginx mTLS proxy in front of the
# app, mints a software-PIV client certificate, provisions a matching user, and
# drives the real flow BOTH directions: a valid card signs in; a request with no
# card is refused (fail-closed). This is what the unit specs cannot prove — that
# the header contract with a real gateway actually works.
#
#   bin/test-piv
#
# NIST 800-53 IA-2 / IA-2(12). See docs/PIV_IDENTITY_MAPPING.md.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

BASE="docker-compose.ubi9.yaml"
PIV="docker-compose.piv.yaml"
CERTS="$ROOT/tmp/piv-certs"
export SPARC_PIV_CERT_DIR="$CERTS"
PROXY="https://localhost:8443"
EDIPI="1234567890"
PIV_EMAIL="john.doe@mail.mil"

compose() { docker compose -f "$BASE" -f "$PIV" "$@"; }

cleanup() {
  echo "==> tearing down"
  compose down -v >/dev/null 2>&1 || true
}
trap cleanup EXIT

echo "==> generating the test CA + software-PIV client certificate"
bash dev/piv/gen-software-piv.sh "$CERTS"

echo "==> bringing up web + db + nginx PIV proxy"
compose up -d >/dev/null

echo "==> waiting for the app to serve"
for i in $(seq 1 60); do
  code=$(curl -s -o /dev/null -w '%{http_code}' http://localhost:3000/ 2>/dev/null || echo 000)
  { [ "$code" = "302" ] || [ "$code" = "200" ]; } && break
  [ "$i" = "60" ] && { echo "!! app never served"; compose logs web | tail -30; exit 1; }
  sleep 5
done

echo "==> waiting for the proxy"
for i in $(seq 1 30); do
  curl -sk -o /dev/null "$PROXY/login" 2>/dev/null && break
  [ "$i" = "30" ] && { echo "!! proxy never served"; compose logs piv-proxy | tail -20; exit 1; }
  sleep 2
done

echo "==> provisioning a user with a PIV identity (uid = EDIPI ${EDIPI})"
compose exec -T web bin/rails runner "
  u = User.find_or_create_by!(email: '${PIV_EMAIL}') do |x|
    x.password = 'Piv-Test-Pass-9!'
    x.password_confirmation = 'Piv-Test-Pass-9!'
    x.name = 'John Doe' if x.respond_to?(:name=)
  end
  u.update!(status: 'active') if u.respond_to?(:status)
  u.update!(must_reset_password: false) if u.respond_to?(:must_reset_password)
  Identity.find_or_create_by!(provider: 'piv', uid: '${EDIPI}') { |i| i.user = u }
  puts \"provisioned user=#{u.id} identity_uid=${EDIPI}\"
" 2>/dev/null | grep provisioned

pass=0; fail=0
check() { # desc expected_pass actual_pass
  if [ "$2" = "$3" ]; then echo "  [PASS] $1"; pass=$((pass+1)); else echo "  [FAIL] $1 (expected $2, got $3)"; fail=$((fail+1)); fi
}

echo
echo "POSITIVE — valid software PIV must sign in"
# The verified cert flows proxy → app; success redirects to / and sets a session.
hdrs=$(curl -sk -D - -o /dev/null \
  --cert "$CERTS/client.crt" --key "$CERTS/client.key" --cacert "$CERTS/ca.crt" \
  "$PROXY/auth/piv")
loc=$(printf '%s' "$hdrs" | tr -d '\r' | awk 'tolower($1)=="location:"{print $2}')
setcookie=$(printf '%s' "$hdrs" | grep -ci 'set-cookie:.*session' || true)
echo "    → Location: ${loc:-<none>}   session-cookie-set: ${setcookie}"
# Signed in ⇒ redirected somewhere OTHER than /login, and a session cookie set.
signed_in=$([ "$setcookie" -ge 1 ] && ! printf '%s' "$loc" | grep -q '/login' && echo yes || echo no)
check "valid PIV card establishes a session" "yes" "$signed_in"

echo
echo "NEGATIVE — no card must be refused (fail-closed)"
loc2=$(curl -sk -D - -o /dev/null --cacert "$CERTS/ca.crt" "$PROXY/auth/piv" \
  | tr -d '\r' | awk 'tolower($1)=="location:"{print $2}')
echo "    → Location: ${loc2:-<none>}"
refused=$(printf '%s' "$loc2" | grep -q '/login' && echo yes || echo no)
check "no client cert is rejected to /login" "yes" "$refused"

echo
echo "NEGATIVE — forged verify header must NOT be trusted (client cannot inject it)"
# Send a client-supplied X-SSL-Client-Verify: SUCCESS with NO cert. nginx
# proxy_set_header overwrites it from the (empty) handshake, so the app sees NONE.
loc3=$(curl -sk -D - -o /dev/null --cacert "$CERTS/ca.crt" \
  -H "X-SSL-Client-Verify: SUCCESS" -H "X-SSL-Client-Cert: forged" \
  "$PROXY/auth/piv" | tr -d '\r' | awk 'tolower($1)=="location:"{print $2}')
echo "    → Location: ${loc3:-<none>}"
forged_refused=$(printf '%s' "$loc3" | grep -q '/login' && echo yes || echo no)
check "forged verify header is stripped and rejected" "yes" "$forged_refused"

echo
echo "==> ${pass} passed, ${fail} failed"
[ "$fail" -eq 0 ]
