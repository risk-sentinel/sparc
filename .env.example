# ============================================================================
# SPARC — Environment Variables (Development)
# ============================================================================
# Copy this file to .env and customize as needed.
# See docs/ENVIRONMENT_VARIABLES.md for the full configuration reference.
#
# In development, dotenv-rails loads this file automatically.
# In production, set these via your orchestrator (Docker, ECS, K8s, etc.).
# ============================================================================

# ── Cryptographic Master Secret ────────────────────────────────────────────
# SPARC_HASH is the per-instance master secret used by SparcKeyDerivation
# to derive purpose-specific keys (federation peer credential encryption,
# bundle signing key derivation, etc.).
#
# Requirements: ≥32 random bytes (recommend `openssl rand -base64 48`).
# Production: provisioned by sparc-iac into AWS Secrets Manager and
#             injected as an env var on the ECS task. Rotation is
#             coordinated through that pipeline.
# Dev/test: optional — when unset SPARC falls back to Rails secret_key_base.
# SPARC_HASH=
#
# ── Authoritative Source Fetching (#372) ───────────────────────────────────
# When enabled, creating a back-matter resource with `auto_fetch: true`
# triggers an outbound HTTPS GET against the resource's href and stores
# the body as an Evidence attachment. Disabled by default for air-gapped
# and restricted-egress deployments.
# SPARC_AUTHORITATIVE_FETCH_ENABLED=false
#
# ── Database ────────────────────────────────────────────────────────────────
# DATABASE_URL takes priority over individual vars when set.
# DATABASE_URL=postgresql://postgres:password@localhost:5432/sparc_development

# Individual fallbacks (used when DATABASE_URL is not set):
# SPARC_DB_HOST=localhost
# SPARC_DB_PORT=5432
# SPARC_DB_NAME=sparc
# SPARC_DB_USER=
# SPARC_DB_PASSWORD=
# SPARC_DB_SSLMODE=prefer

# ── Application ─────────────────────────────────────────────────────────────
# SPARC_APP_URL=http://localhost:3000
# SPARC_APP_NAME=SPARC
# SPARC_CONTACT_EMAIL=
# SPARC_WELCOME_TEXT=Welcome to SPARC
# SPARC_RESOURCES='[{"display_text":"FedRAMP 20x","href":"https://www.fedramp.gov/20x"},{"display_text":"NIST OSCAL","href":"https://pages.nist.gov/OSCAL/"},{"display_text":"MITRE SAF","href":"https://saf.mitre.org/"}]'

# ── Organization ──────────────────────────────────────────────────────────
# SPARC_ORG_NAME=Default Organization
# SPARC_ORG_DESCRIPTION=
# SPARC_ORG_ADDRESS=
# SPARC_ORG_CONTACT_PERSON=
# SPARC_ORG_CONTACT_EMAIL=

# ── User Lifecycle ────────────────────────────────────────────────────────
# SPARC_INACTIVITY_DAYS=30        # Days of inactivity before auto-deactivation
# SPARC_PASSWORD_EXPIRY_DAYS=30   # Days before password expires (local-auth only)

# ── Authentication ──────────────────────────────────────────────────────────
# All auth methods default to disabled. Enable one or more to activate login.
# Local login is required for admin bootstrap and password-based authentication.
SPARC_ENABLE_LOCAL_LOGIN=true
# SPARC_ENABLE_USER_REGISTRATION=false
# SPARC_SESSION_TIMEOUT_MINUTES=60
# SPARC_ADMIN_EMAIL=admin@sparc.local  # Email for bootstrapped admin account

# ── Admin Credential Rotation (#402, #403) ────────────────────────────────
# See docs/ADMIN_CREDENTIAL_ROTATION.md for the full rotation flow.
#
# In production (ECS), SPARC_ADMIN_PASSWORD is injected by ECS from the
# admin-credentials Secrets Manager secret; bootstrap_admin reconciles
# the DB to match on every container start.
# SPARC_ADMIN_PASSWORD=
#
# Enable POST /api/v1/admin/refresh_credentials (off by default, fail-closed).
# Required for the Lambda-driven rotation path.
# SPARC_ADMIN_REFRESH_ENABLED=false
#
# Outside production, the sparc:rotate_admin_credentials rake task refuses
# to run unless this is set to "1".
# SPARC_ALLOW_CRED_ROTATION=
#
# Break-glass only — set to "1" to print the rotated password from the
# rake task. Be mindful of log retention if you use this.
# SPARC_PRINT_ROTATED_PASSWORD=

# ── API Authentication Mode ───────────────────────────────────────────────
# Controls which auth method the REST API accepts (mutually exclusive):
#   local  — SPARC-issued Bearer tokens only (default)
#   oidc   — OIDC/Okta JWT tokens only (requires SPARC_OIDC_ISSUER_URL)
#   hybrid — JWTs for humans + SPARC tokens for service accounts (pipelines)
# SPARC_API_AUTH=local

# ── GitHub OAuth ──────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/organizations/YOUR_ORG/settings/applications
# Set callback URL to: http://localhost:3000/auth/github/callback
# SPARC_GITHUB_CLIENT_ID=
# SPARC_GITHUB_CLIENT_SECRET=

# ── GitLab OAuth ──────────────────────────────────────────────────────────
# Create an application at https://gitlab.com/-/user_settings/applications
# Set callback URL to: http://localhost:3000/auth/gitlab/callback
# Scopes: read_user
# SPARC_GITLAB_CLIENT_ID=
# SPARC_GITLAB_CLIENT_SECRET=
# SPARC_GITLAB_SITE=https://gitlab.com  # Change for self-hosted GitLab

# ── OIDC / OAuth2 (Okta, Keycloak, Entra ID) ─────────────────────────────
# See docs/OKTA_DEV_SETUP.md for Okta configuration guide
# SPARC_ENABLE_OIDC=false
# SPARC_OIDC_ISSUER_URL=
# SPARC_OIDC_CLIENT_ID=
# SPARC_OIDC_CLIENT_SECRET=
# SPARC_OIDC_REDIRECT_URI=
# SPARC_OIDC_SCOPES=openid profile email
# SPARC_OIDC_PROVIDER_TITLE=SSO
# SPARC_OIDC_FORCE_MFA=false

# ── LDAP ────────────────────────────────────────────────────────────────────
# SPARC_ENABLE_LDAP=false
# SPARC_LDAP_HOST=
# SPARC_LDAP_PORT=636
# SPARC_LDAP_ENCRYPTION=simple_tls
# SPARC_LDAP_BIND_DN=
# SPARC_LDAP_BIND_PASSWORD=
# SPARC_LDAP_BASE=
# SPARC_LDAP_ATTRIBUTE=uid

# ── Logging ─────────────────────────────────────────────────────────────────
# SPARC_LOG_LEVEL=info
# SPARC_LOG_TO_STDOUT=false
# SPARC_STRUCTURED_LOGGING=false

# ── Email / SMTP ────────────────────────────────────────────────────────────
# SPARC_ENABLE_SMTP=false
# SPARC_SMTP_ADDRESS=
# SPARC_SMTP_PORT=587
# SPARC_SMTP_USERNAME=
# SPARC_SMTP_PASSWORD=
# SPARC_SMTP_AUTH=plain
# SPARC_SMTP_STARTTLS_AUTO=true
# SPARC_SMTP_FROM_ADDRESS=

# ── Security ────────────────────────────────────────────────────────────────
# SECRET_KEY_BASE=  (auto-generated in dev; required in production)
# FORCE_SSL=false   (set to true in production)

# ── Consent Banner ──────────────────────────────────────────────────────────
# Show a mandatory consent/warning banner modal before login options appear.
# The banner message is loaded from the file at SPARC_BANNER_MESSAGE.
# Relative paths are resolved against Rails.root (e.g., docs/sample-consent-banner.html).
# A sample file is provided at docs/sample-consent-banner.html.
# SPARC_BANNER_ENABLED=false
# SPARC_BANNER_MESSAGE=docs/sample-consent-banner.html

# ── Roles for Organization and Auth Boundaries ──────────────────────────────
# Default values will exist if not set
# Organization Roles: Org Admin (always), Head of Agency, Senior Accountable
# Official, CIO, CISO, Risk Executive, Chief Acqusition Officer, Senior Agency
# Official for Privacy, Member.
# Auth Boundary Roles: Assessor / 3PAO, Authorizing Official, CISO, ISSO, Team
# Member, System Owner (SO), View Only
# SPARC_ORGANIZATION_ROLES=Head of Agency, Senior Accountable, Official, CIO, CISO, Risk Executive, Chief Acqusition Officer, Senior Agency Official for Privacy, Member, Test
# SPARC_AUTH_BOUNDARY_ROLES=Assessor / 3PAO, Authorizing Official (AO), CISO, ISSO, Team Member, System Owner (SO), View Only

# ── Development HTTPS ─────────────────────────────────────────────────────
# Enable HTTPS in development with mkcert certificates.
# Run `bin/setup-ssl` first to generate certificates.
# SSL_DEV=true                  # Enable HTTPS on port 3443
# SSL_PORT=3443                 # Override HTTPS port (default: 3443)

# ── Service Account Lifecycle ─────────────────────────────────────────────
# SPARC_SA_INACTIVITY_DAYS=90  # Days before unused service account is auto-disabled

# ── AWS Secrets Manager ────────────────────────────────────────────────────
# Two-secret strategy for ECS/EC2 deployments (see docs/ENVIRONMENT_VARIABLES.md):
#   Secret 1: admin-credentials (JSON {"password":"..."}; MFA-gated for
#             Console retrieval. ECS injects the password field as
#             SPARC_ADMIN_PASSWORD; the rake task writes back to it via
#             PutSecretValue. SPARC's task role does NOT have
#             GetSecretValue on this secret.)
#   Secret 2: app-config (JSON blob with all other config — read at boot)
# SPARC_AWS_SECRETS_ENABLED=false
# SPARC_APP_CONFIG_SECRET_ARN=
# SPARC_ADMIN_CREDENTIALS_SECRET_ARN=

# ── AWS IAM Database Authentication ──────────────────────────────────────
# Use IAM auth tokens instead of static DB passwords (requires RDS IAM auth enabled)
# SPARC_AWS_IAM_DB_AUTH=false
# SPARC_AWS_REGION=us-east-1

# ── AWS Labs CDEF Fetch (#466) ───────────────────────────────────────────
# Runtime ingestion of OSCAL Component Definitions from
# awslabs/oscal-content-for-aws-services. Apache 2.0 attribution is
# maintained in NOTICE + LICENSES/AWS-LABS-OSCAL-CONTENT-LICENSE +
# docs/compliance/THIRD_PARTY_NOTICES.md.
#
# Default OFF so air-gapped tenants are unaffected. Imported CDEFs are
# read-only; users click "Copy for editing" to amend (clones are isolated
# from future refreshes).
# SPARC_AWS_LABS_CDEF_ENABLED=false
# SPARC_AWS_LABS_CDEF_REPO=awslabs/oscal-content-for-aws-services
# SPARC_AWS_LABS_CDEF_BRANCH=main
# SPARC_AWS_LABS_OSCAL_VERSIONS=        # CSV; defaults to loaded OscalSchema versions
# SPARC_AWS_LABS_CDEF_REFRESH_INTERVAL_DAYS=7   # clamped to 1..90
# SPARC_AWS_LABS_GITHUB_TOKEN=          # optional PAT — raises rate limit 60→5000/hr

# ── Docker Seed Control ──────────────────────────────────────────────────
# Set to true to explicitly run db:seed on container start (non-web containers)
# Web containers run db:prepare automatically which includes seeding
# SPARC_RUN_SEEDS=false
# SPARC_SEED_DEMO=true  # Set to true to include demo data (SSPs, SARs, orgs, evidence)
# SPARC_SEED_MODE=full  # traditional|20x|full — controls which demo sample data is seeded

# ── DISA CCI Retrieval ────────────────────────────────────────────────────────────────
# SPARC_CCI_REVS= # (defualts to 4, 5 to get 800-53 Rev4 and Rev5 CCI's)
# SPARC_DISA_CCI_URL= # Defaults to https://dl.dod.cyber.mil/wp-content/uploads/stigs/zip/U_CCI_List.zip