# ============================================================================
# SPARC — Environment Variables (Development)
# ============================================================================
# Copy this file to .env and customize as needed.
# See docs/ENVIRONMENT_VARIABLES.md for the full configuration reference.
#
# In development, dotenv-rails loads this file automatically.
# In production, set these via your orchestrator (Docker, ECS, K8s, etc.).
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# DATABASE_URL takes priority over individual vars when set.
# DATABASE_URL=postgresql://postgres:password@localhost:5432/sparc_development

# Individual fallbacks (used when DATABASE_URL is not set):
# SPARC_DB_HOST=localhost
# SPARC_DB_PORT=5432
# SPARC_DB_NAME=sparc
# SPARC_DB_USER=
# SPARC_DB_PASSWORD=
# SPARC_DB_SSLMODE=prefer

# ── Application ─────────────────────────────────────────────────────────────
# SPARC_APP_URL=http://localhost:3000
# SPARC_APP_NAME=SPARC
# SPARC_CONTACT_EMAIL=
# SPARC_WELCOME_TEXT=Welcome to SPARC

# ── Authentication ──────────────────────────────────────────────────────────
# All auth methods default to disabled. Enable one or more to activate login.
# SPARC_ENABLE_LOCAL_LOGIN=false
# SPARC_ENABLE_USER_REGISTRATION=false
# SPARC_SESSION_TIMEOUT_MINUTES=60

# ── OIDC / OAuth2 ──────────────────────────────────────────────────────────
# SPARC_ENABLE_OIDC=false
# SPARC_OIDC_ISSUER_URL=
# SPARC_OIDC_CLIENT_ID=
# SPARC_OIDC_CLIENT_SECRET=
# SPARC_OIDC_REDIRECT_URI=
# SPARC_OIDC_SCOPES=openid profile email
# SPARC_OIDC_PROVIDER_TITLE=SSO
# SPARC_OIDC_FORCE_MFA=false

# ── LDAP ────────────────────────────────────────────────────────────────────
# SPARC_ENABLE_LDAP=false
# SPARC_LDAP_HOST=
# SPARC_LDAP_PORT=636
# SPARC_LDAP_ENCRYPTION=simple_tls
# SPARC_LDAP_BIND_DN=
# SPARC_LDAP_BIND_PASSWORD=
# SPARC_LDAP_BASE=
# SPARC_LDAP_ATTRIBUTE=uid

# ── Logging ─────────────────────────────────────────────────────────────────
# SPARC_LOG_LEVEL=info
# SPARC_LOG_TO_STDOUT=false
# SPARC_STRUCTURED_LOGGING=false

# ── Email / SMTP ────────────────────────────────────────────────────────────
# SPARC_ENABLE_SMTP=false
# SPARC_SMTP_ADDRESS=
# SPARC_SMTP_PORT=587
# SPARC_SMTP_USERNAME=
# SPARC_SMTP_PASSWORD=
# SPARC_SMTP_AUTH=plain
# SPARC_SMTP_STARTTLS_AUTO=true
# SPARC_SMTP_FROM_ADDRESS=

# ── Security ────────────────────────────────────────────────────────────────
# SECRET_KEY_BASE=  (auto-generated in dev; required in production)
# FORCE_SSL=false   (set to true in production)
