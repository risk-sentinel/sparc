# SPARC UI smoke (Playwright) test suite — configuration template.
#
# Copy this file to `.env` (which is gitignored) and fill in the values,
# or `source` it / export these vars before running `uv run pytest`.
#
# The service-account token is bridged to a Rails session via the #573
# cookie-bridge (POST /api/v1/sessions/from_token). Generate it via the SPARC
# admin UI (Admin -> Service Accounts -> New). NEVER commit real tokens —
# only this .example template is tracked.

# Root URL of the deployed SPARC instance under test (no trailing slash).
# Defaults to https://sparc.risk-sentinel.org when unset.
SPARC_SMOKE_BASE_URL=https://sparc.risk-sentinel.org

# Service-account bearer token for the authenticated walks. When unset, only
# the unauthenticated login-page / CSP smoke runs (the rest self-skip).
SPARC_SMOKE_SA_TOKEN=sparc_sa_REPLACE_WITH_SA_TOKEN

# Optional: override the Rails session cookie name. Leave unset to auto-detect
# from the bridge response (SPARC's is _ssp_tpr_manager_session).
# SPARC_SESSION_COOKIE_NAME=
