# SPARC API contract test suite — configuration template.
#
# Copy this file to `.env` (which is gitignored) and fill in the values,
# or `source` it / export these vars before running `uv run pytest`.
# conftest.py auto-loads tests/api/.env at import time.
#
# Generate the two tokens via the SPARC admin UI (Admin -> Service Accounts
# -> New) or in the Rails console (see tests/api/README.md). NEVER commit real
# tokens — only this .example template is tracked.

# Root URL of the SPARC instance under test (no trailing slash).
SPARC_TEST_BASE_URL=http://localhost:3000

# Bearer token for a user with the admin role.
SPARC_TEST_ADMIN_TOKEN=sparc_sa_REPLACE_WITH_ADMIN_TOKEN

# Bearer token for a non-admin (read-level) user, used to assert authz gates.
SPARC_TEST_USER_TOKEN=sparc_sa_REPLACE_WITH_USER_TOKEN
