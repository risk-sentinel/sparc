# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files (keep .example templates).
/.env*
!/.env.example
!/.env.production.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore SQLite databases.
/db/*.sqlite3

# macOS metadata
.DS_Store

.claude

# SimpleCov coverage reports (HTML + JSON)
/coverage

# SSL certificates for local development (mkcert)
/ssl/

# puma-dev
.powenv

# Security scan HDF results (downloaded from CI artifacts for local analysis)
/docs/hdf/
saf-cli.log

# OSCAL schema bundle (#453) — build artefact; regenerated by
# `bin/rails oscal:bundle_schemas` during the Docker build stage.
/lib/oscal_schemas_bundle/

# Local-only draft assets (logo experiments, intro videos, draft release notes)
# kept on the maintainer's working tree but never committed.
RELEASE_NOTES_v1.0.1.md
/app/assets/images/sparc_logo-temp.jpg
/docs/SPARC_Video_Script.md
/docs/images/sparc-transparent.jpg
/docs/images/sparc_demo.html
/docs/images/sparc_intro.mp4
/docs/images/sparc_intro_extended_cut.mp4
/docs/images/sparc_intro_long.mp4
/docs/images/sparc_logo copy.jpg
/docs/images/sparc_logo-clean.jpg
/docs/images/sparc_logo_backup.jpg
/docs/images/sparc_logo_clean.jpg
/docs/images/sparc_logo_clear.png
license-inventory.json
