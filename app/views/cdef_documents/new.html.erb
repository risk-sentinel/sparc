<div class="card">
  <h2>Upload Component Definition</h2>

  <%= form_with model: @cdef_document, local: true, multipart: true do |f| %>
    <%= render "shared/dropzone",
      form: f,
      field: :file,
      accept: ".xml,.json,.yaml,.yml",
      hint: "Upload an XCCDF XML file (DISA STIGs, SCAP benchmarks, CIS), a JSON file (InSpec, STIG Viewer export), or an OSCAL YAML file." %>

    <div class="d-flex gap-3">
      <%= f.submit "Upload and Process", class: "btn btn-success" %>
      <%= link_to "Cancel", cdef_documents_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<div class="card">
  <h3>Supported Formats</h3>
  <p class="text-body-secondary mb-3">SPARC automatically detects the format and extracts controls, severity ratings, and CCI references.</p>

  <table class="table table-hover">
    <thead>
      <tr>
        <th>Format</th>
        <th>Extension</th>
        <th>Sources</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><strong>XCCDF XML</strong></td>
        <td>.xml</td>
        <td>DISA STIGs, SCAP benchmarks, CIS Benchmarks</td>
      </tr>
      <tr>
        <td><strong>InSpec JSON</strong></td>
        <td>.json</td>
        <td>Chef InSpec profile results (has <code>profiles</code> and <code>controls</code> keys)</td>
      </tr>
      <tr>
        <td><strong>STIG Viewer JSON</strong></td>
        <td>.json</td>
        <td>STIG Viewer exports (has <code>stigs</code> key)</td>
      </tr>
      <tr>
        <td><strong>Generic JSON</strong></td>
        <td>.json</td>
        <td>Any JSON with a <code>controls</code> array containing <code>id</code>/<code>title</code> fields</td>
      </tr>
    </tbody>
  </table>
</div>

<div class="card">
  <h3>Export Capabilities</h3>
  <p class="text-body-secondary mb-3">After processing, component definitions can be exported in the following formats:</p>

  <div class="row row-cols-1 row-cols-md-2 g-3">
    <div class="col">
      <div class="bg-body-secondary p-3 rounded" style="border: 1px solid var(--bs-border-color); border-left: 3px solid #8e44ad;">
        <div class="fw-bold" style="margin-bottom: 0.35rem; color: #8e44ad;">OSCAL Component Definition</div>
        <div class="text-body-secondary" style="font-size: 0.88rem;">
          NIST OSCAL v1.1.2 compliant Component Definition JSON. Maps controls to implemented-requirements with severity, CCI references, and implementation narratives.
        </div>
      </div>
    </div>
    <div class="col">
      <div class="bg-body-secondary p-3 rounded" style="border: 1px solid var(--bs-border-color); border-left: 3px solid var(--bs-success);">
        <div class="fw-bold" style="margin-bottom: 0.35rem; color: var(--bs-success);">SPARC JSON</div>
        <div class="text-body-secondary" style="font-size: 0.88rem;">
          Standard SPARC JSON export with document metadata, controls, and all associated fields.
        </div>
      </div>
    </div>
  </div>
</div>
