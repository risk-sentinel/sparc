<div class="card">
  <h2>Upload Component Definition</h2>

  <%= form_with model: @cdef_document, local: true, multipart: true do |f| %>
    <div class="form-group">
      <label for="cdef_document_file">Select Component Definition File (.xml, .json)</label>
      <%= f.file_field :file, accept: ".xml,.json", required: true %>
      <small style="color: var(--text-muted); display: block; margin-top: 0.5rem;">
        Upload an XCCDF XML file (DISA STIGs, SCAP benchmarks, CIS) or a JSON file (InSpec, STIG Viewer export).
      </small>
    </div>

    <div style="display: flex; gap: 1rem;">
      <%= f.submit "Upload and Process", class: "btn btn-success" %>
      <%= link_to "Cancel", cdef_documents_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<div class="card">
  <h3>Supported Formats</h3>
  <p style="color: var(--text-muted); margin-bottom: 1rem;">SPARC automatically detects the format and extracts controls, severity ratings, and CCI references.</p>

  <table>
    <thead>
      <tr>
        <th>Format</th>
        <th>Extension</th>
        <th>Sources</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><strong>XCCDF XML</strong></td>
        <td>.xml</td>
        <td>DISA STIGs, SCAP benchmarks, CIS Benchmarks</td>
      </tr>
      <tr>
        <td><strong>InSpec JSON</strong></td>
        <td>.json</td>
        <td>Chef InSpec profile results (has <code>profiles</code> and <code>controls</code> keys)</td>
      </tr>
      <tr>
        <td><strong>STIG Viewer JSON</strong></td>
        <td>.json</td>
        <td>STIG Viewer exports (has <code>stigs</code> key)</td>
      </tr>
      <tr>
        <td><strong>Generic JSON</strong></td>
        <td>.json</td>
        <td>Any JSON with a <code>controls</code> array containing <code>id</code>/<code>title</code> fields</td>
      </tr>
    </tbody>
  </table>
</div>

<div class="card">
  <h3>Export Capabilities</h3>
  <p style="color: var(--text-muted); margin-bottom: 1rem;">After processing, component definitions can be exported in the following formats:</p>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
    <div style="background: var(--surface-alt); border: 1px solid var(--border-soft); border-left: 3px solid var(--link-purple); border-radius: 6px; padding: 1rem;">
      <div style="font-weight: 700; margin-bottom: 0.35rem; color: var(--link-purple);">OSCAL Component Definition</div>
      <div style="font-size: 0.88rem; color: var(--text-muted);">
        NIST OSCAL v1.1.2 compliant Component Definition JSON. Maps controls to implemented-requirements with severity, CCI references, and implementation narratives.
      </div>
    </div>
    <div style="background: var(--surface-alt); border: 1px solid var(--border-soft); border-left: 3px solid var(--btn-success); border-radius: 6px; padding: 1rem;">
      <div style="font-weight: 700; margin-bottom: 0.35rem; color: var(--btn-success);">SPARC JSON</div>
      <div style="font-size: 0.88rem; color: var(--text-muted);">
        Standard SPARC JSON export with document metadata, controls, and all associated fields.
      </div>
    </div>
  </div>
</div>
