<%# ── PROCESSING STATE BANNER ─────────────────────────────────────── %>
<% unless @cdef_document.completed? %>
  <%= render "shared/processing_banner",
       document:     @cdef_document,
       title:        "Processing Your Component Definition",
       back_label:   "Back to Component Definitions",
       back_path:    cdef_documents_path %>

<% else %>
<%
  severity_total = @severity_counts.values.sum
  high_count   = @severity_counts["high"].to_i
  medium_count = @severity_counts["medium"].to_i
  low_count    = @severity_counts["low"].to_i
  info_count   = @severity_counts["info"].to_i

  type_colors = { "disa_stig" => "#e74c3c", "scap" => "#3498db", "cis" => "#f39c12", "custom" => "#95a5a6" }
  type_color  = type_colors[@cdef_document.cdef_type] || "#7f8c8d"
%>

<%# ── HEADER DASHBOARD ──────────────────────────────────────────── %>
<div class="sparc-dashboard-header">

  <div class="d-flex justify-content-between align-items-start mb-4 gap-3 flex-wrap">
    <div>
      <div class="sparc-header-subtitle">Component Definition</div>

      <div id="doc-meta-view">
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <h2 class="sparc-header-title"><%= @cdef_document.name %></h2>
          <% if @cdef_document.cdef_version.present? %>
            <span class="sparc-version-badge">v<%= @cdef_document.cdef_version %></span>
          <% end %>
          <% if signed_in? %>
            <button onclick="toggleDocMeta()" class="sparc-btn-header-edit">Edit</button>
          <% end %>
        </div>
      </div>

      <% if signed_in? %>
        <div id="doc-meta-edit" style="display: none;">
          <%= form_with url: update_metadata_cdef_document_path(@cdef_document), method: :patch, local: true do |f| %>
            <div class="d-flex gap-2 align-items-center flex-wrap">
              <%= f.text_field :name, value: @cdef_document.name,
                    class: "sparc-input-dark sparc-input-dark-lg" %>
              <%= f.text_field :cdef_version, value: @cdef_document.cdef_version, placeholder: "Version",
                    class: "sparc-input-dark sparc-input-dark-sm" %>
              <%= f.submit "Save", class: "sparc-btn-save" %>
              <button type="button" onclick="toggleDocMeta()" class="sparc-btn-cancel-dark">Cancel</button>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="sparc-header-meta">
        <%= @cdef_document.original_filename %>
        &nbsp;&bull;&nbsp;
        <span class="fw-semibold" style="color: <%= type_color %>;"><%= @cdef_document.cdef_type&.upcase&.tr("_", " ") || "Unknown" %></span>
        &nbsp;&bull;&nbsp; <%= @total_controls %> controls
      </div>
      <% if @cdef_document.description.present? %>
        <div style="font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-top: 0.4rem; max-width: 600px;"><%= truncate(@cdef_document.description, length: 200) %></div>
      <% end %>
    </div>
    <div class="d-flex gap-2 flex-shrink-0 flex-wrap">
      <% if signed_in? %>
        <%= button_to "Copy", copy_cdef_document_path(@cdef_document), method: :post,
              class: "sparc-btn-ghost", form: { data: { turbo_confirm: "Duplicate this component definition?" } } %>
      <% end %>
      <% if signed_in? && @cdef_document.draft? %>
        <%= render "shared/publish_button", document: @cdef_document,
              publish_path: publish_cdef_document_path(@cdef_document),
              check_path: publish_check_cdef_document_path(@cdef_document) %>
      <% end %>
      <div class="btn-group">
        <button type="button" class="sparc-btn-oscal dropdown-toggle"
                data-bs-toggle="dropdown" aria-expanded="false">
          Export OSCAL
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li><h6 class="dropdown-header">OSCAL (validated)</h6></li>
          <li><%= link_to "JSON", download_oscal_cdef_document_path(@cdef_document), class: "dropdown-item" %></li>
          <li><%= link_to "YAML", download_yaml_cdef_document_path(@cdef_document), class: "dropdown-item" %></li>
          <li><%= link_to "XML", download_xml_cdef_document_path(@cdef_document), class: "dropdown-item" %></li>
        </ul>
      </div>
      <%= link_to "&#8592; Back".html_safe, cdef_documents_path,
            class: "sparc-btn-ghost-muted" %>
    </div>
  </div>

  <div class="d-flex align-items-center gap-4 flex-wrap">
    <div class="text-center flex-shrink-0" style="min-width: 80px;">
      <div class="sparc-score" style="color: white;"><%= @total_controls %></div>
      <div class="sparc-score-label">Total Controls</div>
    </div>

    <div class="sparc-divider-v"></div>

    <div class="d-flex flex-wrap gap-2" style="flex: 1;">
      <% [["high", high_count, "#e74c3c"], ["medium", medium_count, "#f39c12"], ["low", low_count, "#3498db"], ["info", info_count, "#95a5a6"]].each do |sev, count, color| %>
        <% next if count == 0 %>
        <div class="summary-chip sparc-summary-chip"
             data-filter-value="<%= sev %>"
             onclick="document.getElementById('heatmapSection').dispatchEvent(new CustomEvent('heatmap:chip', {detail: {filter: '<%= j sev %>'}}))"
             role="button"
             tabindex="0"
             title="Click to filter: <%= sev %>"
             style="border-left: 3px solid <%= color %>;">
          <div class="sparc-chip-count"><%= count %></div>
          <div class="sparc-chip-label" style="text-transform: capitalize;"><%= sev %></div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-3">
    <div class="sparc-progress-bar">
      <% [["high", high_count, "#e74c3c"], ["medium", medium_count, "#f39c12"], ["low", low_count, "#3498db"], ["info", info_count, "#95a5a6"]].each do |sev, count, color| %>
        <% next if count == 0 %>
        <div style="width: <%= (count * 100.0 / [severity_total, 1].max).round(3) %>%; background: <%= color %>;" title="<%= sev.capitalize %>: <%= count %>"></div>
      <% end %>
    </div>
  </div>
</div>

<%# ── SEVERITY HEATMAP BY CONTROL FAMILY ─────────────────────────── %>
<%= render "shared/heatmap",
     heatmap_data: @heatmap_data,
     heatmap_families: @heatmap_families,
     heatmap_statuses: @heatmap_severities,
     title: "Severity by Control Family",
     color_helper: :cdef_severity_color,
     filter_key: "severity",
     show_percentage: false,
     legend_items: [["High", "#e74c3c"], ["Medium", "#f39c12"], ["Low", "#3498db"], ["Info", "#95a5a6"]] %>

<%# ── CONTROL CARDS ───────────────────────────────────────────────── %>
<div id="controlsContainer">
  <% @controls.each do |control| %>
    <%
      field_map    = control.cdef_control_fields.index_by(&:field_name)
      sev_val      = control.severity.presence || "(Unknown)"
      sev_colors_map = { "high" => "#e74c3c", "medium" => "#f39c12", "low" => "#3498db", "info" => "#95a5a6" }
      sev_color    = sev_colors_map[sev_val] || "#7f8c8d"
      family_code  = control.control_family.presence || control.control_id.to_s.split("-").first.upcase
      description  = field_map["description"]&.field_value.presence
      cci_refs     = field_map["cci_refs"]&.field_value.presence
    %>
    <div class="control-card"
         data-family="<%= family_code %>"
         data-severity="<%= sev_val %>"
         style="border-left: 4px solid <%= sev_color %>;">

      <%# ── Card header ── %>
      <div class="d-flex justify-content-between align-items-start" style="gap: 1rem;">
        <div style="min-width: 0; flex: 1;">
          <div class="d-flex align-items-center gap-2 flex-wrap" style="margin-bottom: 0.2rem;">
            <span class="sparc-ctrl-id">
              <%= control.control_id.presence || "&mdash;".html_safe %>
            </span>
            <span class="sparc-status-pill" style="background: <%= sev_color %>; text-transform: capitalize;">
              <%= sev_val %>
            </span>
            <% if control.group_id.present? && control.group_id != control.control_id %>
              <span class="sparc-tag-outline bg-body-secondary border fw-semibold text-body-secondary">
                <%= control.group_id %>
              </span>
            <% end %>
            <% if cci_refs.present? %>
              <span class="sparc-tag-outline fw-semibold text-body-secondary" style="background: rgba(39,174,96,0.08); border: 1px solid rgba(39,174,96,0.2); color: var(--bs-secondary-color);">
                CCI (<%= cci_refs.split(",").map(&:strip).size %>)
              </span>
            <% end %>
            <span class="sparc-ctrl-family" style="margin-left: 0.1rem;"><%= family_code %></span>
          </div>
          <% if control.title.present? %>
            <div class="sparc-ctrl-title"><%= control.title %></div>
          <% end %>
        </div>
      </div>

      <%# ── Card body: collapsed by default ── %>
      <details class="card-details" style="margin-top: 0.35rem;">
        <summary class="sparc-card-detail-toggle d-flex align-items-center gap-1">
          <span class="card-arrow sparc-card-arrow">&#9658;</span>
          <span class="sparc-card-detail-separator"></span>
        </summary>

        <div class="mt-2">
          <%# Description block %>
          <% if description.present? %>
            <div class="sparc-statement-block">
              <div class="sparc-statement-label" style="color: var(--bs-primary);">Description</div>
              <div style="font-size: 0.84rem; color: var(--bs-body-color); line-height: 1.5;"><%= description %></div>
            </div>
          <% end %>

          <%# Field table %>
          <%
            ordered_fields = CdefControlField::FIELD_DISPLAY_ORDER.map { |fn| field_map[fn] }.compact
            extras = field_map.values.reject { |f|
              f.field_name == "description" ||
              CdefControlField::FIELD_DISPLAY_ORDER.include?(f.field_name)
            }
            display_fields = ordered_fields + extras
          %>
          <% if display_fields.any? %>
            <table class="sparc-field-table">
              <% display_fields.each do |field| %>
                <% next if field.field_value.blank? %>
                <% next if field.field_name == "description" %>
                <tr>
                  <td class="sparc-field-label">
                    <%= field.field_name.tr("_", " ") %>
                    <% if field.editable %><span class="sparc-editable-indicator">&#x270E;</span><% end %>
                  </td>
                  <td class="sparc-field-value">
                    <% if field.field_name == "severity" %>
                      <span class="sparc-status-pill" style="background: <%= sev_colors_map[field.field_value] || '#7f8c8d' %>; font-size: 0.75rem; font-weight: 600; text-transform: capitalize;"><%= field.field_value %></span>
                    <% elsif field.field_name == "cci_refs" %>
                      <div class="d-flex flex-wrap" style="gap: 0.3rem;">
                        <% field.field_value.split(",").map(&:strip).each do |cci| %>
                          <span class="rounded fw-semibold" style="background: rgba(39,174,96,0.1); border: 1px solid rgba(39,174,96,0.25); color: #27ae60; padding: 0.1rem 0.45rem; font-size: 0.72rem; font-family: monospace;"><%= cci %></span>
                        <% end %>
                      </div>
                    <% else %>
                      <div style="white-space: pre-wrap;"><%= field.field_value %></div>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </table>
          <% end %>
        </div>
      </details>

    </div><%# end .control-card %>
  <% end %>
</div>

<% if signed_in? %>
  <%= render "shared/oscal_metadata_section",
             document: @cdef_document,
             update_path: update_metadata_cdef_document_path(@cdef_document),
             param_key: :cdef_document,
             version_field: :cdef_version %>
<% end %>

<script>
  function toggleDocMeta() {
    var view = document.getElementById('doc-meta-view');
    var edit = document.getElementById('doc-meta-edit');
    var isEditing = edit.style.display !== 'none';
    view.style.display = isEditing ? '' : 'none';
    edit.style.display = isEditing ? 'none' : '';
  }

  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.card-details').forEach(function(det) {
      det.addEventListener('toggle', function() {
        var arrow = det.querySelector('summary .card-arrow');
        if (arrow) arrow.innerHTML = det.open ? '&#9660;' : '&#9658;';
      });
    });
  });
</script>

<% end %><%# end unless completed %>
