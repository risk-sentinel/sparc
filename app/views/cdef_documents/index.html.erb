<%= render "shared/section_summary", tiles: [
  [@total_count, "Component Defs"],
  [@controls_count, "Total Controls"],
  [@completed_count, "Completed"]
] %>

<% if @cdef_documents.any? { |d| d.processing? || d.pending? } %>
  <meta http-equiv="refresh" content="10">
<% end %>

<div class="card" style="overflow-x: auto;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Component Definitions</h2>
    <% if signed_in? %>
      <div class="d-flex gap-2">
        <%# #488: manual trigger for AwsLabsCdefRefreshJob, gated on the
            converters.write permission (same RBAC bucket as the DISA CCI
            "Refresh Now" button). Button + modal are hidden entirely when
            the feature flag is off — no point teasing operators with a
            button that would just flash an error. %>
        <% if can_write_converters? && SparcConfig.aws_labs_cdef_enabled? %>
          <button type="button" class="btn btn-outline-secondary"
                  data-bs-toggle="modal" data-bs-target="#refreshAwsLabsModal"
                  style="padding: 0.5rem 1rem; font-size: 0.875rem;">
            Refresh from AWS Labs
          </button>
        <% end %>
        <%= link_to "Create New", select_profile_cdef_documents_path, class: "btn btn-primary", style: "padding: 0.5rem 1rem; font-size: 0.875rem;" %>
        <%= link_to "Upload File", new_cdef_document_path, class: "btn btn-success" %>
      </div>
    <% end %>
  </div>

  <%# #488 — Refresh from AWS Labs confirmation modal (matches the DISA
      CCI confirmation modal pattern from app/views/converters/show.html.erb). %>
  <% if signed_in? && can_write_converters? && SparcConfig.aws_labs_cdef_enabled? %>
    <div class="modal fade" id="refreshAwsLabsModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Refresh from AWS Labs</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p>This will fetch the latest OSCAL Component Definitions from
              <a href="https://github.com/awslabs/oscal-content-for-aws-services" target="_blank" rel="noopener">
              awslabs/oscal-content-for-aws-services</a> and import any new or
              updated entries.</p>
            <p class="mb-0 small text-body-secondary">Imports are idempotent — existing rows
              with matching SHA are left unchanged. Refreshes typically take a few seconds.
              The job runs asynchronously; new rows appear once the worker processes them.</p>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
            <%= button_to "Refresh Now", refresh_aws_labs_cdef_documents_path,
                  method: :post, class: "btn btn-warning btn-sm fw-semibold",
                  form: { style: "display: inline;" } %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% if @cdef_documents.any? %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th style="white-space: nowrap;">Name</th>
          <th style="white-space: nowrap;">Type</th>
          <th style="white-space: nowrap;">Version</th>
          <th style="white-space: nowrap;">Status</th>
          <th style="white-space: nowrap;">Controls</th>
          <th style="white-space: nowrap;">Created</th>
          <th style="white-space: nowrap;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @cdef_documents.each do |doc| %>
          <tr>
            <td><strong><%= link_to doc.name, cdef_document_path(doc), class: "text-primary", style: "text-decoration: none;" %></strong></td>
            <td>
              <% type_colors = { "disa_stig" => "#e74c3c", "scap" => "#3498db", "cis" => "#f39c12", "custom" => "#95a5a6" } %>
              <span class="rounded fw-semibold" style="padding: 0.2rem 0.6rem; background: <%= type_colors[doc.cdef_type] || '#7f8c8d' %>22; color: <%= type_colors[doc.cdef_type] || '#7f8c8d' %>; border: 1px solid <%= type_colors[doc.cdef_type] || '#7f8c8d' %>44; font-size: 0.78rem; white-space: nowrap;">
                <%= doc.cdef_type&.upcase&.tr("_", " ") || "Unknown" %>
              </span>
            </td>
            <td class="small text-body-secondary"><%= doc.cdef_version.presence || "—" %></td>
            <td style="white-space: nowrap;">
              <% if doc.processing? || doc.pending? || doc.failed? %>
                <span class="<%= doc.completed? ? 'badge-ok' : doc.failed? ? 'badge-fail' : 'badge-warn' %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.85rem;">
                  <%= doc.status %>
                </span>
                <% if doc.processing? && doc.metadata_extra&.dig("processing_message").present? %>
                  <br><span class="text-body-secondary" style="font-size: 0.72rem; white-space: normal;"><%= doc.metadata_extra["processing_message"] %></span>
                <% end %>
              <% else %>
                <span class="<%= doc.lifecycle_badge_class %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.85rem;">
                  <%= doc.lifecycle_label %>
                </span>
              <% end %>
            </td>
            <td><%= doc.cdef_controls.count %></td>
            <td style="white-space: nowrap;"><%= doc.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td>
              <div class="d-flex flex-wrap gap-1" style="max-width: 280px;">
                <%= link_to "View", cdef_document_path(doc), class: "btn btn-primary btn-sm", style: "padding: 0.25rem 0.6rem; font-size: 0.78rem;" %>
                <% if signed_in? && doc.completed? %>
                  <%= button_to "Copy", copy_cdef_document_path(doc), method: :post, class: "btn btn-sm", style: "background: #2980b9; color: white; padding: 0.25rem 0.6rem; font-size: 0.78rem;", form: { data: { turbo_confirm: "Duplicate this component definition?" } } %>
                <% end %>
                <% if doc.completed? %>
                  <%# #451 A1: shared partial routes dropdown clicks through the
                      Stimulus modal that surfaces specific validation errors. %>
                  <%= render "shared/oscal_export_dropdown",
                        validate_path: validate_oscal_export_cdef_document_path(doc),
                        download_json_path: download_oscal_validated_cdef_document_path(doc),
                        download_yaml_path: download_yaml_cdef_document_path(doc),
                        download_xml_path: download_xml_cdef_document_path(doc),
                        fallback_json_path: download_oscal_unvalidated_cdef_document_path(doc),
                        document_type: "CDEF" %>
                <% end %>
                <% if signed_in? %>
                  <%= button_to "Delete", cdef_document_path(doc), method: :delete,
                        class: "btn btn-danger btn-sm",
                        style: "padding: 0.25rem 0.6rem; font-size: 0.78rem;",
                        form: { data: { turbo_confirm: "Delete '#{doc.name}'? This cannot be undone." }, style: "display: inline;" } %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center p-4 text-body-secondary">No component definitions found. Upload your first CDEF to get started.</p>
  <% end %>
</div>
