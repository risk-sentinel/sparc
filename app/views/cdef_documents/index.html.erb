<div class="card" style="overflow-x: auto;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h2>Component Definitions</h2>
    <%= link_to "Upload New", new_cdef_document_path, class: "btn btn-success" %>
  </div>

  <% if @cdef_documents.any? %>
    <table style="min-width: 700px;">
      <thead>
        <tr>
          <th>Name</th>
          <th>Type</th>
          <th>Version</th>
          <th>Status</th>
          <th>Controls</th>
          <th>Created</th>
          <th style="text-align: right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @cdef_documents.each do |doc| %>
          <tr>
            <td style="font-weight: 600;"><%= doc.name %></td>
            <td>
              <% type_colors = { "disa_stig" => "#e74c3c", "scap" => "#3498db", "cis" => "#f39c12", "custom" => "#95a5a6" } %>
              <span style="padding: 0.2rem 0.6rem; background: <%= type_colors[doc.cdef_type] || '#7f8c8d' %>22; color: <%= type_colors[doc.cdef_type] || '#7f8c8d' %>; border: 1px solid <%= type_colors[doc.cdef_type] || '#7f8c8d' %>44; border-radius: 4px; font-size: 0.78rem; font-weight: 600; white-space: nowrap;">
                <%= doc.cdef_type&.upcase&.tr("_", " ") || "Unknown" %>
              </span>
            </td>
            <td style="font-size: 0.85rem; color: var(--text-muted);"><%= doc.cdef_version.presence || "—" %></td>
            <td>
              <span class="<%= doc.completed? ? 'badge-ok' : doc.failed? ? 'badge-fail' : 'badge-warn' %>" style="padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.85rem; font-weight: 600;">
                <%= doc.status %>
              </span>
            </td>
            <td><%= doc.cdef_controls.count %></td>
            <td style="white-space: nowrap;"><%= doc.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td style="text-align: right; white-space: nowrap;">
              <div style="display: inline-flex; gap: 0.35rem;">
                <%= link_to "View", cdef_document_path(doc), class: "btn btn-primary", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;" %>
                <% if doc.completed? %>
                  <%= link_to "OSCAL", download_oscal_cdef_document_path(doc), class: "btn", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem; background: var(--link-purple); color: white;" %>
                  <%= link_to "JSON", download_json_cdef_document_path(doc), class: "btn btn-success", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;" %>
                <% end %>
                <%= link_to "Delete", cdef_document_path(doc), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p style="text-align: center; padding: 2rem; color: var(--text-muted);">No component definitions found. Upload your first CDEF to get started.</p>
  <% end %>
</div>
