<%= render "shared/section_summary", tiles: [
  [@total_count, "Component Defs"],
  [@controls_count, "Total Controls"],
  [@completed_count, "Completed"]
] %>

<% if @cdef_documents.any? { |d| d.processing? || d.pending? } %>
  <meta http-equiv="refresh" content="10">
<% end %>

<div class="card" style="overflow-x: auto;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Component Definitions</h2>
    <% if signed_in? %>
      <%= link_to "Upload New", new_cdef_document_path, class: "btn btn-success" %>
    <% end %>
  </div>

  <% if @cdef_documents.any? %>
    <table class="table table-hover" style="min-width: 700px;">
      <thead>
        <tr>
          <th>Name</th>
          <th>Type</th>
          <th>Version</th>
          <th>Status</th>
          <th>Controls</th>
          <th>Created</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @cdef_documents.each do |doc| %>
          <tr>
            <td class="fw-semibold"><%= doc.name %></td>
            <td>
              <% type_colors = { "disa_stig" => "#e74c3c", "scap" => "#3498db", "cis" => "#f39c12", "custom" => "#95a5a6" } %>
              <span class="rounded fw-semibold" style="padding: 0.2rem 0.6rem; background: <%= type_colors[doc.cdef_type] || '#7f8c8d' %>22; color: <%= type_colors[doc.cdef_type] || '#7f8c8d' %>; border: 1px solid <%= type_colors[doc.cdef_type] || '#7f8c8d' %>44; font-size: 0.78rem; white-space: nowrap;">
                <%= doc.cdef_type&.upcase&.tr("_", " ") || "Unknown" %>
              </span>
            </td>
            <td class="small text-body-secondary"><%= doc.cdef_version.presence || "—" %></td>
            <td>
              <span class="<%= doc.completed? ? 'badge-ok' : doc.failed? ? 'badge-fail' : 'badge-warn' %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.85rem;">
                <%= doc.status %>
              </span>
              <% if doc.processing? && doc.metadata_extra&.dig("processing_message").present? %>
                <br><span class="text-body-secondary" style="font-size: 0.72rem;"><%= doc.metadata_extra["processing_message"] %></span>
              <% end %>
            </td>
            <td><%= doc.cdef_controls.count %></td>
            <td style="white-space: nowrap;"><%= doc.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td class="text-end" style="white-space: nowrap;">
              <div style="display: inline-flex; gap: 0.35rem;">
                <%= link_to "View", cdef_document_path(doc), class: "btn btn-primary", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;" %>
                <% if signed_in? && doc.completed? %>
                  <%= button_to "Copy", copy_cdef_document_path(doc), method: :post, class: "btn btn-sm", style: "background: #2980b9; color: white; padding: 0.35rem 0.75rem; font-size: 0.8rem;", data: { confirm: "Duplicate this component definition?" } %>
                <% end %>
                <% if doc.completed? %>
                  <div class="btn-group">
                    <button type="button" class="btn btn-sm dropdown-toggle" style="background: #8e44ad; color: white;" data-bs-toggle="dropdown" aria-expanded="false">
                      Export OSCAL
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                      <li><h6 class="dropdown-header">OSCAL (validated)</h6></li>
                      <li><%= link_to "JSON", download_oscal_cdef_document_path(doc), class: "dropdown-item" %></li>
                      <li><%= link_to "YAML", download_yaml_cdef_document_path(doc), class: "dropdown-item" %></li>
                      <li><%= link_to "XML", download_xml_cdef_document_path(doc), class: "dropdown-item" %></li>
                    </ul>
                  </div>
                <% end %>
                <% if signed_in? %>
                  <%= button_to "Delete", cdef_document_path(doc), method: :delete,
                        class: "btn btn-danger",
                        style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;",
                        form: { data: { turbo_confirm: "Delete '#{doc.name}'? This cannot be undone." }, style: "display: inline;" } %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center p-4 text-body-secondary">No component definitions found. Upload your first CDEF to get started.</p>
  <% end %>
</div>
