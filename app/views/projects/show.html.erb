<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><%= @project.name %></h2>
  <div class="d-flex gap-2">
    <%= link_to "Edit", edit_project_path(@project), class: "btn btn-secondary btn-sm" %>
    <%= link_to "All Projects", projects_path, class: "btn btn-outline-primary btn-sm" %>
  </div>
</div>

<%# ── Project Details ──────────────────────────────────────── %>
<div class="card mb-4">
  <div class="card-body">
    <div class="row">
      <div class="col-md-6">
        <p class="mb-1"><strong>Status:</strong>
          <% badge_class = @project.authorized? ? "badge-ok" : "badge-warn" %>
          <span class="<%= badge_class %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.85rem;">
            <%= @project.status.titleize %>
          </span>
        </p>
        <p class="mb-1 text-body-secondary"><%= @project.description.presence || "No description." %></p>
      </div>
      <div class="col-md-6">
        <% if @project.authorization_boundary_description.present? %>
          <p class="mb-1"><strong>Authorization Boundary:</strong></p>
          <p class="text-body-secondary"><%= @project.authorization_boundary_description %></p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# ── Artifact Summary ─────────────────────────────────────── %>
<div class="card mb-4">
  <div class="card-body">
    <h4 class="mb-3">Artifact Summary</h4>
    <div class="row row-cols-2 row-cols-md-4 g-3">
      <div class="col">
        <div class="sparc-hero-tile">
          <div class="sparc-hero-tile-label">SSP</div>
          <div class="sparc-hero-tile-count" style="font-size: 1rem;">
            <% if @project.ssp_document %>
              <%= link_to @project.ssp_document.name, ssp_document_path(@project.ssp_document) %>
            <% else %>
              <span class="text-body-secondary">None</span>
            <% end %>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="sparc-hero-tile">
          <div class="sparc-hero-tile-label">SAP</div>
          <div class="sparc-hero-tile-count" style="font-size: 1rem;">
            <% if @project.sap_document %>
              <%= link_to @project.sap_document.name, sap_document_path(@project.sap_document) %>
            <% else %>
              <span class="text-body-secondary">None</span>
            <% end %>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="sparc-hero-tile">
          <div class="sparc-hero-tile-label">SAR</div>
          <div class="sparc-hero-tile-count" style="font-size: 1rem;">
            <% if @project.sar_document %>
              <%= link_to @project.sar_document.name, sar_document_path(@project.sar_document) %>
            <% else %>
              <span class="text-body-secondary">None</span>
            <% end %>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="sparc-hero-tile">
          <div class="sparc-hero-tile-label">POA&amp;Ms</div>
          <div class="sparc-hero-tile-count"><%= @summary[:poam_count] %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# ── Boundaries & Components ──────────────────────────────── %>
<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="mb-0">Boundaries &amp; Components</h4>
      <%= link_to "Add Boundary", new_project_boundary_path(@project), class: "btn btn-success btn-sm" %>
    </div>

    <% if @boundaries.any? %>
      <% @boundaries.each do |boundary| %>
        <div class="card mb-2">
          <div class="card-body py-2">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <strong><%= boundary.name %></strong>
                <span class="badge bg-secondary ms-2"><%= boundary.environment.titleize %></span>
                <% if boundary.description.present? %>
                  <span class="text-body-secondary ms-2"><%= boundary.description %></span>
                <% end %>
              </div>
              <div class="d-flex gap-1">
                <%= link_to "Edit", edit_project_boundary_path(@project, boundary), class: "btn btn-outline-secondary btn-sm" %>
                <%= link_to "Delete", project_boundary_path(@project, boundary), method: :delete, data: { confirm: "Delete boundary?" }, class: "btn btn-outline-danger btn-sm" %>
              </div>
            </div>
            <% if boundary.cdef_documents.any? %>
              <div class="mt-2">
                <% boundary.cdef_documents.each do |cdef| %>
                  <%= link_to cdef.name, cdef_document_path(cdef), class: "badge bg-info text-decoration-none me-1" %>
                <% end %>
              </div>
            <% else %>
              <small class="text-body-secondary mt-1 d-block">No components assigned</small>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-body-secondary text-center">No boundaries defined. Add a boundary to associate components.</p>
    <% end %>
  </div>
</div>

<%# ── Personnel Roster ─────────────────────────────────────── %>
<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="mb-0">Personnel Roster</h4>
      <%= link_to "Add Member", new_project_project_membership_path(@project), class: "btn btn-success btn-sm" %>
    </div>

    <% if @memberships.any? %>
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @memberships.each do |m| %>
            <tr>
              <td><%= m.user_name %></td>
              <td class="text-body-secondary"><%= m.user_email.presence || "—" %></td>
              <td><span class="badge bg-primary"><%= m.role_label %></span></td>
              <td>
                <div class="d-flex gap-1">
                  <%= link_to "Edit", edit_project_project_membership_path(@project, m), class: "btn btn-outline-secondary btn-sm" %>
                  <%= link_to "Remove", project_project_membership_path(@project, m), method: :delete, data: { confirm: "Remove member?" }, class: "btn btn-outline-danger btn-sm" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-body-secondary text-center">No members assigned. Add personnel with RMF roles.</p>
    <% end %>
  </div>
</div>
