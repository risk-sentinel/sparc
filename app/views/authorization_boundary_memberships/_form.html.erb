<%= form_with(model: membership,
             url: membership.persisted? ? authorization_boundary_membership_path(@authorization_boundary, membership) : authorization_boundary_memberships_path(@authorization_boundary),
             method: membership.persisted? ? :patch : :post,
             class: "mb-4") do |f| %>
  <div class="mb-3">
    <%= f.label :user_name, "Name", class: "form-label fw-semibold" %>
    <%= f.text_field :user_name, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :user_email, "Email", class: "form-label fw-semibold" %>
    <%= f.email_field :user_email, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :role, class: "form-label fw-semibold" %>
    <%= f.select :role, AuthorizationBoundaryMembership::ROLE_LABELS.map { |k, v| [ v, k ] }, {}, class: "form-select" %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", authorization_boundary_path(@authorization_boundary), class: "btn btn-secondary" %>
  </div>
<% end %>
