<div class="card" data-controller="family-selector" data-family-selector-catalog-url-value="/control_catalogs">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Create Profile from Catalog</h2>
    <%= link_to "Back to Profiles", profile_documents_path, class: "btn btn-secondary" %>
  </div>

  <% if @catalogs.any? %>
    <%= form_with url: create_from_catalog_profile_documents_path, method: :post, local: true do |f| %>
      <div class="mb-4">
        <label class="form-label fw-semibold">Profile Name</label>
        <%= f.text_field :profile_name, class: "form-control", placeholder: "e.g., My Custom Baseline" %>
      </div>

      <div class="mb-4">
        <label class="form-label fw-semibold">Baseline Level</label>
        <%= f.select :baseline_level, ProfileDocument::BASELINE_LEVELS.map { |l| [ l, l ] },
              { include_blank: "Select level (optional)" }, class: "form-select",
              data: { family_selector_target: "baselineSelect", action: "change->family-selector#baselineChanged" } %>
      </div>

      <div class="mb-4">
        <label class="form-label fw-semibold">Select Catalog</label>
        <%= f.select :catalog_id, @catalogs.map { |c| [ "#{c.name} (#{c.total_controls} controls)", c.id ] },
              { include_blank: "Choose a catalog..." }, class: "form-select",
              data: { family_selector_target: "catalogSelect", action: "change->family-selector#catalogChanged" } %>
      </div>

      <div style="display: none;" data-family-selector-target="controlsSection">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <label class="form-label fw-semibold mb-0">Select Controls</label>
          <div class="d-flex gap-1 flex-wrap">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="click->family-selector#selectAll">Select All</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" data-action="click->family-selector#deselectAll">Deselect All</button>
            <button type="button" class="btn btn-sm btn-outline-info" data-action="click->family-selector#expandAll">Expand All</button>
            <button type="button" class="btn btn-sm btn-outline-info" data-action="click->family-selector#collapseAll">Collapse All</button>
          </div>
        </div>

        <div data-family-selector-target="controlsList"
             style="max-height: 600px; overflow-y: auto; border: 1px solid #dee2e6; border-radius: 0.375rem; padding: 1rem;">
          <p class="text-muted">Select a catalog to load controls...</p>
        </div>

        <div class="mt-2 text-muted small">
          <span data-family-selector-target="selectedCount">0</span> controls selected
        </div>
      </div>

      <div class="mt-4">
        <%= f.submit "Create Profile", class: "btn btn-success btn-lg" %>
      </div>
    <% end %>
  <% else %>
    <p class="text-center p-4 text-body-secondary">No catalogs available. Import a control catalog first.</p>
  <% end %>
</div>
