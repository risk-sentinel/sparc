<%# ── PROCESSING STATE BANNER ─────────────────────────────────────── %>
<% unless @profile_document.completed? %>
  <%= render "shared/processing_banner",
       document:     @profile_document,
       title:        "Processing Your Profile",
       back_label:   "Back to Profiles",
       back_path:    profile_documents_path %>

<% else %>
<%
  priority_total = @priority_counts.values.sum
  p1_count = @priority_counts["P1"].to_i
  p2_count = @priority_counts["P2"].to_i
  p3_count = @priority_counts["P3"].to_i
  none_count = @priority_counts[nil].to_i + (@priority_counts.reject { |k, _| %w[P1 P2 P3].include?(k) || k.nil? }.values.sum)

  level_colors = { "LOW" => "#27ae60", "MODERATE" => "#f39c12", "HIGH" => "#e74c3c" }
  level_color  = level_colors[@profile_document.baseline_level] || "#7f8c8d"
%>

<%# ── HEADER DASHBOARD ──────────────────────────────────────────── %>
<div class="sparc-dashboard-header">

  <div class="d-flex justify-content-between align-items-start mb-4 gap-3 flex-wrap">
    <div>
      <div class="sparc-header-subtitle">OSCAL Profile / Baseline</div>

      <%# ── View mode ── %>
      <div id="doc-meta-view">
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <h2 class="sparc-header-title"><%= @profile_document.name %></h2>
          <% if @profile_document.profile_version.present? %>
            <span class="sparc-version-badge">v<%= @profile_document.profile_version %></span>
          <% end %>
          <% if signed_in? && !@profile_document.published_lifecycle? %>
            <button onclick="toggleDocMeta()" class="sparc-btn-header-edit">Edit</button>
          <% end %>
        </div>
      </div>

      <% if signed_in? && !@profile_document.published_lifecycle? %>
        <%# ── Edit mode (hidden) ── %>
        <div id="doc-meta-edit" style="display: none;">
          <%= form_with url: update_metadata_profile_document_path(@profile_document), method: :patch, local: true do |f| %>
            <div class="d-flex gap-2 align-items-center flex-wrap">
              <%= f.text_field :name, value: @profile_document.name,
                    class: "sparc-input-dark sparc-input-dark-lg" %>
              <%= f.text_field :profile_version, value: @profile_document.profile_version, placeholder: "Version",
                    class: "sparc-input-dark sparc-input-dark-sm" %>
              <%= f.submit "Save", class: "sparc-btn-save" %>
              <button type="button" onclick="toggleDocMeta()" class="sparc-btn-cancel-dark">Cancel</button>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="sparc-header-meta">
        <%= @profile_document.original_filename %>
        &nbsp;&bull;&nbsp;
        <span class="fw-semibold" style="color: <%= level_color %>;"><%= @profile_document.baseline_level || "Custom" %></span>
        &nbsp;&bull;&nbsp; <%= @total_controls %> controls
        <% if @profile_document.control_catalog.present? %>
          &nbsp;&bull;&nbsp;
          Source: <span class="fw-semibold"><%= @profile_document.control_catalog.name %></span>
          <% if @profile_document.control_catalog.short_digest.present? %>
            <code style="font-size: 0.75rem; color: rgba(255,255,255,0.5); margin-left: 0.2rem;"><%= @profile_document.control_catalog.short_digest %></code>
          <% end %>
        <% end %>
        <% if @profile_document.source_profile.present? %>
          &nbsp;&bull;&nbsp;
          Derived from: <%= link_to @profile_document.source_profile.name,
                                    profile_document_path(@profile_document.source_profile),
                                    style: "color: rgba(255,255,255,0.8); text-decoration: underline;" %>
        <% end %>
        &nbsp;&bull;&nbsp;
        <span class="<%= @profile_document.lifecycle_badge_class %> rounded fw-semibold" style="padding: 0.15rem 0.5rem; font-size: 0.78rem;">
          <%= @profile_document.lifecycle_label %>
        </span>
      </div>
      <% if @profile_document.description.present? %>
        <div style="font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-top: 0.4rem; max-width: 600px;"><%= truncate(@profile_document.description, length: 200) %></div>
      <% end %>
    </div>
    <div class="d-flex gap-2 flex-shrink-0 flex-wrap">
      <% if signed_in? %>
        <% if @profile_document.published_lifecycle? %>
          <%= button_to "Create Editable Copy", copy_profile_document_path(@profile_document), method: :post,
                class: "sparc-btn-ghost", form: { data: { turbo_confirm: "Create an editable copy of this published profile?" } } %>
        <% else %>
          <%= button_to "Copy", copy_profile_document_path(@profile_document), method: :post,
                class: "sparc-btn-ghost", form: { data: { turbo_confirm: "Duplicate this profile?" } } %>
          <%= link_to "+ Add Control", new_profile_document_profile_control_path(@profile_document),
                class: "sparc-btn-oscal" %>
          <% if @profile_document.control_catalog.present? %>
            <%= link_to "Manage Controls", manage_controls_profile_document_path(@profile_document),
                  class: "sparc-btn-oscal" %>
          <% end %>
          <% if @profile_document.control_catalog.present? %>
            <%= render "shared/publish_button", document: @profile_document,
                  publish_path: publish_profile_document_path(@profile_document),
                  check_path: publish_check_profile_document_path(@profile_document) %>
          <% end %>
        <% end %>
      <% end %>
      <div class="btn-group">
        <button type="button" class="sparc-btn-oscal dropdown-toggle"
                data-bs-toggle="dropdown" aria-expanded="false">
          Export OSCAL
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li><h6 class="dropdown-header">OSCAL Profile</h6></li>
          <li><%= link_to "JSON", download_oscal_profile_document_path(@profile_document), class: "dropdown-item" %></li>
          <li><%= link_to "YAML", download_yaml_profile_document_path(@profile_document), class: "dropdown-item" %></li>
          <li><%= link_to "XML", download_xml_profile_document_path(@profile_document), class: "dropdown-item" %></li>
          <% if @profile_document.resolved_catalog_json.present? %>
            <li><hr class="dropdown-divider"></li>
            <li><h6 class="dropdown-header">Resolved Catalog</h6></li>
            <li><%= link_to "JSON (Resolved)", download_resolved_catalog_profile_document_path(@profile_document), class: "dropdown-item" %></li>
          <% end %>
        </ul>
      </div>
      <%= link_to "&#8592; Back".html_safe, profile_documents_path,
            class: "sparc-btn-ghost-muted" %>
    </div>
  </div>

  <div class="d-flex align-items-center gap-4 flex-wrap">
    <div class="text-center flex-shrink-0" style="min-width: 80px;">
      <div class="sparc-score" style="color: white;"><%= @total_controls %></div>
      <div class="sparc-score-label">Selected Controls</div>
    </div>

    <div class="sparc-divider-v"></div>

    <div class="d-flex flex-wrap gap-2" style="flex: 1;">
      <% [["P1", p1_count, "#e74c3c"], ["P2", p2_count, "#f39c12"], ["P3", p3_count, "#3498db"], ["None", none_count, "#95a5a6"]].each do |pri, count, color| %>
        <% next if count == 0 %>
        <div class="summary-chip sparc-summary-chip"
             data-filter-value="<%= pri %>"
             onclick="document.getElementById('heatmapSection').dispatchEvent(new CustomEvent('heatmap:chip', {detail: {filter: '<%= j pri %>'}}))"
             role="button"
             tabindex="0"
             title="Click to filter: <%= pri %>"
             style="border-left: 3px solid <%= color %>;">
          <div class="sparc-chip-count"><%= count %></div>
          <div class="sparc-chip-label"><%= pri %></div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-3">
    <div class="sparc-progress-bar">
      <% [["P1", p1_count, "#e74c3c"], ["P2", p2_count, "#f39c12"], ["P3", p3_count, "#3498db"], ["None", none_count, "#95a5a6"]].each do |pri, count, color| %>
        <% next if count == 0 %>
        <div style="width: <%= (count * 100.0 / [priority_total, 1].max).round(3) %>%; background: <%= color %>;" title="<%= pri %>: <%= count %>"></div>
      <% end %>
    </div>
  </div>
</div>

<%# ── PRIORITY HEATMAP BY CONTROL FAMILY ─────────────────────────── %>
<%= render "shared/heatmap",
     heatmap_data: @heatmap_data,
     heatmap_families: @heatmap_families,
     heatmap_statuses: @heatmap_priorities,
     title: "Priority by Control Family",
     color_helper: :profile_priority_color,
     filter_key: "priority",
     show_percentage: false,
     legend_items: [["P1 (High)", "#e74c3c"], ["P2 (Medium)", "#f39c12"], ["P3 (Low)", "#3498db"], ["None", "#95a5a6"]] %>

<%# ── FAMILY-GROUPED CONTROL LIST ──────────────────────────────── %>
<div id="controlsContainer">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <label class="form-label fw-semibold mb-0"><%= @total_controls %> controls in this profile</label>
    <div class="d-flex gap-1">
      <button type="button" class="btn btn-sm btn-outline-info" onclick="toggleAllFamilies(true)">Expand All</button>
      <button type="button" class="btn btn-sm btn-outline-info" onclick="toggleAllFamilies(false)">Collapse All</button>
    </div>
  </div>

  <% @sorted_families.each do |family_code| %>
    <% family_controls = @controls_by_family[family_code] %>
    <% next if family_controls.blank? %>

    <details class="sparc-family-group">
      <summary>
        <strong><%= family_code %></strong> &mdash; <%= @family_names[family_code] || family_code %>
        <span class="badge bg-secondary"><%= family_controls.size %></span>
      </summary>

      <div class="mt-2">
        <% family_controls.sort_by { |c| @sort_id_map[c.control_id] || c.control_id.gsub(/\d+/) { |n| n.rjust(3, "0") } }.each do |control| %>
          <%
            field_map    = control.profile_control_fields.index_by(&:field_name)
            pri_val      = control.priority.presence || "(None)"
            pri_colors_map = { "P1" => "#e74c3c", "P2" => "#f39c12", "P3" => "#3498db" }
            pri_color    = pri_colors_map[pri_val] || "#95a5a6"
          %>
          <div class="control-card"
               data-family="<%= family_code %>"
               data-priority="<%= pri_val %>"
               style="border-left: 4px solid <%= pri_color %>;">

            <%# ── Card header ── %>
            <div class="d-flex justify-content-between align-items-start" style="gap: 1rem;">
              <div style="min-width: 0; flex: 1;">
                <div class="d-flex align-items-center gap-2 flex-wrap" style="margin-bottom: 0.2rem;">
                  <span class="sparc-ctrl-id">
                    <%= control.display_id.presence || "&mdash;".html_safe %>
                  </span>
                  <span class="sparc-status-pill" style="background: <%= pri_color %>;">
                    <%= pri_val %>
                  </span>
                </div>
                <% if control.title.present? %>
                  <div class="sparc-ctrl-title"><%= control.title %></div>
                <% end %>
              </div>
              <% if signed_in? && !@profile_document.published_lifecycle? %>
                <div class="d-flex flex-shrink-0" style="gap: 0.35rem;">
                  <%= link_to "Edit", edit_profile_document_profile_control_path(@profile_document, control),
                        class: "btn btn-primary btn-sm" %>
                  <%= button_to "Delete", profile_document_profile_control_path(@profile_document, control),
                        method: :delete,
                        form: { data: { turbo_confirm: "Remove #{control.display_id} from this profile?" } },
                        class: "btn btn-danger btn-sm" %>
                </div>
              <% end %>
            </div>

            <%# ── Parameters & properties (collapsed by default) ── %>
            <% param_fields = field_map.select { |k, _| k.start_with?("parameter:") } %>
            <% prop_fields  = field_map.select { |k, _| k.start_with?("prop:") } %>
            <% sub_parts    = @catalog_sub_parts[control.control_id] %>
            <% has_details  = param_fields.any? || prop_fields.any? || sub_parts&.any? %>
            <% if has_details %>
              <details class="card-details" style="margin-top: 0.35rem;">
                <summary class="sparc-card-detail-toggle d-flex align-items-center gap-1">
                  <span class="card-arrow sparc-card-arrow">&#9658;</span>
                  <span class="sparc-card-detail-separator"></span>
                </summary>

                <div class="mt-2">
                  <% if param_fields.any? %>
                    <%
                      # Build select/choice metadata from catalog for this control
                      show_select_meta = {}
                      if @profile_document.control_catalog.present?
                        show_cat_ctrl = @profile_document.control_catalog.catalog_controls.find_by(control_id: control.control_id)
                        if show_cat_ctrl
                          show_cat_ctrl.effective_params_list.each do |p|
                            show_select_meta[p["id"]] = p["select"] if p["select"].present?
                          end
                        end
                      end
                    %>
                    <div class="sparc-statement-block">
                      <div class="sparc-statement-label" style="color: var(--bs-primary);">Parameters</div>
                      <table class="sparc-field-table">
                        <% param_fields.each do |fname, field| %>
                          <% param_id = fname.delete_prefix("parameter:") %>
                          <% label_field = field_map["parameter_label:#{param_id}"] %>
                          <% sel = show_select_meta[param_id] %>
                          <tr>
                            <td class="sparc-field-label" style="width: 30%; font-family: monospace;">
                              <%= param_id %>
                            </td>
                            <% if label_field %>
                              <td class="text-body-secondary" style="width: 25%; font-size: 0.82rem;">
                                <%= label_field.field_value %>
                              </td>
                            <% end %>
                            <td class="sparc-field-value" <%= "colspan=2" unless label_field %>>
                              <%= field.field_value %>
                              <% if sel %>
                                <% choices = sel["choice"] || [] %>
                                <% is_multi = sel["how-many"] == "one-or-more" %>
                                <div class="text-body-tertiary" style="font-size: 0.72rem; margin-top: 0.2rem;">
                                  Catalog options<%= is_multi ? " (one or more)" : "" %>:
                                  <%= choices.join(", ") %>
                                </div>
                              <% end %>
                            </td>
                          </tr>
                        <% end %>
                      </table>
                    </div>
                  <% end %>

                  <% if prop_fields.any? %>
                    <table class="sparc-field-table">
                      <% prop_fields.each do |fname, field| %>
                        <tr>
                          <td class="sparc-field-label" style="width: 30%;">
                            <%= fname.delete_prefix("prop:").tr("_", " ") %>
                          </td>
                          <td class="sparc-field-value">
                            <%= field.field_value %>
                          </td>
                        </tr>
                      <% end %>
                    </table>
                  <% end %>

                  <%# ── Catalog sub-parts / implementation statements ── %>
                  <% if sub_parts&.any? %>
                    <div class="sparc-sub-parts-section">
                      <div class="sparc-statement-label">Implementation Statements</div>
                      <% sub_parts.sort_by { |sp| sp.sort_id || sp.control_id.gsub(/\d+/) { |n| n.rjust(3, "0") } }.each do |sp| %>
                        <div class="sparc-sub-part-item">
                          <span class="sparc-sub-part-id"><%= sp.display_id %></span>
                          <% if sp.title.present? %>
                            <span class="sparc-sub-part-title"><%= sp.title %></span>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </details>
            <% end %>

          </div><%# end .control-card %>
        <% end %>
      </div>
    </details>
  <% end %>
</div>

<%= render "shared/oscal_metadata_section",
           document: @profile_document,
           update_path: update_metadata_profile_document_path(@profile_document),
           param_key: :profile_document,
           version_field: :profile_version %>

<script>
  function toggleDocMeta() {
    var view = document.getElementById('doc-meta-view');
    var edit = document.getElementById('doc-meta-edit');
    var isEditing = edit.style.display !== 'none';
    view.style.display = isEditing ? '' : 'none';
    edit.style.display = isEditing ? 'none' : '';
  }

  function toggleAllFamilies(expand) {
    document.querySelectorAll('#controlsContainer > details.sparc-family-group').forEach(function(det) {
      det.open = expand;
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.card-details').forEach(function(det) {
      det.addEventListener('toggle', function() {
        var arrow = det.querySelector('summary .card-arrow');
        if (arrow) arrow.innerHTML = det.open ? '&#9660;' : '&#9658;';
      });
    });
  });
</script>

<% end %><%# end unless completed %>
