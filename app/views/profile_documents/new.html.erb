<div class="card">
  <h2>Upload OSCAL Profile (Baseline)</h2>

  <%= form_with model: @profile_document, local: true, multipart: true do |f| %>
    <%= render "shared/dropzone",
      form: f,
      field: :file,
      accept: ".json,.xml,.yaml,.yml",
      multiple: true,
      hint: "Upload an OSCAL Profile JSON, XML, or YAML file. Supports NIST SP 800-53 baselines (LOW, MODERATE, HIGH), FedRAMP, and custom profiles." %>

    <div class="d-flex gap-3">
      <%= f.submit "Upload and Process", class: "btn btn-success" %>
      <%= link_to "Cancel", profile_documents_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<div class="card">
  <h3>Supported Formats</h3>
  <p class="text-body-secondary mb-3">SPARC parses OSCAL Profile files to extract selected controls, priority levels, and parameter modifications.</p>

  <table class="table table-hover">
    <thead>
      <tr>
        <th>Format</th>
        <th>Extension</th>
        <th>Sources</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><strong>OSCAL Profile JSON</strong></td>
        <td>.json</td>
        <td>NIST SP 800-53 baselines, FedRAMP profiles, custom OSCAL profiles</td>
      </tr>
      <tr>
        <td><strong>OSCAL Profile XML</strong></td>
        <td>.xml</td>
        <td>NIST SP 800-53 baselines in XML format, other OSCAL-compliant profile XML</td>
      </tr>
    </tbody>
  </table>
</div>

<div class="card">
  <h3>Export Capabilities</h3>
  <p class="text-body-secondary mb-3">After processing, profiles can be exported in the following formats:</p>

  <div class="row row-cols-1 row-cols-md-2 g-3">
    <div class="col">
      <div class="bg-body-secondary p-3 rounded" style="border: 1px solid var(--bs-border-color); border-left: 3px solid #8e44ad;">
        <div class="fw-bold" style="margin-bottom: 0.35rem; color: #8e44ad;">OSCAL Profile</div>
        <div class="text-body-secondary" style="font-size: 0.88rem;">
          NIST OSCAL v1.1.2 compliant Profile JSON. Includes selected controls, priority assignments, and parameter modifications.
        </div>
      </div>
    </div>
    <div class="col">
      <div class="bg-body-secondary p-3 rounded" style="border: 1px solid var(--bs-border-color); border-left: 3px solid var(--bs-success);">
        <div class="fw-bold" style="margin-bottom: 0.35rem; color: var(--bs-success);">SPARC JSON</div>
        <div class="text-body-secondary" style="font-size: 0.88rem;">
          Standard SPARC JSON export with document metadata, selected controls, and all associated fields.
        </div>
      </div>
    </div>
  </div>
</div>
