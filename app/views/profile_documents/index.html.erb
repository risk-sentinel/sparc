<%= render "shared/section_summary", tiles: [
  [@total_count, "Baselines"],
  [@controls_count, "Total Controls"],
  [@completed_count, "Completed"]
] %>

<% if @profile_documents.any? { |d| d.processing? || d.pending? } %>
  <meta http-equiv="refresh" content="10">
<% end %>

<div class="card">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Baselines / Profiles</h2>
    <% if signed_in? %>
      <div style="display: inline-flex; gap: 0.5rem;">
        <%= link_to "Upload New", new_profile_document_path, class: "btn btn-success" %>
        <%= link_to "Create from Catalog", select_catalog_profile_documents_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>

  <% if @profile_documents.any? %>
    <table class="table table-hover" style="table-layout: fixed; width: 100%;">
      <thead>
        <tr>
          <th style="width: 22%;">Name</th>
          <th style="width: 9%;">Baseline</th>
          <th style="width: 8%; white-space: nowrap;">Version</th>
          <th style="width: 10%; white-space: nowrap;">Status</th>
          <th style="width: 18%; white-space: nowrap;">Source Catalog</th>
          <th style="width: 7%; white-space: nowrap;">Controls</th>
          <th style="width: 9%; white-space: nowrap;">Created</th>
          <th style="width: 17%;" class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @profile_documents.each do |doc| %>
          <tr>
            <td><strong><%= link_to doc.name, profile_document_path(doc), class: "text-primary", style: "text-decoration: none;" %></strong></td>
            <td>
              <% level_colors = { "LOW" => "#27ae60", "MODERATE" => "#f39c12", "HIGH" => "#e74c3c" } %>
              <% color = level_colors[doc.baseline_level] || "#7f8c8d" %>
              <span class="rounded fw-semibold" style="padding: 0.2rem 0.6rem; background: <%= color %>22; color: <%= color %>; border: 1px solid <%= color %>44; font-size: 0.78rem; white-space: nowrap;">
                <%= doc.baseline_level || "Custom" %>
              </span>
            </td>
            <td class="small text-body-secondary" style="white-space: nowrap;"><%= doc.profile_version.presence || "—" %></td>
            <td style="white-space: nowrap;">
              <% if doc.pending? || doc.processing? || doc.failed? %>
                <span class="<%= doc.failed? ? 'badge-fail' : 'badge-warn' %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.78rem;">
                  <%= doc.status.titleize %>
                </span>
                <% if doc.processing? && doc.metadata_extra&.dig("processing_message").present? %>
                  <br><span class="text-body-secondary" style="font-size: 0.72rem;"><%= doc.metadata_extra["processing_message"] %></span>
                <% end %>
              <% else %>
                <span class="<%= doc.lifecycle_badge_class %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.78rem; white-space: nowrap;">
                  <%= doc.lifecycle_label %>
                </span>
              <% end %>
            </td>
            <td style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= doc.control_catalog&.name %>">
              <% if doc.control_catalog.present? %>
                <%= doc.control_catalog.name %>
                <% if doc.control_catalog.short_digest.present? %>
                  <br><span class="text-body-secondary" style="font-size: 0.72rem;"><%= doc.control_catalog.short_digest %></span>
                <% end %>
              <% else %>
                <span class="text-body-tertiary">&mdash;</span>
              <% end %>
            </td>
            <td><%= doc.profile_controls.count %></td>
            <td style="white-space: nowrap; font-size: 0.85rem;"><%= doc.created_at.strftime("%Y-%m-%d") %></td>
            <td class="text-end" style="white-space: nowrap;">
              <div style="display: inline-flex; gap: 0.3rem; flex-wrap: wrap; justify-content: flex-end;">
                <%= link_to "View", profile_document_path(doc), class: "btn btn-primary btn-sm", style: "font-size: 0.75rem; padding: 0.25rem 0.5rem;" %>
                <% if signed_in? && doc.completed? %>
                  <%= button_to "Copy", copy_profile_document_path(doc), method: :post,
                        class: "btn btn-sm", style: "background: #2980b9; color: white; font-size: 0.75rem; padding: 0.25rem 0.5rem;",
                        form: { data: { turbo_confirm: "Duplicate this profile?" }, style: "display: inline;" } %>
                <% end %>
                <% if doc.completed? %>
                  <div class="btn-group">
                    <button type="button" class="btn btn-sm dropdown-toggle" style="background: #8e44ad; color: white; font-size: 0.75rem; padding: 0.25rem 0.5rem;" data-bs-toggle="dropdown" aria-expanded="false">
                      Export
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                      <li><h6 class="dropdown-header">OSCAL (validated)</h6></li>
                      <li><%= link_to "JSON", download_oscal_profile_document_path(doc), class: "dropdown-item" %></li>
                      <li><%= link_to "YAML", download_yaml_profile_document_path(doc), class: "dropdown-item" %></li>
                      <li><%= link_to "XML", download_xml_profile_document_path(doc), class: "dropdown-item" %></li>
                    </ul>
                  </div>
                <% end %>
                <% if signed_in? %>
                  <%= button_to "Delete", profile_document_path(doc), method: :delete,
                        class: "btn btn-outline-danger btn-sm",
                        style: "font-size: 0.75rem; padding: 0.25rem 0.5rem;",
                        form: { data: { turbo_confirm: "Delete '#{doc.name}'? This cannot be undone." }, style: "display: inline;" } %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center p-4 text-body-secondary">No profiles found. Upload your first OSCAL Profile (Baseline) to get started.</p>
  <% end %>
</div>
