<div class="card">
  <h2 style="margin-bottom: 0.5rem;">Edit Family: <%= @control_family.code %> — <%= @control_family.name %></h2>
  <p style="color: var(--text-muted); margin-bottom: 1.5rem;">
    Catalog: <%= link_to @control_catalog.name, @control_catalog, style: "color: var(--link-accent);" %>
  </p>
  <%= render "form", control_catalog: @control_catalog, control_family: @control_family %>
</div>
