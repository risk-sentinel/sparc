<% can_edit_baselines = can_write_catalogs? && !@control_catalog.published_lifecycle? %>

<div class="card"
     <% if can_edit_baselines %>
       data-controller="baseline-editor"
       data-baseline-editor-update-url-value="<%= update_baseline_control_catalog_path(@control_catalog) %>"
       data-baseline-editor-bulk-url-value="<%= bulk_update_baselines_control_catalog_path(@control_catalog) %>"
     <% end %>>
  <div class="card-body">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <div class="d-flex align-items-center gap-3" style="margin-bottom: 0.5rem;">
        <span class="fw-bold bg-body-secondary rounded" style="font-family: monospace; font-size: 1.5rem; padding: 0.3rem 0.8rem;">
          <%= @control_family.code %>
        </span>
        <h2 style="margin: 0;"><%= @control_family.name %></h2>
      </div>
      <p class="text-body-secondary">
        Catalog: <%= link_to @control_catalog.name, @control_catalog, class: "text-primary" %> &nbsp;|&nbsp;
        Controls: <strong><%= @catalog_controls.size %></strong>
      </p>
      <% if @control_family.description.present? %>
        <p class="text-body-secondary" style="margin-top: 0.5rem;"><%= @control_family.description %></p>
      <% end %>
    </div>
    <div class="d-flex gap-2">
      <% if can_edit_baselines %>
        <button type="button" class="btn btn-sparc-purple fw-semibold" style="font-size: 0.875rem;"
                data-action="click->baseline-editor#toggleEdit"
                data-baseline-editor-target="editToggle">Manage Baselines</button>
      <% end %>
      <% if can_write_catalogs? %>
        <%= link_to "Edit Family", edit_control_family_path(@control_family), class: "btn btn-sparc-orange" %>
        <%= link_to "＋ Add Control", new_control_family_catalog_control_path(@control_family), class: "btn btn-success" %>
        <%= link_to "＋ Batch Add", batch_new_control_family_catalog_controls_path(@control_family), class: "btn btn-sparc-purple fw-semibold", style: "font-size: 0.875rem;" %>
      <% end %>
      <%= link_to "← Back to Catalog", @control_catalog, class: "btn btn-primary" %>
    </div>
  </div>

  <%# ── Bulk toolbar (hidden by default, shown in edit mode) ── %>
  <% if can_edit_baselines %>
    <div data-baseline-editor-target="bulkToolbar" style="display: none; margin-bottom: 1rem; padding: 0.75rem 1rem; background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 0.375rem;">
      <div class="d-flex align-items-center gap-3 flex-wrap">
        <label class="form-check mb-0">
          <input type="checkbox" class="form-check-input" data-baseline-editor-target="selectAll" data-action="change->baseline-editor#toggleSelectAll">
          <span class="form-check-label fw-semibold" style="font-size: 0.85rem;">Select All</span>
        </label>
        <span class="text-body-secondary" style="font-size: 0.85rem;" data-baseline-editor-target="bulkCount">0 selected</span>
        <div class="vr"></div>
        <select class="form-select form-select-sm" style="width: auto;" data-baseline-editor-target="bulkLevel">
          <option value="">Level...</option>
          <option value="LOW">LOW</option>
          <option value="MODERATE">MODERATE</option>
          <option value="HIGH">HIGH</option>
        </select>
        <select class="form-select form-select-sm" style="width: auto;" data-baseline-editor-target="bulkAction">
          <option value="add">Add Level</option>
          <option value="remove">Remove Level</option>
          <option value="set">Set to Only This Level</option>
        </select>
        <button type="button" class="btn btn-sm btn-success" data-action="click->baseline-editor#bulkApply">Apply</button>
        <button type="button" class="btn btn-sm btn-outline-danger" data-action="click->baseline-editor#bulkClear">Clear Baselines</button>
      </div>
    </div>
  <% end %>

  <% if @catalog_controls.any? %>
    <%
      # Depth from control_id suffix after the "xx-N" base:
      #   "ac-1"          → 0   (base control)
      #   "ac-1a"         → 1   (letter part)
      #   "ac-1a.1"       → 2   (number sub-part)
      #   "ac-1a.1.(a)"   → 3   (paren sub-part)
      #   "ac-2.1"        → 0   (enhancement — treated as top-level)
      ctrl_depth = ->(id) {
        suffix = id.to_s.sub(/\A[a-z]+-\d+(\.\d+)?/i, "")
        suffix.blank? ? 0 : suffix.scan(/[a-z]|\.\d+|\.\([^)]+\)/).size
      }
    %>
    <table class="table table-hover">
      <thead>
        <tr>
          <% if can_edit_baselines %>
            <th style="width: 40px; display: none;" data-baseline-checkbox-cell></th>
          <% end %>
          <th style="width: 150px;">Control ID</th>
          <th>Title / Statement</th>
          <th class="text-center" style="width: 60px;">Priority</th>
          <th style="width: 200px;">Baseline Impact</th>
          <% if can_write_catalogs? %><th style="width: 130px;">Actions</th><% end %>
        </tr>
      </thead>
      <tbody>
        <% @catalog_controls.each do |control| %>
          <% depth      = ctrl_depth.call(control.control_id) %>
          <% stmt_text  = control.guidance_data["statement"].presence %>
          <tr style="<%= depth > 0 ? "background: #fafbfc;" : "" %>" data-control-db-id="<%= control.id %>">

            <%# ── Checkbox column (edit mode only) ── %>
            <% if can_edit_baselines %>
              <td style="vertical-align: top; padding-top: 0.55rem; display: none;" data-baseline-checkbox-cell>
                <% if depth == 0 %>
                  <input type="checkbox" class="form-check-input" value="<%= control.id %>"
                         data-baseline-editor-target="checkbox"
                         data-action="change->baseline-editor#checkboxChanged">
                <% end %>
              </td>
            <% end %>

            <%# ── Control ID column ── %>
            <td style="padding-left: <%= 0.5 + depth * 1.1 %>rem; vertical-align: top; padding-top: 0.55rem;">
              <% if depth > 0 %>
                <span style="color: var(--bs-border-color); margin-right: 0.25rem; font-size: 0.75rem;">&#x2514;</span>
              <% end %>
              <span style="font-family: monospace;
                           font-weight: <%= depth == 0 ? 700 : 500 %>;
                           color: <%= depth == 0 ? "#2c3e50" : "#666" %>;
                           font-size: <%= depth == 0 ? "0.95rem" : "0.85rem" %>;">
                <%= control.display_id %>
              </span>
            </td>

            <%# ── Title / Statement column ── %>
            <td style="vertical-align: top;">
              <% if depth == 0 %>
                <%# Base control: show title prominently, then statement below %>
                <div class="fw-semibold small">
                  <%= control.title.presence || "<em style='color:#aaa; font-weight:400;'>No title</em>".html_safe %>
                  <% if control.params_present? %>
                    <span class="badge rounded-pill text-bg-info" style="font-size: 0.68rem; font-weight: 500; margin-left: 0.4rem; vertical-align: middle;"
                          title="<%= control.params_list.size %> parameter(s) requiring organization-defined values">
                      <%= control.params_list.size %> param<%= control.params_list.size == 1 ? "" : "s" %>
                    </span>
                  <% end %>
                </div>
                <% if stmt_text.present? %>
                  <div class="text-body-secondary" style="margin-top: 0.3rem; font-size: 0.8rem; line-height: 1.4;">
                    <%= truncate(stmt_text, length: 200) %>
                  </div>
                <% end %>
                <% if control.params_present? %>
                  <details style="margin-top: 0.4rem;">
                    <summary class="text-primary" style="font-size: 0.78rem; cursor: pointer; list-style: none; display: inline-flex; align-items: center; gap: 0.3rem;">
                      <span class="card-arrow" style="font-size: 0.6rem;">&#9658;</span> View parameters
                    </summary>
                    <table class="table table-sm mb-0" style="font-size: 0.78rem; margin-top: 0.3rem; background: transparent;">
                      <thead>
                        <tr>
                          <th style="width: 25%; padding: 0.2rem 0.4rem; border-bottom-width: 1px;">Param ID</th>
                          <th style="width: 40%; padding: 0.2rem 0.4rem; border-bottom-width: 1px;">Label</th>
                          <th style="padding: 0.2rem 0.4rem; border-bottom-width: 1px;">Constraint / Choices</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% control.params_list.each do |param| %>
                          <tr>
                            <td style="padding: 0.2rem 0.4rem; font-family: monospace; color: var(--bs-primary);"><%= param["id"] %></td>
                            <td style="padding: 0.2rem 0.4rem;"><%= param["label"] %></td>
                            <td style="padding: 0.2rem 0.4rem;">
                              <% if param.dig("select", "choice").present? %>
                                <span class="text-body-secondary">Select <%= param.dig("select", "how-many") || "one" %>:</span>
                                <%= param["select"]["choice"].join("; ") %>
                              <% elsif param.dig("guidelines").present? %>
                                <span class="text-body-tertiary"><%= param["guidelines"].map { |g| g["prose"] }.compact.join("; ").truncate(120) %></span>
                              <% else %>
                                <span class="text-body-tertiary">Organization-defined</span>
                              <% end %>
                            </td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  </details>
                <% end %>
              <% else %>
                <%# Sub-part: show statement prose as the primary content %>
                <% if stmt_text.present? %>
                  <span class="text-body-secondary" style="font-size: 0.875rem;"><%= truncate(stmt_text, length: 150) %></span>
                <% else %>
                  <span class="text-body-tertiary" style="font-size: 0.85rem; font-style: italic;"><%= control.title.presence || "No statement" %></span>
                <% end %>
              <% end %>

              <%# #393: Read-only catalog parts (statement / guidance / etc.) %>
              <%= render "control_catalogs/parts_tree", control: control %>
            </td>

            <%# ── Priority column ── %>
            <td class="text-center" style="vertical-align: top; padding-top: 0.55rem;">
              <% if control.priority.present? %>
                <span class="bg-body-secondary rounded fw-semibold" style="padding: 0.2rem 0.5rem; font-size: 0.82rem;">
                  <%= control.priority %>
                </span>
              <% else %>
                <span style="color: var(--bs-tertiary-color);">—</span>
              <% end %>
            </td>

            <%# ── Baseline Impact column ── %>
            <td style="vertical-align: top; padding-top: 0.55rem;">
              <%# View mode: badges %>
              <span data-baseline-view data-baseline-badges>
                <%= render "shared/baseline_badges", baseline_impact: control.baseline_impact %>
              </span>

              <%# Edit mode: inline checkboxes (top-level only) %>
              <% if can_edit_baselines && depth == 0 %>
                <span data-baseline-edit style="display: none;">
                  <% %w[LOW MODERATE HIGH].each do |level| %>
                    <label class="form-check form-check-inline mb-0" style="font-size: 0.78rem;">
                      <input type="checkbox" class="form-check-input" style="margin-top: 0.15rem;"
                             data-baseline-level="<%= level %>"
                             data-action="change->baseline-editor#inlineToggle"
                             <%= "checked" if control.has_baseline_level?(level) %>>
                      <span class="form-check-label"><%= level %></span>
                    </label>
                  <% end %>
                </span>
              <% end %>
            </td>

            <%# ── Actions column ── %>
            <% if can_write_catalogs? %>
              <td style="vertical-align: top; padding-top: 0.45rem;">
                <div class="d-flex flex-wrap gap-1">
                  <%= link_to "Edit", edit_catalog_control_path(control), class: "btn btn-sm btn-sparc-orange" %>
                  <% if depth == 0 %>
                    <%= button_to "Delete", catalog_control_path(control), method: :delete,
                        form: { data: { turbo_confirm: "Delete #{control.control_id}? This also removes all its sub-parts." } },
                        class: "btn btn-danger btn-sm" %>
                  <% end %>
                </div>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center text-body-secondary p-4">
      <p>No controls in this family yet.
        <% if can_write_catalogs? %>
          <%= link_to "Add the first control", new_control_family_catalog_control_path(@control_family), class: "text-primary" %>
        <% end %>
      </p>
    </div>
  <% end %>
  </div>
</div>
