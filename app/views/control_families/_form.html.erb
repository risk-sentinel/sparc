<%= form_with model: control_family.persisted? ? control_family : [control_catalog, control_family], local: true do |f| %>
  <% if control_family.errors.any? %>
    <div class="flash error mb-4">
      <strong><%= pluralize(control_family.errors.count, "error") %>:</strong>
      <ul style="margin-top: 0.5rem; margin-left: 1.5rem;">
        <% control_family.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-auto" style="width: 120px;">
      <div class="form-group">
        <%= f.label :code, "Code *" %>
        <%= f.text_field :code, class: "form-control fw-semibold", placeholder: "AC", style: "font-family: monospace; font-size: 1rem; text-transform: uppercase;" %>
      </div>
    </div>
    <div class="col">
      <div class="form-group">
        <%= f.label :name, "Family Name *" %>
        <%= f.text_field :name, class: "form-control", placeholder: "e.g. Access Control" %>
      </div>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :description %>
    <%= f.text_area :description, class: "form-control", rows: 2, placeholder: "Optional description..." %>
  </div>

  <div class="form-group" style="max-width: 200px;">
    <%= f.label :sort_order, "Sort Order" %>
    <%= f.number_field :sort_order, class: "form-control", min: 0 %>
  </div>

  <div class="d-flex gap-3 mt-3">
    <%= f.submit "Save Family", class: "btn btn-success" %>
    <%= link_to "Cancel", control_catalog, class: "btn btn-secondary" %>
  </div>
<% end %>
