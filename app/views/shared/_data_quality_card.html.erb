<%# Persistent Data Quality Card (#237)
  Locals:
    warnings       — array of warning hashes from CatalogImportValidationService (may be nil)
    summary        — hash with total_warnings, total_affected, by_severity (may be nil)
    revalidate_path — URL for PATCH to re-run validation
    catalog        — the ControlCatalog record
%>
<% warnings ||= [] %>
<% summary ||= {} %>
<% has_warnings = warnings.any? %>
<% total = summary["total_warnings"] || warnings.size %>
<% total_affected = summary["total_affected"] || 0 %>
<% by_severity = summary["by_severity"] || {} %>
<% last_validated = catalog.metadata_extra&.dig("last_validated_at") %>

<div class="card mb-4 data-quality-card <%= has_warnings ? 'data-quality-card--warnings' : 'data-quality-card--clean' %>">
  <details<%= " open" if has_warnings %>>
    <summary class="card-header d-flex align-items-center justify-content-between" style="cursor: pointer; list-style: none;">
      <div class="d-flex align-items-center gap-2">
        <span class="data-quality-arrow">&#9658;</span>
        <strong>Data Quality</strong>
        <% if has_warnings %>
          <% if (by_severity["warning"] || 0) > 0 %>
            <span class="badge bg-warning text-dark"><%= by_severity["warning"] %> Warning<%= 's' if by_severity["warning"] != 1 %></span>
          <% end %>
          <% if (by_severity["info"] || 0) > 0 %>
            <span class="badge bg-info text-white"><%= by_severity["info"] %> Info</span>
          <% end %>
        <% else %>
          <span class="badge bg-success">No Issues</span>
        <% end %>
      </div>
      <div class="d-flex align-items-center gap-2">
        <% if last_validated %>
          <span class="text-body-secondary small">Last checked: <%= Time.parse(last_validated).strftime("%b %d, %Y %H:%M") rescue last_validated %></span>
        <% end %>
        <%= button_to "Re-validate", revalidate_path, method: :patch,
            class: "btn btn-sm btn-outline-secondary",
            data: { turbo_confirm: "Re-run quality validation on this catalog?" },
            form: { style: "display: inline;" } %>
      </div>
    </summary>

    <div class="card-body">
      <% if has_warnings %>
        <p class="mb-3 text-body-secondary">
          <strong><%= total %> quality issue<%= 's' if total != 1 %></strong> detected
          affecting <strong><%= total_affected %></strong> item<%= 's' if total_affected != 1 %>.
          These are advisory — the catalog imported successfully.
        </p>

        <div class="accordion" id="dataQualityAccordion">
          <% warnings.each_with_index do |warning, idx| %>
            <% severity = warning["severity"] || "info" %>
            <% badge_class = severity == "warning" ? "bg-warning text-dark" : "bg-info text-white" %>
            <% category_label = warning["category"].to_s.tr("_", " ").titleize %>
            <% control_ids = warning["control_ids"] || [] %>
            <% count = warning["count"] || control_ids.size %>

            <div class="accordion-item">
              <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#dq-warning-<%= idx %>"
                        aria-expanded="false"
                        aria-controls="dq-warning-<%= idx %>">
                  <span class="badge <%= badge_class %> me-2"><%= severity.capitalize %></span>
                  <span><%= category_label %></span>
                  <span class="badge bg-secondary ms-2"><%= count %></span>
                </button>
              </h2>
              <div id="dq-warning-<%= idx %>" class="accordion-collapse collapse"
                   data-bs-parent="#dataQualityAccordion">
                <div class="accordion-body">
                  <p><%= warning["message"] %></p>
                  <% if control_ids.any? %>
                    <div class="mt-2">
                      <strong>Affected:</strong>
                      <div class="mt-1" style="max-height: 200px; overflow-y: auto;">
                        <% control_ids.each do |cid| %>
                          <span class="badge bg-light text-dark border me-1 mb-1"><%= cid %></span>
                        <% end %>
                        <% if count > control_ids.size %>
                          <span class="text-body-secondary small">... and <%= count - control_ids.size %> more</span>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="mb-0 text-success">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill me-1" viewBox="0 0 16 16">
            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
          </svg>
          No quality issues detected. All controls passed validation checks.
        </p>
      <% end %>
    </div>
  </details>
</div>

<script nonce="<%= content_security_policy_nonce %>">
  // Toggle arrow on details open/close
  document.querySelectorAll('.data-quality-card details').forEach(function(details) {
    var arrow = details.querySelector('.data-quality-arrow');
    if (arrow) {
      details.addEventListener('toggle', function() {
        arrow.innerHTML = details.open ? '&#9660;' : '&#9658;';
      });
      // Set initial state
      arrow.innerHTML = details.open ? '&#9660;' : '&#9658;';
    }
  });
</script>
