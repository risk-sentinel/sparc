<%# Shared OSCAL-compliant form fields for back-matter resource creation.
    Used in catalog_controls/_form, profile_controls/_form, and
    _oscal_back_matter_section partials.

    Renders inline with flexbox. Expects to be inside a <form> tag.
    Optional locals:
      prefix       — field name prefix (default: "back_matter_resource")
      show_global  — show globally_available checkbox (default: true)
%>
<% prefix ||= "back_matter_resource" %>
<% show_global = true unless defined?(show_global) && show_global == false %>

<div class="d-flex gap-2 align-items-end flex-wrap">
  <div style="flex: 2; min-width: 140px;">
    <label class="form-label small mb-1" for="<%= prefix %>_title">Title <span class="text-danger">*</span></label>
    <input type="text" id="<%= prefix %>_title" name="<%= prefix %>[title]" class="form-control form-control-sm" required placeholder="Policy name..." aria-label="Title">
  </div>
  <div style="flex: 2; min-width: 140px;">
    <label class="form-label small mb-1" for="<%= prefix %>_description">Description</label>
    <input type="text" id="<%= prefix %>_description" name="<%= prefix %>[description]" class="form-control form-control-sm" placeholder="Brief description..." aria-label="Description">
  </div>
  <div style="flex: 1; min-width: 100px;">
    <label class="form-label small mb-1" for="<%= prefix %>_rel">Relationship</label>
    <select id="<%= prefix %>_rel" name="<%= prefix %>[rel]" class="form-select form-select-sm" aria-label="Relationship">
      <% BackMatterResource::REL_VALUES.each do |rv| %>
        <option value="<%= rv %>" <%= "selected" if rv == "reference" %>><%= rv %></option>
      <% end %>
    </select>
  </div>
  <div style="flex: 1; min-width: 120px;">
    <label class="form-label small mb-1" for="<%= prefix %>_media_type">Media Type</label>
    <select id="<%= prefix %>_media_type" name="<%= prefix %>[media_type]" class="form-select form-select-sm" aria-label="Media Type">
      <option value="">— select —</option>
      <% BackMatterResource::MEDIA_TYPE_OPTIONS.each do |label, value| %>
        <option value="<%= value %>"><%= label %></option>
      <% end %>
    </select>
  </div>
  <div style="flex: 3; min-width: 180px;">
    <label class="form-label small mb-1" for="<%= prefix %>_href">Href</label>
    <input type="text" id="<%= prefix %>_href" name="<%= prefix %>[href]" class="form-control form-control-sm" placeholder="https://..." aria-label="Href">
  </div>
  <% if show_global %>
    <div style="min-width: 60px;">
      <label class="form-check-label small d-block mb-1">
        <input type="checkbox" name="<%= prefix %>[globally_available]" value="1" class="form-check-input"> Global
      </label>
    </div>
  <% end %>
  <div>
    <button type="submit" class="btn btn-sm btn-success">Create & Link</button>
  </div>
</div>
