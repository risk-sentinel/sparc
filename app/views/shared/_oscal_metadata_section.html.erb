<%# OSCAL Metadata Section — shared across all document show pages.
    Locals:
      document      — the document record (SspDocument, SarDocument, etc.)
      update_path   — the update_metadata path for this document
      param_key     — the form param key (e.g., :ssp_document)
      version_field — the version attribute name (e.g., :ssp_version)
%>

<% metadata = document.metadata_extra || {} %>
<% roles = metadata["roles"] || [] %>
<% parties = metadata["parties"] || [] %>
<% responsible_parties = metadata["responsible-parties"] || [] %>
<% props = metadata["props"] || [] %>
<% links = metadata["links"] || [] %>
<% revisions = metadata["revisions"] || [] %>
<% document_ids = metadata["document-ids"] || [] %>

<div class="card mt-4">
  <div class="card-header d-flex justify-content-between align-items-center"
       style="cursor: pointer;"
       onclick="document.getElementById('oscal-meta-body').classList.toggle('d-none');
                this.querySelector('.toggle-icon').textContent =
                  document.getElementById('oscal-meta-body').classList.contains('d-none') ? '+' : '-';">
    <h5 class="mb-0 fw-semibold">OSCAL Metadata</h5>
    <span class="toggle-icon fw-bold">+</span>
  </div>

  <div id="oscal-meta-body" class="card-body d-none">

    <%# ── Core Fields ─────────────────────────────────────────── %>
    <div class="row mb-4">
      <div class="col-md-3">
        <label class="form-label fw-semibold small">OSCAL Version</label>
        <p class="mb-0"><%= document.oscal_version.presence || "Not set" %></p>
      </div>
      <div class="col-md-3">
        <label class="form-label fw-semibold small">Document Version</label>
        <p class="mb-0"><%= document.oscal_document_version.presence || "Not set" %></p>
      </div>
      <div class="col-md-3">
        <label class="form-label fw-semibold small">Published</label>
        <p class="mb-0"><%= document.try(:published).presence || "Not set" %></p>
      </div>
      <div class="col-md-3">
        <label class="form-label fw-semibold small">Last Modified</label>
        <p class="mb-0"><%= document.updated_at.iso8601 %></p>
      </div>
    </div>

    <%# ── Roles ───────────────────────────────────────────────── %>
    <div class="mb-4">
      <h6 class="fw-semibold">Roles <span class="badge bg-secondary"><%= roles.size %></span></h6>
      <% if roles.any? %>
        <table class="table table-sm table-hover">
          <thead><tr><th>ID</th><th>Title</th><th>Description</th></tr></thead>
          <tbody>
            <% roles.each do |role| %>
              <tr>
                <td><code><%= role["id"] %></code></td>
                <td><%= role["title"] %></td>
                <td class="text-body-secondary small"><%= role["description"] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-body-tertiary small fst-italic">No roles defined</p>
      <% end %>
    </div>

    <%# ── Parties ─────────────────────────────────────────────── %>
    <div class="mb-4">
      <h6 class="fw-semibold">Parties <span class="badge bg-secondary"><%= parties.size %></span></h6>
      <% if parties.any? %>
        <table class="table table-sm table-hover">
          <thead><tr><th>Name</th><th>Type</th><th>UUID</th></tr></thead>
          <tbody>
            <% parties.each do |party| %>
              <tr>
                <td><%= party["name"] %></td>
                <td><span class="badge bg-body-secondary text-body"><%= party["type"] %></span></td>
                <td><code class="small"><%= party["uuid"] %></code></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-body-tertiary small fst-italic">No parties defined</p>
      <% end %>
    </div>

    <%# ── Responsible Parties ─────────────────────────────────── %>
    <% if responsible_parties.any? %>
      <div class="mb-4">
        <h6 class="fw-semibold">Responsible Parties <span class="badge bg-secondary"><%= responsible_parties.size %></span></h6>
        <table class="table table-sm table-hover">
          <thead><tr><th>Role ID</th><th>Party UUIDs</th></tr></thead>
          <tbody>
            <% responsible_parties.each do |rp| %>
              <tr>
                <td><code><%= rp["role-id"] %></code></td>
                <td>
                  <% (rp["party-uuids"] || []).each do |uuid| %>
                    <code class="small"><%= uuid %></code><br>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <%# ── Properties ──────────────────────────────────────────── %>
    <% if props.any? %>
      <div class="mb-4">
        <h6 class="fw-semibold">Properties <span class="badge bg-secondary"><%= props.size %></span></h6>
        <table class="table table-sm table-hover">
          <thead><tr><th>Name</th><th>Value</th><th>Namespace</th></tr></thead>
          <tbody>
            <% props.each do |prop| %>
              <tr>
                <td><code><%= prop["name"] %></code></td>
                <td><%= prop["value"] %></td>
                <td class="text-body-secondary small"><%= prop["ns"] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <%# ── Links ───────────────────────────────────────────────── %>
    <% if links.any? %>
      <div class="mb-4">
        <h6 class="fw-semibold">Links <span class="badge bg-secondary"><%= links.size %></span></h6>
        <table class="table table-sm table-hover">
          <thead><tr><th>Relation</th><th>Href</th><th>Media Type</th></tr></thead>
          <tbody>
            <% links.each do |link| %>
              <tr>
                <td><code><%= link["rel"] %></code></td>
                <td class="text-break"><%= link["href"] %></td>
                <td class="small"><%= link["media-type"] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <%# ── Document IDs ────────────────────────────────────────── %>
    <% if document_ids.any? %>
      <div class="mb-4">
        <h6 class="fw-semibold">Document IDs <span class="badge bg-secondary"><%= document_ids.size %></span></h6>
        <table class="table table-sm table-hover">
          <thead><tr><th>Scheme</th><th>Identifier</th></tr></thead>
          <tbody>
            <% document_ids.each do |did| %>
              <tr>
                <td><code><%= did["scheme"] %></code></td>
                <td><%= did["identifier"] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <%# ── Revisions ───────────────────────────────────────────── %>
    <% if revisions.any? %>
      <div class="mb-4">
        <h6 class="fw-semibold">Revision History <span class="badge bg-secondary"><%= revisions.size %></span></h6>
        <table class="table table-sm table-hover">
          <thead><tr><th>Version</th><th>Title</th><th>Published</th><th>Last Modified</th></tr></thead>
          <tbody>
            <% revisions.each do |rev| %>
              <tr>
                <td><%= rev["version"] %></td>
                <td><%= rev["title"] %></td>
                <td class="small"><%= rev["published"] %></td>
                <td class="small"><%= rev["last-modified"] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <%# ── Edit Metadata Form ──────────────────────────────────── %>
    <hr>
    <div id="oscal-meta-edit-section"
         <% if signed_in? && defined?(current_user) && current_user %>
           data-user-name="<%= current_user.display_name.presence || "#{current_user.first_name} #{current_user.last_name}".strip %>"
           data-user-email="<%= current_user.email %>"
           <% org = current_user.respond_to?(:organizations) ? current_user.organizations.first : nil %>
           <% if org %>
             data-org-name="<%= org.name %>"
             data-org-email="<%= org.contact_email %>"
           <% end %>
         <% end %>
    >
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-semibold mb-0">Edit OSCAL Metadata</h6>
        <% if signed_in? && document.draft? %>
          <button type="button" class="btn btn-outline-primary btn-sm" onclick="prefillFromProfile()">
            Pre-fill from my profile
          </button>
        <% end %>
      </div>
      <%= form_with url: update_path, method: :patch, local: true do |f| %>

        <%# ── Core fields row ── %>
        <div class="row g-3 mb-3">
          <div class="col-md-3">
            <label class="form-label small fw-semibold">OSCAL Version</label>
            <%= f.text_field :oscal_version, value: document.oscal_version, class: "form-control form-control-sm", placeholder: "1.1.2" %>
          </div>
          <div class="col-md-3">
            <label class="form-label small fw-semibold">Published Date</label>
            <%= f.text_field :published, value: document.try(:published), class: "form-control form-control-sm", placeholder: "2024-01-15T00:00:00Z" %>
          </div>
          <div class="col-md-6">
            <label class="form-label small fw-semibold">Description</label>
            <%= f.text_area :description, value: document.description, class: "form-control form-control-sm", rows: 2 %>
          </div>
        </div>

        <%# ── Structured Roles Editor ── %>
        <div class="mb-3">
          <label class="form-label small fw-semibold">Roles</label>
          <div id="roles-editor">
            <% roles.each_with_index do |role, idx| %>
              <div class="row g-2 mb-2 role-row">
                <div class="col-md-3">
                  <input type="text" class="form-control form-control-sm" placeholder="Role ID (e.g. prepared-by)" data-field="id" value="<%= role["id"] %>">
                </div>
                <div class="col-md-4">
                  <input type="text" class="form-control form-control-sm" placeholder="Title" data-field="title" value="<%= role["title"] %>">
                </div>
                <div class="col-md-4">
                  <input type="text" class="form-control form-control-sm" placeholder="Description" data-field="description" value="<%= role["description"] %>">
                </div>
                <div class="col-md-1">
                  <button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('.role-row').remove(); syncMetadataJson();">x</button>
                </div>
              </div>
            <% end %>
          </div>
          <button type="button" class="btn btn-outline-secondary btn-sm mt-1" onclick="addRoleRow()">+ Add Role</button>
        </div>

        <%# ── Structured Parties Editor ── %>
        <div class="mb-3">
          <label class="form-label small fw-semibold">Parties</label>
          <div id="parties-editor">
            <% parties.each_with_index do |party, idx| %>
              <div class="row g-2 mb-2 party-row">
                <div class="col-md-4">
                  <input type="text" class="form-control form-control-sm" placeholder="Name" data-field="name" value="<%= party["name"] %>">
                </div>
                <div class="col-md-2">
                  <select class="form-select form-select-sm" data-field="type">
                    <option value="organization" <%= "selected" if party["type"] == "organization" %>>Organization</option>
                    <option value="person" <%= "selected" if party["type"] == "person" %>>Person</option>
                  </select>
                </div>
                <div class="col-md-5">
                  <input type="text" class="form-control form-control-sm" placeholder="UUID (auto-generated if blank)" data-field="uuid" value="<%= party["uuid"] %>">
                </div>
                <div class="col-md-1">
                  <button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('.party-row').remove(); syncMetadataJson();">x</button>
                </div>
              </div>
            <% end %>
          </div>
          <button type="button" class="btn btn-outline-secondary btn-sm mt-1" onclick="addPartyRow()">+ Add Party</button>
        </div>

        <%# ── Structured Revisions Editor ── %>
        <div class="mb-3">
          <label class="form-label small fw-semibold">Revisions</label>
          <div id="revisions-editor">
            <% revisions.each_with_index do |rev, idx| %>
              <div class="row g-2 mb-2 revision-row">
                <div class="col-md-2">
                  <input type="text" class="form-control form-control-sm" placeholder="Version" data-field="version" value="<%= rev["version"] %>">
                </div>
                <div class="col-md-3">
                  <input type="text" class="form-control form-control-sm" placeholder="Title" data-field="title" value="<%= rev["title"] %>">
                </div>
                <div class="col-md-3">
                  <input type="text" class="form-control form-control-sm" placeholder="Published (ISO 8601)" data-field="published" value="<%= rev["published"] %>">
                </div>
                <div class="col-md-3">
                  <input type="text" class="form-control form-control-sm" placeholder="Last Modified (ISO 8601)" data-field="last-modified" value="<%= rev["last-modified"] %>">
                </div>
                <div class="col-md-1">
                  <button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('.revision-row').remove(); syncMetadataJson();">x</button>
                </div>
              </div>
            <% end %>
          </div>
          <button type="button" class="btn btn-outline-secondary btn-sm mt-1" onclick="addRevisionRow()">+ Add Revision</button>
        </div>

        <%# ── Advanced: Raw JSON for remaining fields ── %>
        <details class="mb-3">
          <summary class="form-label small fw-semibold" style="cursor: pointer;">Advanced: Edit Raw JSON (responsible-parties, props, links, document-ids)</summary>
          <textarea id="metadata-extra-json"
                    name="<%= param_key %>[metadata_extra_json]"
                    class="form-control form-control-sm font-monospace mt-2"
                    rows="6"
                    placeholder='{"props": [{"name": "keywords", "value": "security"}]}'
          ><%= JSON.pretty_generate(metadata.slice("responsible-parties", "props", "links", "document-ids")) if metadata.any? %></textarea>
          <div class="form-text">Edit additional OSCAL metadata JSON. Structured editors above for roles, parties, and revisions are merged automatically.</div>
        </details>

        <%# Hidden field that holds the merged metadata_extra JSON (roles + parties + revisions + advanced) %>
        <input type="hidden" id="merged-metadata-extra" name="<%= param_key %>[metadata_extra_json]">

        <div class="d-flex gap-2">
          <%= f.submit "Save Metadata", class: "btn btn-primary btn-sm", onclick: "syncMetadataJson();" %>
        </div>
      <% end %>
    </div>

  </div>
</div>

<script>
  function collectRows(containerId, fields) {
    var rows = document.querySelectorAll('#' + containerId + ' > div');
    var items = [];
    rows.forEach(function(row) {
      var item = {};
      var hasValue = false;
      fields.forEach(function(field) {
        var el = row.querySelector('[data-field="' + field + '"]');
        if (el && el.value.trim() !== '') {
          item[field] = el.value.trim();
          hasValue = true;
        }
      });
      if (hasValue) items.push(item);
    });
    return items;
  }

  function syncMetadataJson() {
    var roles = collectRows('roles-editor', ['id', 'title', 'description']);
    var parties = collectRows('parties-editor', ['name', 'type', 'uuid']);
    // Auto-generate UUIDs for parties missing them
    parties.forEach(function(p) {
      if (!p.uuid) p.uuid = crypto.randomUUID();
    });
    var revisions = collectRows('revisions-editor', ['version', 'title', 'published', 'last-modified']);

    // Parse advanced JSON
    var advanced = {};
    var advEl = document.getElementById('metadata-extra-json');
    if (advEl && advEl.value.trim()) {
      try { advanced = JSON.parse(advEl.value); } catch(e) { /* ignore parse errors */ }
    }

    // Merge structured + advanced
    var merged = Object.assign({}, advanced);
    if (roles.length > 0) merged['roles'] = roles;
    if (parties.length > 0) merged['parties'] = parties;
    if (revisions.length > 0) merged['revisions'] = revisions;

    document.getElementById('merged-metadata-extra').value = JSON.stringify(merged);
    // Clear the textarea name so only the hidden field submits
    if (advEl) advEl.removeAttribute('name');
  }

  function addRoleRow() {
    var html = '<div class="row g-2 mb-2 role-row">' +
      '<div class="col-md-3"><input type="text" class="form-control form-control-sm" placeholder="Role ID (e.g. prepared-by)" data-field="id"></div>' +
      '<div class="col-md-4"><input type="text" class="form-control form-control-sm" placeholder="Title" data-field="title"></div>' +
      '<div class="col-md-4"><input type="text" class="form-control form-control-sm" placeholder="Description" data-field="description"></div>' +
      '<div class="col-md-1"><button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest(\'.role-row\').remove(); syncMetadataJson();">x</button></div>' +
      '</div>';
    document.getElementById('roles-editor').insertAdjacentHTML('beforeend', html);
  }

  function addPartyRow() {
    var html = '<div class="row g-2 mb-2 party-row">' +
      '<div class="col-md-4"><input type="text" class="form-control form-control-sm" placeholder="Name" data-field="name"></div>' +
      '<div class="col-md-2"><select class="form-select form-select-sm" data-field="type"><option value="organization">Organization</option><option value="person">Person</option></select></div>' +
      '<div class="col-md-5"><input type="text" class="form-control form-control-sm" placeholder="UUID (auto-generated if blank)" data-field="uuid"></div>' +
      '<div class="col-md-1"><button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest(\'.party-row\').remove(); syncMetadataJson();">x</button></div>' +
      '</div>';
    document.getElementById('parties-editor').insertAdjacentHTML('beforeend', html);
  }

  function addRevisionRow() {
    var html = '<div class="row g-2 mb-2 revision-row">' +
      '<div class="col-md-2"><input type="text" class="form-control form-control-sm" placeholder="Version" data-field="version"></div>' +
      '<div class="col-md-3"><input type="text" class="form-control form-control-sm" placeholder="Title" data-field="title"></div>' +
      '<div class="col-md-3"><input type="text" class="form-control form-control-sm" placeholder="Published (ISO 8601)" data-field="published"></div>' +
      '<div class="col-md-3"><input type="text" class="form-control form-control-sm" placeholder="Last Modified (ISO 8601)" data-field="last-modified"></div>' +
      '<div class="col-md-1"><button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest(\'.revision-row\').remove(); syncMetadataJson();">x</button></div>' +
      '</div>';
    document.getElementById('revisions-editor').insertAdjacentHTML('beforeend', html);
  }

  function prefillFromProfile() {
    var section = document.getElementById('oscal-meta-edit-section');
    if (!section) return;

    var userName = section.dataset.userName || '';
    var userEmail = section.dataset.userEmail || '';
    var orgName = section.dataset.orgName || '';
    var orgEmail = section.dataset.orgEmail || '';

    // Add prepared-by role if no roles exist yet
    var rolesEditor = document.getElementById('roles-editor');
    if (rolesEditor && rolesEditor.querySelectorAll('.role-row').length === 0) {
      addRoleRow();
      var newRow = rolesEditor.querySelector('.role-row:last-child');
      if (newRow) {
        var idField = newRow.querySelector('[data-field="id"]');
        var titleField = newRow.querySelector('[data-field="title"]');
        if (idField) idField.value = 'prepared-by';
        if (titleField) titleField.value = 'Prepared By';
      }
    }

    // Add contact party if no parties exist yet
    var partiesEditor = document.getElementById('parties-editor');
    if (partiesEditor && partiesEditor.querySelectorAll('.party-row').length === 0) {
      addPartyRow();
      var partyRow = partiesEditor.querySelector('.party-row:last-child');
      if (partyRow) {
        var nameField = partyRow.querySelector('[data-field="name"]');
        var typeField = partyRow.querySelector('[data-field="type"]');
        if (orgName) {
          if (nameField) nameField.value = orgName;
          if (typeField) typeField.value = 'organization';
        } else if (userName) {
          if (nameField) nameField.value = userName;
          if (typeField) typeField.value = 'person';
        }
      }
    }

    syncMetadataJson();
  }
</script>
