<%# Renders a compact summary tile bar for a section page.
    Locals:
      tiles: Array of [count, label] tuples
            e.g. [[12, "Documents"], [340, "Controls"]]
%>
<div class="card sparc-gradient-header mb-3" style="padding: 1rem 1.25rem; border-radius: 0.5rem;">
  <div class="row row-cols-2 row-cols-md-<%= [tiles.size, 6].min %> g-2 text-center">
    <% tiles.each do |count, label| %>
      <div class="col">
        <div class="sparc-hero-tile">
          <div class="sparc-hero-tile-count"><%= count %></div>
          <div class="sparc-hero-tile-label"><%= label %></div>
        </div>
      </div>
    <% end %>
  </div>
</div>
