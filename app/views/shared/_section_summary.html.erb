<%# Renders a compact summary tile bar for a section page.
    Locals:
      tiles: Array of [count, label] tuples
            e.g. [[12, "Documents"], [340, "Controls"]]
%>
<div class="card sparc-gradient-header mb-3" style="padding: 0.75rem 1rem; border-radius: 0.5rem;">
  <div class="row row-cols-2 row-cols-md-<%= [tiles.size, 6].min %> g-2 text-center">
    <% tiles.each do |count, label| %>
      <div class="col">
        <div class="sparc-hero-tile" style="padding: 0.4rem 0.25rem;">
          <div class="sparc-hero-tile-count" style="font-size: 1.1rem;"><%= count %></div>
          <div class="sparc-hero-tile-label" style="font-size: 0.6rem;"><%= label %></div>
        </div>
      </div>
    <% end %>
  </div>
</div>
