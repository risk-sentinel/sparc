<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
  <head>
    <title>SPARC</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="turbo-cache-control" content="no-cache">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Apply saved or system theme before first paint to prevent FOUC %>
    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        var t = localStorage.getItem("sparc-theme");
        if (t) {
          document.documentElement.setAttribute("data-bs-theme", t);
        } else {
          var dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.setAttribute("data-bs-theme", dark ? "dark" : "light");
        }
      })();
    </script>

    <%# Bootstrap 5.3 CSS via CDN %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <%# Cropper.js CSS for avatar crop (#234) %>
    <link href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css" rel="stylesheet" integrity="sha384-6LFfkTKLRlzFtgx8xsWyBdKGpcMMQTkv+dB7rAbugeJAu1Ym2q1Aji1cjHBG12Xh" crossorigin="anonymous">

    <%# Bootstrap 5.3 JS bundle — loaded in <head> with defer so it persists
        across Turbo Drive navigations and is always available before turbo:load fires %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous" defer></script>

    <%# Mermaid.js for OSCAL relationship diagrams (loaded on all pages, ~200KB gzipped, renders only .mermaid elements).
        Pinned to an exact version so Subresource Integrity applies (SRI needs a fixed resource) — bump deliberately. %>
    <script src="https://cdn.jsdelivr.net/npm/mermaid@11.16.0/dist/mermaid.min.js" integrity="sha384-T/0lMUdJpd2S1ZHtRiofG3htU3xPCrFVeAQ1UUE2TJwlEJSV5NUwn30kP28n238E" crossorigin="anonymous" defer></script>
    <script nonce="<%= content_security_policy_nonce %>">
      document.addEventListener("DOMContentLoaded", function() {
        if (typeof mermaid !== "undefined") { mermaid.initialize({ startOnLoad: false, theme: "base", themeVariables: { primaryColor: "#2c3e50", primaryTextColor: "#ecf0f1", primaryBorderColor: "#3498db", lineColor: "#5d6d7e", secondaryColor: "#2c3e50", tertiaryColor: "#2c3e50", background: "transparent", mainBkg: "#2c3e50", nodeBorder: "#5d6d7e", clusterBkg: "rgba(255,255,255,0.03)", clusterBorder: "rgba(255,255,255,0.12)", titleColor: "rgba(255,255,255,0.6)", edgeLabelBackground: "transparent", fontFamily: "inherit" } }); mermaid.run(); }
      });
      document.addEventListener("turbo:load", function() {
        if (typeof mermaid !== "undefined" && document.querySelector(".mermaid")) { mermaid.run(); }
      });
    </script>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "sparc-theme", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="video-easter-egg details-arrow">
    <%= render "shared/environment_header" %>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
      <div class="container-fluid">
        <div class="d-flex align-items-center gap-2">
          <a href="#" class="navbar-brand d-flex align-items-center" data-action="click->video-easter-egg#play">
            <%= image_tag "sparc_logo.png", alt: "SPARC", class: "sparc-navbar-logo" %>
          </a>
          <span class="badge text-bg-dark" style="font-size: 0.65rem;">v<%= SparcConfig::VERSION %></span>
        </div>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <%# ── About (left-aligned, next to logo) ── %>
          <ul class="navbar-nav me-auto align-items-center gap-1 ms-3">
            <li class="nav-item d-none d-lg-block">
              <%= link_to "About", about_path, class: "nav-link sparc-nav-btn" %>
            </li>
          </ul>

          <ul class="navbar-nav ms-auto align-items-center gap-1">

            <%# ── Home ── %>
            <li class="nav-item">
              <%= link_to "Home", root_path, class: "nav-link sparc-nav-btn" %>
            </li>

            <%# ── Controls Layer (blue — always visible) ── %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle sparc-nav-btn sparc-nav-controls" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Controls
              </a>
              <ul class="dropdown-menu sparc-dropdown-menu">
                <li class="sparc-dropdown-header sparc-dropdown-header-controls">Controls Layer</li>
                <li><%= link_to control_catalogs_path, class: "dropdown-item" do %>
                  <span class="sparc-dropdown-icon">&#128218;</span> Control Catalogs
                <% end %></li>
                <li><%= link_to profile_documents_path, class: "dropdown-item" do %>
                  <span class="sparc-dropdown-icon">&#128203;</span> Baselines
                <% end %></li>
                <li><%= link_to control_mappings_path, class: "dropdown-item" do %>
                  <span class="sparc-dropdown-icon">&#128260;</span> Mappings
                <% end %></li>
              </ul>
            </li>

            <% if !SparcConfig.any_auth_enabled? || signed_in? %>
              <%# ── Implementation Layer (green) ── %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle sparc-nav-btn sparc-nav-implementation" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  Implementation
                </a>
                <ul class="dropdown-menu sparc-dropdown-menu">
                  <li class="sparc-dropdown-header sparc-dropdown-header-implementation">Implementation Layer</li>
                  <li><%= link_to ssp_documents_path, class: "dropdown-item" do %>
                    <span class="sparc-dropdown-icon">&#128196;</span> System Security Plans
                  <% end %></li>
                  <li><%= link_to cdef_documents_path, class: "dropdown-item" do %>
                    <span class="sparc-dropdown-icon">&#128295;</span> Component Definitions
                  <% end %></li>
                  <li><%= link_to converters_path, class: "dropdown-item" do %>
                    <span class="sparc-dropdown-icon">&#128260;</span> Converters
                  <% end %></li>
                </ul>
              </li>

              <%# ── Assessment Layer (orange) ── %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle sparc-nav-btn sparc-nav-assessment" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  Assessment
                </a>
                <ul class="dropdown-menu sparc-dropdown-menu">
                  <li class="sparc-dropdown-header sparc-dropdown-header-assessment">Assessment Layer</li>
                  <li><%= link_to sap_documents_path, class: "dropdown-item" do %>
                    <span class="sparc-dropdown-icon">&#128221;</span> Assessment Plans
                  <% end %></li>
                  <li><%= link_to sar_documents_path, class: "dropdown-item" do %>
                    <span class="sparc-dropdown-icon">&#128200;</span> Assessment Results
                  <% end %></li>
                  <li><%= link_to evidences_path, class: "dropdown-item" do %>
                    <span class="sparc-dropdown-icon">&#128206;</span> Evidence
                  <% end %></li>
                  <li><%= link_to poam_documents_path, class: "dropdown-item" do %>
                    <span class="sparc-dropdown-icon">&#9888;&#65039;</span> POA&amp;Ms
                  <% end %></li>
                </ul>
              </li>

              <%# ── Enterprise (Auth Boundaries dropdown) ── %>
              <% if signed_in? %>
                <% boundaries = nav_authorization_boundaries %>
                <li class="nav-item dropdown">
                  <a class="nav-link dropdown-toggle sparc-nav-btn sparc-nav-boundaries" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    Enterprise
                  </a>
                  <ul class="dropdown-menu sparc-dropdown-menu">
                    <li class="sparc-dropdown-header sparc-dropdown-header-boundaries">Enterprise</li>
                    <li><%= link_to admin_organizations_path, class: "dropdown-item d-flex align-items-center gap-2" do %>
                      <span>&#127970;</span> Organizations
                      <span class="badge bg-secondary ms-auto" style="font-size: 0.65rem;"><%= Organization.count %></span>
                    <% end %></li>
                    <% if current_user&.admin? %>
                      <li><%= link_to admin_service_accounts_path, class: "dropdown-item d-flex align-items-center gap-2" do %>
                        <span>&#128272;</span> Service Accounts
                      <% end %></li>
                    <% end %>
                    <li><hr class="dropdown-divider"></li>
                    <li class="sparc-dropdown-header" style="font-size: 0.7rem; padding: 0.25rem 1rem; color: rgba(255,255,255,0.5);">Authorization Boundaries</li>
                    <% if boundaries.any? %>
                      <% boundaries.each do |ab| %>
                        <li><%= link_to authorization_boundary_path(ab), class: "dropdown-item d-flex align-items-center justify-content-between gap-2" do %>
                          <span class="text-truncate" style="max-width: 160px;"><%= ab.name %></span>
                          <span class="badge rounded-pill sparc-status--<%= ab_status_variant(ab.status) %>" style="font-size: 0.65rem; padding: 0.1rem 0.4rem;">
                            <%= ab.status.capitalize %>
                          </span>
                        <% end %></li>
                      <% end %>
                      <li><hr class="dropdown-divider"></li>
                    <% else %>
                      <li class="px-3 py-2"><span class="text-body-secondary" style="font-size: 0.8rem;">No boundaries assigned</span></li>
                      <li><hr class="dropdown-divider"></li>
                    <% end %>
                    <li><%= link_to authorization_boundaries_path, class: "dropdown-item" do %>
                      <span class="sparc-dropdown-icon">&#128203;</span> View All Boundaries
                    <% end %></li>
                  </ul>
                </li>
              <% else %>
                <li class="nav-item">
                  <%= link_to "Auth Boundaries", authorization_boundaries_path, class: "nav-link sparc-nav-btn" %>
                </li>
              <% end %>
            <% end %>

            <%# ── Resources ── %>
            <li class="nav-item d-none d-lg-block">
              <%= link_to "Resources", about_resources_path, class: "nav-link sparc-nav-btn" %>
            </li>

            <%# ── OSCAL Overview ── %>
            <li class="nav-item d-none d-lg-block">
              <%= link_to "OSCAL", oscal_overview_path, class: "nav-link sparc-nav-btn",
                    title: "OSCAL Document Relationship Overview" %>
            </li>

            <%# ── Separator ── %>
            <li class="nav-item d-none d-lg-block">
              <span class="sparc-nav-separator"></span>
            </li>

            <%# ── Theme toggle ── %>
            <li class="nav-item" data-controller="theme">
              <button class="btn btn-outline-light btn-sm sparc-nav-theme-btn"
                      data-theme-target="icon"
                      data-action="theme#toggle"
                      title="Toggle light/dark mode">&#127769;</button>
            </li>

            <%# ── User menu / Login ── %>
            <% if SparcConfig.any_auth_enabled? %>
              <% if signed_in? %>
                <li class="nav-item dropdown">
                  <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 sparc-nav-user" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="sparc-avatar">
                      <%= safe_avatar_tag(current_user, alt: current_user.initials) %>
                    </span>
                    <span class="d-none d-xl-inline"><%= current_user.display_label %></span>
                  </a>
                  <ul class="dropdown-menu dropdown-menu-end sparc-dropdown-menu">
                    <li class="px-3 py-2">
                      <div class="d-flex align-items-center gap-2">
                        <span class="sparc-avatar sparc-avatar-md">
                          <%= safe_avatar_tag(current_user, alt: current_user.initials) %>
                        </span>
                        <div>
                          <div class="fw-semibold small"><%= current_user.display_label %></div>
                          <div class="text-body-secondary" style="font-size: 0.75rem;"><%= current_user.email %></div>
                        </div>
                      </div>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <% if current_user.admin? %>
                      <li><h6 class="dropdown-header">Administration</h6></li>
                      <li><%= link_to "Users", admin_users_path, class: "dropdown-item" %></li>
                      <li><%= link_to "Roles", admin_roles_path, class: "dropdown-item" %></li>
                      <li><%= link_to "Service Accounts", admin_service_accounts_path, class: "dropdown-item" %></li>
                      <li><%= link_to "Auth Boundaries", admin_authorization_boundaries_path, class: "dropdown-item" %></li>
                      <li><%= link_to "Organizations", admin_organizations_path, class: "dropdown-item" %></li>
                      <li><%= link_to "Audit Log", admin_audit_logs_path, class: "dropdown-item" %></li>
                      <li><hr class="dropdown-divider"></li>
                    <% end %>
                    <li><%= link_to "Profile", edit_profile_path, class: "dropdown-item" %></li>
                    <li><%= link_to "Change Password", edit_password_path, class: "dropdown-item" %></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><%= button_to "Sign Out", logout_path, method: :delete, class: "dropdown-item" %></li>
                  </ul>
                </li>
              <% else %>
                <li class="nav-item">
                  <%= link_to "Login", login_path, class: "btn btn-outline-info btn-sm fw-semibold" %>
                </li>
              <% end %>
            <% end %>

          </ul>
        </div>
      </div>
    </nav>

    <%# ── Flash notifications (fixed top-right overlay) ──────── %>
    <% if flash[:success] || flash[:error] || flash[:warning] %>
      <div class="flash-container" data-controller="flash">
        <% if flash[:success] %>
          <div class="alert alert-success alert-dismissible fade show flash" data-flash-target="message" role="alert">
            <%= flash[:success] %>
            <button type="button" class="btn-close" data-action="click->flash#dismiss" aria-label="Close"></button>
          </div>
        <% end %>
        <% if flash[:error] %>
          <div class="alert alert-danger alert-dismissible fade show flash" data-flash-target="message" role="alert">
            <%= flash[:error] %>
            <button type="button" class="btn-close" data-action="click->flash#dismiss" aria-label="Close"></button>
          </div>
        <% end %>
        <% if flash[:warning] %>
          <div class="alert alert-warning alert-dismissible fade show flash" data-flash-target="message" role="alert">
            <%= flash[:warning] %>
            <button type="button" class="btn-close" data-action="click->flash#dismiss" aria-label="Close"></button>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if signed_in? %>
      <div class="d-flex">
        <%= render "shared/sidebar" %>
        <div class="sparc-main-content flex-grow-1">
          <div class="container">
            <%= yield %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="container">
        <%= yield %>
      </div>
    <% end %>

    <%# Easter egg video overlay — triggered by navbar logo click %>
    <div class="sparc-video-overlay d-none"
         data-video-easter-egg-target="overlay"
         data-action="click->video-easter-egg#overlayClick">
      <video data-video-easter-egg-target="video"
             data-action="ended->video-easter-egg#videoEnded"
             class="sparc-video-player"
             preload="none">
        <source src="/videos/sparc_intro.mp4" type="video/mp4">
      </video>
    </div>

  </body>
</html>
