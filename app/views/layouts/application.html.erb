<!DOCTYPE html>
<html data-bs-theme="light">
  <head>
    <title>SPARC</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Apply saved theme before first paint to prevent flash of wrong theme %>
    <script>
      (function() {
        var t = localStorage.getItem("sparc-theme");
        if (t) document.documentElement.setAttribute("data-bs-theme", t);
      })();
    </script>

    <%# Bootstrap 5.3 CSS via CDN %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "sparc-theme", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
      <div class="container-fluid">
        <div class="d-flex align-items-center gap-2">
          <%= link_to root_path, class: "navbar-brand d-flex align-items-center" do %>
            <%= image_tag "sparc.png", alt: "SPARC", style: "height: 40px; width: auto;" %>
          <% end %>
          <span class="badge text-bg-secondary opacity-75" style="font-size: 0.65rem;">v3.0.0</span>
        </div>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto align-items-center">
            <li class="nav-item"><%= link_to "Home", root_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Projects", projects_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Control Catalogs", control_catalogs_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Baselines", profile_documents_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Component Definitions", cdef_documents_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Controls Implementation", ssp_documents_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Assessment Plans", sap_documents_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Assessment Results", sar_documents_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "POA&Ms", poam_documents_path, class: "nav-link" %></li>
            <li class="nav-item">
              <button id="themeToggleBtn" class="btn btn-outline-light btn-sm ms-2" onclick="toggleTheme()" title="Toggle light/dark mode">&#127769;</button>
            </li>
            <% if SparcConfig.any_auth_enabled? %>
              <% if signed_in? %>
                <li class="nav-item dropdown ms-2">
                  <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <%= current_user.display_label %>
                  </a>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li><span class="dropdown-item-text small text-body-secondary"><%= current_user.email %></span></li>
                    <% if current_user.admin? %>
                      <li><hr class="dropdown-divider"></li>
                      <li><%= link_to "Admin: Users", admin_users_path, class: "dropdown-item" %></li>
                    <% end %>
                    <li><hr class="dropdown-divider"></li>
                    <li><%= link_to "Change Password", edit_password_path, class: "dropdown-item" %></li>
                    <li><%= button_to "Sign Out", logout_path, method: :delete, class: "dropdown-item" %></li>
                  </ul>
                </li>
              <% else %>
                <li class="nav-item">
                  <%= link_to "Login", login_path, class: "btn btn-outline-info btn-sm ms-2 fw-semibold" %>
                </li>
              <% end %>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <%# ── Flash notifications (fixed top-right overlay) ──────── %>
    <% if flash[:success] || flash[:error] || flash[:warning] %>
      <div class="flash-container" data-controller="flash">
        <% if flash[:success] %>
          <div class="alert alert-success alert-dismissible fade show flash" data-flash-target="message" role="alert">
            <%= flash[:success] %>
            <button type="button" class="btn-close" data-action="click->flash#dismiss" aria-label="Close"></button>
          </div>
        <% end %>
        <% if flash[:error] %>
          <div class="alert alert-danger alert-dismissible fade show flash" data-flash-target="message" role="alert">
            <%= flash[:error] %>
            <button type="button" class="btn-close" data-action="click->flash#dismiss" aria-label="Close"></button>
          </div>
        <% end %>
        <% if flash[:warning] %>
          <div class="alert alert-warning alert-dismissible fade show flash" data-flash-target="message" role="alert">
            <%= flash[:warning] %>
            <button type="button" class="btn-close" data-action="click->flash#dismiss" aria-label="Close"></button>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="container">
      <%= yield %>
    </div>

    <%# Bootstrap 5.3 JS bundle via CDN %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    <script>
      function toggleTheme() {
        var html = document.documentElement;
        var current = html.getAttribute("data-bs-theme");
        var systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var isDark = current === "dark" || (!current && systemDark);
        var next = isDark ? "light" : "dark";
        html.setAttribute("data-bs-theme", next);
        localStorage.setItem("sparc-theme", next);
        updateThemeIcon();
      }

      function updateThemeIcon() {
        var html = document.documentElement;
        var current = html.getAttribute("data-bs-theme");
        var systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var isDark = current === "dark" || (!current && systemDark);
        var btn = document.getElementById("themeToggleBtn");
        if (btn) btn.textContent = isDark ? "\u2600\uFE0F" : "\uD83C\uDF19";
      }

      document.addEventListener("DOMContentLoaded", updateThemeIcon);
      window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", updateThemeIcon);
    </script>
  </body>
</html>
