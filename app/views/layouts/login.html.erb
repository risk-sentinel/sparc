<!DOCTYPE html>
<html data-bs-theme="light">
  <head>
    <title><%= SparcConfig.app_name %> — Login</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Apply saved or system theme before first paint to prevent FOUC %>
    <script>
      (function() {
        var t = localStorage.getItem("sparc-theme");
        if (t) {
          document.documentElement.setAttribute("data-bs-theme", t);
        } else {
          var dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.setAttribute("data-bs-theme", dark ? "dark" : "light");
        }
      })();
    </script>

    <%# Bootstrap 5.3 CSS via CDN %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <%# Bootstrap 5.3 JS bundle — loaded in <head> with defer so it persists across Turbo navigations %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous" defer></script>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "sparc-theme", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="d-flex flex-column min-vh-100">
    <%# ── Navbar (same as application layout) ── %>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
      <div class="container-fluid">
        <div class="d-flex align-items-center gap-2">
          <%= link_to login_path, class: "navbar-brand d-flex align-items-center" do %>
            <%= image_tag "sparc.png", alt: "SPARC", class: "sparc-navbar-logo" %>
          <% end %>
          <span class="badge text-bg-secondary opacity-75" style="font-size: 0.65rem;">v3.2.0</span>
        </div>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto align-items-center">
            <li class="nav-item"><%= link_to "Control Catalogs", control_catalogs_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Baselines", profile_documents_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Component Definitions", cdef_documents_path, class: "nav-link" %></li>
            <li class="nav-item" data-controller="theme">
              <button class="btn btn-outline-light btn-sm ms-2"
                      data-theme-target="icon"
                      data-action="theme#toggle"
                      title="Toggle light/dark mode">&#127769;</button>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <%# ── Main content area ── %>
    <div class="container-fluid p-3 p-md-4" style="max-width: 1100px;">

      <%# ── Top row: Welcome + Login ── %>
      <div class="row g-4 align-items-center mt-2">

        <%# ── Left column (2/3): SPARC info + OSCAL overview ── %>
        <div class="col-lg-8 order-2 order-lg-1">
          <div class="text-center text-lg-start mb-3">
            <%= image_tag "sparc.png", alt: SparcConfig.app_name, class: "sparc-login-logo" %>
            <h1 class="h4 fw-bold mt-3 mb-2"><%= SparcConfig.welcome_text %></h1>
            <p class="text-body-secondary small">
              Centralize, track, and operationalize NIST 800-53 controls &mdash; from catalog management
              and system security plans to security assessment results and OSCAL-ready compliance reporting.
            </p>
          </div>

          <%= render "sessions/oscal_overview" %>

          <% if SparcConfig.contact_email.present? %>
            <div class="text-center text-lg-start mt-3 small text-body-tertiary">
              <%= mail_to SparcConfig.contact_email, "Contact Support", class: "text-primary text-decoration-none" %>
            </div>
          <% end %>
        </div>

        <%# ── Right column (1/3): Login form ── %>
        <div class="col-lg-4 order-1 order-lg-2">
          <%# ── Flash notifications ──────── %>
          <% if flash[:success] || flash[:error] || flash[:warning] %>
            <div class="mb-3">
              <% if flash[:success] %>
                <div class="alert alert-success alert-dismissible fade show small" role="alert">
                  <%= flash[:success] %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              <% end %>
              <% if flash[:error] %>
                <div class="alert alert-danger alert-dismissible fade show small" role="alert">
                  <%= flash[:error] %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              <% end %>
              <% if flash[:warning] %>
                <div class="alert alert-warning alert-dismissible fade show small" role="alert">
                  <%= flash[:warning] %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              <% end %>
            </div>
          <% end %>

          <div class="card shadow-sm border">
            <div class="card-body p-3 small">
              <%= yield %>
            </div>
          </div>
        </div>

      </div>

      <%# ── Features section (full width) ── %>
      <div class="card mt-4">
        <div class="card-body">
          <h3 style="margin-bottom: 1.25rem;">Features</h3>
          <div class="row row-cols-1 row-cols-md-2 g-3">
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span>Convert Excel workbooks (System Security Plans &amp; Security Assessment Results) to JSON</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span>NIST SP 800-53 Rev 4 &amp; Rev 5 control catalogs pre-loaded</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span>Edit control fields with read-only enforcement</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span>Interactive heat maps by NIST control family</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span>Export documents to JSON</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span>Click-to-filter controls by family and status</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span>Bulk update capabilities via API</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span>Manage custom catalogs, families, and controls</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span>Import component definitions from XCCDF XML (DISA STIGs, SCAP, CIS) and JSON (InSpec, STIG Viewer)</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span>Export OSCAL-compliant Component Definitions (NIST OSCAL v1.1.2)</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span>Import NIST SP 800-53 baseline profiles and export OSCAL Profiles</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span>Generate OSCAL Security Assessment Plans (SAP) from SSP + Profile with auto-populated methods and test cases</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span>Import and manage OSCAL Plan of Action &amp; Milestones with risk tracking and OSCAL export</span>
            </div></div>
          </div>
        </div>
      </div>

    </div>

    <script>
      // ── Tab Switching ─────────────────────────────
      function switchTab(tabId) {
        document.querySelectorAll('.login-tab').forEach(function(t) { t.classList.remove('active'); });
        document.querySelectorAll('.login-tab-panel').forEach(function(p) { p.classList.remove('active'); });
        var tab = document.querySelector('[data-tab="' + tabId + '"]');
        var panel = document.getElementById(tabId);
        if (tab) tab.classList.add('active');
        if (panel) panel.classList.add('active');
      }
    </script>
  </body>
</html>
