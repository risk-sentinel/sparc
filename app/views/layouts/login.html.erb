<!DOCTYPE html>
<html data-bs-theme="light">
  <head>
    <title><%= SparcConfig.app_name %> — Login</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Apply saved theme before first paint to prevent flash of wrong theme %>
    <script>
      (function() {
        var t = localStorage.getItem("sparc-theme");
        if (t) document.documentElement.setAttribute("data-bs-theme", t);
      })();
    </script>

    <%# Bootstrap 5.3 CSS via CDN %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YcnS/1p0p/nd6rl5v3TQnuzahR1SSagJPMn" crossorigin="anonymous">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "sparc-theme", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="d-flex align-items-center justify-content-center min-vh-100">
    <button id="themeToggleBtn" class="btn btn-outline-secondary btn-sm position-fixed top-0 end-0 m-3" style="z-index: 10;" onclick="toggleTheme()" title="Toggle light/dark mode">&#127769;</button>

    <div class="w-100 p-3" style="max-width: 440px;">
      <div class="text-center mb-4">
        <%= image_tag "sparc.png", alt: SparcConfig.app_name, style: "height: 48px; width: auto;" %>
        <h1 class="h4 fw-bold mt-3 mb-2"><%= SparcConfig.welcome_text %></h1>
        <p class="text-body-secondary"><%= "Compliance documentation platform" %></p>
      </div>

      <div class="card shadow-sm border">
        <div class="card-body p-4">
          <%= yield %>
        </div>
      </div>

      <div class="text-center mt-4 small text-body-tertiary">
        <%= link_to "Back to #{SparcConfig.app_name}", root_path, class: "text-primary text-decoration-none" %>
        <% if SparcConfig.contact_email.present? %>
          &middot; <%= mail_to SparcConfig.contact_email, "Contact Support", class: "text-primary text-decoration-none" %>
        <% end %>
      </div>
    </div>

    <%# Bootstrap 5.3 JS bundle via CDN %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    <script>
      // ── Theme Toggle ──────────────────────────────
      function toggleTheme() {
        var html = document.documentElement;
        var current = html.getAttribute("data-bs-theme");
        var systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var isDark = current === "dark" || (!current && systemDark);
        var next = isDark ? "light" : "dark";
        html.setAttribute("data-bs-theme", next);
        localStorage.setItem("sparc-theme", next);
        updateThemeIcon();
      }

      function updateThemeIcon() {
        var html = document.documentElement;
        var current = html.getAttribute("data-bs-theme");
        var systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var isDark = current === "dark" || (!current && systemDark);
        var btn = document.getElementById("themeToggleBtn");
        if (btn) btn.innerHTML = isDark ? "&#9728;&#65039;" : "&#127769;";
      }

      document.addEventListener("DOMContentLoaded", updateThemeIcon);
      window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", updateThemeIcon);

      // ── Tab Switching ─────────────────────────────
      function switchTab(tabId) {
        document.querySelectorAll('.login-tab').forEach(function(t) { t.classList.remove('active'); });
        document.querySelectorAll('.login-tab-panel').forEach(function(p) { p.classList.remove('active'); });
        var tab = document.querySelector('[data-tab="' + tabId + '"]');
        var panel = document.getElementById(tabId);
        if (tab) tab.classList.add('active');
        if (panel) panel.classList.add('active');
      }
    </script>
  </body>
</html>
