<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
  <head>
    <title><%= SparcConfig.app_name %> — Login</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="turbo-cache-control" content="no-cache">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Apply saved or system theme before first paint to prevent FOUC %>
    <script nonce="<%= content_security_policy_nonce %>">
      (function() {
        var t = localStorage.getItem("sparc-theme");
        if (t) {
          document.documentElement.setAttribute("data-bs-theme", t);
        } else {
          var dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.setAttribute("data-bs-theme", dark ? "dark" : "light");
        }
      })();
    </script>

    <%# Bootstrap 5.3 CSS via CDN %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <%# Bootstrap 5.3 JS bundle — loaded in <head> with defer so it persists across Turbo navigations %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous" defer></script>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "sparc-theme", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="d-flex flex-column min-vh-100"
        data-controller="video-easter-egg<% if @consent_banner_content.present? %> consent-banner<% end %>">
    <%= render "shared/environment_header" %>
    <%# ── Navbar (same as application layout) ── %>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
      <div class="container-fluid">
        <div class="d-flex align-items-center gap-2">
          <a href="#" class="navbar-brand d-flex align-items-center" data-action="click->video-easter-egg#play">
            <%= image_tag "sparc_logo.png", alt: "SPARC", class: "sparc-navbar-logo" %>
          </a>
          <span class="badge text-bg-dark" style="font-size: 0.65rem;">v<%= SparcConfig::VERSION %></span>
          <%# ── About (left side, next to logo) ── %>
          <%= link_to "About", about_path, class: "nav-link sparc-nav-btn text-light d-none d-lg-inline ms-2" %>
        </div>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto align-items-center gap-1">

            <%# ── Controls Layer (catalogs/baselines/mappings) — gated by #726 ── %>
            <% if controls_publicly_accessible? %>
              <li class="nav-item dropdown">
                <%= render "shared/controls_nav" %>
              </li>
            <% end %>

            <%# ── Resources ── %>
            <li class="nav-item d-none d-lg-block">
              <%= link_to "Resources", about_resources_path, class: "nav-link sparc-nav-btn" %>
            </li>

            <%# ── Separator ── %>
            <li class="nav-item d-none d-lg-block">
              <span class="sparc-nav-separator"></span>
            </li>

            <%# ── Theme toggle ── %>
            <li class="nav-item" data-controller="theme">
              <button class="btn btn-outline-light btn-sm sparc-nav-theme-btn"
                      data-theme-target="icon"
                      data-action="theme#toggle"
                      title="Toggle light/dark mode">&#127769;</button>
            </li>

          </ul>
        </div>
      </div>
    </nav>

    <%# ── Main content area ── %>
    <div class="container-fluid p-3 p-md-4" style="max-width: 1100px;">

      <%# ── Top row: Welcome + Login ── %>
      <div class="row g-4 align-items-center mt-2">

        <%# ── Left column (2/3): SPARC info + OSCAL overview ── %>
        <div class="col-lg-8 order-2 order-lg-1">
          <div class="text-center text-lg-start mb-3">
            <%= image_tag "sparc_logo.png", alt: SparcConfig.app_name, class: "sparc-login-logo" %>
            <h1 class="h3 fw-bold mt-3 mb-2">Welcome to SPARC &mdash; Systematic Policy and Regulatory Compliance</h1>
            <p class="text-body-secondary">
              Centralize, track, and operationalize NIST 800-53 security controls across the full
              Risk Management Framework lifecycle with OSCAL and FedRAMP 20x support.
            </p>
          </div>

          <%= render "sessions/oscal_overview" %>

          <% if SparcConfig.contact_email.present? %>
            <div class="text-center text-lg-start mt-3 small text-body-tertiary">
              <%= mail_to SparcConfig.contact_email, "Support", class: "text-primary text-decoration-none fw-semibold" %>
            </div>
          <% end %>
        </div>

        <%# ── Right column (1/3): Login form ── %>
        <div class="col-lg-4 order-1 order-lg-2">

          <%# ── Consent banner error area ── %>
          <% if @consent_banner_content.present? %>
            <div data-consent-banner-target="errorArea"></div>
          <% end %>

          <%# ── Flash notifications ──────── %>
          <% if flash[:success] || flash[:error] || flash[:warning] %>
            <div class="mb-3">
              <% if flash[:success] %>
                <div class="alert alert-success alert-dismissible fade show small" role="alert">
                  <%= flash[:success] %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              <% end %>
              <% if flash[:error] %>
                <div class="alert alert-danger alert-dismissible fade show small" role="alert">
                  <%= flash[:error] %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              <% end %>
              <% if flash[:warning] %>
                <div class="alert alert-warning alert-dismissible fade show small" role="alert">
                  <%= flash[:warning] %>
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              <% end %>
            </div>
          <% end %>

          <div class="card shadow-sm border <%= 'd-none' if @consent_banner_content.present? %>"
               <% if @consent_banner_content.present? %>data-consent-banner-target="loginCard"<% end %>>
            <div class="card-body p-3 small">
              <%= yield %>
            </div>
          </div>
        </div>

      </div>

      <%# ── Features section (full width) ── %>
      <div class="card mt-4">
        <div class="card-body">
          <h3 style="margin-bottom: 1.25rem;">Features</h3>
          <div class="row row-cols-1 row-cols-md-2 g-3">
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span><strong>FedRAMP 20x Authorizations Supported</strong> &mdash; Handles the latest FedRAMP 20x to NIST 800-53 OSCAL updates</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span><strong>Native OSCAL Import &amp; Export</strong> &mdash; Full read/write support for Catalogs, Baseline/Profile, SSP, SAP, SAR, and POA&amp;M in OSCAL format</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span><strong>OSCAL / Heimdall Data Format (HDF) Conversion</strong> &mdash; Seamless import, export, and validation between HDF and OSCAL</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span><strong>Automated SSP Population &amp; Tailoring</strong> &mdash; Smart control inheritance, response generation, and parameter handling</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span><strong>Security Assessment Result Aggregation</strong> &mdash; Combine findings from HDF, XCCDF, and other sources into unified OSCAL SAR/POA&amp;M</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span><strong>FedRAMP Revision History &amp; Change Tracking</strong> &mdash; Audit-ready lineage of control modifications and document versions</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span><strong>XCCDF Integration</strong> &mdash; Import, normalize, and validate results in Extensible Configuration Checklist Description Format</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span><strong>Build Converters</strong> &mdash; Enables teams to build additional converters for other validation tools (DISA to NIST, CCI to NIST, SCAP to NIST, and CIS to NIST built in)</span>
            </div></div>
            <div class="col"><div class="d-flex align-items-start gap-2" style="padding: 0.4rem 0;">
              <span class="sparc-check-icon fw-bold">&#10003;</span>
              <span><strong>REST API</strong> &mdash; Programmatic endpoints for upload, validation, conversion, generation, and export of authorization artifacts</span>
            </div></div>
          </div>
        </div>
      </div>

    </div>

    <%# ── Consent Banner Modal ── %>
    <% if @consent_banner_content.present? %>
      <div class="modal fade" tabindex="-1"
           data-consent-banner-target="modal"
           aria-labelledby="consentBannerLabel"
           aria-describedby="consentBannerBody">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
          <div class="modal-content">
            <div class="modal-header bg-warning-subtle">
              <h5 class="modal-title" id="consentBannerLabel">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-exclamation-triangle-fill me-2 text-warning" viewBox="0 0 16 16">
                  <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                </svg>
                Notice
              </h5>
            </div>
            <div class="modal-body" id="consentBannerBody" tabindex="0">
              <%= @consent_banner_content.html_safe %>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary"
                      data-action="consent-banner#cancel">Cancel</button>
              <button type="button" class="btn btn-primary"
                      data-action="consent-banner#proceed"
                      autofocus>Proceed</button>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <script nonce="<%= content_security_policy_nonce %>">
      // ── Tab Switching ─────────────────────────────
      // Click delegation off [data-tab]. The previous inline
      // onclick=switchTab() attributes on the nav buttons were
      // silently blocked by the v1.7.0 CSP (#514) — the per-page
      // nonce only exempts nonce-attributed script blocks, not
      // inline event-handler HTML attributes. Result: OIDC / LDAP
      // tab buttons appeared clickable but did nothing — users
      // were stuck on whichever tab rendered first. v1.8.1 hotfix.
      function switchTab(tabId) {
        document.querySelectorAll('[data-tab]').forEach(function(t) { t.classList.remove('active'); });
        document.querySelectorAll('.login-tab-panel').forEach(function(p) { p.classList.remove('active'); });
        var tab = document.querySelector('[data-tab="' + tabId + '"]');
        var panel = document.getElementById(tabId);
        if (tab) tab.classList.add('active');
        if (panel) panel.classList.add('active');
      }

      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('[data-tab]').forEach(function(btn) {
          btn.addEventListener('click', function() { switchTab(btn.getAttribute('data-tab')); });
        });
      });
    </script>

    <%# Easter egg video overlay — triggered by navbar logo click %>
    <div class="sparc-video-overlay d-none"
         data-video-easter-egg-target="overlay"
         data-action="click->video-easter-egg#overlayClick">
      <video data-video-easter-egg-target="video"
             data-action="ended->video-easter-egg#videoEnded"
             class="sparc-video-player"
             preload="none">
        <source src="/videos/sparc_intro.mp4" type="video/mp4">
      </video>
    </div>

  </body>
</html>
