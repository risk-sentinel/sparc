<%= form_with(model: [ @project, membership ], class: "mb-4") do |f| %>
  <div class="mb-3">
    <%= f.label :user_name, "Name", class: "form-label fw-semibold" %>
    <%= f.text_field :user_name, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :user_email, "Email", class: "form-label fw-semibold" %>
    <%= f.email_field :user_email, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :role, class: "form-label fw-semibold" %>
    <%= f.select :role, ProjectMembership::ROLE_LABELS.map { |k, v| [ v, k ] }, {}, class: "form-select" %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", project_path(@project), class: "btn btn-secondary" %>
  </div>
<% end %>
