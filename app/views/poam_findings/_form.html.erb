<%= form_with model: [ poam_document, poam_finding ], local: true do |f| %>
  <% if poam_finding.errors.any? %>
    <div class="alert alert-danger small">
      <%= poam_finding.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :title, class: "fw-semibold" %>
    <%= f.text_field :title, class: "form-control", required: true,
                     placeholder: "e.g., AU-2 audit-event coverage gap" %>
  </div>

  <div class="form-group mt-3">
    <%= f.label :description, class: "fw-semibold" %>
    <%= f.text_area :description, class: "form-control", rows: 3 %>
  </div>

  <div class="form-group mt-3">
    <%= f.label :implementation_statement_uuid, "Implementation statement UUID", class: "fw-semibold" %>
    <%= f.text_field :implementation_statement_uuid, class: "form-control",
                     placeholder: "UUID of the SSP statement this finding targets (optional)" %>
  </div>

  <div class="form-group mt-3">
    <%= f.label :remarks, class: "fw-semibold" %>
    <%= f.text_area :remarks, class: "form-control", rows: 2 %>
  </div>

  <hr class="border-top" style="border: none; margin: 1.5rem 0;">
  <%= render "shared/oscal_props_array",   param_key: "poam_finding", record: poam_finding %>
  <%= render "shared/oscal_links_array",   param_key: "poam_finding", record: poam_finding %>
  <%= render "shared/oscal_origins_array", param_key: "poam_finding", record: poam_finding,
             parties: poam_document.oscal_parties %>

  <div class="d-flex gap-3 mt-3">
    <%= f.submit poam_finding.persisted? ? "Update Finding" : "Add Finding", class: "btn btn-success" %>
    <%= link_to "Cancel", poam_document_path(poam_document), class: "btn btn-secondary" %>
  </div>
<% end %>
