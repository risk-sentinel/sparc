<%# Read-only per-document sync status table for the AuthorizationBoundary
    show page (#395 Phase 3). Renders a row per linked document with a
    colored dot and (when drifted) the number of fields that differ.

    Locals:
      boundary - AuthorizationBoundary instance
%>
<%
  docs = boundary.linked_documents
  service = BoundaryMetadataSyncService.new(boundary)
%>
<div class="sparc-card" style="margin-top: 1.25rem; padding: 1rem 1.25rem;">
  <h3 style="font-size: 1rem; margin-bottom: 0.75rem;">
    Document Metadata Sync
    <span class="text-body-secondary" style="font-weight: 400; font-size: 0.8rem;">
      (boundary is the source of truth for system-level metadata)
    </span>
  </h3>

  <% if docs.empty? %>
    <p class="text-body-secondary" style="font-size: 0.875rem;">No linked documents yet.</p>
  <% else %>
    <table class="table table-sm" style="font-size: 0.85rem; margin-bottom: 0;">
      <thead>
        <tr style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--bs-secondary-color);">
          <th style="width: 18%;">Document</th>
          <th style="width: 18%;">Type</th>
          <th style="width: 14%;">Status</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <% docs.each do |doc| %>
          <%
            status = service.status_for(doc)
            dot_color = case status
                        when :in_sync    then "#27ae60"   # green
                        when :drift      then "#f39c12"   # yellow
                        when :missing_fk then "#e74c3c"   # red
                        end
            drift = status == :drift ? service.drift_for(doc) : {}
          %>
          <tr>
            <td><%= doc.respond_to?(:name) ? doc.name : doc.to_s %></td>
            <td class="text-body-secondary"><%= doc.class.name.underscore.humanize %></td>
            <td>
              <span style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: <%= dot_color %>; margin-right: 0.35rem;"></span>
              <%= status.to_s.humanize %>
            </td>
            <td class="text-body-secondary">
              <% if status == :drift %>
                <%= pluralize(drift.size, "field") %> differ:
                <code style="font-size: 0.72rem;"><%= drift.keys.join(", ") %></code>
              <% elsif status == :missing_fk %>
                Document has no authorization_boundary_id (orphaned)
              <% else %>
                &mdash;
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
