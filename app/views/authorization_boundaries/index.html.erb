<%= render "shared/section_summary", tiles: [
  [@total_count, "Authorization Boundaries"],
  [@active_count, "Active"],
  [@member_count, "Members"]
] %>

<div class="card" style="overflow: hidden;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Authorization Boundaries</h2>
    <%= link_to "New Authorization Boundary", new_authorization_boundary_path, class: "btn btn-primary" %>
  </div>

  <div data-controller="bulk-select">
  <%# #629 — admin-only bulk delete bar; appears when ≥1 row is selected. %>
  <% if can_bulk_delete? && @authorization_boundaries.any? %>
    <div class="mb-2" data-bulk-select-target="bar" hidden>
      <%= form_with url: bulk_destroy_authorization_boundaries_path, method: :delete, id: "abBulkForm" do %>
        <button type="submit" class="btn btn-danger btn-sm" data-bulk-select-target="submit"
                data-turbo-confirm="Delete the selected authorization boundaries? This cannot be undone.">
          Delete (<span data-bulk-select-target="count">0</span> selected)
        </button>
      <% end %>
    </div>
  <% end %>

  <% if @authorization_boundaries.any? %>
    <table class="table table-hover" style="table-layout: fixed;">
      <colgroup>
        <% if can_bulk_delete? %><col style="width: 4%;"><% end %>
        <col style="width: 22%;">
        <col style="width: 30%;">
        <col style="width: 10%;">
        <col style="width: 10%;">
        <col style="width: 10%;">
        <col style="width: 18%;">
      </colgroup>
      <thead>
        <tr>
          <% if can_bulk_delete? %>
            <th><input type="checkbox" data-bulk-select-target="selectAll" data-action="bulk-select#toggleAll" aria-label="Select all"></th>
          <% end %>
          <th>Name</th>
          <th>Description</th>
          <th>Status</th>
          <th>Members</th>
          <th>Boundaries</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @authorization_boundaries.each do |authorization_boundary| %>
          <tr>
            <% if can_bulk_delete? %>
              <td><input type="checkbox" name="ids[]" value="<%= authorization_boundary.id %>" form="abBulkForm" data-bulk-select-target="row" data-action="bulk-select#toggle" aria-label="Select <%= authorization_boundary.name %>"></td>
            <% end %>
            <td style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= authorization_boundary.name %>">
              <%= link_to authorization_boundary.name, authorization_boundary_path(authorization_boundary) %>
            </td>
            <td class="text-body-secondary" style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
              <%= authorization_boundary.description.presence || "—" %>
            </td>
            <td>
              <% badge_class = case authorization_boundary.status
                               when "authorized" then "badge-ok"
                               when "active" then "badge-ok"
                               when "draft" then "badge-warn"
                               else "badge-warn"
                               end %>
              <span class="<%= badge_class %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.85rem;">
                <%= authorization_boundary.status.titleize %>
              </span>
            </td>
            <td><%= authorization_boundary.authorization_boundary_memberships.count %></td>
            <td><%= authorization_boundary.boundaries.count %></td>
            <td>
              <div class="d-flex gap-1">
                <%= link_to "View", authorization_boundary_path(authorization_boundary), class: "btn btn-primary btn-sm" %>
                <%= link_to "Edit", edit_authorization_boundary_path(authorization_boundary), class: "btn btn-secondary btn-sm" %>
                <%= button_to "Delete", authorization_boundary_path(authorization_boundary), method: :delete,
                      class: "btn btn-danger btn-sm",
                      form: { data: { turbo_confirm: "Delete '#{authorization_boundary.name}'? This cannot be undone." }, style: "display: inline;" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center p-4 text-body-secondary">No authorization boundaries yet. Create your first authorization boundary to organize RMF artifacts and personnel.</p>
  <% end %>
  </div>
</div>
