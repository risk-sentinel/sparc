<%= form_with(model: authorization_boundary, class: "mb-4") do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label fw-semibold" %>
    <%= f.text_field :name, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: "form-label fw-semibold" %>
    <%= f.text_area :description, class: "form-control", rows: 3 %>
  </div>

  <div class="mb-3">
    <%= f.label :status, class: "form-label fw-semibold" %>
    <%= f.select :status, AuthorizationBoundary::STATUSES.map { |s| [ s.titleize, s ] }, {}, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :authorization_boundary_description, "Authorization Boundary", class: "form-label fw-semibold" %>
    <%= f.text_area :authorization_boundary_description, class: "form-control", rows: 3 %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", authorization_boundaries_path, class: "btn btn-secondary" %>
  </div>
<% end %>
