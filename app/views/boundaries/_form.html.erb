<%= form_with(model: [ @authorization_boundary, boundary ], class: "mb-4") do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label fw-semibold" %>
    <%= f.text_field :name, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: "form-label fw-semibold" %>
    <%= f.text_area :description, class: "form-control", rows: 3 %>
  </div>

  <div class="mb-3">
    <%= f.label :environment, class: "form-label fw-semibold" %>
    <%= f.select :environment, SparcConfig.environments.map { |e| [ "#{e[:name]} (#{e[:code]})", e[:value] ] }, {}, class: "form-select" %>
  </div>

  <% if @cdef_documents.any? %>
    <div class="mb-3" data-controller="checkbox-filter">
      <span class="form-label fw-semibold d-block">Components (CDEFs)</span>
      <%# #770 bug 2 — filter the CDEF picker; no filter existed here before. %>
      <input type="text" class="form-control form-control-sm mb-2"
             placeholder="Filter components…"
             aria-label="Filter components by name"
             data-checkbox-filter-target="input"
             data-action="input->checkbox-filter#filter">
      <div class="border rounded p-2" style="max-height: 16rem; overflow-y: auto;">
        <% @cdef_documents.each do |cdef| %>
          <div class="form-check" data-checkbox-filter-target="item">
            <%= check_box_tag "boundary[cdef_document_ids][]", cdef.id,
                boundary.cdef_document_ids.include?(cdef.id),
                class: "form-check-input", id: "cdef_#{cdef.id}" %>
            <%= label_tag "cdef_#{cdef.id}", cdef.name, class: "form-check-label" %>
          </div>
        <% end %>
        <div class="text-body-secondary small px-1 py-2" hidden
             data-checkbox-filter-target="empty">
          No components match your filter.
        </div>
      </div>
    </div>
  <% end %>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", authorization_boundary_path(@authorization_boundary), class: "btn btn-secondary" %>
  </div>
<% end %>
