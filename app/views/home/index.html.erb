<%# ── Compact stat tiles ── %>
<div class="card sparc-gradient-header mb-3" style="padding: 1rem 1.25rem; border-radius: 0.5rem;">
  <div class="row row-cols-3 row-cols-md-5 row-cols-lg-10 g-2 text-center">
    <%
      tiles = [
        [@catalog_count, "Catalogs"],
        [@family_count, "Families"],
        [@control_count, "Controls"],
        [@authorization_boundary_count, "Auth Boundaries"],
        [@profile_count, "Baselines"],
        [@cdef_count, "CDEFs"],
        [@ssp_count, "SSPs"],
        [@sap_count, "SAPs"],
        [@sar_count, "SARs"],
        [@poam_count, "POA&Ms"],
        [@evidence_count, "Evidence"],
      ]
    %>
    <% tiles.each do |count, label| %>
      <div class="col">
        <div class="sparc-hero-tile" style="padding: 0.5rem 0.25rem;">
          <div class="sparc-hero-tile-count" style="font-size: 1.25rem;"><%= count %></div>
          <div class="sparc-hero-tile-label" style="font-size: 0.65rem;"><%= label %></div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%# ── Compact section navigation grid ── %>
<div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3 mb-4">
  <%
    sections = [
      { title: "Auth Boundaries",    path: authorization_boundaries_path, new_path: new_authorization_boundary_path, icon: "&#128188;", color: "#9b59b6" },
      { title: "Control Catalogs",   path: control_catalogs_path,  new_path: new_control_catalog_path,  icon: "&#128218;", color: "#3498db" },
      { title: "Baselines",          path: profile_documents_path, new_path: new_profile_document_path, icon: "&#128203;", color: nil },
      { title: "CDEFs",              path: cdef_documents_path,    new_path: new_cdef_document_path,    icon: "&#128737;", color: nil },
      { title: "SSPs",               path: ssp_documents_path,     new_path: new_ssp_document_path,     icon: "&#128196;", color: nil },
      { title: "SAPs",               path: sap_documents_path,     new_path: new_sap_document_path,     icon: "&#128221;", color: nil },
      { title: "SARs",               path: sar_documents_path,     new_path: new_sar_document_path,     icon: "&#128203;", color: nil },
      { title: "POA&Ms",             path: poam_documents_path,    new_path: new_poam_document_path,    icon: "&#128270;", color: nil },
      { title: "Evidence",           path: evidences_path,         new_path: new_evidence_path,         icon: "&#128274;", color: "#27ae60" },
    ]
  %>
  <% sections.each do |s| %>
    <div class="col">
      <div class="card text-center h-100" style="<%= s[:color] ? "border: 2px solid #{s[:color]};" : "" %>">
        <div class="card-body" style="padding: 1rem;">
          <div style="font-size: 1.75rem; margin-bottom: 0.5rem;"><%= s[:icon].html_safe %></div>
          <h5 style="margin-bottom: 0.75rem; font-size: 0.95rem;"><%= s[:title] %></h5>
          <div class="d-flex flex-column gap-1">
            <%= link_to "View", s[:path], class: "btn btn-primary btn-sm" %>
            <%= link_to "New", s[:new_path], class: "btn btn-success btn-sm" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

