<%# ── Stat tiles grouped by OSCAL layer ── %>
<div class="card sparc-gradient-header mb-3" style="padding: 1rem 1.25rem; border-radius: 0.5rem;">
  <div class="d-flex flex-wrap justify-content-center gap-3">

    <%# ── Controls Layer ── %>
    <div style="border: 1px solid rgba(52,152,219,0.45); border-top: 3px solid #3498db; border-radius: 0.375rem; padding: 0.35rem 0.5rem 0.5rem; background: rgba(52,152,219,0.06);">
      <div class="text-center" style="margin-bottom: 0.3rem;">
        <span class="badge" style="background: #3498db; font-size: 0.6rem; letter-spacing: 0.05rem; padding: 0.2rem 0.5rem;">CONTROLS</span>
      </div>
      <div class="d-flex gap-2">
        <% [[@catalog_count, "Catalogs"], [@family_count, "Families"], [@control_count, "Controls"], [@profile_count, "Baselines"], [@mapping_count, "Mappings"]].each do |count, label| %>
          <div class="sparc-hero-tile text-center" style="padding: 0.5rem 0.4rem; min-width: 60px;">
            <div class="sparc-hero-tile-count" style="font-size: 1.25rem;"><%= count %></div>
            <div class="sparc-hero-tile-label" style="font-size: 0.6rem;"><%= label %></div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Implementation Layer ── %>
    <div style="border: 1px solid rgba(39,174,96,0.45); border-top: 3px solid #27ae60; border-radius: 0.375rem; padding: 0.35rem 0.5rem 0.5rem; background: rgba(39,174,96,0.06);">
      <div class="text-center" style="margin-bottom: 0.3rem;">
        <span class="badge" style="background: #27ae60; font-size: 0.6rem; letter-spacing: 0.05rem; padding: 0.2rem 0.5rem;">IMPLEMENTATION</span>
      </div>
      <div class="d-flex gap-2">
        <% [[@ssp_count, "SSPs"], [@cdef_count, "CDEFs"], [@converter_count, "Converters"]].each do |count, label| %>
          <div class="sparc-hero-tile text-center" style="padding: 0.5rem 0.4rem; min-width: 60px;">
            <div class="sparc-hero-tile-count" style="font-size: 1.25rem;"><%= count %></div>
            <div class="sparc-hero-tile-label" style="font-size: 0.6rem;"><%= label %></div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Assessment Layer ── %>
    <div style="border: 1px solid rgba(230,126,34,0.45); border-top: 3px solid #e67e22; border-radius: 0.375rem; padding: 0.35rem 0.5rem 0.5rem; background: rgba(230,126,34,0.06);">
      <div class="text-center" style="margin-bottom: 0.3rem;">
        <span class="badge" style="background: #e67e22; font-size: 0.6rem; letter-spacing: 0.05rem; padding: 0.2rem 0.5rem;">ASSESSMENT</span>
      </div>
      <div class="d-flex gap-2">
        <% [[@sap_count, "SAPs"], [@evidence_count, "Evidence"], [@sar_count, "SARs"], [@poam_count, "POA&Ms"]].each do |count, label| %>
          <div class="sparc-hero-tile text-center" style="padding: 0.5rem 0.4rem; min-width: 60px;">
            <div class="sparc-hero-tile-count" style="font-size: 1.25rem;"><%= count %></div>
            <div class="sparc-hero-tile-label" style="font-size: 0.6rem;"><%= label %></div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Enterprise ── %>
    <div style="border: 1px solid rgba(155,89,182,0.45); border-top: 3px solid #9b59b6; border-radius: 0.375rem; padding: 0.35rem 0.5rem 0.5rem; background: rgba(155,89,182,0.06);">
      <div class="text-center" style="margin-bottom: 0.3rem;">
        <span class="badge" style="background: #9b59b6; font-size: 0.6rem; letter-spacing: 0.05rem; padding: 0.2rem 0.5rem;">ENTERPRISE</span>
      </div>
      <div class="d-flex gap-2">
        <% [[@organization_count, "Organizations"], [@authorization_boundary_count, "Auth Boundaries"]].each do |count, label| %>
          <div class="sparc-hero-tile text-center" style="padding: 0.5rem 0.4rem; min-width: 60px;">
            <div class="sparc-hero-tile-count" style="font-size: 1.25rem;"><%= count %></div>
            <div class="sparc-hero-tile-label" style="font-size: 0.6rem;"><%= label %></div>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>

<%# ── Section navigation grid grouped by OSCAL layers ── %>
<%
  layer_groups = [
    {
      label: "Controls Layer",
      color: "#3498db",
      cards: [
        { title: "Control Catalogs",     path: control_catalogs_path,   new_path: new_control_catalog_path,   icon: "&#128218;" },
        { title: "Baselines / Profiles", path: profile_documents_path,  new_path: new_profile_document_path,  icon: "&#128203;" },
        { title: "Control Mapping",      path: control_mappings_path,   new_path: new_control_mapping_path,   icon: "&#128279;" },
      ]
    },
    {
      label: "Implementation Layer",
      color: "#27ae60",
      cards: [
        { title: "SSPs",        path: ssp_documents_path,   new_path: new_ssp_document_path,   icon: "&#128196;" },
        { title: "CDEFs",       path: cdef_documents_path,  new_path: new_cdef_document_path,  icon: "&#128737;" },
        { title: "Converters",  path: converters_path,      new_path: new_converter_path,      icon: "&#128260;" },
      ]
    },
    {
      label: "Assessment Layer",
      color: "#e67e22",
      cards: [
        { title: "SAPs",      path: sap_documents_path,  new_path: new_sap_document_path,  icon: "&#128221;" },
        { title: "Evidence",   path: evidences_path,       new_path: new_evidence_path,      icon: "&#128274;" },
        { title: "SARs",      path: sar_documents_path,   new_path: new_sar_document_path,  icon: "&#128203;" },
        { title: "POA&Ms",    path: poam_documents_path,  new_path: new_poam_document_path, icon: "&#128270;" },
      ]
    },
    {
      label: "Enterprise",
      color: "#9b59b6",
      cards: [
        { title: "Organizations",    path: admin_organizations_path,     new_path: new_admin_organization_path,     icon: "&#127970;" },
        { title: "Auth Boundaries",  path: authorization_boundaries_path, new_path: new_authorization_boundary_path, icon: "&#128188;" },
      ]
    }
  ]
%>

<% layer_groups.each do |group| %>
  <div class="mb-2">
    <div class="d-flex align-items-center gap-2 mb-2">
      <span style="display: inline-block; width: 4px; height: 1.1rem; background: <%= group[:color] %>; border-radius: 2px;"></span>
      <h6 class="mb-0 fw-bold" style="font-size: 0.85rem; color: <%= group[:color] %>;"><%= group[:label] %></h6>
    </div>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-2">
      <% group[:cards].each do |s| %>
        <div class="col">
          <div class="card sparc-section-card h-100" style="border-color: <%= group[:color] %>; --sparc-card-accent: <%= group[:color] %>;">
            <div class="card-body d-flex flex-row align-items-center gap-3" style="padding: 0.35rem 0.85rem;">
              <div style="font-size: 2.2rem; flex-shrink: 0;"><%= s[:icon].html_safe %></div>
              <h5 class="mb-0 flex-grow-1" style="font-size: 0.95rem;"><%= s[:title] %></h5>
              <div class="d-flex gap-2 flex-shrink-0">
                <%= link_to "View", s[:path], class: "btn btn-primary btn-sm px-3" %>
                <%= link_to "New", s[:new_path], class: "btn btn-success btn-sm px-3" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
