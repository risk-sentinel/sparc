<div class="card sparc-gradient-header" style="padding: 2.5rem 2rem; margin: 0 0 2rem 0; border-radius: 0.5rem;">
  <div style="margin-bottom: 0.25rem;">
    <span style="font-size: 2rem; font-weight: 800; letter-spacing: 0.08em; color: white;">SPARC</span>
    <span style="font-size: 0.85rem; color: rgba(255,255,255,0.6); letter-spacing: 0.06em; text-transform: uppercase; margin-left: 0.75rem; vertical-align: middle;">Systemized Policy and Regulatory Controls</span>
  </div>
  <p style="color: rgba(255,255,255,0.8); font-size: 1.05rem;">
    Centralize, track, and operationalize NIST 800-53 controls — from catalog management and controls implementation to security assessment results and OSCAL-ready compliance reporting.
  </p>

  <div class="row row-cols-1 row-cols-md-3 g-3" style="margin-top: 2rem;">
    <div class="col">
      <div class="sparc-hero-tile">
        <div class="sparc-hero-tile-count"><%= @catalog_count %></div>
        <div class="sparc-hero-tile-label">Control Catalogs</div>
      </div>
    </div>
    <div class="col">
      <div class="sparc-hero-tile">
        <div class="sparc-hero-tile-count"><%= @family_count %></div>
        <div class="sparc-hero-tile-label">Control Families</div>
      </div>
    </div>
    <div class="col">
      <div class="sparc-hero-tile">
        <div class="sparc-hero-tile-count"><%= @control_count %></div>
        <div class="sparc-hero-tile-label">Catalog Controls</div>
      </div>
    </div>
  </div>
  <div class="row row-cols-2 row-cols-md-7 g-3" style="margin-top: 0.75rem;">
    <div class="col">
      <div class="sparc-hero-tile">
        <div class="sparc-hero-tile-count"><%= @project_count %></div>
        <div class="sparc-hero-tile-label">Projects</div>
      </div>
    </div>
    <div class="col">
      <div class="sparc-hero-tile">
        <div class="sparc-hero-tile-count"><%= @profile_count %></div>
        <div class="sparc-hero-tile-label">Baseline Profiles</div>
      </div>
    </div>
    <div class="col">
      <div class="sparc-hero-tile">
        <div class="sparc-hero-tile-count"><%= @cdef_count %></div>
        <div class="sparc-hero-tile-label">Component Definitions</div>
      </div>
    </div>
    <div class="col">
      <div class="sparc-hero-tile">
        <div class="sparc-hero-tile-count"><%= @ssp_count %></div>
        <div class="sparc-hero-tile-label">Controls Implementation</div>
      </div>
    </div>
    <div class="col">
      <div class="sparc-hero-tile">
        <div class="sparc-hero-tile-count"><%= @sap_count %></div>
        <div class="sparc-hero-tile-label">Assessment Plans</div>
      </div>
    </div>
    <div class="col">
      <div class="sparc-hero-tile">
        <div class="sparc-hero-tile-count"><%= @sar_count %></div>
        <div class="sparc-hero-tile-label">Assessment Results</div>
      </div>
    </div>
    <div class="col">
      <div class="sparc-hero-tile">
        <div class="sparc-hero-tile-count"><%= @poam_count %></div>
        <div class="sparc-hero-tile-label">POA&amp;Ms</div>
      </div>
    </div>
  </div>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4 mb-4">

  <div class="col">
    <div class="card text-center h-100" style="border: 2px solid #9b59b6;">
      <div class="card-body">
        <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">&#128188;</div>
        <h3 style="margin-bottom: 0.5rem;">Projects</h3>
        <p class="text-body-secondary small" style="margin-bottom: 1.25rem; min-height: 2.5rem;">
          Organize RMF artifacts under authorization boundaries. Assign personnel with RMF-defined roles.
        </p>
        <div class="d-flex flex-column gap-2">
          <%= link_to "View Projects", projects_path, class: "btn btn-primary" %>
          <%= link_to "New Project", new_project_path, class: "btn btn-success" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col">
    <div class="card text-center h-100" style="border: 2px solid #3498db;">
      <div class="card-body">
        <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">&#128218;</div>
        <h3 style="margin-bottom: 0.5rem;">Control Catalogs</h3>
        <p class="text-body-secondary small" style="margin-bottom: 1.25rem; min-height: 2.5rem;">
          Browse NIST SP 800-53 Rev 4 and Rev 5 control families and base controls. Add custom catalogs or entries.
        </p>
        <div class="d-flex flex-column gap-2">
          <%= link_to "View Catalogs", control_catalogs_path, class: "btn btn-primary" %>
          <%= link_to "New Catalog", new_control_catalog_path, class: "btn btn-success" %>
        </div>
        <div class="mt-3 bg-body-secondary rounded text-primary" style="padding: 0.5rem; font-size: 0.8rem;">
          NIST SP 800-53 Rev 4 &amp; Rev 5 pre-loaded
        </div>
      </div>
    </div>
  </div>

  <div class="col">
    <div class="card text-center h-100">
      <div class="card-body">
        <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">&#128203;</div>
        <h3 style="margin-bottom: 0.5rem;">Baseline Profiles</h3>
        <p class="text-body-secondary small" style="margin-bottom: 1.25rem; min-height: 2.5rem;">
          Import NIST SP 800-53 baseline profiles (LOW, MODERATE, HIGH) and export OSCAL Profiles.
        </p>
        <div class="d-flex flex-column gap-2">
          <%= link_to "View Baselines", profile_documents_path, class: "btn btn-primary" %>
          <%= link_to "Upload New", new_profile_document_path, class: "btn btn-success" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col">
    <div class="card text-center h-100">
      <div class="card-body">
        <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">&#128737;</div>
        <h3 style="margin-bottom: 0.5rem;">Component Definitions</h3>
        <p class="text-body-secondary small" style="margin-bottom: 1.25rem; min-height: 2.5rem;">
          Import DISA STIGs, SCAP, and CIS benchmarks. Export OSCAL-compliant Component Definitions.
        </p>
        <div class="d-flex flex-column gap-2">
          <%= link_to "View CDEFs", cdef_documents_path, class: "btn btn-primary" %>
          <%= link_to "Upload New", new_cdef_document_path, class: "btn btn-success" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col">
    <div class="card text-center h-100">
      <div class="card-body">
        <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">&#128196;</div>
        <h3 style="margin-bottom: 0.5rem;">Controls Implementation</h3>
        <p class="text-body-secondary small" style="margin-bottom: 1.25rem; min-height: 2.5rem;">
          Upload and manage controls implementation workbooks. Edit editable fields, track status, and export to JSON.
        </p>
        <div class="d-flex flex-column gap-2">
          <%= link_to "View Documents", ssp_documents_path, class: "btn btn-primary" %>
          <%= link_to "Upload New", new_ssp_document_path, class: "btn btn-success" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col">
    <div class="card text-center h-100">
      <div class="card-body">
        <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">&#128221;</div>
        <h3 style="margin-bottom: 0.5rem;">Assessment Plans</h3>
        <p class="text-body-secondary small" style="margin-bottom: 1.25rem; min-height: 2.5rem;">
          Generate OSCAL-compliant Security Assessment Plans from SSP and Profile data with assessment method wizards.
        </p>
        <div class="d-flex flex-column gap-2">
          <%= link_to "View Plans", sap_documents_path, class: "btn btn-primary" %>
          <%= link_to "Create New", new_sap_document_path, class: "btn btn-success" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col">
    <div class="card text-center h-100">
      <div class="card-body">
        <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">&#128203;</div>
        <h3 style="margin-bottom: 0.5rem;">Assessment Results</h3>
        <p class="text-body-secondary small" style="margin-bottom: 1.25rem; min-height: 2.5rem;">
          Upload multi-tab security assessment workbooks. View results by section, asset, and environment with heat maps.
        </p>
        <div class="d-flex flex-column gap-2">
          <%= link_to "View Documents", sar_documents_path, class: "btn btn-primary" %>
          <%= link_to "Upload New", new_sar_document_path, class: "btn btn-success" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col">
    <div class="card text-center h-100">
      <div class="card-body">
        <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">&#128270;</div>
        <h3 style="margin-bottom: 0.5rem;">POA&amp;Ms</h3>
        <p class="text-body-secondary small" style="margin-bottom: 1.25rem; min-height: 2.5rem;">
          Import and manage OSCAL Plan of Action &amp; Milestones. Track risks, deadlines, and remediation progress.
        </p>
        <div class="d-flex flex-column gap-2">
          <%= link_to "View POA&Ms", poam_documents_path, class: "btn btn-primary" %>
          <%= link_to "Upload New", new_poam_document_path, class: "btn btn-success" %>
        </div>
      </div>
    </div>
  </div>

</div>

<div class="card">
