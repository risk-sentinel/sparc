<%= form_with model: [poam_document, poam_item], local: true do |f| %>
  <% if poam_item.errors.any? %>
    <div class="rounded mb-4" style="background: var(--bs-danger-bg-subtle); color: var(--bs-danger-text-emphasis); border: 1px solid var(--bs-danger-border-subtle); padding: 1rem;">
      <strong><%= pluralize(poam_item.errors.count, "error") %> prevented this item from being saved:</strong>
      <ul class="mt-2" style="padding-left: 1.25rem;">
        <% poam_item.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :title, "Title", class: "fw-semibold" %>
    <%= f.text_field :title, class: "form-control", required: true, placeholder: "e.g., Update Django Framework Configuration" %>
  </div>

  <div class="form-group">
    <%= f.label :description, "Description", class: "fw-semibold" %>
    <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Describe the weakness and required remediation..." %>
  </div>

  <div class="row row-cols-1 row-cols-md-2 g-3">
    <div class="col">
      <div class="form-group">
        <%= f.label :risk_status, "Risk Status", class: "fw-semibold" %>
        <%= f.select :risk_status, options_for_select([
          ["Open", "open"], ["Investigating", "investigating"], ["Remediating", "remediating"],
          ["Deviation Requested", "deviation-requested"], ["Deviation Approved", "deviation-approved"],
          ["Closed", "closed"]
        ], poam_item.risk_status), { include_blank: "— Select —" }, class: "form-control" %>
      </div>
    </div>

    <div class="col">
      <div class="form-group">
        <%= f.label :risk_level, "Risk Level", class: "fw-semibold" %>
        <%= f.select :risk_level, options_for_select([["High", "high"], ["Medium", "medium"], ["Low", "low"]], poam_item.risk_level), { include_blank: "— Select —" }, class: "form-control" %>
      </div>
    </div>
  </div>

  <div class="row row-cols-1 row-cols-md-3 g-3">
    <div class="col">
      <div class="form-group">
        <%= f.label :likelihood, "Likelihood", class: "fw-semibold" %>
        <%= f.select :likelihood, options_for_select([["High", "high"], ["Medium", "medium"], ["Low", "low"]], poam_item.likelihood), { include_blank: "— Select —" }, class: "form-control" %>
      </div>
    </div>

    <div class="col">
      <div class="form-group">
        <%= f.label :impact, "Impact", class: "fw-semibold" %>
        <%= f.select :impact, options_for_select([["High", "high"], ["Medium", "medium"], ["Low", "low"]], poam_item.impact), { include_blank: "— Select —" }, class: "form-control" %>
      </div>
    </div>

    <div class="col">
      <div class="form-group">
        <%= f.label :deadline, "Deadline", class: "fw-semibold" %>
        <%= f.date_field :deadline, class: "form-control" %>
      </div>
    </div>
  </div>

  <hr class="border-top" style="border: none; margin: 1.5rem 0;">

  <%# ── Linked SSP Implementation Statement (#393) ── %>
  <% if defined?(@available_ssp_statements) && @available_ssp_statements.any? %>
    <div class="form-group">
      <%= f.label :ssp_control_statement_id, "Linked SSP Statement", class: "fw-semibold" %>
      <%= f.select :ssp_control_statement_id,
            options_for_select(
              @available_ssp_statements.map { |s|
                ctrl_label = s.ssp_control.control_id.presence || "ctrl-#{s.ssp_control_id}"
                stmt_label = s.label.presence || s.statement_id
                ["#{ctrl_label} — #{stmt_label}", s.id]
              },
              poam_item.ssp_control_statement_id
            ),
            { include_blank: "— None —" },
            class: "form-control" %>
      <small class="text-body-secondary">
        Optional. Links this POA&amp;M item to the specific SSP implementation statement it remediates.
      </small>
    </div>
  <% elsif @poam_document.authorization_boundary&.ssp_document.present? %>
    <div class="form-group">
      <label class="fw-semibold">Linked SSP Statement</label>
      <div class="text-body-secondary fst-italic" style="font-size: 0.85rem;">
        The boundary's SSP has no implementation statements yet. Backfill statements on the SSP to enable linking.
      </div>
    </div>
  <% end %>

  <%# ── Associated Entities ── %>
  <% if defined?(@available_risks) && @available_risks&.any? %>
    <div class="form-group">
      <label class="fw-semibold">Associated Risks</label>
      <select name="poam_risk_ids[]" multiple class="form-control" style="min-height: 80px;">
        <% @available_risks.each do |risk| %>
          <option value="<%= risk.id %>" <%= "selected" if poam_item.poam_risk_ids.include?(risk.id) %>><%= truncate(risk.title.to_s, length: 100) %> (<%= risk.status %>)</option>
        <% end %>
      </select>
      <small class="text-body-secondary">Hold Ctrl/Cmd to select multiple</small>
    </div>
  <% end %>

  <% if defined?(@available_observations) && @available_observations&.any? %>
    <div class="form-group">
      <label class="fw-semibold">Associated Observations</label>
      <select name="poam_observation_ids[]" multiple class="form-control" style="min-height: 80px;">
        <% @available_observations.each do |obs| %>
          <option value="<%= obs.id %>" <%= "selected" if poam_item.poam_observation_ids.include?(obs.id) %>><%= truncate(obs.title.to_s, length: 100) %></option>
        <% end %>
      </select>
      <small class="text-body-secondary">Hold Ctrl/Cmd to select multiple</small>
    </div>
  <% end %>

  <% if defined?(@available_findings) && @available_findings&.any? %>
    <div class="form-group">
      <label class="fw-semibold">Associated Findings</label>
      <select name="poam_finding_ids[]" multiple class="form-control" style="min-height: 80px;">
        <% @available_findings.each do |finding| %>
          <option value="<%= finding.id %>" <%= "selected" if poam_item.poam_finding_ids.include?(finding.id) %>><%= truncate(finding.title.to_s, length: 100) %></option>
        <% end %>
      </select>
      <small class="text-body-secondary">Hold Ctrl/Cmd to select multiple</small>
    </div>
  <% end %>

  <hr class="border-top" style="border: none; margin: 1.5rem 0;">
  <h3 class="mb-3" style="font-size: 1rem;">Notes &amp; Evidence</h3>

  <div class="form-group">
    <%= f.label :internal_notes, "Internal Notes", class: "fw-semibold" %>
    <%= f.text_area :internal_notes, class: "form-control", rows: 2, placeholder: "Internal tracking notes..." %>
  </div>

  <div class="form-group">
    <%= f.label :closure_evidence, "Closure Evidence", class: "fw-semibold" %>
    <%= f.text_area :closure_evidence, class: "form-control", rows: 2, placeholder: "Evidence or documentation for closure..." %>
  </div>

  <%# ── OSCAL extensibility arrays (#389): props + links ───────────────
       Stored in JSONB columns; round-trip with OSCAL parsers/exporters.
       Origins UI deferred — needs a parties/actors picker. %>

  <hr class="border-top" style="border: none; margin: 1.5rem 0;">
  <details class="mb-3">
    <summary class="fw-semibold" style="font-size: 1rem; cursor: pointer;">
      Properties <span class="text-body-secondary">(OSCAL <code>props</code>)</span>
    </summary>
    <p class="text-body-secondary small mt-2 mb-2">
      Extensible name-value pairs. Use to attach custom metadata that doesn't fit standard fields.
    </p>

    <div data-controller="oscal-repeater">
      <template data-oscal-repeater-target="template">
        <div class="repeater-row d-flex gap-2 mb-2">
          <input type="text" name="poam_item[props_data][][name]"
                 placeholder="name (e.g., severity)" class="form-control form-control-sm" />
          <input type="text" name="poam_item[props_data][][value]"
                 placeholder="value" class="form-control form-control-sm" />
          <input type="text" name="poam_item[props_data][][class]"
                 placeholder="class (optional)" class="form-control form-control-sm" />
          <button type="button" data-action="click->oscal-repeater#remove"
                  class="btn btn-sm btn-outline-danger" aria-label="Remove">×</button>
        </div>
      </template>

      <div data-oscal-repeater-target="rows">
        <% Array(poam_item.props_data).each do |prop| %>
          <div class="repeater-row d-flex gap-2 mb-2">
            <input type="text" name="poam_item[props_data][][name]"
                   value="<%= prop["name"] %>"
                   placeholder="name" class="form-control form-control-sm" />
            <input type="text" name="poam_item[props_data][][value]"
                   value="<%= prop["value"] %>"
                   placeholder="value" class="form-control form-control-sm" />
            <input type="text" name="poam_item[props_data][][class]"
                   value="<%= prop["class"] %>"
                   placeholder="class (optional)" class="form-control form-control-sm" />
            <button type="button" data-action="click->oscal-repeater#remove"
                    class="btn btn-sm btn-outline-danger" aria-label="Remove">×</button>
          </div>
        <% end %>
      </div>

      <button type="button" data-action="click->oscal-repeater#add"
              class="btn btn-sm btn-outline-primary mt-1">+ Add property</button>
    </div>
  </details>

  <details class="mb-3">
    <summary class="fw-semibold" style="font-size: 1rem; cursor: pointer;">
      Links <span class="text-body-secondary">(OSCAL <code>links</code>)</span>
    </summary>
    <p class="text-body-secondary small mt-2 mb-2">
      Cross-references to other artifacts (URLs, internal docs, related findings).
      <code>media-type</code> uses an underscore here and is converted on save.
    </p>

    <div data-controller="oscal-repeater">
      <template data-oscal-repeater-target="template">
        <div class="repeater-row d-flex gap-2 mb-2 flex-wrap">
          <input type="url" name="poam_item[links_data][][href]"
                 placeholder="https://… or #fragment-uuid"
                 class="form-control form-control-sm" style="flex: 2 1 250px;" />
          <input type="text" name="poam_item[links_data][][rel]"
                 list="oscal-link-rels"
                 placeholder="rel (e.g., reference)"
                 class="form-control form-control-sm" style="flex: 1 1 140px;" />
          <input type="text" name="poam_item[links_data][][media_type]"
                 placeholder="media-type (e.g., text/html)"
                 class="form-control form-control-sm" style="flex: 1 1 160px;" />
          <input type="text" name="poam_item[links_data][][text]"
                 placeholder="display text (optional)"
                 class="form-control form-control-sm" style="flex: 1 1 160px;" />
          <button type="button" data-action="click->oscal-repeater#remove"
                  class="btn btn-sm btn-outline-danger" aria-label="Remove">×</button>
        </div>
      </template>

      <div data-oscal-repeater-target="rows">
        <% Array(poam_item.links_data).each do |link| %>
          <div class="repeater-row d-flex gap-2 mb-2 flex-wrap">
            <input type="url" name="poam_item[links_data][][href]"
                   value="<%= link["href"] %>"
                   placeholder="https://… or #fragment-uuid"
                   class="form-control form-control-sm" style="flex: 2 1 250px;" />
            <input type="text" name="poam_item[links_data][][rel]"
                   value="<%= link["rel"] %>"
                   list="oscal-link-rels"
                   placeholder="rel"
                   class="form-control form-control-sm" style="flex: 1 1 140px;" />
            <input type="text" name="poam_item[links_data][][media_type]"
                   value="<%= link["media-type"] %>"
                   placeholder="media-type"
                   class="form-control form-control-sm" style="flex: 1 1 160px;" />
            <input type="text" name="poam_item[links_data][][text]"
                   value="<%= link["text"] %>"
                   placeholder="display text"
                   class="form-control form-control-sm" style="flex: 1 1 160px;" />
            <button type="button" data-action="click->oscal-repeater#remove"
                    class="btn btn-sm btn-outline-danger" aria-label="Remove">×</button>
          </div>
        <% end %>
      </div>

      <button type="button" data-action="click->oscal-repeater#add"
              class="btn btn-sm btn-outline-primary mt-1">+ Add link</button>
    </div>

    <datalist id="oscal-link-rels">
      <option value="reference"></option>
      <option value="related-observation"></option>
      <option value="closes-finding"></option>
      <option value="depends-on"></option>
      <option value="provided-by"></option>
      <option value="used-by"></option>
    </datalist>
  </details>

  <div class="d-flex gap-3 mt-3">
    <%= f.submit poam_item.persisted? ? "Update Item" : "Add Item", class: "btn btn-success" %>
    <%= link_to "Cancel", poam_document_path(poam_document), class: "btn btn-secondary" %>
  </div>
<% end %>
