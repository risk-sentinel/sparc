<%= form_with(model: [profile_document, profile_control], local: true) do |f| %>
  <% if profile_control.errors.any? %>
    <div class="rounded mb-3" style="background: var(--bs-danger-bg-subtle); border: 1px solid var(--bs-danger-border-subtle); padding: 0.75rem;">
      <% profile_control.errors.full_messages.each do |msg| %>
        <p style="color: var(--bs-danger-text-emphasis); font-size: 0.85rem; margin: 0.2rem 0;"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form-group">
    <label>Control ID <span class="sparc-required">*</span></label>
    <%= f.text_field :control_id, class: "form-control", placeholder: "e.g. AC-1, SI-3(1)" %>
  </div>

  <div class="form-group">
    <label>Title</label>
    <%= f.text_field :title, class: "form-control", placeholder: "Control title" %>
  </div>

  <div class="form-group">
    <label>Priority</label>
    <%= f.select :priority,
          options_for_select([["P1", "P1"], ["P2", "P2"], ["P3", "P3"]], profile_control.priority),
          { include_blank: "-- select --" },
          class: "form-control" %>
  </div>

  <%# ── Per-Parameter Value Fields ── %>
  <%
    param_fields = profile_control.profile_control_fields.select { |pcf| pcf.field_name.start_with?("parameter:") && !pcf.field_name.start_with?("parameter_label:") }
    label_map = profile_control.profile_control_fields
                  .select { |pcf| pcf.field_name.start_with?("parameter_label:") }
                  .index_by { |pcf| pcf.field_name.delete_prefix("parameter_label:") }

    # Build select/choice metadata from the linked catalog control (if available),
    # including parent-control params inherited by sub-controls
    select_meta = {}
    if profile_document.control_catalog.present?
      cat_ctrl = profile_document.control_catalog.catalog_controls.find_by(control_id: profile_control.control_id)
      if cat_ctrl
        cat_ctrl.effective_params_list.each do |p|
          select_meta[p["id"]] = p["select"] if p["select"].present?
        end
      end
    end
  %>
  <% if param_fields.any? %>
    <details class="border rounded" style="margin-bottom: 1.25rem; padding: 0;" open>
      <summary class="fw-semibold small bg-body-secondary rounded d-flex align-items-center gap-2" style="padding: 0.65rem 1rem; cursor: pointer; list-style: none;">
        <span>&#9656;</span> Parameters
        <span class="badge rounded-pill text-bg-info" style="font-size: 0.7rem; font-weight: 500;">
          <%= param_fields.size %> param<%= param_fields.size == 1 ? "" : "s" %>
        </span>
      </summary>
      <div class="p-3">
        <p class="text-body-tertiary" style="font-size: 0.78rem; margin-bottom: 0.75rem;">
          Parameters inherited from the catalog. Edit the <strong>Value</strong> to set organization-specific definitions.
          <% if select_meta.any? %>
            Click a suggestion badge to use a catalog-defined value, or type a custom value.
          <% end %>
        </p>
        <table class="table table-sm mb-0" style="font-size: 0.82rem;">
          <thead>
            <tr>
              <th style="width: 22%; padding: 0.3rem 0.5rem;">Param ID</th>
              <th style="width: 30%; padding: 0.3rem 0.5rem;">Label</th>
              <th style="padding: 0.3rem 0.5rem;">Value</th>
            </tr>
          </thead>
          <tbody>
            <% param_fields.each do |pf| %>
              <% param_id = pf.field_name.delete_prefix("parameter:") %>
              <% label_field = label_map[param_id] %>
              <% sel = select_meta[param_id] %>
              <tr>
                <td style="padding: 0.3rem 0.5rem; font-family: monospace; color: var(--bs-primary);">
                  <%= param_id %>
                </td>
                <td style="padding: 0.3rem 0.5rem;" class="text-body-secondary">
                  <%= label_field&.field_value %>
                </td>
                <td style="padding: 0.3rem 0.5rem;">
                  <% if sel %>
                    <% choices = sel["choice"] || [] %>
                    <% is_multi = sel["how-many"] == "one-or-more" %>
                    <div style="margin-bottom: 0.35rem;">
                      <span class="text-body-tertiary" style="font-size: 0.72rem;">
                        Selection<%= is_multi ? " (one or more)" : "" %>:
                      </span>
                      <% choices.each do |choice| %>
                        <span class="badge bg-primary-subtle text-primary-emphasis sparc-param-choice"
                              style="cursor: pointer; font-size: 0.72rem; font-weight: 500; margin: 0.1rem 0;"
                              data-multi="<%= is_multi %>"
                              onclick="sparc.pickParamChoice(this)">
                          <%= choice %>
                        </span>
                      <% end %>
                    </div>
                  <% end %>
                  <%= text_field_tag "param_values[#{param_id}]",
                      pf.field_value,
                      class: "form-control form-control-sm",
                      style: "font-size: 0.82rem;",
                      placeholder: sel ? "Choose above or enter custom value..." : "Organization-defined value..." %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </details>
  <% end %>

  <% ProfileControlField::EDITABLE_FIELDS.each do |fname| %>
    <% field = profile_control.profile_control_fields.find { |pcf| pcf.field_name == fname } %>
    <div class="form-group">
      <label>
        <%= fname.tr("_", " ").titleize %>
        <span style="color: var(--bs-success); font-size: 0.75rem; font-weight: 400;">(editable)</span>
      </label>
      <%= text_area_tag "fields[#{fname}]", field&.field_value.to_s,
            class: "form-control", rows: 3 %>
    </div>
  <% end %>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit(profile_control.persisted? ? "Save Changes" : "Add Control", class: "btn btn-success") %>
    <%= link_to "Cancel", profile_document_path(profile_document), class: "btn btn-secondary" %>
  </div>
<% end %>

<%# ── Back-Matter References (outside parent form to avoid nested forms) ── %>
<% if profile_control.persisted? %>
  <% linked = defined?(@linked_resources) ? @linked_resources : profile_control.back_matter_resources.order(:title) %>
  <% available = defined?(@available_resources) ? @available_resources : [] %>
  <details class="border rounded mt-4" style="padding: 0;" <%= "open" if linked.any? %>>
    <summary class="fw-semibold small bg-body-secondary rounded d-flex align-items-center gap-2" style="padding: 0.65rem 1rem; cursor: pointer; list-style: none;">
      <span>&#9656;</span> Back-Matter References
      <span class="badge rounded-pill text-bg-info" style="font-size: 0.7rem; font-weight: 500;">
        <%= linked.size %>
      </span>
    </summary>
    <div class="p-3">
      <p class="text-body-tertiary" style="font-size: 0.78rem; margin-bottom: 0.75rem;">
        Link back-matter resources (policies, evidence, external references) to this control.
        Linked resources appear as <code>href="#uuid"</code> references in OSCAL exports.
      </p>

      <%# ── Currently linked ── %>
      <% if linked.any? %>
        <table class="table table-sm mb-3" style="font-size: 0.82rem;">
          <thead>
            <tr><th>Title</th><th>UUID</th><th>Href</th><th></th></tr>
          </thead>
          <tbody>
            <% linked.each do |resource| %>
              <tr>
                <td><%= resource.title %></td>
                <td><code class="small"><%= resource.uuid.truncate(20) %></code></td>
                <td class="text-break small"><%= resource.href %></td>
                <td>
                  <% link_record = profile_control.control_back_matter_links.find_by(back_matter_resource: resource) %>
                  <% if link_record %>
                    <%= button_to "Unlink",
                          profile_document_profile_control_control_back_matter_link_path(profile_document, profile_control, link_record),
                          method: :delete,
                          class: "btn btn-sm btn-outline-danger",
                          data: { turbo_confirm: "Unlink \"#{resource.title}\"?" } %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>

      <%# ── Link existing resource ── %>
      <% if available.any? %>
        <div class="mb-3">
          <h6 class="fw-semibold small">Link Existing Resource</h6>
          <%= form_with url: link_resource_profile_document_profile_control_path(profile_document, profile_control), method: :post, local: true, class: "d-flex gap-2 align-items-end" do %>
            <div class="flex-grow-1">
              <select name="back_matter_resource_id" class="form-select form-select-sm">
                <option value="">Select a resource...</option>
                <% available.each do |r| %>
                  <option value="<%= r.id %>"><%= r.title %> (<%= r.uuid.truncate(12) %>)</option>
                <% end %>
              </select>
            </div>
            <button type="submit" class="btn btn-sm btn-outline-primary">Link</button>
          <% end %>
        </div>
      <% end %>

      <%# ── Create new resource ── %>
      <h6 class="fw-semibold small">Create New Resource</h6>
      <%= form_with url: profile_document_profile_control_control_back_matter_links_path(profile_document, profile_control), method: :post, local: true do %>
        <%= render "shared/resource_form_fields" %>
      <% end %>
    </div>
  </details>
<% end %>
