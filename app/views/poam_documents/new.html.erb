<div class="card">
  <h2>Create POA&amp;M</h2>
  <p class="text-body-secondary mb-4">
    Create a new Plan of Action &amp; Milestones document. Add items, risks, and observations after creation.
  </p>

  <%= form_with model: PoamDocument.new, url: poam_documents_path, local: true do |f| %>
    <div class="bg-body-secondary rounded-3 mb-4" style="border: 1px solid var(--bs-border-color); border-left: 4px solid #e74c3c; padding: 1.25rem;">
      <h3 class="mb-3" style="font-size: 1rem; color: #e74c3c;">POA&amp;M Details</h3>

      <div class="form-group">
        <label for="poam_document_name">Name</label>
        <%= f.text_field :name, placeholder: "e.g., FY26 POA&M — System XYZ", class: "form-control", required: true %>
      </div>

      <div class="form-group">
        <label for="poam_document_description">Description</label>
        <%= f.text_area :description, rows: 2, placeholder: "Brief description of the POA&M scope", class: "form-control", style: "min-height: 60px;" %>
      </div>

      <div class="row row-cols-1 row-cols-md-2 g-3">
        <div class="col">
          <div class="form-group">
            <label for="poam_document_system_id">System Identifier</label>
            <%= f.text_field :system_id, placeholder: "e.g., SPARC-PROD-001", class: "form-control" %>
          </div>
        </div>
        <div class="col">
          <div class="form-group">
            <label for="poam_document_authorization_boundary_id">Authorization Boundary</label>
            <%= f.select :authorization_boundary_id,
                  options_for_select(
                    AuthorizationBoundary.order(:name).map { |b| [b.name, b.id] },
                    nil
                  ),
                  { include_blank: "— Select (optional) —" },
                  class: "form-control" %>
          </div>
        </div>
      </div>
    </div>

    <%= f.hidden_field :status, value: "completed" %>
    <%= f.hidden_field :creation_method, value: "wizard" %>

    <div class="d-flex gap-3">
      <%= f.submit "Create POA&M", class: "btn btn-success" %>
      <%= link_to "Cancel", poam_documents_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<%# ── OR: Upload existing POAM file ── %>
<div class="card" id="upload-poam">
  <h3>Or Upload Existing POA&amp;M</h3>
  <p class="text-body-secondary mb-3">
    Already have an OSCAL POA&amp;M? Upload the file directly.
  </p>

  <%= form_with model: @poam_document, local: true, multipart: true do |f| %>
    <%= render "shared/dropzone",
      form: f,
      field: :file,
      accept: ".json,.xml,.yaml,.yml",
      multiple: true,
      hint: "Upload an OSCAL Plan of Action and Milestones (POA&M) in JSON, XML, or YAML format." %>

    <div class="d-flex gap-3">
      <%= f.submit "Upload and Process", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
