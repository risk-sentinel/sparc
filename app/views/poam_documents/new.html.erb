<div class="card">
  <h2>Upload OSCAL POA&amp;M</h2>

  <%= form_with model: @poam_document, local: true, multipart: true do |f| %>
    <div class="form-group">
      <label for="poam_document_file">Select POA&amp;M File (.json, .xml)</label>
      <%= f.file_field :file, accept: ".json,.xml", required: true %>
      <small class="text-body-secondary d-block mt-2">
        Upload an OSCAL Plan of Action and Milestones (POA&amp;M) in JSON or XML format.
      </small>
    </div>

    <div class="d-flex gap-3">
      <%= f.submit "Upload and Process", class: "btn btn-success" %>
      <%= link_to "Cancel", poam_documents_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<div class="card">
  <h3>Supported Formats</h3>
  <p class="text-body-secondary mb-3">SPARC parses OSCAL POA&amp;M files to extract action items, risks, observations, and milestones.</p>

  <table class="table table-hover">
    <thead>
      <tr>
        <th>Format</th>
        <th>Extension</th>
        <th>Sources</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><strong>OSCAL POA&amp;M JSON</strong></td>
        <td>.json</td>
        <td>NIST OSCAL examples, FedRAMP POA&amp;Ms, tool-generated outputs</td>
      </tr>
      <tr>
        <td><strong>OSCAL POA&amp;M XML</strong></td>
        <td>.xml</td>
        <td>NIST OSCAL examples, XSLT-transformed outputs</td>
      </tr>
    </tbody>
  </table>
</div>

<div class="card">
  <h3>What Gets Parsed</h3>
  <p class="text-body-secondary mb-3">The following OSCAL elements are extracted and stored:</p>

  <div class="row row-cols-1 row-cols-md-2 g-3">
    <div class="col">
      <div class="bg-body-secondary p-3 rounded" style="border: 1px solid var(--bs-border-color); border-left: 3px solid #e74c3c;">
        <div class="fw-bold" style="margin-bottom: 0.35rem; color: #e74c3c;">POA&amp;M Items</div>
        <div class="text-body-secondary" style="font-size: 0.88rem;">Action items with titles, descriptions, and links to related risks and observations.</div>
      </div>
    </div>
    <div class="col">
      <div class="bg-body-secondary p-3 rounded" style="border: 1px solid var(--bs-border-color); border-left: 3px solid #f39c12;">
        <div class="fw-bold" style="margin-bottom: 0.35rem; color: #f39c12;">Risks &amp; Observations</div>
        <div class="text-body-secondary" style="font-size: 0.88rem;">Risk characterizations (likelihood, impact, status) and assessment observations are preserved for OSCAL round-trip export.</div>
      </div>
    </div>
  </div>
</div>
