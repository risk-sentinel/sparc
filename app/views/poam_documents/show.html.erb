<%# #395 P3: boundary context header %>
<%= render "shared/boundary_header", document: @poam_document %>

<%# ── PROCESSING STATE BANNER ─────────────────────────────────────── %>
<% unless @poam_document.completed? %>
  <%= render "shared/processing_banner",
       document:     @poam_document,
       title:        "Processing Your POA&amp;M",
       back_label:   "Back to POA&amp;Ms",
       back_path:    poam_documents_path %>

<% else %>
<%
  open_count   = @status_counts.select { |s, _| s.to_s.downcase == "open" }.values.sum
  closed_count = @status_counts.select { |s, _| s.to_s.downcase == "closed" }.values.sum
  other_count  = @total_items - open_count - closed_count

  impact_colors = { "high" => "#e74c3c", "medium" => "#f39c12", "low" => "#3498db" }
  status_colors = {
    "open" => "#e74c3c", "investigating" => "#e67e22", "remediating" => "#f39c12",
    "deviation-requested" => "#d35400", "deviation-approved" => "#f39c12", "closed" => "#27ae60"
  }

  risk_status_options = [
    ["Open", "open"], ["Investigating", "investigating"], ["Remediating", "remediating"],
    ["Deviation Requested", "deviation-requested"], ["Deviation Approved", "deviation-approved"],
    ["Closed", "closed"]
  ]

  active_status = params[:risk_status]
  active_impact = params[:impact]
  has_filters   = [active_status, active_impact].any?(&:present?)
%>

<%# ── HEADER DASHBOARD ──────────────────────────────────────────── %>
<div class="sparc-gradient-header" style="border-radius: 12px; padding: 1.75rem 2rem; margin-bottom: 1.5rem; color: white;">

  <div class="d-flex justify-content-between align-items-start mb-4 gap-3 flex-wrap">
    <div>
      <div class="sparc-header-subtitle">Plan of Action &amp; Milestones</div>

      <%# ── View mode ── %>
      <div id="doc-meta-view">
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <h2 class="sparc-header-title"><%= @poam_document.name %></h2>
          <% if @poam_document.poam_version.present? %>
            <span class="sparc-version-badge">v<%= @poam_document.poam_version %></span>
          <% end %>
          <button onclick="toggleDocMeta()" class="sparc-btn-header-edit">Edit</button>
        </div>
      </div>

      <%# ── Edit mode (hidden) ── %>
      <div id="doc-meta-edit" style="display: none;">
        <%= form_with model: @poam_document, url: update_metadata_poam_document_path(@poam_document), method: :patch, local: true, class: "d-flex align-items-center gap-2 flex-wrap" do |f| %>
          <%= f.text_field :name, value: @poam_document.name, class: "sparc-input-dark sparc-input-dark-lg", placeholder: "Document name" %>
          <%= f.text_field :poam_version, value: @poam_document.poam_version, class: "sparc-input-dark sparc-input-dark-sm", placeholder: "Version" %>
          <%= f.submit "Save", class: "sparc-btn-save" %>
          <button type="button" onclick="toggleDocMeta()" class="sparc-btn-cancel-dark">Cancel</button>
        <% end %>
      </div>
    </div>

    <%# ── Action buttons ── %>
    <div class="d-flex gap-2 flex-wrap">
      <%= link_to "+ Add Item", new_poam_document_poam_item_path(@poam_document), class: "sparc-btn-oscal" %>
      <% if signed_in? && @poam_document.draft? %>
        <%= render "shared/publish_button", document: @poam_document,
              publish_path: publish_poam_document_path(@poam_document),
              check_path: publish_check_poam_document_path(@poam_document) %>
      <% end %>
      <%= render "shared/oscal_export_dropdown",
            validate_path: validate_oscal_export_poam_document_path(@poam_document),
            download_json_path: download_oscal_validated_poam_document_path(@poam_document),
            download_yaml_path: download_yaml_poam_document_path(@poam_document),
            download_xml_path: download_xml_poam_document_path(@poam_document),
            fallback_json_path: download_oscal_unvalidated_poam_document_path(@poam_document),
            document_type: "POA&M" %>
      <%= link_to "&#8592; All POA&Ms".html_safe, poam_documents_path, class: "sparc-btn-ghost-muted" %>
    </div>
  </div>

  <%# ── Summary stats ── %>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 0.75rem;">
    <div class="sparc-hero-tile rounded-3">
      <div class="sparc-hero-tile-count"><%= @total_items %></div>
      <div class="sparc-hero-tile-label">Total Items</div>
    </div>
    <div class="sparc-hero-tile rounded-3" style="background: rgba(231,76,60,0.15); border: 1px solid rgba(231,76,60,0.3);">
      <div class="sparc-hero-tile-count" style="color: #e74c3c;"><%= open_count %></div>
      <div class="sparc-hero-tile-label">Open</div>
    </div>
    <div class="sparc-hero-tile rounded-3" style="background: rgba(243,156,18,0.15); border: 1px solid rgba(243,156,18,0.3);">
      <div class="sparc-hero-tile-count" style="color: #f39c12;"><%= other_count %></div>
      <div class="sparc-hero-tile-label">In Progress</div>
    </div>
    <div class="sparc-hero-tile rounded-3" style="background: rgba(39,174,96,0.15); border: 1px solid rgba(39,174,96,0.3);">
      <div class="sparc-hero-tile-count" style="color: #27ae60;"><%= closed_count %></div>
      <div class="sparc-hero-tile-label">Closed</div>
    </div>
    <div class="sparc-hero-tile rounded-3" style="background: rgba(52,152,219,0.15); border: 1px solid rgba(52,152,219,0.3);">
      <div class="sparc-hero-tile-count" style="color: #3498db;"><%= @risk_count %></div>
      <div class="sparc-hero-tile-label">Risks</div>
    </div>
    <div class="sparc-hero-tile rounded-3" style="background: rgba(155,89,182,0.15); border: 1px solid rgba(155,89,182,0.3);">
      <div class="sparc-hero-tile-count" style="color: #9b59b6;"><%= @observation_count %></div>
      <div class="sparc-hero-tile-label">Observations</div>
    </div>
    <div class="sparc-hero-tile rounded-3" style="background: rgba(230,126,34,0.15); border: 1px solid rgba(230,126,34,0.3);">
      <div class="sparc-hero-tile-count" style="color: #e67e22;"><%= @finding_count %></div>
      <div class="sparc-hero-tile-label">Findings</div>
    </div>
  </div>
</div>

<%# ── HEATMAP ────────────────────────────────────────────────────── %>
<% if @heatmap_data.any? %>
<div class="card" style="overflow-x: auto;">
  <h3 class="mb-3">Risk Status x Impact</h3>
  <table class="table table-hover" style="min-width: 400px;">
    <thead>
      <tr>
        <th>Status</th>
        <% @heatmap_impacts.each do |imp| %>
          <th class="text-center" style="min-width: 80px;"><%= imp.capitalize %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% @heatmap_statuses.each do |status| %>
        <tr>
          <td class="fw-semibold">
            <% sc = status_colors[status] || "#7f8c8d" %>
            <span class="sparc-tag-outline" style="background: <%= sc %>22; color: <%= sc %>; border: 1px solid <%= sc %>44;"><%= status %></span>
          </td>
          <% @heatmap_impacts.each do |imp| %>
            <% count = @heatmap_data.dig(status, imp) || 0 %>
            <% ic = impact_colors[imp] || "#7f8c8d" %>
            <td class="text-center">
              <% if count > 0 %>
                <%= link_to count, poam_document_path(@poam_document, risk_status: status, impact: imp),
                      class: "sparc-heatmap-badge",
                      role: "button",
                      "aria-label": "#{status} #{imp}: #{count} items",
                      style: "background: #{ic}22; color: #{ic}; border: 1px solid #{ic}44; min-width: 28px;" %>
              <% else %>
                <span class="text-body-tertiary">—</span>
              <% end %>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% end %>

<%# ── PUBLISH-READINESS WARNING (#389) ─────────────────────────────
     Surfaces an actionable warning when an in-progress POA&M has no items.
     OscalPoamExportService.validate! already enforces this at publish time
     (OSCAL schema requires poam-items to contain ≥1 entry); this banner
     prompts the user before they hit that error. %>
<% if @total_items.to_i.zero? && !@poam_document.published_lifecycle? %>
  <div class="card d-flex align-items-center gap-3" style="border-left: 4px solid #f39c12; padding: 1rem 1.25rem;">
    <span style="font-size: 1.5rem;">&#9888;</span>
    <div class="flex-grow-1">
      <div class="fw-semibold" style="font-size: 0.95rem; color: #f39c12;">Add at least one POA&amp;M item before publishing</div>
      <div class="text-body-secondary" style="font-size: 0.85rem;">
        OSCAL schema requires the <code>poam-items</code> array to contain at least one entry.
        Publishing now will fail schema validation.
      </div>
    </div>
    <%= link_to "+ Add First Item", new_poam_document_poam_item_path(@poam_document),
                class: "btn btn-warning btn-sm" %>
  </div>
<% end %>

<%# ── ACTIVE FILTERS ─────────────────────────────────────────────── %>
<% if has_filters %>
  <div class="card d-flex align-items-center gap-3 flex-wrap" style="padding: 0.75rem 1.25rem;">
    <span class="fw-semibold" style="font-size: 0.85rem;">Filters:</span>
    <% if active_status.present? %>
      <span class="sparc-tag-outline" style="background: var(--bs-warning-bg-subtle); color: var(--bs-warning-text-emphasis);">Status: <%= active_status %></span>
    <% end %>
    <% if active_impact.present? %>
      <span class="sparc-tag-outline" style="background: var(--bs-danger-bg-subtle); color: var(--bs-danger-text-emphasis);">Impact: <%= active_impact %></span>
    <% end %>
    <%= link_to "Clear Filters", poam_document_path(@poam_document), class: "text-primary", style: "font-size: 0.85rem;" %>
    <span class="text-body-secondary" style="margin-left: auto; font-size: 0.85rem;">Showing <%= @filtered_count %> of <%= @total_items %> items</span>
  </div>
<% end %>

<%# ── POA&M ITEM CARDS WITH INLINE EDITING ────────────────────── %>
<% @items.each_with_index do |item, idx| %>
  <%
    sc = status_colors[item.risk_status] || "#7f8c8d"
    ic = impact_colors[item.impact] || "#7f8c8d"
    risks = item.poam_risks
    observations = item.poam_observations
    findings = item.poam_findings
    related_controls = item.related_control_ids
  %>
  <div class="card" style="border-left: 4px solid <%= sc %>; padding: 1.25rem 1.5rem;">

    <%# ── Card header ── %>
    <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap" style="margin-bottom: 0.75rem;">
      <div style="flex: 1;">
        <div class="d-flex align-items-center gap-2 flex-wrap" style="margin-bottom: 0.35rem;">
          <span class="text-body-tertiary fw-semibold" style="font-size: 0.7rem;">#<%= idx + 1 %></span>
          <h3 style="margin: 0; font-size: 1.05rem;"><%= item.title %></h3>
          <% related_controls.each do |cid| %>
            <span class="sparc-tag-outline" title="NIST 800-53 control referenced in this item"
                  style="background: rgba(52,152,219,0.15); color: #3498db; border: 1px solid rgba(52,152,219,0.3); font-family: monospace; font-weight: 600;">
              <%= cid.upcase %>
            </span>
          <% end %>
        </div>
        <% if item.description.present? %>
          <p class="text-body-secondary" style="font-size: 0.88rem; margin: 0 0 0.4rem 0; white-space: pre-wrap;"><%= item.description %></p>
        <% end %>
        <% if item.remarks.present? %>
          <div class="bg-body-tertiary rounded" style="border-left: 3px solid var(--bs-border-color); padding: 0.4rem 0.7rem; margin-top: 0.4rem; font-size: 0.82rem;">
            <span class="text-body-tertiary fw-semibold" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.04em;">Remarks</span>
            <div style="white-space: pre-wrap; margin-top: 0.2rem;"><%= item.remarks %></div>
          </div>
        <% end %>
      </div>
      <div class="d-flex flex-shrink-0" style="gap: 0.35rem;">
        <button onclick="toggleItemEdit(<%= item.id %>)" id="edit-btn-<%= item.id %>" class="sparc-btn-edit">Edit</button>
        <%= link_to "Full Edit", edit_poam_document_poam_item_path(@poam_document, item), class: "bg-body-secondary text-body-secondary rounded", style: "text-decoration: none; border: 1px solid var(--bs-border-color); padding: 0.3rem 0.7rem; font-size: 0.78rem;" %>
        <%= button_to "Delete", poam_document_poam_item_path(@poam_document, item), method: :delete, data: { turbo_confirm: "Remove \"#{item.title}\"?" }, class: "btn btn-danger", style: "padding: 0.3rem 0.7rem; font-size: 0.78rem;" %>
      </div>
    </div>

    <%# ── Status/risk badges ── %>
    <div class="d-flex gap-2 flex-wrap" style="margin-bottom: 0.75rem;">
      <% if item.risk_status.present? %>
        <span class="sparc-tag-outline" style="background: <%= sc %>22; color: <%= sc %>; border: 1px solid <%= sc %>44;"><%= item.risk_status %></span>
      <% end %>
      <% if item.impact.present? %>
        <span class="sparc-tag-outline" style="background: <%= ic %>22; color: <%= ic %>; border: 1px solid <%= ic %>44;">Impact: <%= item.impact %></span>
      <% end %>
      <% if item.likelihood.present? %>
        <span class="sparc-tag-outline bg-body-secondary text-body-secondary" style="border: 1px solid var(--bs-border-color);">Likelihood: <%= item.likelihood %></span>
      <% end %>
      <% if item.deadline.present? %>
        <span class="sparc-tag-outline bg-body-secondary text-body-secondary" style="border: 1px solid var(--bs-border-color);">Deadline: <%= item.deadline.strftime("%Y-%m-%d") %></span>
      <% end %>
      <% if risks.any? %>
        <span class="sparc-tag-outline" style="background: rgba(52,152,219,0.15); border: 1px solid rgba(52,152,219,0.3); color: #3498db;"><%= pluralize(risks.size, "risk") %></span>
      <% end %>
      <% if observations.any? %>
        <span class="sparc-tag-outline" style="background: rgba(155,89,182,0.15); border: 1px solid rgba(155,89,182,0.3); color: #9b59b6;"><%= pluralize(observations.size, "observation") %></span>
      <% end %>
      <% if findings.any? %>
        <span class="sparc-tag-outline" style="background: rgba(230,126,34,0.15); border: 1px solid rgba(230,126,34,0.3); color: #e67e22;"><%= pluralize(findings.size, "finding") %></span>
      <% end %>
    </div>

    <%# ── Expandable details section ── %>
    <details id="details-<%= item.id %>" class="card-details">
      <summary class="text-primary fw-semibold" style="cursor: pointer; font-size: 0.82rem; margin-bottom: 0.75rem; user-select: none;">
        Show Details
      </summary>

      <%# ══════ VIEW MODE ══════ %>
      <div id="view-<%= item.id %>">
        <%# ── Related risks ── %>
        <% if risks.any? %>
          <div style="margin-bottom: 0.75rem;">
            <div class="sparc-statement-label">Related Risks</div>
            <% risks.each do |risk| %>
              <div class="bg-body-secondary rounded" style="border: 1px solid var(--bs-border-color); padding: 0.6rem 0.8rem; margin-bottom: 0.4rem;">
                <div class="d-flex align-items-center gap-2 flex-wrap" style="margin-bottom: 0.3rem;">
                  <% rsc = status_colors[risk.status] || "#7f8c8d" %>
                  <span class="sparc-tag-outline" style="background: <%= rsc %>22; color: <%= rsc %>; border: 1px solid <%= rsc %>44;"><%= risk.status %></span>
                  <span class="fw-semibold" style="font-size: 0.88rem; color: var(--bs-body-color);"><%= risk.title %></span>
                </div>
                <% if risk.description.present? %>
                  <div class="text-body-secondary" style="font-size: 0.82rem; margin-bottom: 0.3rem;"><%= truncate(risk.description, length: 300) %></div>
                <% end %>
                <% if risk.statement.present? %>
                  <div class="text-body-secondary" style="font-size: 0.8rem; font-style: italic; margin-bottom: 0.3rem; padding-left: 0.5rem; border-left: 2px solid var(--bs-border-color);"><%= truncate(risk.statement, length: 200) %></div>
                <% end %>

                <%# ── Remediations + Milestones ── %>
                <% risk.poam_remediations.each do |rem| %>
                  <div class="rounded mt-2" style="padding: 0.4rem 0.6rem; background: rgba(52,152,219,0.06); border: 1px solid rgba(52,152,219,0.15);">
                    <div class="sparc-statement-label" style="color: #3498db;">
                      Remediation: <%= rem.lifecycle %>
                    </div>
                    <div class="fw-semibold" style="font-size: 0.82rem; color: var(--bs-body-color);"><%= rem.title %></div>
                    <% if rem.description.present? %>
                      <div class="text-body-secondary" style="font-size: 0.8rem;"><%= truncate(rem.description, length: 200) %></div>
                    <% end %>

                    <% rem.poam_milestones.each do |ms| %>
                      <div class="rounded mt-1" style="padding: 0.3rem 0.5rem; background: rgba(39,174,96,0.06); border: 1px solid rgba(39,174,96,0.15);">
                        <div class="sparc-statement-label" style="color: #27ae60;">
                          Milestone
                          <% if ms.due_date.present? %>
                            <span class="text-body-secondary" style="font-weight: 400;">&middot; Due: <%= ms.due_date.strftime("%Y-%m-%d") %></span>
                          <% end %>
                        </div>
                        <div style="font-size: 0.8rem; color: var(--bs-body-color);"><%= ms.title %></div>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# ── Related observations ── %>
        <% if observations.any? %>
          <div style="margin-bottom: 0.75rem;">
            <div class="sparc-statement-label">Related Observations</div>
            <% observations.each do |obs| %>
              <div class="bg-body-secondary rounded" style="border: 1px solid var(--bs-border-color); padding: 0.5rem 0.8rem; margin-bottom: 0.4rem;">
                <div class="fw-semibold" style="font-size: 0.88rem; color: var(--bs-body-color);"><%= obs.title %></div>
                <% if obs.description.present? %>
                  <div class="text-body-secondary" style="font-size: 0.82rem;"><%= truncate(obs.description, length: 200) %></div>
                <% end %>
                <div class="text-body-tertiary" style="font-size: 0.72rem; margin-top: 0.2rem;">
                  <% if obs.collected.present? %>Collected: <%= obs.collected.strftime("%Y-%m-%d") %><% end %>
                  <% if obs.methods_data.present? %>&middot; Methods: <%= obs.methods_data.join(", ") %><% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# ── Related findings ── %>
        <% if findings.any? %>
          <div style="margin-bottom: 0.75rem;">
            <div class="sparc-statement-label">Related Findings</div>
            <% findings.each do |finding| %>
              <div class="bg-body-secondary rounded" style="border: 1px solid var(--bs-border-color); padding: 0.5rem 0.8rem; margin-bottom: 0.4rem;">
                <div class="fw-semibold" style="font-size: 0.88rem; color: var(--bs-body-color);"><%= finding.title %></div>
                <% if finding.description.present? %>
                  <div class="text-body-secondary" style="font-size: 0.82rem;"><%= truncate(finding.description, length: 200) %></div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# ── Internal Notes / Closure Evidence (read-only) ── %>
        <% if item.internal_notes.present? %>
          <div class="bg-body-secondary rounded" style="border: 1px solid var(--bs-border-color); padding: 0.6rem 0.8rem; margin-bottom: 0.5rem;">
            <div class="sparc-statement-label">Internal Notes</div>
            <div style="font-size: 0.85rem; white-space: pre-wrap; color: var(--bs-body-color);"><%= item.internal_notes %></div>
          </div>
        <% end %>
        <% if item.closure_evidence.present? %>
          <div class="bg-body-secondary rounded" style="border: 1px solid var(--bs-border-color); padding: 0.6rem 0.8rem; margin-bottom: 0.5rem;">
            <div class="sparc-statement-label">Closure Evidence</div>
            <div style="font-size: 0.85rem; white-space: pre-wrap; color: var(--bs-body-color);"><%= item.closure_evidence %></div>
          </div>
        <% end %>
      </div>

      <%# ══════ EDIT MODE (hidden initially) ══════ %>
      <div id="edit-<%= item.id %>" style="display: none;">
        <%= form_with url: poam_document_path(@poam_document), method: :patch, local: true do |f| %>
          <%= hidden_field_tag :poam_item_id, item.id %>

          <div class="row row-cols-1 row-cols-md-2 g-3" style="margin-bottom: 0.75rem;">
            <div class="col">
              <div class="form-group" style="margin-bottom: 0;">
                <label class="fw-semibold" style="font-size: 0.82rem;">Risk Status</label>
                <%= select_tag "fields[risk_status]",
                      options_for_select(risk_status_options, item.risk_status),
                      include_blank: "— Select —",
                      class: "form-control", style: "font-size: 0.88rem;" %>
              </div>
            </div>
          </div>

          <div class="form-group" style="margin-bottom: 0.75rem;">
            <label class="fw-semibold" style="font-size: 0.82rem;">Internal Notes</label>
            <textarea name="fields[internal_notes]" class="form-control" rows="3" style="font-size: 0.88rem;" placeholder="Internal tracking notes..."><%= item.internal_notes %></textarea>
          </div>

          <div class="form-group" style="margin-bottom: 0.75rem;">
            <label class="fw-semibold" style="font-size: 0.82rem;">Closure Evidence</label>
            <textarea name="fields[closure_evidence]" class="form-control" rows="3" style="font-size: 0.88rem;" placeholder="Evidence or documentation for closure..."><%= item.closure_evidence %></textarea>
          </div>

          <div class="d-flex gap-2">
            <%= f.submit "Save Changes", class: "btn btn-success", style: "padding: 0.35rem 0.9rem; font-size: 0.82rem;" %>
            <button type="button" onclick="toggleItemEdit(<%= item.id %>)" class="btn btn-secondary" style="padding: 0.35rem 0.9rem; font-size: 0.82rem;">Cancel</button>
          </div>
        <% end %>
      </div>
    </details>
  </div>
<% end %>

<% if @items.empty? && !has_filters %>
  <div class="card text-center p-4 text-body-secondary">
    No POA&amp;M items found. <%= link_to "Add your first item", new_poam_document_poam_item_path(@poam_document) %>.
  </div>
<% elsif @items.empty? && has_filters %>
  <div class="card text-center p-4 text-body-secondary">
    No items match the current filters. <%= link_to "Clear filters", poam_document_path(@poam_document) %>.
  </div>
<% end %>

<% end %>

<%= render "shared/uuid_replaced_warning", document: @poam_document %>

<%= render "shared/oscal_metadata_section",
           document: @poam_document,
           update_path: update_metadata_poam_document_path(@poam_document),
           param_key: :poam_document,
           version_field: :poam_version %>

<%= render "shared/oscal_back_matter_section",
           document: @poam_document,
           resources_path: poam_document_back_matter_resources_path(@poam_document) %>

<script>
  function toggleDocMeta() {
    var view = document.getElementById('doc-meta-view');
    var edit = document.getElementById('doc-meta-edit');
    if (view && edit) {
      var hidden = edit.style.display === 'none';
      view.style.display = hidden ? 'none' : '';
      edit.style.display = hidden ? '' : 'none';
    }
  }

  function toggleItemEdit(itemId) {
    var details = document.getElementById('details-' + itemId);
    if (details && !details.open) details.open = true;

    var view = document.getElementById('view-' + itemId);
    var edit = document.getElementById('edit-' + itemId);
    var btn  = document.getElementById('edit-btn-' + itemId);

    var isEditing = edit.style.display !== 'none';

    view.style.display   = isEditing ? '' : 'none';
    edit.style.display   = isEditing ? 'none' : '';
    btn.textContent      = isEditing ? 'Edit' : 'Cancel';
    btn.style.background = isEditing ? '#3498db' : 'var(--bs-secondary-bg)';
    btn.style.color      = isEditing ? 'white' : 'var(--bs-secondary-color)';
  }
</script>
