<%= render "shared/section_summary", tiles: [
  [@total_count, "POA&M Documents"],
  [@items_count, "Total Items"],
  [@completed_count, "Completed"]
] %>

<% if @poam_documents.any? { |d| d.processing? || d.pending? } %>
  <div data-controller="auto-refresh" data-auto-refresh-interval-value="10000" hidden></div>
<% end %>

<div class="card" style="overflow-x: auto;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Plan of Action &amp; Milestones</h2>
    <div class="d-flex gap-2">
      <%= link_to "Create New", new_poam_document_path, class: "btn btn-primary", style: "padding: 0.5rem 1rem; font-size: 0.875rem;" %>
      <%= link_to "Upload File", new_poam_document_path(anchor: "upload-poam"), class: "btn btn-success" %>
    </div>
  </div>

  <%= render "shared/index_search", placeholder: "Search POA&Ms…" %>

  <% if @poam_documents.any? %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th style="white-space: nowrap;">Name</th>
          <th style="white-space: nowrap;">Version</th>
          <th style="white-space: nowrap;">Status</th>
          <th style="white-space: nowrap;">Items</th>
          <th style="white-space: nowrap;">Entities</th>
          <th style="white-space: nowrap;">Created</th>
          <th style="white-space: nowrap;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @poam_documents.each do |doc| %>
          <tr>
            <td><strong><%= link_to doc.name, poam_document_path(doc), class: "text-primary", style: "text-decoration: none;" %></strong></td>
            <td class="small text-body-secondary"><%= doc.poam_version.presence || "—" %></td>
            <td style="white-space: nowrap;">
              <% if doc.processing? || doc.pending? || doc.failed? %>
                <span class="<%= doc.completed? ? 'badge-ok' : doc.failed? ? 'badge-fail' : 'badge-warn' %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.85rem;">
                  <%= doc.status %>
                </span>
                <% if doc.processing? && doc.metadata_extra&.dig("processing_message").present? %>
                  <br><span class="text-body-secondary" style="font-size: 0.72rem; white-space: normal;"><%= doc.metadata_extra["processing_message"] %></span>
                <% end %>
              <% else %>
                <span class="<%= doc.lifecycle_badge_class %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.85rem;">
                  <%= doc.lifecycle_label %>
                </span>
              <% end %>
            </td>
            <td><%= doc.poam_items.count %></td>
            <td style="font-size: 0.8rem;">
              <% if doc.completed? %>
                <span class="text-primary" title="Risks"><%= doc.poam_risks.count %>R</span>
                <span class="sparc-heading-enterprise" title="Observations"><%= doc.poam_observations.count %>O</span>
                <span class="sparc-heading-assessment" title="Findings"><%= doc.poam_findings.count %>F</span>
              <% else %>
                <span class="text-body-tertiary">—</span>
              <% end %>
            </td>
            <td style="white-space: nowrap;"><%= doc.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td>
              <div class="d-flex flex-wrap gap-1" style="max-width: 280px;">
                <%= link_to "View", poam_document_path(doc), class: "btn btn-primary btn-sm", style: "padding: 0.25rem 0.6rem; font-size: 0.78rem;" %>
                <% if doc.completed? %>
                  <%# #451 A1: shared partial routes dropdown clicks through the
                      Stimulus modal that surfaces specific validation errors. %>
                  <%= render "shared/oscal_export_dropdown",
                        validate_path: validate_oscal_export_poam_document_path(doc),
                        download_json_path: download_oscal_validated_poam_document_path(doc),
                        download_yaml_path: download_yaml_poam_document_path(doc),
                        download_xml_path: download_xml_poam_document_path(doc),
                        fallback_json_path: download_oscal_unvalidated_poam_document_path(doc),
                        document_type: "POAM" %>
                <% end %>
                <%= button_to "Delete", poam_document_path(doc), method: :delete,
                      class: "btn btn-danger btn-sm",
                      style: "padding: 0.25rem 0.6rem; font-size: 0.78rem;",
                      form: { data: { turbo_confirm: "Delete '#{doc.name}'? This cannot be undone." }, style: "display: inline;" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center p-4 text-body-secondary">No POA&M documents found. Upload your first OSCAL POA&M to get started.</p>
  <% end %>
</div>
