<%= form_with(model: [:admin, organization], class: "needs-validation") do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label fw-semibold" %>
    <%= f.text_field :name, class: "form-control", required: true, placeholder: "Organization name" %>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: "form-label fw-semibold" %>
    <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Brief description of the organization" %>
  </div>

  <div class="mb-3">
    <%= f.label :address, class: "form-label fw-semibold" %>
    <%= f.text_area :address, class: "form-control", rows: 2, placeholder: "Street address, city, state, zip" %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :contact_person, class: "form-label fw-semibold" %>
      <%= f.text_field :contact_person, class: "form-control", placeholder: "Primary contact name" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= f.label :contact_email, class: "form-label fw-semibold" %>
      <%= f.email_field :contact_email, class: "form-control", placeholder: "contact@example.gov" %>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center">
    <%= f.submit organization.persisted? ? "Save Changes" : "Create Organization", class: "btn btn-primary fw-semibold" %>
    <% if organization.persisted? %>
      <%= link_to "Cancel", admin_organization_path(organization), class: "btn btn-outline-secondary" %>
    <% else %>
      <%= link_to "Cancel", admin_organizations_path, class: "btn btn-outline-secondary" %>
    <% end %>
  </div>
<% end %>
