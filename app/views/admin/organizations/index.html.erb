<div class="d-flex justify-content-between align-items-center my-4">
  <h1 class="h3 fw-bold mb-0">Organization Management</h1>
  <div class="d-flex align-items-center gap-2">
    <span class="badge text-bg-secondary"><%= @pagy.count %> organizations</span>
    <%= link_to "New Organization", new_admin_organization_path, class: "btn btn-sm btn-success fw-semibold" %>
  </div>
</div>

<%# ── Search / Filter ──────────────────────────────────── %>
<div class="card mb-3">
  <div class="card-body py-2">
    <%= form_tag admin_organizations_path, method: :get, class: "row g-2 align-items-end" do %>
      <div class="col-md-5">
        <input type="text" name="q" value="<%= params[:q] %>" class="form-control form-control-sm"
               placeholder="Search by name, contact, or email...">
      </div>
      <div class="col-md-3">
        <select name="status" aria-label="Filter by status" class="form-select form-select-sm">
          <option value="">All statuses</option>
          <% %w[active inactive].each do |s| %>
            <option value="<%= s %>" <%= "selected" if params[:status] == s %>><%= s.capitalize %></option>
          <% end %>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-sm btn-primary w-100">Search</button>
      </div>
      <div class="col-md-2">
        <%= link_to "Clear", admin_organizations_path, class: "btn btn-sm btn-outline-secondary w-100" %>
      </div>
    <% end %>
  </div>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead>
        <tr>
          <th>Name</th>
          <th>Contact</th>
          <th>Members</th>
          <th>Auth Boundaries</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @organizations.each do |org| %>
          <tr>
            <td class="fw-semibold"><%= org.name %></td>
            <td class="small text-body-secondary">
              <% if org.contact_person.present? || org.contact_email.present? %>
                <%= org.contact_person %><%= " — #{org.contact_email}" if org.contact_email.present? %>
              <% else %>
                —
              <% end %>
            </td>
            <td><%= org.organization_memberships.count %></td>
            <td><%= org.authorization_boundaries.count %></td>
            <td>
              <% if org.active? %>
                <span class="badge text-bg-success">Active</span>
              <% else %>
                <span class="badge text-bg-secondary">Inactive</span>
              <% end %>
            </td>
            <td class="text-end">
              <%= link_to "Manage", admin_organization_path(org), class: "btn btn-sm btn-outline-primary" %>
            </td>
          </tr>
        <% end %>
        <% if @organizations.empty? %>
          <tr><td colspan="6" class="text-center text-body-secondary small py-3">No organizations found.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%# ── Pagination ──────────────────────────────────────── %>
<% if @pagy.pages > 1 %>
  <div class="mt-3 text-center">
    <%== @pagy.series_nav %>
  </div>
<% end %>
