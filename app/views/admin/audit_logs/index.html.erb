<div class="d-flex justify-content-between align-items-center my-4">
  <h1 class="h3 fw-bold mb-0">Audit Log</h1>
  <div class="d-flex align-items-center gap-2">
    <span class="badge text-bg-secondary"><%= @pagy.count %> events</span>
    <%= link_to "Export CSV", admin_audit_logs_path(request.query_parameters.merge(format: :csv)),
        class: "btn btn-sm btn-outline-success" %>
  </div>
</div>

<%# ── Filters ──────────────────────────────────────────── %>
<div class="card mb-3">
  <div class="card-body py-2">
    <%= form_tag admin_audit_logs_path, method: :get do %>
      <div class="row g-2 align-items-end">
        <div class="col-md-3">
          <label for="audit_search" class="form-label small fw-semibold mb-1">Search</label>
          <input type="text" id="audit_search" name="q" value="<%= params[:q] %>" class="form-control form-control-sm"
                 placeholder="Search actions or metadata...">
        </div>
        <div class="col-md-2">
          <label for="filter_user_id" class="form-label small fw-semibold mb-1">User</label>
          <select id="filter_user_id" name="user_id" class="form-select form-select-sm">
            <option value="">All users</option>
            <% @users.each do |u| %>
              <option value="<%= u.id %>" <%= "selected" if params[:user_id].to_s == u.id.to_s %>><%= u.email %></option>
            <% end %>
          </select>
        </div>
        <div class="col-md-2">
          <label for="filter_category" class="form-label small fw-semibold mb-1">Category</label>
          <select id="filter_category" name="category" class="form-select form-select-sm">
            <option value="">All categories</option>
            <% @categories.each do |cat| %>
              <option value="<%= cat %>" <%= "selected" if params[:category] == cat %>><%= cat %></option>
            <% end %>
          </select>
        </div>
        <div class="col-md-2">
          <label for="filter_subject_type" class="form-label small fw-semibold mb-1">Resource Type</label>
          <select id="filter_subject_type" name="subject_type" class="form-select form-select-sm">
            <option value="">All types</option>
            <% @subject_types.each do |st| %>
              <option value="<%= st %>" <%= "selected" if params[:subject_type] == st %>><%= st %></option>
            <% end %>
          </select>
        </div>
        <div class="col-md-3">
          <span class="form-label small fw-semibold mb-1 d-block">Date Range</span>
          <div class="input-group input-group-sm">
            <input type="date" name="start_date" value="<%= params[:start_date] %>"
                   aria-label="Start date" class="form-control form-control-sm" placeholder="From">
            <input type="date" name="end_date" value="<%= params[:end_date] %>"
                   aria-label="End date" class="form-control form-control-sm" placeholder="To">
          </div>
        </div>
      </div>
      <div class="row g-2 mt-1">
        <div class="col-md-2">
          <button type="submit" class="btn btn-sm btn-primary w-100">Filter</button>
        </div>
        <div class="col-md-2">
          <%= link_to "Clear", admin_audit_logs_path, class: "btn btn-sm btn-outline-secondary w-100" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%# ── Results Table ────────────────────────────────────── %>
<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead>
        <tr>
          <th>Time</th>
          <th>User</th>
          <th>Action</th>
          <th>Category</th>
          <th>Subject</th>
          <th>IP Address</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @audit_events.each do |event| %>
          <tr>
            <td class="small text-nowrap"><%= event.created_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
            <td class="small">
              <% if event.user %>
                <%= link_to event.user.email, admin_user_path(event.user), class: "text-decoration-none" %>
              <% else %>
                <span class="text-body-secondary">(system)</span>
              <% end %>
            </td>
            <td>
              <% badge_class = case event.action
                 when /failure/ then "text-bg-danger"
                 when /deleted/ then "text-bg-warning"
                 when /created|imported/ then "text-bg-success"
                 when /exported|copied/ then "text-bg-info"
                 when /published/ then "text-bg-primary"
                 else "text-bg-secondary"
                 end %>
              <span class="badge <%= badge_class %>"><%= event.action.humanize %></span>
            </td>
            <td class="small text-body-secondary"><%= event.category %></td>
            <td class="small">
              <% if event.subject_type.present? %>
                <span class="text-body-secondary"><%= event.subject_type.underscore.humanize %></span>
                <span class="text-body-tertiary">#<%= event.subject_id %></span>
              <% else %>
                <span class="text-body-tertiary">&mdash;</span>
              <% end %>
            </td>
            <td class="small text-body-secondary"><%= event.ip_address || "&mdash;".html_safe %></td>
            <td>
              <%= link_to "Details", admin_audit_log_path(event), class: "btn btn-sm btn-outline-primary" %>
            </td>
          </tr>
        <% end %>
        <% if @audit_events.empty? %>
          <tr>
            <td colspan="7" class="text-center text-body-secondary small py-4">
              No audit events found matching your filters.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%# ── Pagination ──────────────────────────────────────── %>
<% if @pagy.pages > 1 %>
  <div class="mt-3 text-center">
    <%== @pagy.series_nav %>
  </div>
<% end %>
