<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2>Service Accounts</h2>
      <p class="text-muted mb-0">API-only accounts for pipelines, CI/CD, and integrations</p>
    </div>
    <%= link_to new_admin_service_account_path, class: "btn btn-success" do %>
      <i class="bi bi-plus-circle"></i> New Service Account
    <% end %>
  </div>

  <% if params[:q].present? %>
    <div class="mb-3">
      <span class="text-muted">Showing results for "<%= params[:q] %>"</span>
      <%= link_to "Clear", admin_service_accounts_path, class: "ms-2 text-decoration-none" %>
    </div>
  <% end %>

  <%= form_tag admin_service_accounts_path, method: :get, class: "mb-4" do %>
    <div class="input-group" style="max-width: 400px;">
      <%= text_field_tag :q, params[:q], class: "form-control", placeholder: "Search by name or email..." %>
      <button type="submit" class="btn btn-outline-secondary">Search</button>
    </div>
  <% end %>

  <div class="card sparc-card">
    <div class="table-responsive">
      <table class="table tabletable-hover mb-0">
        <thead>
          <tr>
            <th>Name</th>
            <th>Owner</th>
            <th>Status</th>
            <th>Token Status</th>
            <th>Last Used</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @service_accounts.each do |sa| %>
            <tr>
              <td>
                <%= link_to sa.display_label, admin_service_account_path(sa), class: "text-decoration-none" %>
                <br><small class="text-muted"><%= sa.email %></small>
              </td>
              <td><%= sa.owner&.display_label || "—" %></td>
              <td>
                <% if sa.disabled? %>
                  <span class="badge bg-danger">Disabled</span>
                <% elsif sa.active? %>
                  <span class="badge bg-success">Active</span>
                <% else %>
                  <span class="badge bg-warning"><%= sa.status.titleize %></span>
                <% end %>
              </td>
              <td>
                <% active_token = sa.api_tokens.active.first %>
                <% if active_token %>
                  <span class="badge bg-success">Active</span>
                  <% if active_token.expires_at %>
                    <br><small class="text-muted">Expires <%= distance_of_time_in_words_to_now(active_token.expires_at) %></small>
                  <% end %>
                <% else %>
                  <span class="badge bg-secondary">No active token</span>
                <% end %>
              </td>
              <td>
                <% last_token = sa.api_tokens.order(last_used_at: :desc).first %>
                <% if last_token&.last_used_at %>
                  <%= time_ago_in_words(last_token.last_used_at) %> ago
                <% else %>
                  Never
                <% end %>
              </td>
              <td>
                <%= link_to "View", admin_service_account_path(sa), class: "btn btn-sm btn-primary" %>
              </td>
            </tr>
          <% end %>
          <% if @service_accounts.empty? %>
            <tr><td colspan="6" class="text-center text-muted py-4">No service accounts found.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
