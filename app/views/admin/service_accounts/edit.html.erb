<div class="container-fluid py-4" style="max-width: 700px;">
  <h2>Edit Service Account</h2>
  <p class="text-muted"><%= @service_account.display_label %> (<%= @service_account.email %>)</p>

  <%= form_with(model: @service_account, url: admin_service_account_path(@service_account), method: :patch, class: "mt-4") do |f| %>
    <% if @service_account.errors.any? %>
      <div class="alert alert-danger">
        <h6>Please fix the following errors:</h6>
        <ul class="mb-0">
          <% @service_account.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="card sparc-card mb-4">
      <div class="card-header"><h5 class="mb-0">Account Details</h5></div>
      <div class="card-body">
        <div class="mb-3">
          <%= f.label :display_name, "Name", class: "form-label" %>
          <%= f.text_field :display_name, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :owner_id, "Owner", class: "form-label" %>
          <%= f.select :owner_id, @human_users.map { |u| [u.display_label, u.id] },
              { prompt: "Select owner..." }, class: "form-select", required: true %>
          <div class="form-text">Human user accountable for this service account.</div>
        </div>
      </div>
    </div>

    <div class="d-flex gap-2">
      <%= f.submit "Update Service Account", class: "btn btn-primary" %>
      <%= link_to "Cancel", admin_service_account_path(@service_account), class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>
