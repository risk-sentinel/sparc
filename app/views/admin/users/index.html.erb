<div class="d-flex justify-content-between align-items-center my-4">
  <h1 class="h3 fw-bold mb-0">User Management</h1>
  <div class="d-flex align-items-center gap-2">
    <span class="badge text-bg-secondary"><%= @pagy.count %> users</span>
    <%= link_to "+ New User", new_admin_user_path, class: "btn btn-sm btn-primary" %>
  </div>
</div>

<%# ── Search / Filter ──────────────────────────────────── %>
<div class="card mb-3">
  <div class="card-body py-2">
    <%= form_tag admin_users_path, method: :get, class: "row g-2 align-items-end" do %>
      <div class="col-md-5">
        <input type="text" name="q" value="<%= params[:q] %>" class="form-control form-control-sm"
               aria-label="Search users by email or name"
               placeholder="Search by email or name...">
      </div>
      <div class="col-md-3">
        <select name="status" aria-label="Filter by status" class="form-select form-select-sm">
          <option value="">All statuses</option>
          <% %w[active suspended deactivated].each do |s| %>
            <option value="<%= s %>" <%= "selected" if params[:status] == s %>><%= s.capitalize %></option>
          <% end %>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-sm btn-primary w-100">Search</button>
      </div>
      <div class="col-md-2">
        <%= link_to "Clear", admin_users_path, class: "btn btn-sm btn-outline-secondary w-100" %>
      </div>
    <% end %>
  </div>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead>
        <tr>
          <th>Email</th>
          <th>Name</th>
          <th>Status</th>
          <th>Admin</th>
          <th>Roles</th>
          <th>Sign-ins</th>
          <th>Last Active</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= user.email %></td>
            <td><%= user.display_label %></td>
            <td>
              <% case user.status %>
              <% when "active" %>
                <span class="badge text-bg-success">Active</span>
              <% when "suspended" %>
                <span class="badge text-bg-warning">Suspended</span>
              <% when "deactivated" %>
                <span class="badge text-bg-secondary">Deactivated</span>
              <% end %>
            </td>
            <td>
              <% if user.admin? %>
                <span class="badge text-bg-danger">Admin</span>
              <% end %>
            </td>
            <td>
              <% user.roles.each do |role| %>
                <span class="badge text-bg-info"><%= role.display_name %></span>
              <% end %>
            </td>
            <td><%= user.sign_in_count %></td>
            <td><%= user.last_sign_in_at&.strftime("%Y-%m-%d %H:%M") || "Never" %></td>
            <td>
              <%= link_to "View", admin_user_path(user), class: "btn btn-sm btn-outline-primary" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%# ── Pagination ──────────────────────────────────────── %>
<% if @pagy.pages > 1 %>
  <div class="mt-3 text-center">
    <%== @pagy.series_nav %>
  </div>
<% end %>
