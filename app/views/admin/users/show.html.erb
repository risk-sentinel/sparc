<div class="my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold mb-0"><%= @user.display_label %></h1>
    <div class="d-flex gap-2">
      <%= link_to "Edit", edit_admin_user_path(@user), class: "btn btn-sm btn-outline-primary" %>
      <% if @user.active? && @user != current_user %>
        <%= button_to "Suspend", suspend_admin_user_path(@user), method: :patch,
              class: "btn btn-sm btn-outline-warning",
              data: { turbo_confirm: "Suspend #{@user.email}?" } %>
        <%= button_to "Deactivate", deactivate_admin_user_path(@user), method: :patch,
              class: "btn btn-sm btn-outline-danger",
              data: { turbo_confirm: "Deactivate #{@user.email}? This will soft-delete the account." } %>
      <% elsif @user.suspended? %>
        <%= button_to "Reactivate", reactivate_admin_user_path(@user), method: :patch,
              class: "btn btn-sm btn-outline-success" %>
        <%= button_to "Deactivate", deactivate_admin_user_path(@user), method: :patch,
              class: "btn btn-sm btn-outline-danger",
              data: { turbo_confirm: "Deactivate #{@user.email}? This will soft-delete the account." } %>
      <% elsif @user.deactivated? %>
        <%= form_with url: reactivate_admin_user_path(@user), method: :patch, class: "d-inline" do |f| %>
          <div class="d-inline-flex align-items-center gap-2">
            <div class="form-check form-check-inline mb-0">
              <%= f.check_box :force_password_reset, { class: "form-check-input", id: "force_pw_reset" }, "1", "0" %>
              <label class="form-check-label small" for="force_pw_reset">Force password reset</label>
            </div>
            <%= f.submit "Reactivate", class: "btn btn-sm btn-outline-success" %>
          </div>
        <% end %>
      <% end %>
      <% if SparcConfig.fido2_enabled? && @user.webauthn_registered? %>
        <%= button_to "Reset security keys", reset_security_keys_admin_user_path(@user), method: :delete,
              class: "btn btn-sm btn-outline-danger",
              data: { turbo_confirm: "Remove all of #{@user.email}'s security keys? They will need to re-enroll to sign in with a key." } %>
      <% end %>
      <%= link_to "Back to Users", admin_users_path, class: "btn btn-sm btn-outline-secondary" %>
    </div>
  </div>

  <div class="row g-4">
    <%# ── User Details ──────────────────────────────────── %>
    <div class="col-lg-6">
      <div class="card">
        <div class="card-header fw-semibold">Account Details</div>
        <div class="card-body">
          <% status_badge = case @user.status
               when "active" then "success"
               when "suspended" then "warning"
               when "deactivated" then "danger"
               else "secondary"
               end %>
          <dl class="row mb-0">
            <dt class="col-sm-4">UUID</dt>
            <dd class="col-sm-8"><code class="small"><%= @user.uuid %></code></dd>
            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8"><%= @user.email %></dd>
            <dt class="col-sm-4">Display Name</dt>
            <dd class="col-sm-8"><%= @user.display_name || "\u2014" %></dd>
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8"><%= [@user.first_name, @user.last_name].compact_blank.join(" ").presence || "\u2014" %></dd>
            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8"><span class="badge text-bg-<%= status_badge %>"><%= @user.status.capitalize %></span></dd>
            <dt class="col-sm-4">Admin</dt>
            <dd class="col-sm-8"><%= @user.admin? ? "Yes" : "No" %></dd>
            <dt class="col-sm-4">Sign-in Count</dt>
            <dd class="col-sm-8"><%= @user.sign_in_count %></dd>
            <dt class="col-sm-4">Last Sign-in</dt>
            <dd class="col-sm-8"><%= @user.last_sign_in_at&.strftime("%Y-%m-%d %H:%M UTC") || "Never" %></dd>
            <dt class="col-sm-4">Last IP</dt>
            <dd class="col-sm-8"><%= @user.last_sign_in_ip || "\u2014" %></dd>
            <dt class="col-sm-4">Password Changed</dt>
            <dd class="col-sm-8"><%= @user.password_changed_at&.strftime("%Y-%m-%d %H:%M UTC") || "Never" %></dd>
            <% if @user.deactivated? %>
              <dt class="col-sm-4">Deactivated At</dt>
              <dd class="col-sm-8"><%= @user.deleted_at&.strftime("%Y-%m-%d %H:%M UTC") || "\u2014" %></dd>
              <dt class="col-sm-4">Inactive Reason</dt>
              <dd class="col-sm-8"><span class="badge text-bg-secondary"><%= @user.inactive_reason&.titleize || "\u2014" %></span></dd>
            <% end %>
            <dt class="col-sm-4">Created</dt>
            <dd class="col-sm-8"><%= @user.created_at.strftime("%Y-%m-%d %H:%M UTC") %></dd>
          </dl>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <%# ── Instance Roles ──────────────────────────────── %>
      <div class="card mb-4">
        <div class="card-header fw-semibold">Instance Roles</div>
        <div class="card-body">
          <% if @instance_roles.any? %>
            <% @instance_roles.each do |ur| %>
              <span class="badge text-bg-warning me-1"><%= ur.role.display_name %></span>
            <% end %>
          <% else %>
            <p class="text-body-secondary small mb-0">No instance roles assigned.</p>
          <% end %>
        </div>
      </div>

      <%# ── Authorization Boundary Roles ───────────────────────────────── %>
      <div class="card mb-4">
        <div class="card-header fw-semibold">Authorization Boundary Roles</div>
        <div class="card-body">
          <% if @authorization_boundary_roles.any? %>
            <% @authorization_boundary_roles.group_by(&:authorization_boundary).each do |authorization_boundary, urs| %>
              <div class="mb-2">
                <strong><%= authorization_boundary&.name || "Unknown Authorization Boundary" %></strong>
                <% urs.each do |ur| %>
                  <span class="badge text-bg-info ms-1"><%= ur.role.display_name %></span>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <p class="text-body-secondary small mb-0">No authorization boundary roles assigned.</p>
          <% end %>
        </div>
      </div>

      <%# ── Linked Identities ────────────────────────────── %>
      <div class="card">
        <div class="card-header fw-semibold">Linked Identities</div>
        <div class="card-body">
          <% if @identities.any? %>
            <% @identities.each do |id| %>
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span><span class="badge text-bg-dark"><%= id.provider.titleize %></span> <small class="text-body-secondary"><%= id.uid %></small></span>
                <small class="text-body-tertiary"><%= id.last_used_at&.strftime("%Y-%m-%d") || "Never used" %></small>
              </div>
            <% end %>
          <% else %>
            <p class="text-body-secondary small mb-0">No linked providers.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── API Tokens ────────────────────────────────────────── %>
  <div class="card mt-4">
    <div class="card-header fw-semibold">API Tokens</div>
    <div class="card-body">
      <% if flash[:api_token].present? %>
        <div class="alert alert-success" role="alert">
          <strong>New API Token:</strong>
          <code class="user-select-all"><%= flash[:api_token] %></code>
          <br><small>Copy this token now — it will not be shown again.</small>
        </div>
      <% end %>

      <div class="table-responsive">
        <table class="table table-sm mb-0 align-middle">
          <thead>
            <tr>
              <th>Name</th>
              <th>Created</th>
              <th>Last Used</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @user.api_tokens.order(created_at: :desc).each do |token| %>
              <tr>
                <td><%= token.name %></td>
                <td class="small"><%= token.created_at.strftime("%Y-%m-%d %H:%M UTC") %></td>
                <td class="small"><%= token.last_used_at&.strftime("%Y-%m-%d %H:%M UTC") || "Never" %></td>
                <td>
                  <%= button_to "Revoke", admin_user_api_token_path(@user, token),
                        method: :delete,
                        class: "btn btn-sm btn-outline-danger",
                        data: { turbo_confirm: "Revoke token '#{token.name}'?" } %>
                </td>
              </tr>
            <% end %>
            <% if @user.api_tokens.empty? %>
              <tr><td colspan="4" class="text-center text-body-secondary small py-3">No API tokens.</td></tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <hr>

      <%= form_with url: admin_user_api_tokens_path(@user), method: :post, class: "row g-2 align-items-end" do |f| %>
        <div class="col-auto">
          <%= f.label :name, "Token Name", class: "form-label small" %>
          <%= f.text_field :name, class: "form-control form-control-sm", placeholder: "e.g. CI Pipeline",
                name: "api_token[name]" %>
        </div>
        <div class="col-auto">
          <%= f.label :expires_in_days, "Expires", class: "form-label small" %>
          <%= f.select :expires_in_days, [["30 days", 30], ["60 days", 60], ["90 days", 90], ["Never", 0]],
                {}, { class: "form-select form-select-sm", name: "api_token[expires_in_days]" } %>
        </div>
        <div class="col-auto">
          <%= f.submit "Generate Token", class: "btn btn-sm btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Audit Events ──────────────────────────────────────── %>
  <div class="card mt-4">
    <div class="card-header fw-semibold">Recent Activity</div>
    <div class="table-responsive">
      <table class="table table-sm mb-0 align-middle">
        <thead>
          <tr>
            <th>Time</th>
            <th>Action</th>
            <th>Provider</th>
            <th>IP Address</th>
          </tr>
        </thead>
        <tbody>
          <% @audit_events.each do |event| %>
            <tr>
              <td class="small"><%= event.created_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
              <td><span class="badge text-bg-<%= event.action.include?('failure') ? 'danger' : 'secondary' %>"><%= event.action.humanize %></span></td>
              <td><%= event.provider || "\u2014" %></td>
              <td class="small text-body-secondary"><%= event.ip_address || "\u2014" %></td>
            </tr>
          <% end %>
          <% if @audit_events.empty? %>
            <tr><td colspan="4" class="text-center text-body-secondary small py-3">No activity recorded.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
