<%= form_with model: catalog_control.new_record? ? [control_family, catalog_control] : catalog_control, local: true do |f| %>
  <% if catalog_control.errors.any? %>
    <div class="flash error mb-4">
      <strong><%= pluralize(catalog_control.errors.count, "error") %>:</strong>
      <ul style="margin-top: 0.5rem; margin-left: 1.5rem;">
        <% catalog_control.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ── Identity row ── %>
  <div class="row g-3">
    <div class="col-auto" style="width: 160px;">
      <div class="form-group">
        <%= f.label :control_id, "Control ID *" %>
        <%= f.text_field :control_id, class: "form-control fw-semibold", placeholder: "e.g. AC-01", style: "font-family: monospace;" %>
      </div>
    </div>
    <div class="col">
      <div class="form-group">
        <%= f.label :title %>
        <%= f.text_field :title, class: "form-control", placeholder: "Control title..." %>
      </div>
    </div>
  </div>

  <%# ── Statement (primary guidance_data field) ── %>
  <div class="form-group">
    <label for="catalog_control_guidance_data_statement" class="fw-semibold">Statement</label>
    <p class="text-body-tertiary" style="font-size: 0.82rem; margin: 0.15rem 0 0.4rem;">
      The formal control requirement text. For parent controls, this is the lead-in sentence;
      for sub-parts (AC-01a, AC-01a.1 …) this is the specific requirement prose.
    </p>
    <%= text_area_tag "catalog_control[guidance_data][statement]",
        (catalog_control.guidance_data || {})["statement"],
        id: "catalog_control_guidance_data_statement",
        class: "form-control", rows: 5,
        placeholder: "Enter the control statement text..." %>
  </div>

  <%# ── Priority + Baseline ── %>
  <div class="row row-cols-1 row-cols-md-2 g-3">
    <div class="col">
      <div class="form-group">
        <%= f.label :priority %>
        <%= f.select :priority, [["—", ""], ["P0", "P0"], ["P1", "P1"], ["P2", "P2"], ["P3", "P3"]],
            { selected: catalog_control.priority },
            class: "form-control" %>
      </div>
    </div>
    <div class="col">
      <div class="form-group">
        <label class="fw-semibold">Baseline Impact</label>
        <div class="d-flex gap-3 mt-1" style="padding-top: 0.35rem;">
          <% CatalogControl::BASELINE_LEVELS.each do |level| %>
            <label class="form-check mb-0">
              <input type="checkbox" class="form-check-input" name="catalog_control[baseline_levels][]"
                     value="<%= level %>"
                     <%= "checked" if catalog_control.has_baseline_level?(level) %>>
              <span class="form-check-label"><%= level %></span>
            </label>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── Parameters (editable labels, populated from OSCAL import) ── %>
  <% if catalog_control.params_present? %>
    <details class="border rounded" style="margin-bottom: 1.25rem; padding: 0;" open>
      <summary class="fw-semibold small bg-body-secondary rounded d-flex align-items-center gap-2" style="padding: 0.65rem 1rem; cursor: pointer; list-style: none;">
        <span>&#9656;</span> OSCAL Parameters
        <span class="badge rounded-pill text-bg-info" style="font-size: 0.7rem; font-weight: 500;">
          <%= catalog_control.params_list.size %> param<%= catalog_control.params_list.size == 1 ? "" : "s" %>
        </span>
      </summary>
      <div class="p-3">
        <p class="text-body-tertiary" style="font-size: 0.78rem; margin-bottom: 0.75rem;">
          Parameters referenced by the control statement via <code>{{ insert: param, &lt;id&gt; }}</code>.
          Edit the <strong>Label</strong> to customize organization-specific values.
          Param IDs and structural constraints are read-only.
        </p>
        <table class="table table-sm mb-0" style="font-size: 0.82rem;">
          <thead>
            <tr>
              <th style="width: 22%; padding: 0.3rem 0.5rem;">Param ID</th>
              <th style="width: 40%; padding: 0.3rem 0.5rem;">Label</th>
              <th style="padding: 0.3rem 0.5rem;">Constraint / Choices</th>
            </tr>
          </thead>
          <tbody>
            <% catalog_control.params_list.each do |param| %>
              <tr>
                <td style="padding: 0.3rem 0.5rem; font-family: monospace; color: var(--bs-primary);">
                  <%= param["id"] %>
                </td>
                <td style="padding: 0.3rem 0.5rem;">
                  <%= text_field_tag "catalog_control[params_labels][#{param['id']}]",
                      param["label"],
                      class: "form-control form-control-sm",
                      style: "font-size: 0.82rem;",
                      placeholder: "Organization-defined value..." %>
                </td>
                <td style="padding: 0.3rem 0.5rem;">
                  <% if param.dig("select", "choice").present? %>
                    <span class="text-body-secondary">Select <%= param.dig("select", "how-many") || "one" %>:</span>
                    <%= param["select"]["choice"].join("; ") %>
                  <% elsif param.dig("guidelines").present? %>
                    <span class="text-body-tertiary"><%= param["guidelines"].map { |g| g["prose"] }.compact.join("; ").truncate(120) %></span>
                  <% else %>
                    <span class="text-body-tertiary">Organization-defined</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </details>
  <% end %>

  <%# ── Additional guidance fields (collapsible) ── %>
  <%
    gd = (catalog_control.guidance_data || {})
    extra_fields = [
      ["supplemental_guidance",    "Supplemental Guidance",    8, "Additional context and implementation notes from the catalog..."],
      ["related_controls",         "Related Controls",         2, "e.g. AC-02, AC-03"],
      ["implementation_guidance",  "Implementation Guidance",  4, "Guidance for implementing this control..."],
      ["check",                    "Check Procedure",          3, "How to verify this control is implemented..."],
      ["fix",                      "Fix Procedure",            3, "How to remediate failures of this control..."],
      ["nist_references",          "NIST References",          2, "e.g. NIST SP 800-53 Rev 5, Section 2.1"],
      ["org_ref",                  "Org Reference",            2, "Internal policy or procedure reference..."],
    ]
    has_extra = extra_fields.any? { |key, *| gd[key].present? }
  %>
  <details <%= "open" if has_extra %> class="border rounded" style="margin-bottom: 1.25rem; padding: 0;">
    <summary class="fw-semibold small bg-body-secondary rounded d-flex align-items-center gap-2" style="padding: 0.65rem 1rem; cursor: pointer; list-style: none;">
      <span>&#9656;</span> Additional Guidance Fields
      <% if has_extra %>
        <span class="text-body-tertiary" style="font-size: 0.75rem; font-weight: 400; margin-left: 0.25rem;">(populated)</span>
      <% end %>
    </summary>
    <div class="d-flex flex-column gap-2 p-3">
      <% extra_fields.each do |key, label, rows, placeholder| %>
        <div class="form-group" style="margin-bottom: 0;">
          <label for="catalog_control_guidance_data_<%= key %>" class="fw-semibold text-body-secondary" style="font-size: 0.88rem;">
            <%= label %>
          </label>
          <%= text_area_tag "catalog_control[guidance_data][#{key}]",
              gd[key],
              id: "catalog_control_guidance_data_#{key}",
              class: "form-control",
              rows: rows,
              style: "font-size: 0.88rem;",
              placeholder: placeholder %>
        </div>
      <% end %>
    </div>
  </details>

  <%# ── Submit ── %>
  <div class="d-flex gap-3" style="margin-top: 0.5rem;">
    <%= f.submit "Save Control", class: "btn btn-success" %>
    <%= link_to "Cancel", control_family, class: "btn btn-secondary" %>
  </div>
<% end %>
