<div class="card">
  <h2>Upload Security Assessment Results</h2>

  <%= form_with model: @sar_document, local: true, multipart: true do |f| %>
    <div class="form-group">
      <label for="sar_document_file">Select File (.xlsx, .xls, .json, .xml)</label>
      <%= f.file_field :file, accept: ".xlsx,.xls,.json,.xml", required: true %>
      <small class="text-body-secondary d-block" style="margin-top: 0.5rem;">
        Upload an Excel workbook, OSCAL Assessment Results JSON, or OSCAL Assessment Results XML file.
        Excel workbooks with multiple tabs will each be imported as a separate section.
        OSCAL files will import observations, findings, risks, and metadata.
      </small>
    </div>

    <div class="d-flex gap-3 align-items-center">
      <%= f.submit "Upload and Convert", class: "btn btn-success" %>
      <%= link_to "or Create from Wizard", wizard_sar_documents_path,
            style: "color: var(--bs-link-color); font-size: 0.9rem;" %>
      <%= link_to "Cancel", sar_documents_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<div class="card">
  <h3>Expected Excel Format</h3>
  <p class="text-body-secondary mb-3">Each worksheet tab is treated as a named section. Read-only fields are imported as-is; editable fields can be updated after upload.</p>

  <table class="table table-hover">
    <thead>
      <tr>
        <th>Column</th>
        <th>Editable</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      <tr><td><strong>#</strong></td><td>No</td><td>Row index.</td></tr>
      <tr><td><strong>Inherited</strong></td><td>No</td><td></td></tr>
      <tr><td><strong>Date</strong></td><td>Yes</td><td>Format: 23-Jan-2025. Calendar picker in UI.</td></tr>
      <tr><td><strong>Paragraph</strong></td><td>No</td><td>Links to Paragraph/ReqID in the System Security Plan.</td></tr>
      <tr><td><strong>Provided As</strong></td><td>No</td><td></td></tr>
      <tr><td><strong>Tester</strong></td><td>No</td><td></td></tr>
      <tr><td><strong>Result</strong></td><td>Yes</td><td>Pass · Failed · Null. Defaults to imported value.</td></tr>
      <tr><td><strong>Notes/Weakness</strong></td><td>Yes</td><td></td></tr>
      <tr><td><strong>Recommended Fix</strong></td><td>Yes</td><td></td></tr>
      <tr><td><strong>Subject</strong></td><td>No</td><td>Parsed for filtering: left of | = Asset/Component, right = Environment. No | = boundary-level finding.</td></tr>
      <tr><td><strong>Control Status</strong></td><td>No</td><td></td></tr>
      <tr><td><strong>Responsibility</strong></td><td>No</td><td></td></tr>
      <tr><td><strong>Test Title</strong></td><td>No</td><td></td></tr>
      <tr><td><strong>Impact Statement</strong></td><td>No</td><td></td></tr>
      <tr><td><strong>Test Text</strong></td><td>Yes</td><td>Collapsed by default.</td></tr>
      <tr><td><strong>Expected Result</strong></td><td>Yes</td><td>Collapsed by default.</td></tr>
      <tr><td><strong>Custom</strong></td><td>Yes</td><td>Collapsed by default.</td></tr>
      <tr><td><strong>Custom Name</strong></td><td>Yes</td><td>Collapsed by default.</td></tr>
      <tr><td><strong>Custom Author</strong></td><td>Yes</td><td>Collapsed by default.</td></tr>
      <tr><td><strong>Control Text</strong></td><td>No</td><td></td></tr>
      <tr><td><strong>Implementation</strong></td><td>No</td><td>Pulled from the System Security Plan.</td></tr>
      <tr><td><strong>Working Comments</strong></td><td>Yes</td><td></td></tr>
      <tr><td><strong>Working Status</strong></td><td>Yes</td><td>Final - Not Satisfied · Final Satisfied · Not Satisfied · Not Specified · Null</td></tr>
    </tbody>
  </table>
</div>
