<div class="card">
  <h2>Upload Security Assessment Results</h2>

  <%= form_with model: @sar_document, local: true, multipart: true do |f| %>
    <div class="form-group">
      <label for="sar_document_file">Select File (.xlsx, .xls, .json, .xml, .yaml, .yml)</label>
      <%= f.file_field :file, accept: ".xlsx,.xls,.json,.xml,.yaml,.yml", required: true %>
      <small class="text-body-secondary d-block" style="margin-top: 0.5rem;">
        Upload an Excel workbook, OSCAL Assessment Results JSON, XML, or YAML file.
        Excel workbooks with multiple tabs will each be imported as a separate section.
        OSCAL files will import observations, findings, risks, and metadata.
      </small>
    </div>

    <div class="d-flex gap-3 align-items-center">
      <%= f.submit "Upload and Convert", class: "btn btn-success" %>
      <%= link_to "or Create from Wizard", wizard_sar_documents_path,
            style: "color: var(--bs-link-color); font-size: 0.9rem;" %>
      <%= link_to "Cancel", sar_documents_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<div class="card">
  <h3>Import Notes</h3>
  <div class="text-body-secondary" style="font-size: 0.9rem; line-height: 1.6;">
    <p class="mb-2"><strong>Excel (.xlsx, .xls)</strong> &mdash; Workbooks must follow the expected column mapping for successful import. Each worksheet tab is treated as a named section.</p>
    <p class="mb-0"><strong>OSCAL (JSON, XML, YAML)</strong> &mdash; OSCAL Assessment Results files are auto-detected and require no column mapping.</p>
  </div>
</div>
