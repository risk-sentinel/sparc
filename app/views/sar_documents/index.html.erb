<div class="card">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Security Assessment Results</h2>
    <%= link_to "Upload New", new_sar_document_path, class: "btn btn-success" %>
  </div>

  <% if @sar_documents.any? %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Name</th>
          <th>Original Filename</th>
          <th>Version</th>
          <th>Status</th>
          <th>Controls</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @sar_documents.each do |doc| %>
          <tr>
            <td><%= doc.name %></td>
            <td><%= doc.original_filename %></td>
            <td class="text-body-secondary" style="font-size: 0.85rem;"><%= doc.sar_version.presence || "—" %></td>
            <td><span class="<%= doc.completed? ? 'badge-ok' : 'badge-warn' %> rounded fw-semibold" style="padding: 0.25rem 0.75rem;"><%= doc.status %></span></td>
            <td><%= doc.sar_controls.count %></td>
            <td><%= doc.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td>
              <%= link_to "View", sar_document_path(doc), class: "btn btn-primary", style: "padding: 0.5rem 1rem; font-size: 0.875rem;" %>
              <%= link_to "Download JSON", download_json_sar_document_path(doc), class: "btn btn-success", style: "padding: 0.5rem 1rem; font-size: 0.875rem;" %>
              <%= link_to "Delete", sar_document_path(doc), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger", style: "padding: 0.5rem 1rem; font-size: 0.875rem;" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center p-4 text-body-secondary">No Security Assessment Results found. Upload your first workbook to get started.</p>
  <% end %>
</div>