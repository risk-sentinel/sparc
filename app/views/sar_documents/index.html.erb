<%= render "shared/section_summary", tiles: [
  [@total_count, "SAR Documents"],
  [@controls_count, "Total Controls"],
  [@completed_count, "Completed"]
] %>

<% if @sar_documents.any? { |d| d.processing? || d.pending? } %>
  <meta http-equiv="refresh" content="10">
<% end %>

<div class="card">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Security Assessment Results</h2>
    <div class="d-flex gap-2">
      <%= link_to "Create from Wizard", wizard_sar_documents_path, class: "btn btn-primary", style: "padding: 0.5rem 1rem; font-size: 0.875rem;" %>
      <%= link_to "Upload New", new_sar_document_path, class: "btn btn-success" %>
    </div>
  </div>

  <% if @sar_documents.any? %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Name</th>
          <th>Source</th>
          <th>Version</th>
          <th>Status</th>
          <th>OSCAL</th>
          <th>Controls</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @sar_documents.each do |doc| %>
          <tr>
            <td><%= doc.name %></td>
            <td>
              <% source_label, source_class = case doc.creation_method
                               when "wizard" then ["Wizard", "sparc-source-wizard"]
                               when "oscal_import" then ["OSCAL", "sparc-source-oscal"]
                               else ["Excel", "sparc-source-excel"]
                               end %>
              <span class="sparc-source-badge <%= source_class %>"><%= source_label %></span>
            </td>
            <td class="text-body-secondary" style="font-size: 0.85rem;"><%= doc.sar_version.presence || "\u2014" %></td>
            <td>
              <span class="<%= doc.completed? ? 'badge-ok' : 'badge-warn' %> rounded fw-semibold" style="padding: 0.25rem 0.75rem;"><%= doc.status %></span>
              <% if doc.processing? && doc.metadata_extra&.dig("processing_message").present? %>
                <br><span class="text-body-secondary" style="font-size: 0.72rem;"><%= doc.metadata_extra["processing_message"] %></span>
              <% end %>
            </td>
            <td>
              <% if doc.enriched? %>
                <span class="sparc-oscal-enriched">Enriched</span>
              <% else %>
                <span class="sparc-oscal-basic">Basic</span>
              <% end %>
            </td>
            <td><%= doc.sar_controls.count %></td>
            <td><%= doc.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td style="white-space: nowrap;">
              <div style="display: inline-flex; gap: 0.35rem;">
                <%= link_to "View", sar_document_path(doc), class: "btn btn-primary", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;" %>
                <% unless doc.enriched? %>
                  <%= link_to "Enrich", enrich_sar_document_path(doc), class: "sparc-btn-enrich-sm" %>
                <% end %>
                <% if doc.completed? %>
                  <div class="btn-group">
                    <button type="button" class="btn btn-sm dropdown-toggle" style="background: #8e44ad; color: white;" data-bs-toggle="dropdown" aria-expanded="false">
                      Export OSCAL
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                      <li><h6 class="dropdown-header">OSCAL (validated)</h6></li>
                      <li><%= link_to "JSON", download_oscal_sar_document_path(doc), class: "dropdown-item" %></li>
                      <li><%= link_to "YAML", download_yaml_sar_document_path(doc), class: "dropdown-item" %></li>
                      <li><%= link_to "XML", download_xml_sar_document_path(doc), class: "dropdown-item" %></li>
                      <li><hr class="dropdown-divider"></li>
                      <li><%= link_to "Excel", download_excel_sar_document_path(doc), class: "dropdown-item" %></li>
                    </ul>
                  </div>
                <% end %>
                <%= button_to "Delete", sar_document_path(doc), method: :delete,
                      class: "btn btn-danger",
                      style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;",
                      form: { data: { turbo_confirm: "Delete '#{doc.name}'? This cannot be undone." }, style: "display: inline;" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center p-4 text-body-secondary">No Security Assessment Results found. Upload a workbook or create from the wizard to get started.</p>
  <% end %>
</div>
