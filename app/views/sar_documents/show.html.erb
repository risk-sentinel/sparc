<%# ── PROCESSING STATE BANNER ─────────────────────────────────────── %>
<% unless @sar_document.completed? %>
  <div class="sparc-processing-banner">
    <% if @sar_document.failed? %>
      <div class="sparc-processing-icon">&#x26A0;</div>
      <h2 class="sparc-processing-title sparc-processing-title-error">Processing Failed</h2>
      <p class="sparc-processing-text">
        <%= @sar_document.error_message.presence || "An unknown error occurred." %>
      </p>
      <div style="margin-top: 1.25rem;">
        <%= link_to "&#8592; Back to Documents".html_safe, sar_documents_path,
              class: "sparc-btn-ghost" %>
      </div>
    <% else %>
      <div style="margin-bottom: 0.75rem;">
        <span class="sparc-spinner"></span>
      </div>
      <h2 class="sparc-processing-title sparc-processing-title-pending">Processing Your Workbook</h2>
      <p class="sparc-processing-text-muted">
        <strong><%= @sar_document.original_filename %></strong> is being parsed.
        This page will automatically refresh when processing is complete.
      </p>
    <% end %>
  </div>

  <% unless @sar_document.failed? %>
    <meta http-equiv="refresh" content="5">
  <% end %>


<% else %>
<%
  total_by_status = {}
  @heatmap_statuses.each { |s| total_by_status[s] = @heatmap_families.sum { |f| @heatmap_data.dig(f, s) || 0 } }
  total_controls = total_by_status.values.sum

  # Case-insensitive matching for pass/fail variants (Pass, Passed, PASS, Failed, Fail, etc.)
  pass_count  = total_by_status.sum { |s, c| s.to_s.downcase.start_with?("pass") ? c : 0 }
  fail_count  = total_by_status.sum { |s, c| s.to_s.downcase.match?(/\A(fail|not satisfied)/) ? c : 0 }
  tested      = pass_count + fail_count
  pass_pct    = tested > 0 ? (pass_count * 100.0 / tested).round(1) : 0.0
  score_color = pass_pct >= 80 ? "#2ecc71" : pass_pct >= 50 ? "#f39c12" : "#e74c3c"

  # Field display order for the read view
  field_order = %w[
    date tester notes_weakness recommended_fix
    working_comments working_status
    provided_as inherited row_number
  ]

  # Context field names excluded from the generic field loop
  ctx_field_names = %w[control_status responsibility impact_statement control_text implementation]

  # Active filter tracking
  active_section = params[:section]
  active_family  = params[:family]
  active_status  = params[:status]
  active_asset   = params[:asset]
  active_env     = params[:environment]
  has_filters    = [active_section, active_family, active_status, active_asset, active_env].any?(&:present?)
%>

<%# ── HEADER DASHBOARD ──────────────────────────────────────────── %>
<div class="sparc-dashboard-header">

  <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap" style="gap: 1rem;">
    <div>
      <div class="sparc-header-subtitle">Security Assessment Results</div>

      <div id="doc-meta-view">
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <h2 class="sparc-header-title"><%= @sar_document.name %></h2>
          <% if @sar_document.sar_version.present? %>
            <span class="sparc-version-badge">v<%= @sar_document.sar_version %></span>
          <% end %>
          <button onclick="toggleDocMeta()" class="sparc-btn-header-edit">Edit</button>
        </div>
      </div>

      <div id="doc-meta-edit" style="display: none;">
        <%= form_with url: update_metadata_sar_document_path(@sar_document), method: :patch, local: true do |f| %>
          <div class="d-flex gap-2 align-items-center flex-wrap">
            <%= f.text_field :name, value: @sar_document.name,
                  class: "sparc-input-dark sparc-input-dark-lg" %>
            <%= f.text_field :sar_version, value: @sar_document.sar_version, placeholder: "Version",
                  class: "sparc-input-dark sparc-input-dark-sm" %>
            <%= f.submit "Save", class: "sparc-btn-save" %>
            <button type="button" onclick="toggleDocMeta()" class="sparc-btn-cancel-dark">Cancel</button>
          </div>
        <% end %>
      </div>

      <div class="sparc-header-meta">
        <%= @sar_document.original_filename %>
        &nbsp;&bull;&nbsp;
        <span class="sparc-text-success-bold"><%= @sar_document.status %></span>
        &nbsp;&bull;&nbsp; <%= @total_controls %> tests
        <% if @sections.size > 1 %>&nbsp;&bull;&nbsp; <%= @sections.size %> sections<% end %>
        <% if @assets.any? %>&nbsp;&bull;&nbsp; <%= @assets.size %> assets<% end %>
        <% if @sar_document.creation_method.present? %>
          &nbsp;&bull;&nbsp;
          <span class="sparc-creation-badge">
            <%= { "excel" => "Excel Import", "wizard" => "Wizard", "oscal_import" => "OSCAL Import" }[@sar_document.creation_method] || @sar_document.creation_method %>
          </span>
        <% end %>
        <% if @sar_document.enriched? %>
          &nbsp;
          <span class="sparc-enriched-badge">OSCAL Enriched</span>
        <% end %>
      </div>
    </div>
    <div class="d-flex flex-wrap gap-2" style="flex-shrink: 0;">
      <div class="btn-group">
        <button type="button" class="sparc-btn-oscal dropdown-toggle"
                data-bs-toggle="dropdown" aria-expanded="false">
          Export OSCAL
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li><h6 class="dropdown-header">OSCAL (validated)</h6></li>
          <li><%= link_to "JSON", download_oscal_sar_document_path(@sar_document), class: "dropdown-item" %></li>
          <li><%= link_to "YAML", download_yaml_sar_document_path(@sar_document), class: "dropdown-item" %></li>
          <li><%= link_to "XML", download_xml_sar_document_path(@sar_document), class: "dropdown-item" %></li>
          <li><hr class="dropdown-divider"></li>
          <li><%= link_to "Excel", download_excel_sar_document_path(@sar_document), class: "dropdown-item" %></li>
        </ul>
      </div>
      <% unless @sar_document.enriched? %>
        <%= link_to "&#x2728; Enrich".html_safe, enrich_sar_document_path(@sar_document),
              class: "sparc-btn-enrich" %>
      <% end %>
      <%= link_to "&#8592; Back".html_safe, sar_documents_path,
            class: "sparc-btn-ghost-muted" %>
    </div>
  </div>

  <div class="d-flex align-items-center flex-wrap" style="gap: 1.5rem;">
    <div style="text-align: center; min-width: 80px; flex-shrink: 0;">
      <div class="sparc-score" style="color: <%= score_color %>;"><%= pass_pct %>%</div>
      <div class="sparc-score-label">Pass Rate</div>
      <div class="sparc-score-detail"><%= pass_count %> / <%= tested %> tested</div>
    </div>
    <div class="sparc-divider-v"></div>
    <div class="d-flex flex-wrap" style="gap: 0.45rem; flex: 1;">
      <% total_by_status.each do |status, count| %>
        <% next if count == 0 %>
        <% chip_active = active_status == status && active_family.blank? %>
        <%= link_to sar_document_path(@sar_document, filter_params.except(:page).merge(chip_active ? { status: nil } : { status: status, family: nil })),
              class: "sparc-summary-chip#{' active' if chip_active}",
              style: "border-left: 3px solid #{sar_status_color(status)};" do %>
          <div class="sparc-chip-count"><%= count %></div>
          <div class="sparc-chip-label"><%= status %></div>
        <% end %>
      <% end %>
    </div>
  </div>

  <div style="margin-top: 1.25rem;">
    <div class="sparc-progress-bar rounded-pill">
      <% total_by_status.each do |status, count| %>
        <% next if count == 0 %>
        <div style="width: <%= (count * 100.0 / [total_controls, 1].max).round(3) %>%; background: <%= sar_status_color(status) %>;" title="<%= status %>: <%= count %>"></div>
      <% end %>
    </div>
  </div>
</div>

<%# ── ASSET / ENVIRONMENT FILTER BAR ──────────────────────────────── %>
<% if @assets.any? || @environments.any? %>
<div class="bg-body border rounded-3 d-flex flex-column gap-2 mb-3" style="padding: 0.85rem 1rem;">
  <% if @assets.any? %>
  <div class="d-flex align-items-center gap-2">
    <span style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--bs-tertiary-color); white-space: nowrap;">&#x1F4BB; Asset</span>
    <select onchange="if(this.value) window.location=this.value;"
            style="padding: 0.35rem 0.6rem; border-radius: 6px; border: 1px solid var(--bs-border-color); background: var(--bs-secondary-bg); color: var(--bs-body-color); font-size: 0.82rem; cursor: pointer; min-width: 180px; max-width: 360px;">
      <option value="<%= sar_document_path(@sar_document, filter_params.except(:page, :asset)) %>"
              <%= 'selected' if active_asset.blank? %>>All Assets (<%= @assets.size %>)</option>
      <% @assets.each do |asset| %>
        <option value="<%= sar_document_path(@sar_document, filter_params.except(:page).merge(asset: asset)) %>"
                <%= 'selected' if active_asset == asset %>><%= asset %></option>
      <% end %>
    </select>
  </div>
  <% end %>
  <% if @environments.any? %>
  <div class="d-flex align-items-center gap-2 flex-wrap">
    <span style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--bs-tertiary-color); white-space: nowrap; min-width: 6rem;">&#x1F30D; Environment</span>
    <% all_active = active_env.blank? %>
    <%= link_to "All", sar_document_path(@sar_document, filter_params.except(:page, :environment)),
          style: "padding: 0.25rem 0.7rem; border-radius: 20px; border: 1px solid var(--bs-border-color); background: #{all_active ? '#2c3e50' : 'var(--bs-secondary-bg)'}; color: #{all_active ? 'white' : 'var(--bs-body-color)'}; font-size: 0.78rem; cursor: pointer; font-weight: #{all_active ? '600' : '400'}; text-decoration: none;" %>
    <% @environments.each do |env| %>
      <% is_active = active_env == env %>
      <%= link_to env, sar_document_path(@sar_document, filter_params.except(:page).merge(is_active ? { environment: nil } : { environment: env })),
            style: "padding: 0.25rem 0.7rem; border-radius: 20px; border: 1px solid var(--bs-border-color); background: #{is_active ? '#2c3e50' : 'var(--bs-secondary-bg)'}; color: #{is_active ? 'white' : 'var(--bs-body-color)'}; font-size: 0.78rem; cursor: pointer; font-weight: #{is_active ? '600' : '400'}; text-decoration: none;" %>
    <% end %>
  </div>
  <% end %>
</div>
<% end %>

<%# ── SECTION TABS ─────────────────────────────────────────────────── %>
<% if @sections.size > 1 %>
<div class="d-flex flex-wrap gap-1 mb-3">
  <% tab_active = active_section.blank? %>
  <%= link_to "All (#{@total_controls})", sar_document_path(@sar_document, filter_params.except(:page, :section)),
        class: "sparc-pill-filter#{' active' if tab_active}" %>
  <% @sections.each do |section_name| %>
    <% is_active = active_section == section_name %>
    <%= link_to section_name, sar_document_path(@sar_document, filter_params.except(:page).merge(is_active ? { section: nil } : { section: section_name })),
          class: "sparc-pill-filter#{' active' if is_active}" %>
  <% end %>
</div>
<% end %>

<%# ── ACTIVE FILTER BANNER ──────────────────────────────────────────── %>
<% if has_filters %>
<div class="sparc-filter-banner d-flex align-items-center justify-content-between gap-2 rounded-3 mb-3">
  <span class="sparc-filter-text">
    Showing: <%= @filtered_count %> of <%= @total_controls %> controls
    <% if active_family %> &bull; Family: <strong><%= active_family %></strong><% end %>
    <% if active_status %> &bull; Status: <strong><%= active_status %></strong><% end %>
    <% if active_section %> &bull; Section: <strong><%= active_section %></strong><% end %>
    <% if active_asset %> &bull; Asset: <strong><%= active_asset %></strong><% end %>
    <% if active_env %> &bull; Env: <strong><%= active_env %></strong><% end %>
  </span>
  <%= link_to "&#x2715; Clear All".html_safe, sar_document_path(@sar_document),
        class: "sparc-btn-clear-filter" %>
</div>
<% end %>

<%# ── FAMILY RESULTS GRID ─────────────────────────────────────────── %>
<%= render "shared/heatmap",
     heatmap_data: @heatmap_data,
     heatmap_families: @heatmap_families,
     heatmap_statuses: @heatmap_statuses,
     title: "Results by Control Family",
     color_helper: :sar_status_color,
     filter_key: "status",
     link_mode: :server,
     document: @sar_document,
     path_helper: :sar_document_path,
     filter_params: filter_params,
     active_family: active_family,
     active_status: active_status,
     percentage_calc: ->(fd, _ft) {
       fp = fd.sum { |s, c| s.to_s.downcase.start_with?("pass") ? c : 0 }
       ff = fd.sum { |s, c| s.to_s.downcase.match?(/\A(fail|not satisfied)/) ? c : 0 }
       (fp * 100.0 / [fp + ff, 1].max).round
     },
     legend_items: [["Passed", "#27ae60"], ["Failed", "#e74c3c"], ["Not Satisfied", "#f39c12"], ["Not Specified", "#95a5a6"]] %>

<%# ── CONTROL CARDS (paginated) ─────────────────────────────────── %>
<div id="controlsContainer">
  <% @controls.each do |control| %>
    <%
      field_map    = control.sar_control_fields.index_by(&:field_name)
      result_val   = field_map["result"]&.field_value.presence || "(Unknown)"
      result_color = sar_status_color(result_val)
      ws_val       = field_map["working_status"]&.field_value.presence
      family_code  = control.control_family.presence || control.control_id.to_s.split("-").first.upcase
      card_asset   = control.subject_asset.to_s.strip
      card_env     = control.subject_environment.to_s.strip
      catalog_ctrl = @catalog_guidance[normalize_ctrl_id(control.control_id)]
      catalog_stmt = (catalog_ctrl&.guidance_data || {})["statement"].presence
    %>
    <div class="control-card" style="border-left: 4px solid <%= result_color %>">

      <%# ── Card header: ID, Asset/Env, Result, WS, Family | Edit ── %>
      <div class="d-flex justify-content-between align-items-start gap-3">
        <div style="min-width: 0; flex: 1;">
          <div class="d-flex align-items-center flex-wrap gap-1" style="margin-bottom: 0.2rem;">
            <span class="sparc-ctrl-id">
              <%= control.control_id.presence || "&mdash;".html_safe %>
            </span>

            <% if card_asset.present? %>
              <span class="sparc-asset-tag">
                &#x1F4BB; <%= card_asset %>
              </span>
            <% end %>
            <% if card_env.present? %>
              <span class="sparc-env-tag">
                &#x1F30D; <%= card_env %>
              </span>
            <% end %>

            <% if card_asset.present? || card_env.present? %>
              <span class="sparc-tag-separator">&#x25B6;</span>
            <% end %>

            <span class="sparc-status-pill" style="background: <%= result_color %>;">
              <%= result_val %>
            </span>

            <% if ws_val.present? %>
              <span class="sparc-tag-outline" style="background: <%= sar_status_color(ws_val) %>22; color: <%= sar_status_color(ws_val) %>; border: 1px solid <%= sar_status_color(ws_val) %>55;">
                <%= ws_val %>
              </span>
            <% end %>

            <span class="sparc-ctrl-family"><%= family_code %></span>
          </div>

          <% if control.title.present? %>
            <div class="sparc-ctrl-title"><%= control.title %></div>
          <% end %>
        </div>

        <button onclick="toggleEdit(<%= control.id %>)"
                id="edit-btn-<%= control.id %>"
                class="sparc-btn-edit">
          Edit
        </button>
      </div>

      <%# ── Card body: collapsed by default ── %>
      <details id="details-<%= control.id %>" class="card-details" style="margin-top: 0.35rem;">
        <summary class="sparc-card-detail-toggle d-flex align-items-center gap-1">
          <span class="card-arrow sparc-card-arrow">&#9658;</span>
          <span class="sparc-card-detail-separator"></span>
        </summary>

        <%# ── View mode: Assessment Context + field table ── %>
        <div id="view-<%= control.id %>" style="margin-top: 0.5rem;">
          <%
            ctx_rows = [
              ["Subject",             [card_asset, card_env].select(&:present?).join(" | ")],
              ["Control Status",      field_map["control_status"]&.field_value.to_s],
              ["Responsibility",      field_map["responsibility"]&.field_value.to_s],
              ["Impact Statement",    field_map["impact_statement"]&.field_value.to_s],
              ["Control Text",        field_map["control_text"]&.field_value.to_s],
              ["Catalog Description", catalog_stmt.to_s],
              ["SSP Implementation",  field_map["implementation"]&.field_value.to_s],
            ]
            any_ctx = ctx_rows.any? { |_, v| v.present? }
          %>

          <% if any_ctx %>
            <% ctx_filled = ctx_rows.count { |_, v| v.present? } %>
            <details class="sparc-ctx-panel">
              <summary class="sparc-ctx-header d-flex align-items-center gap-1 fw-bold">
                <span class="ctx-arrow sparc-ctx-arrow">&#9658;</span>
                Assessment Context
                <span style="font-weight: 400; text-transform: none; letter-spacing: 0;">(<%= ctx_filled %> fields)</span>
              </summary>
              <table class="sparc-field-table">
                <% ctx_rows.each do |lbl, val| %>
                  <tr>
                    <td class="sparc-field-label-padded">
                      <%= lbl %>
                    </td>
                    <td class="sparc-field-value-padded" style="color: <%= val.present? ? "var(--bs-body-color)" : "var(--bs-tertiary-color)" %>;">
                      <%= val.present? ? val : "&mdash;".html_safe %>
                    </td>
                  </tr>
                <% end %>
              </table>
            </details>
          <% end %>

          <%
            ordered_fields = field_order.map { |fn| field_map[fn] }.compact
            extra_fields   = field_map.values.reject { |f|
              f.field_name == "result" ||
              f.field_name == "working_status" ||
              ctx_field_names.include?(f.field_name) ||
              field_order.include?(f.field_name)
            }
            display_fields = ordered_fields + extra_fields
          %>
          <% if display_fields.any? %>
            <table class="sparc-field-table" style="margin-top: 0.4rem;">
              <% display_fields.each do |field| %>
                <% next if field.field_value.blank? %>
                <tr>
                  <td class="sparc-field-label">
                    <%= field.field_name.tr("_", " ") %>
                    <% if field.editable %><span class="sparc-editable-indicator">&#x270E;</span><% end %>
                  </td>
                  <td class="sparc-field-value">
                    <% if field.field_name == "working_status" %>
                      <span class="sparc-tag-outline" style="background: <%= sar_status_color(field.field_value) %>22; color: <%= sar_status_color(field.field_value) %>; border: 1px solid <%= sar_status_color(field.field_value) %>55;"><%= field.field_value %></span>
                    <% else %>
                      <%= field.field_value %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </table>
          <% end %>
        </div>

        <%# ── Edit form (toggled via JS) ── %>
        <div id="edit-<%= control.id %>" style="display: none; margin-top: 0.75rem; border-top: 1px solid var(--bs-border-color); padding-top: 0.75rem;">
          <%= form_with url: sar_document_path(@sar_document, filter_params), method: :patch, local: true do |f| %>
            <%= hidden_field_tag :sar_control_id, control.id %>

            <% if any_ctx %>
              <div class="sparc-edit-ctx-panel">
                <div class="sparc-edit-ctx-header">
                  Assessment Context
                  <span style="font-weight: 400; font-size: 0.7rem; text-transform: none; letter-spacing: 0; margin-left: 0.4rem;">(read-only reference)</span>
                </div>
                <table class="sparc-field-table">
                  <% ctx_rows.each do |lbl, val| %>
                    <tr>
                      <td class="sparc-field-label-padded">
                        <%= lbl %>
                      </td>
                      <td class="sparc-field-value-padded" style="color: <%= val.present? ? "var(--bs-secondary-color)" : "var(--bs-tertiary-color)" %>;">
                        <%= val.present? ? val : "&mdash;".html_safe %>
                      </td>
                    </tr>
                  <% end %>
                </table>
              </div>
            <% end %>

            <% SarControlField::EDITABLE_FIELDS.each do |fname| %>
              <% field = field_map[fname] %>
              <% fval  = field&.field_value.to_s %>
              <div class="form-group">
                <label class="sparc-edit-label">
                  <%= fname.tr("_", " ") %>
                  <span class="sparc-edit-editable-hint">(editable)</span>
                </label>
                <% if fname == "result" %>
                  <%= select_tag "fields[#{fname}]",
                        options_for_select(SarControlField::RESULT_VALUES, fval),
                        include_blank: "&mdash; select &mdash;".html_safe, class: "form-control",
                        style: "font-size: 0.875rem;" %>
                <% elsif fname == "working_status" %>
                  <%= select_tag "fields[#{fname}]",
                        options_for_select(SarControlField::WORKING_STATUS_VALUES, fval),
                        include_blank: "&mdash; select &mdash;".html_safe, class: "form-control",
                        style: "font-size: 0.875rem;" %>
                <% else %>
                  <%= text_area_tag "fields[#{fname}]", fval,
                        class: "form-control", rows: 3,
                        style: "font-size: 0.875rem;" %>
                <% end %>
              </div>
            <% end %>

            <% misc_ro_fields = field_map.values.reject { |f|
                 SarControlField::EDITABLE_FIELDS.include?(f.field_name) ||
                 ctx_field_names.include?(f.field_name)
               } %>
            <% if misc_ro_fields.any? %>
              <details style="margin-top: 0.5rem;">
                <summary style="font-size: 0.8rem; color: var(--bs-tertiary-color); cursor: pointer; padding: 0.35rem 0; user-select: none;">
                  Other read-only fields (<%= misc_ro_fields.count { |f| f.field_value.present? } %>)
                </summary>
                <% misc_ro_fields.each do |field| %>
                  <% next if field.field_value.blank? %>
                  <div class="form-group" style="margin-top: 0.5rem;">
                    <label class="sparc-edit-label" style="color: var(--bs-tertiary-color);">
                      <%= field.field_name.tr("_", " ") %>
                      <span class="sparc-edit-readonly-hint">(read-only)</span>
                    </label>
                    <p class="sparc-readonly-value"><%= field.field_value.presence || "&mdash;".html_safe %></p>
                  </div>
                <% end %>
              </details>
            <% end %>

            <div class="d-flex gap-2 mt-3">
              <%= f.submit "Save Changes", class: "sparc-btn-save", style: "padding: 0.5rem 1.25rem; font-size: 0.875rem;" %>
              <button type="button" onclick="toggleEdit(<%= control.id %>)"
                      style="background: var(--bs-secondary-bg); color: var(--bs-secondary-color); border: 1px solid var(--bs-border-color); border-radius: 4px; padding: 0.5rem 1rem; cursor: pointer; font-size: 0.875rem;">
                Cancel
              </button>
            </div>
          <% end %>
        </div>
      </details>

    </div><%# end .control-card %>
  <% end %>
</div>

<%# ── PAGINATION ──────────────────────────────────────────────────── %>
<% if @pagy.pages > 1 %>
<div class="mt-4 text-center">
  <%== @pagy.series_nav %>
  <div class="sparc-pagination-info">
    Showing <%= @pagy.from %>-<%= @pagy.to %> of <%= @pagy.count %> controls
  </div>
</div>
<% end %>

<%= render "shared/oscal_metadata_section",
           document: @sar_document,
           update_path: update_metadata_sar_document_path(@sar_document),
           param_key: :sar_document,
           version_field: :sar_version %>

<script>
  function toggleEdit(id) {
    // Auto-expand card details if collapsed
    var details = document.getElementById('details-' + id);
    if (details && !details.open) details.open = true;

    var view = document.getElementById('view-' + id);
    var edit = document.getElementById('edit-' + id);
    var btn  = document.getElementById('edit-btn-' + id);
    var now  = edit.style.display !== 'none';
    view.style.display   = now ? '' : 'none';
    edit.style.display   = now ? 'none' : '';
    btn.textContent      = now ? 'Edit' : 'Cancel';
    btn.style.background = now ? '#3498db' : 'var(--bs-secondary-bg)';
    btn.style.color      = now ? 'white'   : 'var(--bs-secondary-color)';
  }

  var hs = document.getElementById('heatmapSection');
  if (hs) hs.addEventListener('toggle', function() {
    document.getElementById('heatmapToggleIcon').innerHTML = this.open ? '&#9660;' : '&#9658;';
  });

  // Toggle arrow icons for card details, assessment context, and other collapsibles
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.card-details').forEach(function(det) {
      det.addEventListener('toggle', function() {
        var arrow = det.querySelector('summary .card-arrow');
        if (arrow) arrow.innerHTML = det.open ? '&#9660;' : '&#9658;';
      });
    });
    document.querySelectorAll('.control-card details').forEach(function(det) {
      det.addEventListener('toggle', function() {
        var arrow = det.querySelector('summary .ctx-arrow');
        if (arrow) arrow.innerHTML = det.open ? '&#9660;' : '&#9658;';
      });
    });
  });

  function toggleDocMeta() {
    var view = document.getElementById('doc-meta-view');
    var edit = document.getElementById('doc-meta-edit');
    var isEditing = edit.style.display !== 'none';
    view.style.display = isEditing ? '' : 'none';
    edit.style.display = isEditing ? 'none' : '';
  }
</script>

