<% if SparcConfig.any_auth_enabled? %>
  <%# ── Tab Navigation ────────────────────────────────────────────── %>
  <ul class="nav nav-tabs nav-fill mb-3" role="tablist" style="font-size: 0.85rem;">
    <% tab_index = 0 %>

    <%# Inline event-handler attributes (onclick=, onload=, etc.) are
        blocked by the v1.7.0 CSP — no 'unsafe-inline' in script-src,
        and the per-page nonce only exempts nonce-attributed script
        blocks. Click delegation happens in the nonced script block
        in the login layout, keyed off data-tab. v1.8.1 hotfix. %>
    <% if SparcConfig.enable_local_login? %>
      <li class="nav-item flex-fill" role="presentation">
        <button class="nav-link w-100 fw-semibold <%= 'active' if tab_index == 0 %>"
                data-tab="tab-local"
                type="button" role="tab">
          Local Login
        </button>
      </li>
      <% tab_index += 1 %>
    <% end %>

    <% if SparcConfig.enable_oidc? %>
      <li class="nav-item flex-fill" role="presentation">
        <button class="nav-link w-100 fw-semibold <%= 'active' if tab_index == 0 %>"
                data-tab="tab-oidc"
                type="button" role="tab">
          <%= SparcConfig.oidc_provider_title %>
        </button>
      </li>
      <% tab_index += 1 %>
    <% end %>

    <% if SparcConfig.enable_ldap? %>
      <li class="nav-item flex-fill" role="presentation">
        <button class="nav-link w-100 fw-semibold <%= 'active' if tab_index == 0 %>"
                data-tab="tab-ldap"
                type="button" role="tab">
          LDAP
        </button>
      </li>
      <% tab_index += 1 %>
    <% end %>
  </ul>

  <%# ── Tab Panels ────────────────────────────────────────────────── %>
  <% panel_index = 0 %>

  <%# ── Local Login ─────────────────────────────────────────── %>
  <% if SparcConfig.enable_local_login? %>
    <div id="tab-local" class="login-tab-panel <%= 'active' if panel_index == 0 %>">
      <%= form_tag login_path, method: :post do %>
        <div class="mb-2">
          <label for="email" class="form-label fw-semibold mb-1">Email Address</label>
          <input type="email" name="email" id="email" class="form-control form-control-sm"
                 placeholder="you@example.com" required autofocus
                 value="<%= params[:email] %>">
        </div>
        <div class="mb-2">
          <label for="password" class="form-label fw-semibold mb-1">Password</label>
          <input type="password" name="password" id="password" class="form-control form-control-sm"
                 placeholder="Enter your password" required>
        </div>
        <button type="submit" class="btn btn-primary btn-sm w-100 fw-semibold">Sign In</button>
      <% end %>

      <% if SparcConfig.enable_registration? %>
        <div class="d-flex align-items-center my-2 text-body-tertiary">
          <hr class="flex-grow-1 m-0"><span class="px-3">or</span><hr class="flex-grow-1 m-0">
        </div>
        <%= link_to "Create Account", register_path, class: "btn btn-success btn-sm w-100 fw-semibold" %>
      <% end %>
    </div>
    <% panel_index += 1 %>
  <% end %>

  <%# ── OIDC / SSO ─────────────────────────────────────────── %>
  <% if SparcConfig.enable_oidc? %>
    <div id="tab-oidc" class="login-tab-panel <%= 'active' if panel_index == 0 %>">
      <div class="text-center p-3">
        <p class="text-body-secondary mb-4 small">
          Sign in with your organization's identity provider
        </p>
        <%# POST form for CSRF safety (OmniAuth requires POST) %>
        <%= form_tag "/auth/oidc", method: :post, data: { turbo: false } do %>
          <button type="submit" class="btn btn-dark btn-sm w-100 fw-semibold">
            Sign in with <%= SparcConfig.oidc_provider_title %>
          </button>
        <% end %>
      </div>
    </div>
    <% panel_index += 1 %>
  <% end %>

  <%# ── LDAP ───────────────────────────────────────────────── %>
  <% if SparcConfig.enable_ldap? %>
    <div id="tab-ldap" class="login-tab-panel <%= 'active' if panel_index == 0 %>">
      <%= form_tag login_path, method: :post do %>
        <input type="hidden" name="auth_method" value="ldap">
        <div class="mb-2">
          <label for="ldap-username" class="form-label fw-semibold mb-1">Username</label>
          <input type="text" name="username" id="ldap-username" class="form-control form-control-sm"
                 placeholder="Enter your username" required>
        </div>
        <div class="mb-2">
          <label for="ldap-password" class="form-label fw-semibold mb-1">Password</label>
          <input type="password" name="password" id="ldap-password" class="form-control form-control-sm"
                 placeholder="Enter your password" required>
        </div>
        <button type="submit" class="btn btn-primary btn-sm w-100 fw-semibold">Sign In with LDAP</button>
      <% end %>
    </div>
    <% panel_index += 1 %>
  <% end %>

  <%# ── FIDO2 security key (passwordless — the key + PIN is the login) ── %>
  <% if SparcConfig.fido2_enabled? %>
    <div class="d-flex align-items-center my-2 text-body-tertiary">
      <hr class="flex-grow-1 m-0"><span class="px-3">or</span><hr class="flex-grow-1 m-0">
    </div>
    <div data-controller="webauthn"
         data-webauthn-auth-options-url-value="<%= webauthn_authentication_options_path %>"
         data-webauthn-auth-url-value="<%= webauthn_session_path %>">
      <button type="button" class="btn btn-outline-primary btn-sm w-100 fw-semibold"
              data-webauthn-target="submit"
              data-action="webauthn#login">
        Sign in with a security key
      </button>
      <output class="alert mt-2 small d-block" hidden data-webauthn-target="status"></output>
    </div>
  <% end %>

  <%# ── PIV / CAC smart-card (cert + PIN, validated by the gateway) ── %>
  <% if SparcConfig.enable_piv? %>
    <div class="d-flex align-items-center my-2 text-body-tertiary">
      <hr class="flex-grow-1 m-0"><span class="px-3">or</span><hr class="flex-grow-1 m-0">
    </div>
    <%= link_to "Sign in with your CAC / smart card", piv_session_path,
          class: "btn btn-outline-secondary btn-sm w-100 fw-semibold", data: { turbo: false } %>
  <% end %>

  <%# ── SSO Buttons (GitHub / GitLab) ───────────────────── %>
  <% if SparcConfig.github_enabled? || SparcConfig.gitlab_enabled? %>
    <div class="d-flex align-items-center my-2 text-body-tertiary">
      <hr class="flex-grow-1 m-0"><span class="px-3">or sign in with</span><hr class="flex-grow-1 m-0">
    </div>
    <div class="d-grid gap-2">
      <% if SparcConfig.github_enabled? %>
        <%= form_tag "/auth/github", method: :post, data: { turbo: false } do %>
          <button type="submit" class="btn btn-dark btn-sm w-100 fw-semibold">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-github me-1" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
            Sign in with GitHub
          </button>
        <% end %>
      <% end %>
      <% if SparcConfig.gitlab_enabled? %>
        <%= form_tag "/auth/gitlab", method: :post, data: { turbo: false } do %>
          <button type="submit" class="btn btn-warning btn-sm w-100 fw-semibold text-dark">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 512 512"><path d="M503.5 204.6L502.8 202.8L433.1 21C431.7 17.5 429.2 14.4 425.9 12.4C422.8 10.4 419.3 9.3 415.7 9.5C412.1 9.6 408.6 10.9 405.7 13.1C402.8 15.3 400.6 18.4 399.4 21.9L347.6 154.5H164.6L112.8 21.9C111.6 18.4 109.4 15.3 106.5 13.1C103.6 10.9 100.1 9.6 96.5 9.5C92.9 9.4 89.4 10.4 86.3 12.4C83 14.4 80.5 17.5 79.1 21L9.3 202.8L8.5 204.6C-1.5 230.8-2.7 259.6 5 286.3C12.6 313.1 29.1 336.6 51.4 353.5L51.7 353.7L52.7 354.4L163.5 437L217.9 479L251.2 504.4C254.2 506.7 257.8 508 261.5 508C265.2 508 268.8 506.7 271.8 504.4L305.1 479L359.5 437L470.5 354.4L470.6 354.3C492.9 337.4 509.4 313.8 517.1 287C524.7 260.2 523.6 231.4 513.6 205.2L503.5 204.6Z"/></svg>
            Sign in with GitLab
          </button>
        <% end %>
      <% end %>
    </div>
  <% end %>

<% else %>
  <%# ── No Auth Configured ──────────────────────────────────── %>
  <div class="text-center p-4">
    <div style="font-size: 2.5rem;" class="mb-2">&#128274;</div>
    <h3 class="mb-2">Authentication Not Configured</h3>
    <p class="text-body-secondary small">
      No authentication methods are currently enabled.
      Set one or more <code>SPARC_ENABLE_*</code> environment variables
      to activate login.
    </p>
    <p class="mt-3 small">
      See
      <a href="https://github.com/risk-sentinel/sparc/blob/main/docs/ENVIRONMENT_VARIABLES.md"
         target="_blank" rel="noopener" class="text-primary">
        docs/ENVIRONMENT_VARIABLES.md
      </a>
      for configuration details.
    </p>
  </div>
<% end %>
