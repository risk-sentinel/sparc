<% if SparcConfig.any_auth_enabled? %>
  <%# ── Tab Navigation ────────────────────────────────────────────── %>
  <ul class="nav nav-tabs mb-4" role="tablist">
    <% tab_index = 0 %>

    <% if SparcConfig.enable_local_login? %>
      <li class="nav-item flex-fill" role="presentation">
        <button class="nav-link w-100 fw-semibold <%= 'active' if tab_index == 0 %>"
                data-tab="tab-local"
                onclick="switchTab('tab-local')"
                type="button" role="tab">
          Local Login
        </button>
      </li>
      <% tab_index += 1 %>
    <% end %>

    <% if SparcConfig.enable_oidc? %>
      <li class="nav-item flex-fill" role="presentation">
        <button class="nav-link w-100 fw-semibold <%= 'active' if tab_index == 0 %>"
                data-tab="tab-oidc"
                onclick="switchTab('tab-oidc')"
                type="button" role="tab">
          <%= SparcConfig.oidc_provider_title %>
        </button>
      </li>
      <% tab_index += 1 %>
    <% end %>

    <% if SparcConfig.enable_ldap? %>
      <li class="nav-item flex-fill" role="presentation">
        <button class="nav-link w-100 fw-semibold <%= 'active' if tab_index == 0 %>"
                data-tab="tab-ldap"
                onclick="switchTab('tab-ldap')"
                type="button" role="tab">
          LDAP
        </button>
      </li>
      <% tab_index += 1 %>
    <% end %>
  </ul>

  <%# ── Tab Panels ────────────────────────────────────────────────── %>
  <% panel_index = 0 %>

  <%# ── Local Login ─────────────────────────────────────────── %>
  <% if SparcConfig.enable_local_login? %>
    <div id="tab-local" class="login-tab-panel <%= 'active' if panel_index == 0 %>">
      <div class="mb-3">
        <label for="local-email" class="form-label fw-semibold small">Email Address</label>
        <input type="email" id="local-email" class="form-control" placeholder="you@example.com" disabled>
      </div>
      <div class="mb-3">
        <label for="local-password" class="form-label fw-semibold small">Password</label>
        <input type="password" id="local-password" class="form-control" placeholder="Enter your password" disabled>
      </div>
      <button class="btn btn-primary w-100 fw-semibold" disabled>Sign In</button>
      <div class="text-center text-body-tertiary small fst-italic mt-2">Local authentication coming soon</div>

      <% if SparcConfig.enable_registration? %>
        <div class="d-flex align-items-center my-3 text-body-tertiary small">
          <hr class="flex-grow-1 m-0"><span class="px-3">or</span><hr class="flex-grow-1 m-0">
        </div>
        <button class="btn btn-success w-100 fw-semibold" disabled>
          Create Account
        </button>
        <div class="text-center text-body-tertiary small fst-italic mt-2">User registration coming soon</div>
      <% end %>
    </div>
    <% panel_index += 1 %>
  <% end %>

  <%# ── OIDC / SSO ─────────────────────────────────────────── %>
  <% if SparcConfig.enable_oidc? %>
    <div id="tab-oidc" class="login-tab-panel <%= 'active' if panel_index == 0 %>">
      <div class="text-center p-3">
        <p class="text-body-secondary mb-4 small">
          Sign in with your organization's identity provider
        </p>
        <button class="btn btn-dark w-100 fw-semibold" disabled>
          Sign in with <%= SparcConfig.oidc_provider_title %>
        </button>
        <div class="text-center text-body-tertiary small fst-italic mt-2">OIDC/OAuth2 integration coming soon</div>
      </div>
    </div>
    <% panel_index += 1 %>
  <% end %>

  <%# ── LDAP ───────────────────────────────────────────────── %>
  <% if SparcConfig.enable_ldap? %>
    <div id="tab-ldap" class="login-tab-panel <%= 'active' if panel_index == 0 %>">
      <div class="mb-3">
        <label for="ldap-username" class="form-label fw-semibold small">Username</label>
        <input type="text" id="ldap-username" class="form-control" placeholder="Enter your username" disabled>
      </div>
      <div class="mb-3">
        <label for="ldap-password" class="form-label fw-semibold small">Password</label>
        <input type="password" id="ldap-password" class="form-control" placeholder="Enter your password" disabled>
      </div>
      <button class="btn btn-primary w-100 fw-semibold" disabled>Sign In with LDAP</button>
      <div class="text-center text-body-tertiary small fst-italic mt-2">LDAP authentication coming soon</div>
    </div>
    <% panel_index += 1 %>
  <% end %>

<% else %>
  <%# ── No Auth Configured ──────────────────────────────────── %>
  <div class="text-center p-4">
    <div style="font-size: 2.5rem;" class="mb-3">&#128274;</div>
    <h3 class="mb-3">Authentication Not Configured</h3>
    <p class="text-body-secondary small">
      No authentication methods are currently enabled.
      Set one or more <code>SPARC_ENABLE_*</code> environment variables
      to activate login.
    </p>
    <p class="mt-3 small">
      See
      <a href="https://github.com/Rebel-Raiders/sparc/blob/main/docs/ENVIRONMENT_VARIABLES.md"
         target="_blank" rel="noopener" class="text-primary">
        docs/ENVIRONMENT_VARIABLES.md
      </a>
      for configuration details.
    </p>
  </div>
<% end %>
