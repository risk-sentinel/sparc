<div class="card">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2>Enrich SSP: <%= @ssp_document.name %></h2>
      <p class="text-body-secondary" style="margin: 0;">
        Add system characteristics, components, and users to uplift this SSP for OSCAL-compliant export.
      </p>
    </div>
    <%= link_to "Back to SSP", ssp_document_path(@ssp_document), class: "btn btn-secondary", style: "flex-shrink: 0;" %>
  </div>

  <%= form_with model: @ssp_document, url: update_enrich_ssp_document_path(@ssp_document), method: :patch, local: true, html: { data: { controller: "ssp-enrich" } } do |f| %>

    <%# ── System Information ── %>
    <details open class="mb-3 sparc-enrich-section" style="padding: 0; overflow: hidden;">
      <summary class="bg-body-secondary sparc-enrich-section-header" style="cursor: pointer; padding: 0.85rem 1rem; list-style: none; user-select: none;">
        System Information
      </summary>
      <div style="padding: 1rem 1.25rem;">
        <div class="row row-cols-1 row-cols-md-2 g-3" style="gap: 0.75rem 1.25rem;">
          <div class="form-group">
            <%= f.label :description, "Description" %>
            <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "System description..." %>
          </div>
          <div class="form-group">
            <%= f.label :system_name_short, "Short Name" %>
            <%= f.text_field :system_name_short, class: "form-control", placeholder: "e.g., ACME" %>
          </div>
          <div class="form-group">
            <%= f.label :system_id, "System ID" %>
            <%= f.text_field :system_id, class: "form-control", placeholder: "e.g., system-uuid" %>
          </div>
          <div class="form-group">
            <%= f.label :system_status, "System Status" %>
            <%= f.select :system_status,
                  SspDocument::SYSTEM_STATUSES.map { |s| [s.titleize, s] },
                  { include_blank: "-- Select --" },
                  { class: "form-control" } %>
          </div>
          <div class="form-group">
            <%= f.label :date_authorized, "Date Authorized" %>
            <%= f.date_field :date_authorized, class: "form-control" %>
          </div>
        </div>
      </div>
    </details>

    <%# ── Security Levels ── %>
    <details class="mb-3 sparc-enrich-section" style="padding: 0; overflow: hidden;">
      <summary class="bg-body-secondary sparc-enrich-section-header" style="cursor: pointer; padding: 0.85rem 1rem; list-style: none; user-select: none;">
        Security Levels
      </summary>
      <div style="padding: 1rem 1.25rem;">
        <div class="row row-cols-1 row-cols-md-2 g-3">
          <div class="form-group">
            <%= f.label :security_sensitivity_level, "Security Sensitivity Level" %>
            <%= f.select :security_sensitivity_level,
                  [["Low (FIPS 199)", "fips-199-low"], ["Moderate (FIPS 199)", "fips-199-moderate"], ["High (FIPS 199)", "fips-199-high"]],
                  { include_blank: "-- Select --" },
                  { class: "form-control" } %>
          </div>
          <div class="form-group">
            <%= f.label :security_objective_confidentiality, "Confidentiality Objective" %>
            <%= f.select :security_objective_confidentiality,
                  [["Low", "fips-199-low"], ["Moderate", "fips-199-moderate"], ["High", "fips-199-high"]],
                  { include_blank: "-- Select --" },
                  { class: "form-control" } %>
          </div>
          <div class="form-group">
            <%= f.label :security_objective_integrity, "Integrity Objective" %>
            <%= f.select :security_objective_integrity,
                  [["Low", "fips-199-low"], ["Moderate", "fips-199-moderate"], ["High", "fips-199-high"]],
                  { include_blank: "-- Select --" },
                  { class: "form-control" } %>
          </div>
          <div class="form-group">
            <%= f.label :security_objective_availability, "Availability Objective" %>
            <%= f.select :security_objective_availability,
                  [["Low", "fips-199-low"], ["Moderate", "fips-199-moderate"], ["High", "fips-199-high"]],
                  { include_blank: "-- Select --" },
                  { class: "form-control" } %>
          </div>
        </div>
      </div>
    </details>

    <%# ── Authorization Boundary ── %>
    <details class="mb-3 sparc-enrich-section" style="padding: 0; overflow: hidden;">
      <summary class="bg-body-secondary sparc-enrich-section-header" style="cursor: pointer; padding: 0.85rem 1rem; list-style: none; user-select: none;">
        Boundaries & Architecture
      </summary>
      <div style="padding: 1rem 1.25rem;">
        <div class="form-group">
          <%= f.label :authorization_boundary_description, "Authorization Boundary" %>
          <%= f.text_area :authorization_boundary_description, class: "form-control", rows: 3,
                placeholder: "Describe the authorization boundary..." %>
        </div>
        <div class="form-group">
          <%= f.label :network_architecture_description, "Network Architecture" %>
          <%= f.text_area :network_architecture_description, class: "form-control", rows: 3,
                placeholder: "Describe the network architecture..." %>
        </div>
        <div class="form-group">
          <%= f.label :data_flow_description, "Data Flow" %>
          <%= f.text_area :data_flow_description, class: "form-control", rows: 3,
                placeholder: "Describe the data flow..." %>
        </div>
      </div>
    </details>

    <%# ── Information Types ── %>
    <details class="mb-3 sparc-enrich-section" style="padding: 0; overflow: hidden;">
      <summary class="bg-body-secondary sparc-enrich-section-header" style="cursor: pointer; padding: 0.85rem 1rem; list-style: none; user-select: none;">
        Information Types (<%= @info_types.count %>)
      </summary>
      <div style="padding: 1rem 1.25rem;" id="info-types-container" data-ssp-enrich-target="infoTypesContainer">
        <% @info_types.each_with_index do |it, idx| %>
          <div class="info-type-entry" style="border: 1px solid var(--bs-border-color); border-radius: 6px; padding: 0.75rem; margin-bottom: 0.5rem; background: var(--bs-body-bg);">
            <input type="hidden" name="ssp_document[information_types][][id]" value="<%= it.id %>">
            <div class="row row-cols-1 row-cols-md-2 g-2">
              <div class="form-group" style="margin-bottom: 0.25rem;">
                <div style="font-size: 0.75rem;">Title</div>
                <input type="text" name="ssp_document[information_types][][title]" value="<%= it.title %>" aria-label="Information Type Title" class="form-control" style="font-size: 0.85rem;">
              </div>
              <div class="form-group" style="margin-bottom: 0.25rem;">
                <div style="font-size: 0.75rem;">Description</div>
                <input type="text" name="ssp_document[information_types][][description]" value="<%= it.description %>" aria-label="Information Type Description" class="form-control" style="font-size: 0.85rem;">
              </div>
              <div class="form-group" style="margin-bottom: 0;">
                <div style="font-size: 0.75rem;">Confidentiality (Base)</div>
                <select name="ssp_document[information_types][][confidentiality_impact_base]" aria-label="Confidentiality (Base)" class="form-control" style="font-size: 0.85rem;">
                  <option value="">--</option>
                  <% %w[fips-199-low fips-199-moderate fips-199-high].each do |v| %>
                    <option value="<%= v %>" <%= "selected" if it.confidentiality_impact_base == v %>><%= v.split("-").last.capitalize %></option>
                  <% end %>
                </select>
              </div>
              <div class="form-group" style="margin-bottom: 0;">
                <div style="font-size: 0.75rem;">Integrity (Base)</div>
                <select name="ssp_document[information_types][][integrity_impact_base]" aria-label="Integrity (Base)" class="form-control" style="font-size: 0.85rem;">
                  <option value="">--</option>
                  <% %w[fips-199-low fips-199-moderate fips-199-high].each do |v| %>
                    <option value="<%= v %>" <%= "selected" if it.integrity_impact_base == v %>><%= v.split("-").last.capitalize %></option>
                  <% end %>
                </select>
              </div>
            </div>
          </div>
        <% end %>
        <template data-ssp-enrich-target="infoTypeTemplate">
          <div class="info-type-entry" style="border: 1px solid var(--bs-border-color); border-radius: 6px; padding: 0.75rem; margin-bottom: 0.5rem; background: var(--bs-body-bg);">
            <div class="row row-cols-1 row-cols-md-2 g-2">
              <div class="form-group" style="margin-bottom: 0.25rem;">
                <div style="font-size: 0.75rem;">Title</div>
                <input type="text" name="ssp_document[information_types][][title]" aria-label="Information Type Title" class="form-control" style="font-size: 0.85rem;" placeholder="Information Type">
              </div>
              <div class="form-group" style="margin-bottom: 0.25rem;">
                <div style="font-size: 0.75rem;">Description</div>
                <input type="text" name="ssp_document[information_types][][description]" aria-label="Information Type Description" class="form-control" style="font-size: 0.85rem;" placeholder="Description">
              </div>
              <div class="form-group" style="margin-bottom: 0;">
                <div style="font-size: 0.75rem;">Confidentiality (Base)</div>
                <select name="ssp_document[information_types][][confidentiality_impact_base]" aria-label="Confidentiality (Base)" class="form-control" style="font-size: 0.85rem;">
                  <option value="">--</option>
                  <option value="fips-199-low">Low</option>
                  <option value="fips-199-moderate">Moderate</option>
                  <option value="fips-199-high">High</option>
                </select>
              </div>
              <div class="form-group" style="margin-bottom: 0;">
                <div style="font-size: 0.75rem;">Integrity (Base)</div>
                <select name="ssp_document[information_types][][integrity_impact_base]" aria-label="Integrity (Base)" class="form-control" style="font-size: 0.85rem;">
                  <option value="">--</option>
                  <option value="fips-199-low">Low</option>
                  <option value="fips-199-moderate">Moderate</option>
                  <option value="fips-199-high">High</option>
                </select>
              </div>
            </div>
          </div>
        </template>
        <button type="button" data-action="ssp-enrich#addInfoType" class="btn btn-secondary" style="font-size: 0.8rem; padding: 0.35rem 0.75rem; margin-top: 0.5rem;">
          + Add Information Type
        </button>
      </div>
    </details>

    <%# ── Components ── %>
    <details class="mb-3 sparc-enrich-section" style="padding: 0; overflow: hidden;">
      <summary class="bg-body-secondary sparc-enrich-section-header" style="cursor: pointer; padding: 0.85rem 1rem; list-style: none; user-select: none;">
        Components (<%= @components.count %>)
      </summary>
      <div style="padding: 1rem 1.25rem;" id="components-container" data-ssp-enrich-target="componentsContainer">
        <% @components.reject { |c| c.component_type == "this-system" }.each_with_index do |comp, comp_idx| %>
          <div class="component-entry" style="border: 1px solid var(--bs-border-color); border-radius: 6px; padding: 0.75rem; margin-bottom: 0.5rem; background: var(--bs-body-bg);">
            <input type="hidden" name="ssp_document[components][][id]" value="<%= comp.id %>">
            <div class="row row-cols-1 row-cols-md-2 g-2">
              <div class="form-group" style="margin-bottom: 0.25rem;">
                <label for="ssp-component-<%= comp_idx %>-title" style="font-size: 0.75rem;">Title</label>
                <input type="text" id="ssp-component-<%= comp_idx %>-title" name="ssp_document[components][][title]" value="<%= comp.title %>" class="form-control" style="font-size: 0.85rem;">
              </div>
              <div class="form-group" style="margin-bottom: 0.25rem;">
                <label for="ssp-component-<%= comp_idx %>-type" style="font-size: 0.75rem;">Type</label>
                <select id="ssp-component-<%= comp_idx %>-type" name="ssp_document[components][][component_type]" class="form-control" style="font-size: 0.85rem;">
                  <% SspComponent::COMPONENT_TYPES.reject { |t| t == "this-system" }.each do |t| %>
                    <option value="<%= t %>" <%= "selected" if comp.component_type == t %>><%= t.titleize %></option>
                  <% end %>
                </select>
              </div>
              <div class="form-group" style="margin-bottom: 0; grid-column: 1 / -1;">
                <label for="ssp-component-<%= comp_idx %>-description" style="font-size: 0.75rem;">Description</label>
                <input type="text" id="ssp-component-<%= comp_idx %>-description" name="ssp_document[components][][description]" value="<%= comp.description %>" class="form-control" style="font-size: 0.85rem;">
              </div>
            </div>
          </div>
        <% end %>
        <template data-ssp-enrich-target="componentTemplate">
          <div class="component-entry" style="border: 1px solid var(--bs-border-color); border-radius: 6px; padding: 0.75rem; margin-bottom: 0.5rem; background: var(--bs-body-bg);">
            <div class="row row-cols-1 row-cols-md-2 g-2">
              <div class="form-group" style="margin-bottom: 0.25rem;">
                <span style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.75rem;">Title</span>
                <input type="text" name="ssp_document[components][][title]" class="form-control" style="font-size: 0.85rem;" placeholder="Component name" aria-label="Component Title">
              </div>
              <div class="form-group" style="margin-bottom: 0.25rem;">
                <span style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.75rem;">Type</span>
                <select name="ssp_document[components][][component_type]" class="form-control" style="font-size: 0.85rem;" aria-label="Component Type">
                  <option value="software">Software</option>
                  <option value="hardware">Hardware</option>
                  <option value="service">Service</option>
                  <option value="policy">Policy</option>
                  <option value="process-procedure">Process Procedure</option>
                  <option value="plan">Plan</option>
                  <option value="guidance">Guidance</option>
                  <option value="standard">Standard</option>
                  <option value="validation">Validation</option>
                </select>
              </div>
              <div class="form-group" style="margin-bottom: 0; grid-column: 1 / -1;">
                <span style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.75rem;">Description</span>
                <input type="text" name="ssp_document[components][][description]" class="form-control" style="font-size: 0.85rem;" placeholder="Component description" aria-label="Component Description">
              </div>
            </div>
          </div>
        </template>
        <button type="button" data-action="ssp-enrich#addComponent" class="btn btn-secondary" style="font-size: 0.8rem; padding: 0.35rem 0.75rem; margin-top: 0.5rem;">
          + Add Component
        </button>
      </div>
    </details>

    <%# ── Users ── %>
    <details class="mb-3 sparc-enrich-section" style="padding: 0; overflow: hidden;">
      <summary class="bg-body-secondary sparc-enrich-section-header" style="cursor: pointer; padding: 0.85rem 1rem; list-style: none; user-select: none;">
        System Users (<%= @users.count %>)
      </summary>
      <div style="padding: 1rem 1.25rem;" id="users-container" data-ssp-enrich-target="usersContainer">
        <% @users.each_with_index do |user, user_idx| %>
          <div class="user-entry" style="border: 1px solid var(--bs-border-color); border-radius: 6px; padding: 0.75rem; margin-bottom: 0.5rem; background: var(--bs-body-bg);">
            <input type="hidden" name="ssp_document[users][][id]" value="<%= user.id %>">
            <div class="row row-cols-1 row-cols-md-2 g-2">
              <div class="form-group" style="margin-bottom: 0.25rem;">
                <label for="ssp-user-<%= user_idx %>-title" style="font-size: 0.75rem;">Title</label>
                <input type="text" id="ssp-user-<%= user_idx %>-title" name="ssp_document[users][][title]" value="<%= user.title %>" class="form-control" style="font-size: 0.85rem;">
              </div>
              <div class="form-group" style="margin-bottom: 0;">
                <label for="ssp-user-<%= user_idx %>-description" style="font-size: 0.75rem;">Description</label>
                <input type="text" id="ssp-user-<%= user_idx %>-description" name="ssp_document[users][][description]" value="<%= user.description %>" class="form-control" style="font-size: 0.85rem;">
              </div>
            </div>
          </div>
        <% end %>
        <template data-ssp-enrich-target="userTemplate">
          <div class="user-entry" style="border: 1px solid var(--bs-border-color); border-radius: 6px; padding: 0.75rem; margin-bottom: 0.5rem; background: var(--bs-body-bg);">
            <div class="row row-cols-1 row-cols-md-2 g-2">
              <div class="form-group" style="margin-bottom: 0.25rem;">
                <span style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.75rem;">Title</span>
                <input type="text" name="ssp_document[users][][title]" class="form-control" style="font-size: 0.85rem;" placeholder="User title" aria-label="User Title">
              </div>
              <div class="form-group" style="margin-bottom: 0;">
                <span style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.75rem;">Description</span>
                <input type="text" name="ssp_document[users][][description]" class="form-control" style="font-size: 0.85rem;" placeholder="Description" aria-label="User Description">
              </div>
            </div>
          </div>
        </template>
        <button type="button" data-action="ssp-enrich#addUser" class="btn btn-secondary" style="font-size: 0.8rem; padding: 0.35rem 0.75rem; margin-top: 0.5rem;">
          + Add User
        </button>
      </div>
    </details>

    <%# ── Submit ── %>
    <div class="d-flex gap-3 mt-3">
      <%= f.submit "Save Enrichment Data", class: "btn btn-success" %>
      <%= link_to "Cancel", ssp_document_path(@ssp_document), class: "btn btn-secondary" %>
    </div>

  <% end %>
</div>
