<%# #395 P3: boundary context header (system title, impact level, link) %>
<%= render "shared/boundary_header", document: @ssp_document %>

<%# ── PROCESSING STATE BANNER ─────────────────────────────────────── %>
<% unless @ssp_document.completed? %>
  <%= render "shared/processing_banner",
       document:     @ssp_document,
       title:        "Processing Your Workbook",
       back_label:   "Back to Documents",
       back_path:    ssp_documents_path %>

<% else %>
<%
  total_by_status = {}
  @heatmap_statuses.each { |s| total_by_status[s] = @heatmap_families.sum { |f| @heatmap_data.dig(f, s) || 0 } }
  total_controls = total_by_status.values.sum

  compliant_count = total_by_status["Implemented"].to_i
  not_applicable  = total_by_status["Not Applicable"].to_i
  denominator     = [total_controls - not_applicable, 1].max
  compliance_pct  = (compliant_count * 100.0 / denominator).round(1)
  score_color     = compliance_pct >= 80 ? "#2ecc71" : compliance_pct >= 50 ? "#f39c12" : "#e74c3c"
%>

<%# ── HEADER DASHBOARD ──────────────────────────────────────────── %>
<div class="sparc-dashboard-header">

  <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap" style="gap: 1rem;">
    <div>
      <div class="sparc-header-subtitle">System Security Plan</div>

      <div id="doc-meta-view">
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <h2 class="sparc-header-title"><%= @ssp_document.name %></h2>
          <% if @ssp_document.ssp_version.present? %>
            <span class="sparc-version-badge">v<%= @ssp_document.ssp_version %></span>
          <% end %>
          <button onclick="toggleDocMeta()" class="sparc-btn-header-edit">Edit</button>
        </div>
      </div>

      <div id="doc-meta-edit" style="display: none;">
        <%= form_with url: update_metadata_ssp_document_path(@ssp_document), method: :patch, local: true do |f| %>
          <div class="d-flex gap-2 align-items-center flex-wrap">
            <%= f.text_field :name, value: @ssp_document.name,
                  class: "sparc-input-dark sparc-input-dark-lg" %>
            <%= f.text_field :ssp_version, value: @ssp_document.ssp_version, placeholder: "Version",
                  class: "sparc-input-dark sparc-input-dark-sm" %>
            <%= f.submit "Save", class: "sparc-btn-save" %>
            <button type="button" onclick="toggleDocMeta()" class="sparc-btn-cancel-dark">Cancel</button>
          </div>
        <% end %>
      </div>

      <div class="sparc-header-meta">
        <%= @ssp_document.original_filename %>
        &nbsp;•&nbsp;
        <span style="color: <%= @ssp_document.completed? ? '#2ecc71' : '#f39c12' %>; font-weight: 600;">
          <%= @ssp_document.status %>
        </span>
        &nbsp;•&nbsp; <%= total_controls %> controls
      </div>
    </div>
    <div class="d-flex flex-wrap gap-2" style="flex-shrink: 0;">
      <% if signed_in? && @ssp_document.draft? %>
        <%= render "shared/publish_button", document: @ssp_document,
              publish_path: publish_ssp_document_path(@ssp_document),
              check_path: publish_check_ssp_document_path(@ssp_document) %>
      <% end %>
      <%= render "shared/oscal_export_dropdown",
            validate_path: validate_oscal_export_ssp_document_path(@ssp_document),
            download_json_path: download_oscal_validated_ssp_document_path(@ssp_document),
            download_yaml_path: download_yaml_ssp_document_path(@ssp_document),
            download_xml_path: download_xml_ssp_document_path(@ssp_document),
            fallback_json_path: download_oscal_unvalidated_ssp_document_path(@ssp_document),
            document_type: "SSP" %>
      <%= link_to "Enrich", enrich_ssp_document_path(@ssp_document),
            class: "sparc-btn-enrich" %>
      <%# #398: bulk refresh inherited statements from linked CDEFs %>
      <% if signed_in? && @ssp_document.ssp_components.where.not(cdef_document_id: nil).exists? %>
        <%= button_to "Refresh Inherited",
              refresh_inherited_statements_ssp_document_path(@ssp_document),
              method: :post,
              class: "sparc-btn-enrich",
              form: { style: "display: inline;" } %>
      <% end %>
      <%= link_to "&#8592; Back".html_safe, ssp_documents_path,
            class: "sparc-btn-ghost-muted" %>
    </div>
  </div>

  <div class="d-flex align-items-center flex-wrap" style="gap: 1.5rem;">
    <div style="text-align: center; min-width: 80px; flex-shrink: 0;">
      <div class="sparc-score" style="color: <%= score_color %>;">
        <%= compliance_pct %>%
      </div>
      <div class="sparc-score-label">Compliant</div>
    </div>

    <div class="sparc-divider-v"></div>

    <div class="d-flex flex-wrap" style="gap: 0.45rem; flex: 1;">
      <% total_by_status.each do |status, count| %>
        <% next if count == 0 %>
        <div class="summary-chip sparc-summary-chip"
             data-filter-value="<%= status %>"
             role="button"
             tabindex="0"
             title="Click to filter: <%= status %>"
             onclick="document.getElementById('heatmapSection').dispatchEvent(new CustomEvent('heatmap:chip', {detail: {filter: '<%= j status %>'}}))"
             style="border-left: 3px solid <%= ssp_status_color(status) %>;">
          <div class="sparc-chip-count"><%= count %></div>
          <div class="sparc-chip-label"><%= status %></div>
        </div>
      <% end %>
    </div>
  </div>

  <div style="margin-top: 1.25rem;">
    <div class="sparc-progress-bar rounded-pill">
      <% total_by_status.each do |status, count| %>
        <% next if count == 0 %>
        <div style="width: <%= (count * 100.0 / [total_controls, 1].max).round(3) %>%; background: <%= ssp_status_color(status) %>;"
             title="<%= status %>: <%= count %>"></div>
      <% end %>
    </div>
  </div>
</div>

<%# ── OSCAL ENRICHMENT PANELS ────────────────────────────────────── %>
<% if @ssp_document.enriched? %>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 0.75rem; margin-bottom: 1.5rem;">

    <%# System Characteristics %>
    <div style="background: var(--bs-body-bg); border: 1px solid var(--bs-border-color); border-radius: 8px; padding: 1rem;">
      <div class="d-flex justify-content-between align-items-center" style="margin-bottom: 0.5rem;">
        <span style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--bs-tertiary-color);">System Characteristics</span>
        <% if signed_in? && @ssp_document.draft? %>
          <%= link_to enrich_ssp_document_path(@ssp_document), style: "font-size: 0.72rem; color: var(--bs-tertiary-color); text-decoration: none;" do %>&#9998; Edit<% end %>
        <% end %>
      </div>
      <% if @ssp_document.description.present? %>
        <div style="font-size: 0.82rem; color: var(--bs-body-color); margin-bottom: 0.4rem;"><%= truncate(@ssp_document.description, length: 120) %></div>
      <% end %>
      <div class="d-flex flex-wrap gap-1" style="margin-top: 0.25rem;">
        <% if @ssp_document.security_sensitivity_level.present? %>
          <span class="sparc-status sparc-status--info" style="font-size: 0.72rem;"><%= @ssp_document.security_sensitivity_level.split("-").last.capitalize %></span>
        <% end %>
        <% if @ssp_document.system_status.present? %>
          <span class="sparc-status sparc-status--success" style="font-size: 0.72rem;"><%= @ssp_document.system_status.titleize %></span>
        <% end %>
      </div>
    </div>

    <%# Components %>
    <div style="background: var(--bs-body-bg); border: 1px solid var(--bs-border-color); border-radius: 8px; padding: 1rem;">
      <div class="d-flex justify-content-between align-items-center" style="margin-bottom: 0.5rem;">
        <span style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--bs-tertiary-color);">Components (<%= @components.count %>)</span>
        <% if signed_in? && @ssp_document.draft? %>
          <%= link_to enrich_ssp_document_path(@ssp_document, anchor: "components"), style: "font-size: 0.72rem; color: var(--bs-tertiary-color); text-decoration: none;" do %>&#9998; Edit<% end %>
        <% end %>
      </div>
      <% @components.first(5).each do |comp| %>
        <div class="d-flex align-items-center gap-1" style="margin-bottom: 0.25rem;">
          <span class="sparc-status sparc-status--<%= comp.component_type == 'this-system' ? 'purple' : 'info' %>" style="font-size: 0.68rem;"><%= comp.component_type %></span>
          <span style="font-size: 0.82rem; color: var(--bs-body-color);"><%= truncate(comp.title, length: 30) %></span>
        </div>
      <% end %>
      <% if @components.count > 5 %>
        <div style="font-size: 0.75rem; color: var(--bs-tertiary-color); margin-top: 0.25rem;">+ <%= @components.count - 5 %> more</div>
      <% end %>
    </div>

    <%# Users %>
    <div style="background: var(--bs-body-bg); border: 1px solid var(--bs-border-color); border-radius: 8px; padding: 1rem;">
      <div class="d-flex justify-content-between align-items-center" style="margin-bottom: 0.5rem;">
        <span style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--bs-tertiary-color);">Users (<%= @users.count %>)</span>
        <% if signed_in? && @ssp_document.draft? %>
          <%= link_to enrich_ssp_document_path(@ssp_document, anchor: "users"), style: "font-size: 0.72rem; color: var(--bs-tertiary-color); text-decoration: none;" do %>&#9998; Edit<% end %>
        <% end %>
      </div>
      <% @users.first(5).each do |user| %>
        <div style="font-size: 0.82rem; color: var(--bs-body-color); margin-bottom: 0.2rem;">
          <%= user.title.presence || "Unnamed User" %>
          <% if user.role_ids_data.present? %>
            <span style="font-size: 0.7rem; color: var(--bs-tertiary-color);"> &mdash; <%= user.role_ids_data.join(", ") %></span>
          <% end %>
        </div>
      <% end %>
      <% if @users.count > 5 %>
        <div style="font-size: 0.75rem; color: var(--bs-tertiary-color); margin-top: 0.25rem;">+ <%= @users.count - 5 %> more</div>
      <% end %>
    </div>
  </div>
<% elsif !@ssp_document.enriched? %>
  <%# Enrichment prompt banner for SSPs missing OSCAL fields %>
  <div class="d-flex align-items-center justify-content-between gap-3 rounded-3 mb-4" style="background: rgba(241,196,15,0.08); border: 1px solid rgba(241,196,15,0.25); padding: 0.85rem 1.25rem;">
    <div>
      <div class="fw-semibold" style="font-size: 0.88rem; color: var(--bs-body-color);">Enrich for OSCAL Compliance</div>
      <div class="text-body-secondary" style="font-size: 0.78rem;">Add system characteristics, components, and users to produce a fully valid OSCAL SSP export.</div>
    </div>
    <%= link_to "Enrich SSP", enrich_ssp_document_path(@ssp_document), class: "btn btn-success", style: "flex-shrink: 0; font-size: 0.85rem; padding: 0.4rem 1rem;" %>
  </div>
<% end %>

<%# ── FAMILY COMPLIANCE GRID ─────────────────────────────────────── %>
<%= render "shared/heatmap",
     heatmap_data: @heatmap_data,
     heatmap_families: @heatmap_families,
     heatmap_statuses: @heatmap_statuses,
     title: "Compliance by Control Family",
     variant_helper: :ssp_status_variant,
     filter_key: "status",
     url_sync: true,
     initial_family: params[:family],
     initial_filter: params[:status],
     legend_items: ApplicationHelper::SSP_STATUS_COLORS.first(4).to_a %>

<%# ── CONTROL CARDS ───────────────────────────────────────────────── %>
<div id="controlsContainer">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <label class="form-label fw-semibold mb-0"><%= total_controls %> controls</label>
    <div class="d-flex gap-1">
      <button type="button" class="btn btn-sm btn-outline-info" onclick="toggleAllFamilies(true)">Expand All</button>
      <button type="button" class="btn btn-sm btn-outline-info" onclick="toggleAllFamilies(false)">Collapse All</button>
    </div>
  </div>

  <% @sorted_families.each do |family_code| %>
    <% family_controls = @controls_by_family[family_code] %>
    <% next if family_controls.blank? %>

    <details class="sparc-family-group" data-family-group="<%= family_code %>">
      <summary>
        <strong><%= family_code %></strong> &mdash; <%= @family_names[family_code] || @family_names[family_code.downcase] || family_code %>
        <span class="badge bg-secondary"><%= family_controls.size %></span>
      </summary>

      <div class="mt-2">
  <% family_controls.sort_by { |c| c.control_id.gsub(/\d+/) { |n| n.rjust(3, "0") } }.each do |control| %>
    <%
      field_map   = control.ssp_control_fields.index_by(&:field_name)
      status_val  = field_map["status"]&.field_value.presence || "(Unknown)"
      status_color = ssp_status_color(status_val)
      status_variant = ssp_status_variant(status_val)
      family_code  = control.control_id.to_s.split("-").first.upcase
      stated_req   = field_map["stated_requirement"]&.field_value.presence
      type_use_val = field_map["control_application"]&.field_value.presence
      prov_as_val  = field_map["coverage_level"]&.field_value.presence
      catalog_ctrl = @catalog_guidance[normalize_ctrl_id(control.control_id)]
    %>
    <div class="control-card"
         data-family="<%= family_code %>"
         data-status="<%= status_val %>"
         style="border-left: 4px solid <%= status_color %>;">

      <%# ── Card header ── %>
      <div class="d-flex justify-content-between align-items-start gap-3">
        <div style="min-width: 0; flex: 1;">
          <div class="d-flex align-items-center gap-2 flex-wrap" style="margin-bottom: 0.2rem;">
            <span class="sparc-ctrl-id"><%= control.control_id %></span>
            <span class="sparc-status-pill sparc-status--<%= status_variant %>"><%= status_val %></span>
            <% if type_use_val.present? %>
              <span class="sparc-asset-tag"><%= type_use_val %></span>
            <% end %>
            <% if prov_as_val.present? %>
              <span class="sparc-env-tag">&#x2713; <%= prov_as_val %></span>
            <% end %>
            <span class="sparc-ctrl-family" style="margin-left: 0.1rem;"><%= family_code %></span>
          </div>
          <div class="sparc-ctrl-title" style="margin-top: 0.1rem;"><%= control.title %></div>
        </div>
        <button onclick="toggleEdit(<%= control.id %>)"
                id="edit-btn-<%= control.id %>"
                class="sparc-btn-edit">
          Edit
        </button>
      </div>

      <%# ── Card body: collapsed by default ── %>
      <details id="details-<%= control.id %>" class="card-details" style="margin-top: 0.35rem;">
        <summary class="sparc-card-detail-toggle d-flex align-items-center gap-1">
          <span class="card-arrow sparc-card-arrow">&#9658;</span>
          <span class="sparc-card-detail-separator"></span>
        </summary>

        <%# ── View mode ── %>
        <div id="view-<%= control.id %>" style="margin-top: 0.5rem;">

          <%# Stated requirement — highlighted block when present %>
          <% if stated_req.present? %>
            <div class="sparc-statement-block">
              <div class="sparc-statement-label" style="color: var(--bs-primary);">Required Statement</div>
              <div style="font-size: 0.84rem; color: var(--bs-body-color); line-height: 1.5;"><%= stated_req %></div>
            </div>
          <% end %>

          <%# Ordered field table — editable fields first, then supplemental %>
          <%
            ordered = SspControlField::FIELD_DISPLAY_ORDER.map { |fn| field_map[fn] }.compact
            extras  = field_map.values.reject { |f|
              SspControlField::FIELD_DISPLAY_ORDER.include?(f.field_name) ||
              f.field_name == "stated_requirement"
            }
            display_fields = ordered + extras
          %>
          <% if display_fields.any? %>
            <table class="sparc-field-table">
              <% display_fields.each do |field| %>
                <% next if field.field_value.blank? %>
                <tr>
                  <td class="sparc-field-label">
                    <%= field.field_name.tr("_", " ") %>
                    <% if field.editable %><span class="sparc-editable-indicator">✎</span><% end %>
                  </td>
                  <td class="sparc-field-value">
                    <% if field.field_name == "status" %>
                      <span class="sparc-status-pill sparc-status--<%= ssp_status_variant(field.field_value) %>" style="font-size: 0.75rem; font-weight: 600;"><%= field.field_value %></span>
                    <% else %>
                      <%= field.field_value %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </table>
          <% end %>

          <%# ── Inherited / Provider Statements (collapsible) ── %>
          <% if control.provider_statements.any? %>
            <details style="margin-top: 0.85rem;">
              <summary class="sparc-ctx-header d-flex align-items-center gap-1 fw-bold rounded" style="color: var(--sparc-purple); background: rgba(142,68,173,0.06); border: 1px solid rgba(142,68,173,0.18);">
                <span class="inherited-arrow sparc-ctx-arrow">&#9658;</span>
                Inherited Rows (<%= control.provider_statements.count %>)
              </summary>
              <div style="margin-top: 0.5rem;">
                <% control.provider_statements.each_with_index do |stmt, i| %>
                  <div style="margin-bottom: 0.6rem; padding: 0.75rem 1rem; background: var(--bs-secondary-bg); border-left: 3px solid #8e44ad; border-radius: 0 6px 6px 0;">
                    <div class="d-flex align-items-center gap-2 flex-wrap" style="margin-bottom: 0.4rem;">
                      <span class="sparc-status sparc-status--purple" style="font-size: 0.64rem;">INHERITED</span>
                      <% if stmt.title.present? %>
                        <span style="font-size: 0.82rem; font-weight: 600; color: var(--bs-body-color);">
                          <%= stmt.title %>
                        </span>
                      <% else %>
                        <span style="font-size: 0.78rem; color: var(--bs-secondary-color);">Provider Statement <%= i + 1 %></span>
                      <% end %>
                    </div>
                    <% stmt_fields = stmt.ssp_control_fields.reject { |f| f.field_value.blank? } %>
                    <% if stmt_fields.any? %>
                      <table class="sparc-field-table">
                        <% stmt_fields.each do |field| %>
                          <tr>
                            <td class="sparc-field-label">
                              <%= field.field_name.tr("_", " ") %>
                              <% if field.editable %><span class="sparc-editable-indicator">✎</span><% end %>
                            </td>
                            <td class="sparc-field-value">
                              <%= field.field_value %>
                            </td>
                          </tr>
                        <% end %>
                      </table>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </details>
          <% end %>

          <%# ── Catalog Guidance (collapsible) ── %>
          <% if catalog_ctrl&.guidance_present? %>
            <details style="margin-top: 0.85rem;">
              <summary class="sparc-ctx-header d-flex align-items-center gap-1 fw-semibold text-body-secondary rounded" style="font-size: 0.8rem; background: rgba(155,89,182,0.06); border: 1px solid rgba(155,89,182,0.18);">
                <span class="catalog-arrow sparc-ctx-arrow">&#9658;</span>
                Catalog Guidance
                <span class="sparc-section-hint" style="font-size: 0.7rem;">— supplemental context from the providing catalog</span>
              </summary>
              <div style="margin-top: 0.5rem; padding: 0.85rem 1rem; background: rgba(155,89,182,0.04); border: 1px solid rgba(155,89,182,0.12); border-radius: 0 0 6px 6px;">
                <table class="sparc-field-table">
                  <% catalog_ctrl.guidance_fields.each do |fname, fval| %>
                    <% display_val = fval.is_a?(Array) ? fval.join(", ") : fval.to_s %>
                    <% next if display_val.blank? %>
                    <tr>
                      <td class="sparc-field-label" style="color: var(--sparc-purple);">
                        <%= fname.tr("_", " ") %>
                      </td>
                      <td class="sparc-field-value" style="line-height: 1.5;">
                        <%= display_val %>
                      </td>
                    </tr>
                  <% end %>
                </table>
              </div>
            </details>
          <% end %>
        </div>

        <%# ── Edit form ── %>
        <div id="edit-<%= control.id %>" style="display: none; margin-top: 0.75rem; border-top: 1px solid var(--bs-border-color); padding-top: 0.75rem;">
          <%= form_with url: ssp_document_path(@ssp_document), method: :patch, local: true do |f| %>
            <%= hidden_field_tag :control_id, control.control_id %>

            <%#
              Iterate ALL EDITABLE_FIELDS so control_application, coverage_level, etc. always
              appear even if no DB record exists yet for that field.
            %>
            <% SspControlField::EDITABLE_FIELDS.each do |fname| %>
              <% field = field_map[fname] %>
              <% fval  = field&.field_value.to_s %>
              <div class="form-group">
                <label class="sparc-edit-label">
                  <%= fname.tr("_", " ") %>
                  <span class="sparc-edit-editable-hint">(editable)</span>
                </label>
                <% if fname == "status" %>
                  <%= select_tag "fields[#{fname}]",
                        options_for_select(SspControlField::VALID_STATUSES, fval),
                        include_blank: "— select —", class: "form-control",
                        style: "font-size: 0.875rem;" %>
                <% elsif fname == "control_application" %>
                  <%= select_tag "fields[#{fname}]",
                        options_for_select(SspControlField::TYPE_USE_AS_VALUES, fval),
                        include_blank: "— select —", class: "form-control",
                        style: "font-size: 0.875rem;" %>
                <% elsif fname == "coverage_level" %>
                  <%= select_tag "fields[#{fname}]",
                        options_for_select(SspControlField::PROVIDED_AS_VALUES, fval),
                        include_blank: "— select —", class: "form-control",
                        style: "font-size: 0.875rem;" %>
                <% elsif fname == "control_type" %>
                  <%= select_tag "fields[#{fname}]",
                        options_for_select(SspControlField::CONTROL_ORIGINATION_VALUES, fval),
                        include_blank: "— select —", class: "form-control",
                        style: "font-size: 0.875rem;" %>
                <% elsif fname == "expected_completion" %>
                  <%= text_field_tag "fields[#{fname}]", fval,
                        class: "form-control", placeholder: "YYYY-MM-DD",
                        style: "font-size: 0.875rem;" %>
                <% else %>
                  <%= text_area_tag "fields[#{fname}]", fval,
                        class: "form-control", rows: 3,
                        style: "font-size: 0.875rem;" %>
                <% end %>
              </div>
            <% end %>

            <%# Read-only fields (from upstream import, not user-editable) %>
            <% ro_fields = field_map.values.reject { |f|
                 SspControlField::EDITABLE_FIELDS.include?(f.field_name)
               }.select { |f| f.field_value.present? } %>
            <% if stated_req.present? || ro_fields.any? %>
              <details style="margin-top: 0.5rem;">
                <summary style="font-size: 0.8rem; color: var(--bs-tertiary-color); cursor: pointer; padding: 0.35rem 0; user-select: none;">
                  Read-only fields (<%= ro_fields.size + (stated_req.present? ? 1 : 0) %>)
                </summary>
                <% if stated_req.present? %>
                  <div class="form-group" style="margin-top: 0.5rem;">
                    <label class="sparc-edit-label" style="color: var(--bs-tertiary-color);">
                      Stated Requirement
                      <span class="sparc-edit-readonly-hint">(read-only)</span>
                    </label>
                    <p class="sparc-readonly-value"><%= stated_req %></p>
                  </div>
                <% end %>
                <% ro_fields.each do |field| %>
                  <div class="form-group" style="margin-top: 0.5rem;">
                    <label class="sparc-edit-label" style="color: var(--bs-tertiary-color);">
                      <%= field.field_name.tr("_", " ") %>
                      <span class="sparc-edit-readonly-hint">(read-only)</span>
                    </label>
                    <p class="sparc-readonly-value"><%= field.field_value %></p>
                  </div>
                <% end %>
              </details>
            <% end %>

            <%# Catalog guidance in edit mode (read-only context panel) %>
            <% if catalog_ctrl&.guidance_present? %>
              <details style="margin-top: 0.75rem; border-top: 1px solid var(--bs-border-color); padding-top: 0.75rem;">
                <summary style="font-size: 0.8rem; font-weight: 600; color: var(--sparc-purple); cursor: pointer; padding: 0.35rem 0; user-select: none;">
                  Catalog Guidance (reference only — not saved)
                </summary>
                <div style="margin-top: 0.5rem; padding: 0.75rem; background: rgba(155,89,182,0.04); border: 1px solid rgba(155,89,182,0.15); border-radius: 5px;">
                  <% catalog_ctrl.guidance_fields.each do |fname, fval| %>
                    <% display_val = fval.is_a?(Array) ? fval.join(", ") : fval.to_s %>
                    <% next if display_val.blank? %>
                    <div style="margin-bottom: 0.6rem;">
                      <div class="sparc-edit-label" style="font-size: 0.68rem; letter-spacing: 0.07em; color: var(--sparc-purple); margin-bottom: 0.2rem;"><%= fname.tr("_", " ") %></div>
                      <div style="font-size: 0.82rem; color: var(--bs-secondary-color); line-height: 1.5;"><%= display_val %></div>
                    </div>
                  <% end %>
                </div>
              </details>
            <% end %>

            <%# ── #393: Implementation statements (per-statement edit modal) ── %>
            <%= render "ssp_documents/statements_table", control: control, ssp_document: @ssp_document %>

            <%# ── Back-Matter References ── %>
            <% ssp_ctrl_resources = control.back_matter_resources.order(:title) %>
            <div class="mt-3" style="border-top: 1px solid var(--bs-border-color); padding-top: 0.75rem;">
              <h6 class="fw-semibold small">
                Back-Matter References
                <span class="badge bg-secondary" style="font-size: 0.65rem;"><%= ssp_ctrl_resources.size %></span>
              </h6>
              <% if ssp_ctrl_resources.any? %>
                <div class="d-flex flex-wrap gap-2 mb-2">
                  <% ssp_ctrl_resources.each do |resource| %>
                    <% ssp_link_record = control.control_back_matter_links.find_by(back_matter_resource: resource) %>
                    <span class="badge bg-body-secondary text-body d-inline-flex align-items-center gap-1" style="font-size: 0.78rem; font-weight: 500;">
                      <% if resource.href.present? %>
                        <a href="<%= resource.href %>" target="_blank" class="text-decoration-none"><%= resource.title %></a>
                      <% else %>
                        <%= resource.title %>
                      <% end %>
                      <code class="small text-body-tertiary ms-1">#<%= resource.uuid.truncate(12) %></code>
                      <% if ssp_link_record %>
                        <button type="button" class="btn-close btn-close-sm ms-1" style="font-size: 0.5rem;"
                                onclick="unlinkSspControlResource('<%= control.control_id %>', '<%= ssp_link_record.id %>')"
                                title="Unlink"></button>
                      <% end %>
                    </span>
                  <% end %>
                </div>
              <% end %>
              <div id="ssp-add-ref-<%= control.id %>" style="display: none;" class="mb-2">
                <div class="row g-2 align-items-end">
                  <div class="col-md-3">
                    <input type="text" id="ssp-ref-title-<%= control.id %>" class="form-control form-control-sm" placeholder="Title *">
                  </div>
                  <div class="col-md-3">
                    <input type="text" id="ssp-ref-href-<%= control.id %>" class="form-control form-control-sm" placeholder="https://...">
                  </div>
                  <div class="col-md-2">
                    <input type="text" id="ssp-ref-media-<%= control.id %>" class="form-control form-control-sm" placeholder="application/pdf">
                  </div>
                  <div class="col-md-4 d-flex gap-1">
                    <button type="button" class="btn btn-sm btn-success" onclick="createSspControlResource('<%= control.control_id %>', '<%= control.id %>')">Create & Link</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleSspAddRef('<%= control.id %>')">Cancel</button>
                  </div>
                </div>
              </div>
              <button type="button" class="btn btn-sm btn-outline-primary" id="ssp-add-ref-btn-<%= control.id %>" onclick="toggleSspAddRef('<%= control.id %>')" style="font-size: 0.75rem;">
                + Add Reference
              </button>
            </div>

            <div class="d-flex gap-2 mt-3">
              <%= f.submit "Save Changes",
                    class: "sparc-btn-save", style: "padding: 0.5rem 1.25rem; font-size: 0.875rem;" %>
              <button type="button" onclick="toggleEdit(<%= control.id %>)"
                      style="background: var(--bs-secondary-bg); color: var(--bs-secondary-color); border: 1px solid var(--bs-border-color); border-radius: 4px; padding: 0.5rem 1rem; cursor: pointer; font-size: 0.875rem;">
                Cancel
              </button>
            </div>
          <% end %>
        </div>
      </details>
    </div><%# end .control-card %>
  <% end %>
      </div><%# end family controls %>
    </details><%# end sparc-family-group %>
  <% end %>
</div>

<%# ── #393: Statement edit modal (deep-linked via ?statement_id=N) ── %>
<% if @editing_statement %>
  <% stmt = @editing_statement %>
  <div id="editStatementModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; align-items: center; justify-content: center;">
    <div class="bg-body rounded-3" style="padding: 2rem; max-width: 700px; width: 90%; max-height: 85vh; overflow-y: auto; box-shadow: 0 8px 32px rgba(0,0,0,0.3);">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <div class="text-body-tertiary" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.04em;">
            Implementation Statement (read-only references from catalog)
          </div>
          <h3 style="margin: 0;"><%= stmt.label.presence || stmt.statement_id %></h3>
          <code class="text-body-secondary" style="font-size: 0.78rem;"><%= stmt.statement_id %></code>
        </div>
        <%= link_to "&times;".html_safe, ssp_document_path(@ssp_document),
              class: "text-body-secondary", style: "font-size: 1.5rem; text-decoration: none; line-height: 1;" %>
      </div>

      <%= form_with url: update_statement_ssp_document_path(@ssp_document), method: :patch, local: true do |f| %>
        <%= hidden_field_tag :statement_id, stmt.id %>

        <div class="form-group mb-3">
          <label class="fw-semibold">Implementation Prose</label>
          <%= text_area_tag "ssp_control_statement[implementation_prose]",
                stmt.implementation_prose, rows: 6, class: "form-control",
                placeholder: "Describe how this system implements this catalog statement..." %>
        </div>

        <div class="form-group mb-3">
          <label class="fw-semibold">Remarks</label>
          <%= text_area_tag "ssp_control_statement[remarks]", stmt.remarks, rows: 2, class: "form-control" %>
        </div>

        <div class="d-flex gap-2">
          <%= f.submit "Save Statement", class: "btn btn-success" %>
          <%= link_to "Cancel", ssp_document_path(@ssp_document), class: "btn btn-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%= render "shared/uuid_replaced_warning", document: @ssp_document %>

<%= render "shared/oscal_metadata_section",
           document: @ssp_document,
           update_path: update_metadata_ssp_document_path(@ssp_document),
           param_key: :ssp_document,
           version_field: :ssp_version %>

<%= render "shared/oscal_back_matter_section",
           document: @ssp_document,
           resources_path: ssp_document_back_matter_resources_path(@ssp_document) %>

<script nonce="<%= content_security_policy_nonce %>">
  function toggleAllFamilies(expand) {
    document.querySelectorAll('#controlsContainer details.sparc-family-group').forEach(function(det) {
      det.open = expand;
    });
  }

  function toggleEdit(controlId) {
    // Auto-expand card details if collapsed
    var details = document.getElementById('details-' + controlId);
    if (details && !details.open) details.open = true;

    var view = document.getElementById('view-' + controlId);
    var edit = document.getElementById('edit-' + controlId);
    var btn  = document.getElementById('edit-btn-' + controlId);
    var isEditing = edit.style.display !== 'none';
    view.style.display   = isEditing ? '' : 'none';
    edit.style.display   = isEditing ? 'none' : '';
    btn.textContent      = isEditing ? 'Edit' : 'Cancel';
    btn.style.background = isEditing ? '#3498db' : 'var(--bs-secondary-bg)';
    btn.style.color      = isEditing ? 'white'   : 'var(--bs-secondary-color)';
  }

  // Toggle arrow icons for card details, inherited rows, and catalog guidance
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.card-details').forEach(function(det) {
      det.addEventListener('toggle', function() {
        var arrow = det.querySelector('summary .card-arrow');
        if (arrow) arrow.innerHTML = det.open ? '&#9660;' : '&#9658;';
      });
    });
    document.querySelectorAll('.control-card details').forEach(function(det) {
      det.addEventListener('toggle', function() {
        var arrow = det.querySelector('summary .catalog-arrow');
        if (arrow) arrow.innerHTML = det.open ? '&#9660;' : '&#9658;';
        var inhArrow = det.querySelector('summary .inherited-arrow');
        if (inhArrow) inhArrow.innerHTML = det.open ? '&#9660;' : '&#9658;';
      });
    });
  });

  function toggleDocMeta() {
    var view = document.getElementById('doc-meta-view');
    var edit = document.getElementById('doc-meta-edit');
    var isEditing = edit.style.display !== 'none';
    view.style.display = isEditing ? '' : 'none';
    edit.style.display = isEditing ? 'none' : '';
  }

  // ── Control-level resource linking ────────────────────────────
  function toggleSspAddRef(controlId) {
    var form = document.getElementById('ssp-add-ref-' + controlId);
    var btn = document.getElementById('ssp-add-ref-btn-' + controlId);
    var isVisible = form.style.display !== 'none';
    form.style.display = isVisible ? 'none' : '';
    btn.style.display = isVisible ? '' : 'none';
    if (!isVisible) document.getElementById('ssp-ref-title-' + controlId).focus();
  }

  function createSspControlResource(controlId, controlDbId) {
    var title = document.getElementById('ssp-ref-title-' + controlDbId).value.trim();
    if (!title) { alert('Title is required'); return; }
    var href = document.getElementById('ssp-ref-href-' + controlDbId).value.trim();
    var mediaType = document.getElementById('ssp-ref-media-' + controlDbId).value.trim();
    var url = '<%= create_control_resource_ssp_document_path(@ssp_document) %>';
    var token = document.querySelector('meta[name="csrf-token"]').content;

    fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token, 'Accept': 'application/json' },
      body: JSON.stringify({ control_id: controlId, back_matter_resource: { title: title, href: href, media_type: mediaType } })
    })
    .then(function(resp) { return resp.json(); })
    .then(function(data) {
      if (data.success) { location.reload(); }
      else { alert('Error: ' + (data.error || 'Unknown error')); }
    })
    .catch(function(err) { alert('Failed: ' + err.message); });
  }

  function unlinkSspControlResource(controlId, linkId) {
    if (!confirm('Unlink this resource?')) return;
    var url = '<%= unlink_control_resource_ssp_document_path(@ssp_document) %>';
    var token = document.querySelector('meta[name="csrf-token"]').content;

    fetch(url, {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token, 'Accept': 'application/json' },
      body: JSON.stringify({ control_id: controlId, link_id: linkId })
    })
    .then(function(resp) { return resp.json(); })
    .then(function(data) {
      if (data.success) { location.reload(); }
      else { alert('Error: ' + (data.error || 'Unknown error')); }
    })
    .catch(function(err) { alert('Failed: ' + err.message); });
  }
</script>
<% end %>
