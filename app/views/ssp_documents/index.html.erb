<%= render "shared/section_summary", tiles: [
  [@total_count, "SSP Documents"],
  [@controls_count, "Total Controls"],
  [@completed_count, "Completed"]
] %>

<% if @ssp_documents.any? { |d| d.processing? || d.pending? } %>
  <meta http-equiv="refresh" content="10">
<% end %>

<div class="card">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>System Security Plans</h2>
    <div class="d-flex gap-2">
      <%= link_to "Create New SSP", wizard_ssp_documents_path, class: "btn btn-primary", style: "padding: 0.5rem 1rem; font-size: 0.875rem;" %>
      <%= link_to "Upload File", new_ssp_document_path, class: "btn btn-success" %>
    </div>
  </div>

  <% if @ssp_documents.any? %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th style="white-space: nowrap;">Name</th>
          <th style="white-space: nowrap;">Source</th>
          <th style="white-space: nowrap;">Version</th>
          <th style="white-space: nowrap;">Status</th>
          <th style="white-space: nowrap;">OSCAL</th>
          <th style="white-space: nowrap;">Controls</th>
          <th style="white-space: nowrap;">Created</th>
          <th style="white-space: nowrap;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @ssp_documents.each do |doc| %>
          <tr>
            <td><strong><%= link_to doc.name, ssp_document_path(doc), class: "text-primary", style: "text-decoration: none;" %></strong></td>
            <td>
              <% source_label, source_class = case doc.creation_method
                               when "wizard" then ["Wizard", "sparc-source-wizard"]
                               when "oscal_import" then ["OSCAL", "sparc-source-oscal"]
                               else ["Excel", "sparc-source-excel"]
                               end %>
              <span class="sparc-source-badge <%= source_class %>"><%= source_label %></span>
            </td>
            <td class="text-body-secondary" style="font-size: 0.85rem;"><%= doc.ssp_version.presence || "\u2014" %></td>
            <td style="white-space: nowrap;">
              <% if doc.processing? || doc.pending? || doc.failed? %>
                <span class="<%= doc.completed? ? 'badge-ok' : doc.failed? ? 'badge-fail' : 'badge-warn' %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.85rem;">
                  <%= doc.status %>
                </span>
                <% if doc.processing? && doc.metadata_extra&.dig("processing_message").present? %>
                  <br><span class="text-body-secondary" style="font-size: 0.72rem; white-space: normal;"><%= doc.metadata_extra["processing_message"] %></span>
                <% end %>
              <% else %>
                <span class="<%= doc.lifecycle_badge_class %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.85rem;">
                  <%= doc.lifecycle_label %>
                </span>
              <% end %>
            </td>
            <td>
              <% if doc.enriched? %>
                <span class="sparc-oscal-enriched">Enriched</span>
              <% else %>
                <span class="sparc-oscal-basic">Basic</span>
              <% end %>
            </td>
            <td><%= doc.ssp_controls.count %></td>
            <td style="white-space: nowrap;"><%= doc.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td>
              <div class="d-flex flex-wrap gap-1" style="max-width: 280px;">
                <%= link_to "View", ssp_document_path(doc), class: "btn btn-primary btn-sm", style: "padding: 0.25rem 0.6rem; font-size: 0.78rem;" %>
                <% unless doc.enriched? %>
                  <%= link_to "Enrich", enrich_ssp_document_path(doc), class: "sparc-btn-enrich-sm" %>
                <% end %>
                <% if doc.completed? %>
                  <%# #451 A1: shared partial routes dropdown clicks through the
                      Stimulus modal that surfaces specific validation errors. %>
                  <%= render "shared/oscal_export_dropdown",
                        validate_path: validate_oscal_export_ssp_document_path(doc),
                        download_json_path: download_oscal_validated_ssp_document_path(doc),
                        download_yaml_path: download_yaml_ssp_document_path(doc),
                        download_xml_path: download_xml_ssp_document_path(doc),
                        fallback_json_path: download_oscal_unvalidated_ssp_document_path(doc),
                        document_type: "SSP" %>
                <% end %>
                <%= button_to "Delete", ssp_document_path(doc), method: :delete,
                      class: "btn btn-danger btn-sm",
                      style: "padding: 0.25rem 0.6rem; font-size: 0.78rem;",
                      form: { data: { turbo_confirm: "Delete '#{doc.name}'? This cannot be undone." }, style: "display: inline;" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center p-4 text-body-secondary">No System Security Plan documents found. Upload your first workbook to get started.</p>
  <% end %>
</div>
