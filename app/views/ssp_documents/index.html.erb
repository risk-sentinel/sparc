<div class="card" style="overflow: hidden;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h2>Controls Implementation</h2>
    <%= link_to "Upload New", new_ssp_document_path, class: "btn btn-success" %>
  </div>

  <% if @ssp_documents.any? %>
    <table style="table-layout: fixed;">
      <colgroup>
        <col style="width: 20%;">
        <col style="width: 24%;">
        <col style="width: 8%;">
        <col style="width: 10%;">
        <col style="width: 10%;">
        <col style="width: 13%;">
        <col style="width: 15%;">
      </colgroup>
      <thead>
        <tr>
          <th>Name</th>
          <th>Original Filename</th>
          <th>Version</th>
          <th>Status</th>
          <th>Controls</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @ssp_documents.each do |doc| %>
          <tr>
            <td style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= doc.name %>"><%= doc.name %></td>
            <td style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 0.88rem; color: var(--text-muted);" title="<%= doc.original_filename %>"><%= doc.original_filename %></td>
            <td style="font-size: 0.85rem; color: var(--text-muted);"><%= doc.ssp_version.presence || "—" %></td>
            <td><span class="<%= doc.completed? ? 'badge-ok' : 'badge-warn' %>" style="padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.85rem; font-weight: 600;"><%= doc.status %></span></td>
            <td><%= doc.ssp_controls.count %></td>
            <td style="white-space: nowrap; font-size: 0.88rem;"><%= doc.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td>
              <div style="display: flex; flex-direction: column; gap: 0.3rem;">
                <%= link_to "View", ssp_document_path(doc), class: "btn btn-primary", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem; text-align: center;" %>
                <%= link_to "↓ JSON", download_json_ssp_document_path(doc), class: "btn btn-success", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem; text-align: center;" %>
                <%= link_to "Delete", ssp_document_path(doc), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem; text-align: center;" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p style="text-align: center; padding: 2rem; color: var(--text-muted);">No Controls Implementation documents found. Upload your first workbook to get started.</p>
  <% end %>
</div>