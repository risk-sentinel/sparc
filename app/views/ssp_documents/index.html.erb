<div class="card" style="overflow: hidden;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>System Security Plans</h2>
    <div class="d-flex gap-2">
      <%= link_to "Create New SSP", wizard_ssp_documents_path, class: "btn btn-primary" %>
      <%= link_to "Upload File", new_ssp_document_path, class: "btn btn-success" %>
    </div>
  </div>

  <% if @ssp_documents.any? %>
    <table class="table table-hover" style="table-layout: fixed;">
      <colgroup>
        <col style="width: 18%;">
        <col style="width: 18%;">
        <col style="width: 7%;">
        <col style="width: 8%;">
        <col style="width: 8%;">
        <col style="width: 8%;">
        <col style="width: 12%;">
        <col style="width: 21%;">
      </colgroup>
      <thead>
        <tr>
          <th>Name</th>
          <th>Source</th>
          <th>Version</th>
          <th>Status</th>
          <th>Controls</th>
          <th>OSCAL</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @ssp_documents.each do |doc| %>
          <tr>
            <td style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= doc.name %>"><%= doc.name %></td>
            <td class="text-body-secondary" style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
              <% case doc.creation_method %>
              <% when "wizard" %>
                <span class="sparc-source-badge sparc-source-wizard">Wizard</span>
              <% when "oscal_import" %>
                <span class="sparc-source-badge sparc-source-oscal">OSCAL Import</span>
              <% else %>
                <span class="sparc-source-badge sparc-source-excel" title="<%= doc.original_filename %>"><%= doc.original_filename.presence || "Excel" %></span>
              <% end %>
            </td>
            <td class="text-body-secondary" style="font-size: 0.85rem;"><%= doc.ssp_version.presence || "—" %></td>
            <td><span class="<%= doc.completed? ? 'badge-ok' : 'badge-warn' %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.85rem;"><%= doc.status %></span></td>
            <td><%= doc.ssp_controls.count %></td>
            <td>
              <% if doc.enriched? %>
                <span class="sparc-oscal-enriched">Enriched</span>
              <% else %>
                <span class="sparc-oscal-basic">Basic</span>
              <% end %>
            </td>
            <td style="white-space: nowrap; font-size: 0.88rem;"><%= doc.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td>
              <div class="d-flex flex-column gap-1">
                <%= link_to "View", ssp_document_path(doc), class: "btn btn-primary text-center", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;" %>
                <% unless doc.enriched? %>
                  <%= link_to "Enrich", enrich_ssp_document_path(doc), class: "sparc-btn-enrich-sm text-center" %>
                <% end %>
                <%= link_to "Delete", ssp_document_path(doc), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger text-center", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center p-4 text-body-secondary">No System Security Plan documents found. Upload your first workbook to get started.</p>
  <% end %>
</div>