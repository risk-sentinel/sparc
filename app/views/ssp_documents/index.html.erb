<div class="card" style="overflow-x: auto;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h2>Controls Implementation</h2>
    <%= link_to "Upload New", new_ssp_document_path, class: "btn btn-success" %>
  </div>

  <% if @ssp_documents.any? %>
    <table style="min-width: 700px;">
      <thead>
        <tr>
          <th>Name</th>
          <th>Original Filename</th>
          <th>Status</th>
          <th>Controls</th>
          <th>Created</th>
          <th style="text-align: right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @ssp_documents.each do |doc| %>
          <tr>
            <td style="font-weight: 600;"><%= doc.name %></td>
            <td style="font-size: 0.88rem; color: var(--text-muted);"><%= doc.original_filename %></td>
            <td><span style="padding: 0.2rem 0.6rem; background: <%= doc.completed? ? '#d4edda' : '#fff3cd' %>; color: <%= doc.completed? ? '#155724' : '#856404' %>; border-radius: 4px; font-size: 0.85rem; font-weight: 600;"><%= doc.status %></span></td>
            <td><%= doc.ssp_controls.count %></td>
            <td style="white-space: nowrap;"><%= doc.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td style="text-align: right; white-space: nowrap;">
              <div style="display: inline-flex; gap: 0.35rem;">
                <%= link_to "View", ssp_document_path(doc), class: "btn btn-primary", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;" %>
                <%= link_to "↓ JSON", download_json_ssp_document_path(doc), class: "btn btn-success", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;" %>
                <%= link_to "Delete", ssp_document_path(doc), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p style="text-align: center; padding: 2rem; color: var(--text-muted);">No Controls Implementation documents found. Upload your first workbook to get started.</p>
  <% end %>
</div>