<%= render "shared/section_summary", tiles: [
  [@total_count, "SSP Documents"],
  [@controls_count, "Total Controls"],
  [@completed_count, "Completed"]
] %>

<div class="card">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>System Security Plans</h2>
    <div class="d-flex gap-2">
      <%= link_to "Create New SSP", wizard_ssp_documents_path, class: "btn btn-primary", style: "padding: 0.5rem 1rem; font-size: 0.875rem;" %>
      <%= link_to "Upload File", new_ssp_document_path, class: "btn btn-success" %>
    </div>
  </div>

  <% if @ssp_documents.any? %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Name</th>
          <th>Source</th>
          <th>Version</th>
          <th>Status</th>
          <th>OSCAL</th>
          <th>Controls</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @ssp_documents.each do |doc| %>
          <tr>
            <td><%= doc.name %></td>
            <td>
              <% source_label, source_class = case doc.creation_method
                               when "wizard" then ["Wizard", "sparc-source-wizard"]
                               when "oscal_import" then ["OSCAL", "sparc-source-oscal"]
                               else ["Excel", "sparc-source-excel"]
                               end %>
              <span class="sparc-source-badge <%= source_class %>"><%= source_label %></span>
            </td>
            <td class="text-body-secondary" style="font-size: 0.85rem;"><%= doc.ssp_version.presence || "\u2014" %></td>
            <td><span class="<%= doc.completed? ? 'badge-ok' : 'badge-warn' %> rounded fw-semibold" style="padding: 0.25rem 0.75rem;"><%= doc.status %></span></td>
            <td>
              <% if doc.enriched? %>
                <span class="sparc-oscal-enriched">Enriched</span>
              <% else %>
                <span class="sparc-oscal-basic">Basic</span>
              <% end %>
            </td>
            <td><%= doc.ssp_controls.count %></td>
            <td><%= doc.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td style="white-space: nowrap;">
              <div style="display: inline-flex; gap: 0.35rem;">
                <%= link_to "View", ssp_document_path(doc), class: "btn btn-primary", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;" %>
                <% unless doc.enriched? %>
                  <%= link_to "Enrich", enrich_ssp_document_path(doc), class: "sparc-btn-enrich-sm" %>
                <% end %>
                <% if doc.completed? %>
                  <div class="btn-group">
                    <button type="button" class="btn btn-sm dropdown-toggle" style="background: #8e44ad; color: white;" data-bs-toggle="dropdown" aria-expanded="false">
                      Export OSCAL
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                      <li><%= link_to "OSCAL (validated)", download_oscal_ssp_document_path(doc), class: "dropdown-item" %></li>
                      <li><%= link_to "JSON", download_json_ssp_document_path(doc), class: "dropdown-item" %></li>
                      <li><%= link_to "YAML", download_yaml_ssp_document_path(doc), class: "dropdown-item" %></li>
                      <li><%= link_to "XML", download_xml_ssp_document_path(doc), class: "dropdown-item" %></li>
                    </ul>
                  </div>
                <% end %>
                <%= link_to "Delete", ssp_document_path(doc), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger", style: "padding: 0.35rem 0.75rem; font-size: 0.8rem;" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center p-4 text-body-secondary">No System Security Plan documents found. Upload your first workbook to get started.</p>
  <% end %>
</div>