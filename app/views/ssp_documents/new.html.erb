<div class="card">
  <h2>Upload System Security Plan</h2>

  <%= form_with model: @ssp_document, local: true, multipart: true do |f| %>
    <div class="form-group">
      <label for="ssp_document_file">Select File (.xlsx, .xls, .json, .xml, .yaml, .yml)</label>
      <%= f.file_field :file, accept: ".xlsx,.xls,.json,.xml,.yaml,.yml", required: true %>
      <small class="text-body-secondary d-block" style="margin-top: 0.5rem;">
        Upload an Excel workbook, OSCAL SSP JSON, OSCAL SSP XML, or OSCAL SSP YAML file.
      </small>
    </div>

    <div class="d-flex gap-3">
      <%= f.submit "Upload and Convert", class: "btn btn-success" %>
      <%= link_to "or Create from Wizard", wizard_ssp_documents_path, class: "text-body-secondary", style: "align-self: center; font-size: 0.88rem;" %>
      <%= link_to "Cancel", ssp_documents_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<div class="card">
  <h3>Import Notes</h3>
  <div class="text-body-secondary" style="font-size: 0.9rem; line-height: 1.6;">
    <p class="mb-2"><strong>Excel (.xlsx, .xls)</strong> &mdash; Workbooks must follow the expected column mapping for successful import. The mapping definition is located at <code>lib/data_mappings/ssp_excel.json</code>.</p>
    <p class="mb-0"><strong>OSCAL (JSON, XML, YAML)</strong> &mdash; OSCAL System Security Plan files are auto-detected and require no column mapping.</p>
  </div>
</div>
