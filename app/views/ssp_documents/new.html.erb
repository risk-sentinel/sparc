<div class="card">
  <h2>Upload Controls Implementation</h2>

  <%= form_with model: @ssp_document, local: true, multipart: true do |f| %>
    <div class="form-group">
      <label for="ssp_document_file">Select File (.xlsx, .xls, .json, .xml)</label>
      <%= f.file_field :file, accept: ".xlsx,.xls,.json,.xml", required: true %>
      <small style="color: var(--text-muted); display: block; margin-top: 0.5rem;">
        Upload an Excel workbook, OSCAL SSP JSON, or OSCAL SSP XML file.
      </small>
    </div>

    <div style="display: flex; gap: 1rem;">
      <%= f.submit "Upload and Convert", class: "btn btn-success" %>
      <%= link_to "or Create from Wizard", wizard_ssp_documents_path, style: "align-self: center; color: var(--text-muted); font-size: 0.88rem;" %>
      <%= link_to "Cancel", ssp_documents_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<div class="card">
  <h3>Expected Excel Format</h3>
  <p style="color: var(--text-muted); margin-bottom: 1rem;">Your workbook should contain the following columns. Read-only fields are imported as-is; editable fields can be updated after upload.</p>

  <table>
    <thead>
      <tr>
        <th>Column</th>
        <th>Editable</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      <tr><td><strong>Paragraph/ReqID</strong></td><td>No</td><td>Primary identifier. Null rows are Provider Statements collapsed under the last populated ID.</td></tr>
      <tr><td><strong>Title</strong></td><td>No</td><td>Null on provider rows.</td></tr>
      <tr><td><strong>Stated Requirement</strong></td><td>No</td><td></td></tr>
      <tr><td><strong>Private Implementation</strong></td><td>Yes</td><td></td></tr>
      <tr><td><strong>Public Implementation</strong></td><td>Yes</td><td>Null on provider rows; shown collapsed.</td></tr>
      <tr><td><strong>Notes</strong></td><td>Yes</td><td>Collapsed by default.</td></tr>
      <tr><td><strong>Status</strong></td><td>Yes</td><td>Deferred · Implemented · Not Applicable · Will Not Implement</td></tr>
      <tr><td><strong>Expected Completion</strong></td><td>Yes</td><td>Null on provider rows; collapsed.</td></tr>
      <tr><td><strong>Class</strong></td><td>No</td><td></td></tr>
      <tr><td><strong>Priority</strong></td><td>No</td><td></td></tr>
      <tr><td><strong>Responsible Entities</strong></td><td>Yes</td><td>Null on provider rows; collapsed.</td></tr>
      <tr><td><strong>Control Owner</strong></td><td>No</td><td>Null on provider rows; collapsed.</td></tr>
      <tr><td><strong>Type/Use As</strong></td><td>Yes</td><td></td></tr>
      <tr><td><strong>Inherited From</strong></td><td>No</td><td></td></tr>
      <tr><td><strong>Provided As</strong></td><td>Yes</td><td></td></tr>
      <tr><td><strong>Control Origination</strong></td><td>Yes</td><td></td></tr>
      <tr><td><strong>History</strong></td><td>No</td><td></td></tr>
    </tbody>
  </table>
</div>
