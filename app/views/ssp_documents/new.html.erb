<div class="card">
  <h2>Upload System Security Plan</h2>

  <%= form_with model: @ssp_document, local: true, multipart: true do |f| %>
    <%= render "shared/dropzone",
      form: f,
      field: :file,
      accept: ".xlsx,.xls,.json,.xml,.yaml,.yml",
      multiple: true,
      hint: "Upload an Excel workbook, OSCAL SSP JSON, OSCAL SSP XML, or OSCAL SSP YAML file." %>

    <div class="d-flex gap-3">
      <%= f.submit "Upload and Convert", class: "btn btn-success" %>
      <%= link_to "or Create from Wizard", wizard_ssp_documents_path, class: "text-body-secondary", style: "align-self: center; font-size: 0.88rem;" %>
      <%= link_to "Cancel", ssp_documents_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

<div class="card">
  <h2>Create from Published Profile</h2>
  <p class="text-body-secondary mb-3">
    Generate a System Security Plan from a published OSCAL Profile's resolved catalog.
    Baseline controls, statements, and guidance will be pre-populated. Implementation
    details, status, and responsible entities can be edited after creation.
  </p>
  <%= link_to "Select a Profile", select_profile_ssp_documents_path, class: "btn btn-primary" %>
</div>

<div class="card">
  <h3>Supported Formats</h3>
  <p class="text-body-secondary mb-3">SPARC automatically detects the file format and parses OSCAL SSP content including system characteristics, components, users, and control implementations.</p>

  <table class="table table-hover">
    <thead>
      <tr>
        <th>Format</th>
        <th>Extension</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><strong>Excel</strong></td>
        <td>.xlsx, .xls</td>
        <td>Workbooks following the expected SSP column mapping</td>
      </tr>
      <tr>
        <td><strong>OSCAL JSON</strong></td>
        <td>.json</td>
        <td>NIST OSCAL v1.1.2 System Security Plan documents</td>
      </tr>
      <tr>
        <td><strong>OSCAL YAML</strong></td>
        <td>.yaml, .yml</td>
        <td>OSCAL SSP in YAML format (auto-converted to JSON for parsing)</td>
      </tr>
      <tr>
        <td><strong>OSCAL XML</strong></td>
        <td>.xml</td>
        <td>OSCAL SSP in XML format (auto-converted to JSON for parsing)</td>
      </tr>
    </tbody>
  </table>
</div>
