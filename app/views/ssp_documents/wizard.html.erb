<div class="card">
  <h2>Create New SSP from Wizard</h2>
  <p class="text-body-secondary mb-4">
    Build a System Security Plan by selecting a Profile baseline, assembling components from CDEFs,
    and configuring system characteristics. Controls are auto-populated from the selected profile.
  </p>

  <%= form_with url: create_from_wizard_ssp_documents_path, method: :post, local: true do |f| %>

    <%# ── Step 1: Basics ── %>
    <details open class="mb-3 border rounded-3" style="overflow: hidden;">
      <summary class="bg-body-secondary fw-semibold d-flex align-items-center gap-2" style="cursor: pointer; padding: 0.85rem 1rem; font-size: 0.95rem; color: var(--bs-body-color); list-style: none; user-select: none;">
        <span class="sparc-status--info" style="border-radius: 50%; width: 22px; height: 22px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">1</span>
        System Basics
      </summary>
      <div style="padding: 1rem 1.25rem;">
        <div class="form-group">
          <label for="name">System Name <span class="sparc-required">*</span></label>
          <%= f.text_field :name, required: true, class: "form-control", placeholder: "e.g., My Agency System" %>
        </div>
        <div class="form-group">
          <label for="description">Description</label>
          <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Brief description of the system..." %>
        </div>
        <div class="form-group">
          <label for="profile_document_id">Profile Baseline <span class="sparc-required">*</span></label>
          <% if @profiles.any? %>
            <%= f.select :profile_document_id,
                  @profiles.map { |p| ["#{p.name} (#{p.profile_controls.count} controls)", p.id] },
                  { include_blank: "-- Select a Profile --" },
                  { required: true, class: "form-control" } %>
            <small class="text-body-secondary d-block" style="margin-top: 0.3rem;">
              Controls from this profile will be imported into the SSP.
            </small>
          <% else %>
            <p class="sparc-heading-danger" style="font-size: 0.88rem;">
              No completed profiles found. Please
              <%= link_to "upload a Profile", new_profile_document_path %> first.
            </p>
          <% end %>
        </div>
      </div>
    </details>

    <%# ── Step 2: Components (CDEFs) ── %>
    <details class="mb-3 border rounded-3" style="overflow: hidden;">
      <summary class="bg-body-secondary fw-semibold d-flex align-items-center gap-2" style="cursor: pointer; padding: 0.85rem 1rem; font-size: 0.95rem; color: var(--bs-body-color); list-style: none; user-select: none;">
        <span class="sparc-status--success" style="border-radius: 50%; width: 22px; height: 22px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">2</span>
        Component Definitions (Optional)
      </summary>
      <div style="padding: 1rem 1.25rem;">
        <% if @cdefs.any? %>
          <p class="text-body-secondary" style="font-size: 0.88rem; margin-bottom: 0.75rem;">
            Select CDEFs to import as components. Matching control implementations will be auto-filled.
          </p>
          <% @cdefs.each do |cdef| %>
            <label class="d-flex align-items-center gap-2 border rounded-2 bg-body" style="padding: 0.6rem 0.75rem; margin-bottom: 0.4rem; cursor: pointer;" for="cdef-import-<%= cdef.id %>">
              <%= check_box_tag "cdef_document_ids[]", cdef.id, false, id: "cdef-import-#{cdef.id}", style: "width: 16px; height: 16px;" %>
              <div>
                <div class="fw-semibold" style="font-size: 0.88rem;"><%= cdef.name %></div>
                <div class="text-body-secondary" style="font-size: 0.75rem;">
                  <%= cdef.cdef_controls.count %> controls
                  <% if cdef.description.present? %>
                    &mdash; <%= truncate(cdef.description, length: 80) %>
                  <% end %>
                </div>
              </div>
            </label>
          <% end %>
        <% else %>
          <p class="text-body-secondary" style="font-size: 0.88rem;">
            No completed CDEFs found. You can still create an SSP without components, or
            <%= link_to "upload a CDEF", new_cdef_document_path %> first.
          </p>
        <% end %>
      </div>
    </details>

    <%# ── Step 3: System Characteristics ── %>
    <details class="mb-3 border rounded-3" style="overflow: hidden;">
      <summary class="bg-body-secondary fw-semibold d-flex align-items-center gap-2" style="cursor: pointer; padding: 0.85rem 1rem; font-size: 0.95rem; color: var(--bs-body-color); list-style: none; user-select: none;">
        <span class="sparc-status--orange" style="border-radius: 50%; width: 22px; height: 22px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">3</span>
        System Characteristics
      </summary>
      <div style="padding: 1rem 1.25rem;">
        <div class="row row-cols-1 row-cols-md-2 g-3">
          <div class="form-group">
            <label for="security_sensitivity_level">Security Sensitivity Level</label>
            <%= f.select :security_sensitivity_level,
                  [["Low (FIPS 199)", "fips-199-low"], ["Moderate (FIPS 199)", "fips-199-moderate"], ["High (FIPS 199)", "fips-199-high"]],
                  { include_blank: "-- Select --" },
                  { class: "form-control" } %>
          </div>
          <div class="form-group">
            <label for="system_status">System Status</label>
            <%= f.select :system_status,
                  SspDocument::SYSTEM_STATUSES.map { |s| [s.titleize, s] },
                  { include_blank: "-- Select --" },
                  { class: "form-control" } %>
          </div>
          <div class="form-group">
            <label for="security_objective_confidentiality">Confidentiality Objective</label>
            <%= f.select :security_objective_confidentiality,
                  [["Low", "fips-199-low"], ["Moderate", "fips-199-moderate"], ["High", "fips-199-high"]],
                  { include_blank: "-- Select --" },
                  { class: "form-control" } %>
          </div>
          <div class="form-group">
            <label for="security_objective_integrity">Integrity Objective</label>
            <%= f.select :security_objective_integrity,
                  [["Low", "fips-199-low"], ["Moderate", "fips-199-moderate"], ["High", "fips-199-high"]],
                  { include_blank: "-- Select --" },
                  { class: "form-control" } %>
          </div>
          <div class="form-group">
            <label for="security_objective_availability">Availability Objective</label>
            <%= f.select :security_objective_availability,
                  [["Low", "fips-199-low"], ["Moderate", "fips-199-moderate"], ["High", "fips-199-high"]],
                  { include_blank: "-- Select --" },
                  { class: "form-control" } %>
          </div>
        </div>
        <div class="form-group">
          <label for="authorization_boundary_description">Authorization Boundary</label>
          <%= f.text_area :authorization_boundary_description, class: "form-control", rows: 3,
                placeholder: "Describe the authorization boundary for this system..." %>
        </div>
      </div>
    </details>

    <%# ── Step 4: Review & Create ── %>
    <details open class="mb-3 border rounded-3" style="overflow: hidden;">
      <summary class="bg-body-secondary fw-semibold d-flex align-items-center gap-2" style="cursor: pointer; padding: 0.85rem 1rem; font-size: 0.95rem; color: var(--bs-body-color); list-style: none; user-select: none;">
        <span class="sparc-status--purple" style="border-radius: 50%; width: 22px; height: 22px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">4</span>
        Review & Create
      </summary>
      <div style="padding: 1rem 1.25rem;">
        <p class="text-body-secondary mb-3" style="font-size: 0.88rem;">
          Review your selections above, then click "Create SSP" to generate the System Security Plan.
          Controls from the selected profile will be imported, and matching CDEF implementations will be auto-filled.
        </p>
        <div class="d-flex gap-3">
          <%= f.submit "Create SSP", class: "btn btn-success" %>
          <%= link_to "Cancel", ssp_documents_path, class: "btn btn-secondary" %>
        </div>
      </div>
    </details>

  <% end %>
</div>
