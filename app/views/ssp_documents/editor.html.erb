<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>System Security Plan Editor</title>
    <link rel="stylesheet" href="<%= asset_path 'ssp_editor.css' %>">
</head>
<body>
    <div class="container"
         data-controller="ssp-editor"
         data-ssp-editor-api-base-url-value="/api/v1"
         data-ssp-editor-download-path-value="/ssp_documents/__ID__/download_json">
        <h1>🔐 System Security Plan Editor</h1>

        <%# #479: The Excel-to-JSON upload section was removed from the UI.
            The underlying conversion route and parser service still exist
            for API consumers; this view no longer surfaces the entry point. %>

        <!-- Existing Document Selector -->
        <div class="json-section">
            <h2>📁 Load Existing Document</h2>
            <div class="upload-container">
                <label for="documentSelector"><strong>Select Document:</strong></label>
                <select id="documentSelector" data-ssp-editor-target="documentSelector" data-action="change->ssp-editor#loadExistingDocument">
                    <option value="">-- Select a document --</option>
                    <% SspDocument.completed.order(created_at: :desc).each do |doc| %>
                      <option value="<%= doc.id %>"><%= doc.name %> (<%= doc.created_at.strftime('%Y-%m-%d') %>)</option>
                    <% end %>
                </select>
            </div>
        </div>
        
        <div id="notification" class="notification" data-ssp-editor-target="notification"></div>

        <div id="navigationContainer" class="navigation-container" style="display: none;" data-ssp-editor-target="navigationContainer">
            <div class="navigation-controls">
                <div class="record-counter">
                    <span id="recordCounter" data-ssp-editor-target="recordCounter">Record 0 of 0</span>
                </div>
                <select id="recordSelector" aria-label="Select record" data-ssp-editor-target="recordSelector" data-action="change->ssp-editor#selectRecord">
                    <!-- Options will be populated dynamically -->
                </select>
                <div class="nav-buttons">
                    <button class="nav-btn" id="prevBtn" data-ssp-editor-target="prevBtn" data-action="ssp-editor#navigatePrev">⬅️ Previous</button>
                    <button class="nav-btn" id="nextBtn" data-ssp-editor-target="nextBtn" data-action="ssp-editor#navigateNext">Next ➡️</button>
                </div>
            </div>
        </div>
        
        <div class="legend" style="display: none;" data-ssp-editor-target="legend">
            <div class="legend-title">Legend:</div>
            <div class="legend-items">
                <div class="legend-item">
                    <span class="editable-icon">✏️</span>
                    <span>Editable Field</span>
                </div>
                <div class="legend-item">
                    <span class="locked-icon">🔒</span>
                    <span>Locked Field</span>
                </div>
            </div>
        </div>
        
        <div id="headerInfo" class="header-info" style="display: none;" data-ssp-editor-target="headerInfo">
            <strong>Control ID:</strong> <span id="controlId" data-ssp-editor-target="controlId"></span> |
            <strong>Title:</strong> <span id="controlTitle" data-ssp-editor-target="controlTitle"></span>
        </div>

        <table id="dataTable" class="table table-hover" style="display: none;" data-ssp-editor-target="dataTable">
            <thead>
                <tr>
                    <th>Field Name</th>
                    <th>Value</th>
                </tr>
            </thead>
            <tbody id="tableBody" data-ssp-editor-target="tableBody">
                <!-- Data will be inserted here -->
            </tbody>
        </table>
        
        <div class="button-container" id="actionButtons" style="display: none;" data-ssp-editor-target="actionButtons">
            <button class="reset-btn" data-action="ssp-editor#resetCurrentRecord">🔄 Reset Current</button>
            <button class="save-btn" data-action="ssp-editor#saveCurrentRecord">💾 Save Current</button>
            <button class="save-all-btn" data-action="ssp-editor#saveAllRecords">💾 Save All Changes</button>
            <button class="export-btn" data-action="ssp-editor#exportJSON">📥 Export JSON</button>
        </div>
    </div>
</body>
</html>