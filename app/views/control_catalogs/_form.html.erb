<%= form_with model: control_catalog, local: true do |f| %>
  <% if control_catalog.errors.any? %>
    <div class="flash error mb-4">
      <strong><%= pluralize(control_catalog.errors.count, "error") %>:</strong>
      <ul style="margin-top: 0.5rem; margin-left: 1.5rem;">
        <% control_catalog.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name, "Catalog Name *" %>
    <%= f.text_field :name, class: "form-control", placeholder: "e.g. NIST SP 800-53 Rev 5" %>
  </div>

  <div class="row row-cols-1 row-cols-md-2 g-3">
    <div class="col">
      <div class="form-group">
        <%= f.label :version, "Version" %>
        <%= f.text_field :version, class: "form-control", placeholder: "e.g. 5.1.1" %>
      </div>
    </div>
    <div class="col">
      <div class="form-group">
        <%= f.label :source, "Source" %>
        <%= f.text_field :source, class: "form-control", placeholder: "e.g. NIST, CIS, ISO" %>
      </div>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :description %>
    <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Optional description of this catalog..." %>
  </div>

  <div class="d-flex gap-3 mt-3">
    <%= f.submit "Save Catalog", class: "btn btn-success" %>
    <%= link_to "Cancel", control_catalogs_path, class: "btn btn-secondary" %>
  </div>
<% end %>
