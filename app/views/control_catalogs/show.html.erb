<div class="card">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <div>
      <h2><%= @control_catalog.name %></h2>
      <p style="color: var(--text-muted); margin-top: 0.5rem;">
        <% if @control_catalog.version.present? %>
          Version: <strong><%= @control_catalog.version %></strong> &nbsp;|&nbsp;
        <% end %>
        <% if @control_catalog.source.present? %>
          Source: <strong><%= @control_catalog.source %></strong> &nbsp;|&nbsp;
        <% end %>
        Families: <strong><%= @control_families.size %></strong> &nbsp;|&nbsp;
        Total Controls: <strong><%= @control_catalog.total_controls %></strong>
      </p>
      <% if @control_catalog.description.present? %>
        <p style="margin-top: 0.5rem; color: var(--text-muted);"><%= @control_catalog.description %></p>
      <% end %>
    </div>
    <div style="display: flex; gap: 0.75rem;">
      <%= link_to "↑ Import / Refresh", import_control_catalogs_path,
            style: "background: #8e44ad; color: white; text-decoration: none; padding: 0.45rem 1rem; border-radius: 5px; font-size: 0.875rem; font-weight: 600;" %>
      <%= link_to "Edit Catalog", edit_control_catalog_path(@control_catalog), class: "btn", style: "background: #f39c12; color: white;" %>
      <%= link_to "＋ Add Family", new_control_catalog_control_family_path(@control_catalog), class: "btn btn-success" %>
      <%= link_to "← All Catalogs", control_catalogs_path, class: "btn btn-primary" %>
    </div>
  </div>

  <% if @control_families.any? %>
    <table>
      <thead>
        <tr>
          <th style="width: 80px;">Code</th>
          <th>Family Name</th>
          <th>Description</th>
          <th style="text-align: center;">Controls</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @control_families.each do |family| %>
          <tr>
            <td>
              <span style="font-family: monospace; font-size: 1rem; font-weight: 700; color: var(--text); background: var(--surface-alt); padding: 0.25rem 0.6rem; border-radius: 4px;">
                <%= family.code %>
              </span>
            </td>
            <td><strong><%= link_to family.name, family, style: "color: var(--link-accent); text-decoration: none;" %></strong></td>
            <td style="color: var(--text-muted); font-size: 0.9rem;"><%= truncate(family.description, length: 80) %></td>
            <td style="text-align: center;"><%= family.catalog_controls.size %></td>
            <td>
              <div style="display: flex; gap: 0.5rem;">
                <%= link_to "View", family, class: "btn btn-primary", style: "padding: 0.35rem 0.7rem; font-size: 0.8rem;" %>
                <%= link_to "Edit", edit_control_family_path(family), class: "btn", style: "background: #f39c12; color: white; padding: 0.35rem 0.7rem; font-size: 0.8rem;" %>
                <%= button_to "Delete", family, method: :delete,
                    data: { confirm: "Delete family #{family.code}? This removes all its controls." },
                    class: "btn btn-danger", style: "padding: 0.35rem 0.7rem; font-size: 0.8rem;" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
      <p>No families yet. <%= link_to "Add the first family", new_control_catalog_control_family_path(@control_catalog), style: "color: var(--link-accent);" %></p>
    </div>
  <% end %>
</div>
