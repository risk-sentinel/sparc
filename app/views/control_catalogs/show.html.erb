<div class="card">
  <div class="card-body">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2><%= @control_catalog.name %></h2>
      <p class="text-body-secondary" style="margin-top: 0.5rem;">
        <% if @control_catalog.version.present? %>
          Version: <strong><%= @control_catalog.version %></strong> &nbsp;|&nbsp;
        <% end %>
        <% if @control_catalog.source.present? %>
          Source: <strong><%= @control_catalog.source %></strong> &nbsp;|&nbsp;
        <% end %>
        Families: <strong><%= @control_families.size %></strong> &nbsp;|&nbsp;
        Total Controls: <strong><%= @control_catalog.total_controls %></strong>
      </p>
      <% if @control_catalog.description.present? %>
        <p class="text-body-secondary" style="margin-top: 0.5rem;"><%= @control_catalog.description %></p>
      <% end %>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <%= link_to "Export OSCAL".html_safe, download_oscal_control_catalog_path(@control_catalog),
            style: "background: rgba(142,68,173,0.3); color: white; text-decoration: none; padding: 0.45rem 1rem; border-radius: 6px; font-size: 0.85rem; border: 1px solid rgba(142,68,173,0.5); white-space: nowrap;" %>
      <%= link_to "↑ Import / Refresh", import_control_catalogs_path,
            class: "btn fw-semibold", style: "background: #8e44ad; color: white; text-decoration: none; font-size: 0.875rem;" %>
      <%= link_to "Edit Catalog", edit_control_catalog_path(@control_catalog), class: "btn", style: "background: #f39c12; color: white;" %>
      <%= link_to "＋ Add Family", new_control_catalog_control_family_path(@control_catalog), class: "btn btn-success" %>
      <%= link_to "← All Catalogs", control_catalogs_path, class: "btn btn-primary" %>
    </div>
  </div>

  <% if @control_catalog.uuid.present? || @control_catalog.oscal_version.present? %>
    <div class="card bg-body-secondary mb-3" style="border: 1px solid rgba(142,68,173,0.3);">
      <div class="card-body py-2 px-3">
        <small class="text-body-secondary">
          <strong>OSCAL</strong>
          <% if @control_catalog.uuid.present? %>
            &nbsp;|&nbsp; UUID: <code><%= @control_catalog.uuid %></code>
          <% end %>
          <% if @control_catalog.oscal_version.present? %>
            &nbsp;|&nbsp; OSCAL Version: <strong><%= @control_catalog.oscal_version %></strong>
          <% end %>
          <% if @control_catalog.metadata_extra.present? && @control_catalog.metadata_extra.any? %>
            &nbsp;|&nbsp; Metadata: <%= @control_catalog.metadata_extra.keys.join(", ") %>
          <% end %>
        </small>
      </div>
    </div>
  <% end %>

  <% if @control_families.any? %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th style="width: 80px;">Code</th>
          <th>Family Name</th>
          <th>Description</th>
          <th class="text-center">Controls</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @control_families.each do |family| %>
          <tr>
            <td>
              <span class="fw-bold bg-body-secondary rounded" style="font-family: monospace; font-size: 1rem; padding: 0.25rem 0.6rem;">
                <%= family.code %>
              </span>
            </td>
            <td><strong><%= link_to family.name, family, class: "text-primary", style: "text-decoration: none;" %></strong></td>
            <td class="text-body-secondary small"><%= truncate(family.description, length: 80) %></td>
            <td class="text-center"><%= family.catalog_controls.size %></td>
            <td>
              <div class="d-flex gap-2">
                <%= link_to "View", family, class: "btn btn-primary btn-sm" %>
                <%= link_to "Edit", edit_control_family_path(family), class: "btn btn-sm", style: "background: #f39c12; color: white;" %>
                <%= button_to "Delete", family, method: :delete,
                    data: { confirm: "Delete family #{family.code}? This removes all its controls." },
                    class: "btn btn-danger btn-sm" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center text-body-secondary p-4">
      <p>No families yet. <%= link_to "Add the first family", new_control_catalog_control_family_path(@control_catalog), class: "text-primary" %></p>
    </div>
  <% end %>
  </div>
</div>
