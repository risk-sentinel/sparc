<div class="card">
  <div class="card-body">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2><%= @control_catalog.name %></h2>
      <p class="text-body-secondary" style="margin-top: 0.5rem;">
        <% if @control_catalog.version.present? %>
          Version: <strong><%= @control_catalog.version %></strong> &nbsp;|&nbsp;
        <% end %>
        <% if @control_catalog.source.present? %>
          Source: <strong><%= @control_catalog.source %></strong> &nbsp;|&nbsp;
        <% end %>
        Families: <strong><%= @control_families.size %></strong> &nbsp;|&nbsp;
        Total Controls: <strong><%= @control_catalog.total_controls %></strong>
      </p>
      <% if @control_catalog.description.present? %>
        <p class="text-body-secondary" style="margin-top: 0.5rem;"><%= @control_catalog.description %></p>
      <% end %>
    </div>
    <div class="d-flex gap-2">
      <% if can_write_catalogs? %>
        <%= link_to "↑ Import / Refresh", import_control_catalogs_path,
              class: "btn btn-sparc-purple fw-semibold", style: "font-size: 0.875rem;" %>
        <%= link_to "Edit Catalog", edit_control_catalog_path(@control_catalog), class: "btn btn-sparc-orange" %>
        <%= link_to "＋ Add Family", new_control_catalog_control_family_path(@control_catalog), class: "btn btn-success" %>
      <% end %>
      <% if signed_in? %>
        <div class="btn-group">
          <button type="button" class="btn btn-sparc-purple fw-semibold dropdown-toggle"
                  data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.875rem;">
            Export OSCAL
          </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><%= link_to "OSCAL JSON (validated)", download_oscal_control_catalog_path(@control_catalog), class: "dropdown-item" %></li>
            <li><%= link_to "YAML", download_yaml_control_catalog_path(@control_catalog), class: "dropdown-item" %></li>
            <li><%= link_to "XML", download_xml_control_catalog_path(@control_catalog), class: "dropdown-item" %></li>
          </ul>
        </div>
      <% end %>
      <%= link_to "← All Catalogs", control_catalogs_path, class: "btn btn-primary" %>
    </div>
  </div>

  <% if @control_families.any? %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th style="width: 80px;">Code</th>
          <th>Family Name</th>
          <th>Description</th>
          <th class="text-center">Controls</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @control_families.each do |family| %>
          <tr>
            <td>
              <span class="fw-bold bg-body-secondary rounded" style="font-family: monospace; font-size: 1rem; padding: 0.25rem 0.6rem;">
                <%= family.code %>
              </span>
            </td>
            <td><strong><%= link_to family.name, family, class: "text-primary", style: "text-decoration: none;" %></strong></td>
            <td class="text-body-secondary small"><%= truncate(family.description, length: 80) %></td>
            <td class="text-center"><%= family.catalog_controls.size %></td>
            <td>
              <div class="d-flex gap-2">
                <%= link_to "View", family, class: "btn btn-primary btn-sm" %>
                <% if can_write_catalogs? %>
                  <%= link_to "Edit", edit_control_family_path(family), class: "btn btn-sm btn-sparc-orange" %>
                  <%= button_to "Delete", family, method: :delete,
                      data: { confirm: "Delete family #{family.code}? This removes all its controls." },
                      class: "btn btn-danger btn-sm" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center text-body-secondary p-4">
      <p>No families yet.
        <% if can_write_catalogs? %>
          <%= link_to "Add the first family", new_control_catalog_control_family_path(@control_catalog), class: "text-primary" %>
        <% end %>
      </p>
    </div>
  <% end %>
  </div>
</div>

<% if can_write_catalogs? %>
  <%= render "shared/oscal_metadata_section",
             document: @control_catalog,
             update_path: update_metadata_control_catalog_path(@control_catalog),
             param_key: :control_catalog,
             version_field: :version %>
<% end %>
