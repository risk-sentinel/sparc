<div class="card">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <div>
      <h2>Control Catalogs</h2>
      <p style="color: var(--text-muted); margin-top: 0.5rem;">Manage NIST and custom control catalogs</p>
    </div>
    <div style="display: flex; gap: 0.6rem; flex-wrap: wrap;">
      <%= link_to "↑ Import from File", import_control_catalogs_path,
            style: "background: #8e44ad; color: white; text-decoration: none; padding: 0.45rem 1rem; border-radius: 5px; font-size: 0.875rem; font-weight: 600; white-space: nowrap;" %>
      <%= link_to "＋ New Catalog", new_control_catalog_path, class: "btn btn-success" %>
    </div>
  </div>

  <% if @control_catalogs.any? %>
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Version</th>
          <th>Source</th>
          <th>Families</th>
          <th>Controls</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @control_catalogs.each do |catalog| %>
          <tr>
            <td><strong><%= link_to catalog.name, catalog, style: "color: var(--link-accent); text-decoration: none;" %></strong></td>
            <td><%= catalog.version.presence || "—" %></td>
            <td><%= catalog.source.presence || "—" %></td>
            <td><%= catalog.control_families.size %></td>
            <td><%= catalog.total_controls %></td>
            <td>
              <div style="display: flex; gap: 0.5rem;">
                <%= link_to "View", catalog, class: "btn btn-primary", style: "padding: 0.4rem 0.8rem; font-size: 0.85rem;" %>
                <%= link_to "Edit", edit_control_catalog_path(catalog), class: "btn", style: "background: #f39c12; color: white; padding: 0.4rem 0.8rem; font-size: 0.85rem;" %>
                <%= button_to "Delete", catalog, method: :delete,
                    data: { confirm: "Delete '#{catalog.name}'? This will remove all families and controls." },
                    class: "btn btn-danger", style: "padding: 0.4rem 0.8rem; font-size: 0.85rem;" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div style="text-align: center; padding: 3rem; color: var(--text-muted);">
      <p style="font-size: 1.1rem; margin-bottom: 1rem;">No control catalogs yet.</p>
      <%= link_to "Create your first catalog", new_control_catalog_path, class: "btn btn-success" %>
      <p style="margin-top: 1rem; font-size: 0.9rem;">Or run <code>bin/rails db:seed</code> to load the NIST SP 800-53 Rev 5 catalog.</p>
    </div>
  <% end %>
</div>
