<%= render "shared/section_summary", tiles: [
  [@total_count, "Catalogs"],
  [@family_count, "Families"],
  [@control_count, "Controls"]
] %>

<% if @control_catalogs.any? { |c| c.processing? || c.pending? } %>
  <meta http-equiv="refresh" content="10">
<% end %>

<div class="card">
  <div class="card-body">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2>Control Catalogs</h2>
      <p class="text-body-secondary" style="margin-top: 0.5rem;">Manage NIST and custom control catalogs</p>
    </div>
    <% if can_write_catalogs? %>
      <div class="d-flex flex-wrap gap-2">
        <%= link_to "↑ Import from File", import_control_catalogs_path,
              class: "btn fw-semibold", style: "background: #8e44ad; color: white; text-decoration: none; font-size: 0.875rem; white-space: nowrap;" %>
        <%= link_to "＋ New Catalog", new_control_catalog_path, class: "btn btn-success" %>
      </div>
    <% end %>
  </div>

  <% if @control_catalogs.any? %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Name</th>
          <th>Version</th>
          <th>Source</th>
          <th>Status</th>
          <th>Families</th>
          <th>Controls</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @control_catalogs.each do |catalog| %>
          <tr>
            <td>
              <strong><%= link_to catalog.name, catalog, class: "text-primary", style: "text-decoration: none;" %></strong>
              <% if catalog.original_filename.present? %>
                <% ext = File.extname(catalog.original_filename).delete(".").upcase %>
                <% badge_color = { "JSON" => "#3498db", "XML" => "#27ae60", "YAML" => "#8e44ad", "YML" => "#8e44ad" }[ext] || "#95a5a6" %>
                <span class="badge" style="background: <%= badge_color %>; font-size: 0.65rem; vertical-align: middle; margin-left: 0.35rem;"><%= ext %></span>
              <% end %>
            </td>
            <td><%= catalog.version.presence || "—" %></td>
            <td><%= catalog.source.presence || "—" %></td>
            <td style="white-space: nowrap;">
              <span class="<%= catalog.completed? ? 'badge-ok' : catalog.failed? ? 'badge-fail' : 'badge-warn' %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.85rem;">
                <%= catalog.status %>
              </span>
              <% if catalog.processing? && catalog.metadata_extra&.dig("processing_message").present? %>
                <br><span class="text-body-secondary" style="font-size: 0.72rem; white-space: normal;"><%= catalog.metadata_extra["processing_message"] %></span>
              <% end %>
            </td>
            <td><%= catalog.control_families.size %></td>
            <td><%= catalog.total_controls %></td>
            <td>
              <div style="display: inline-flex; gap: 0.35rem;">
                <%= link_to "View", catalog, class: "btn btn-primary", style: "padding: 0.4rem 0.8rem; font-size: 0.85rem;" %>
                <div class="btn-group">
                  <button type="button" class="btn btn-sm dropdown-toggle" style="background: #8e44ad; color: white;" data-bs-toggle="dropdown" aria-expanded="false">
                    Export OSCAL
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li><h6 class="dropdown-header">OSCAL (validated)</h6></li>
                    <li><%= link_to "JSON", download_oscal_control_catalog_path(catalog), class: "dropdown-item" %></li>
                    <li><%= link_to "YAML", download_yaml_control_catalog_path(catalog), class: "dropdown-item" %></li>
                    <li><%= link_to "XML", download_xml_control_catalog_path(catalog), class: "dropdown-item" %></li>
                  </ul>
                </div>
                <% if can_write_catalogs? %>
                  <%= link_to "Edit", edit_control_catalog_path(catalog), class: "btn", style: "background: #f39c12; color: white; padding: 0.4rem 0.8rem; font-size: 0.85rem;" %>
                  <%= button_to "Delete", catalog, method: :delete,
                      form: { data: { turbo_confirm: "Delete '#{catalog.name}'? This will remove all families and controls." } },
                      class: "btn btn-danger", style: "padding: 0.4rem 0.8rem; font-size: 0.85rem;" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center text-body-secondary p-4">
      <p style="font-size: 1.1rem;" class="mb-3">No control catalogs yet.</p>
      <% if can_write_catalogs? %>
        <%= link_to "Create your first catalog", new_control_catalog_path, class: "btn btn-success" %>
        <p class="mt-3 small">Or run <code>bin/rails db:seed</code> to load the NIST SP 800-53 Rev 5 catalog.</p>
      <% end %>
    </div>
  <% end %>
  </div>
</div>
