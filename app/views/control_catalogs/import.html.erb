<div class="card" style="max-width: 760px; margin: 0 auto;">
  <div class="card-body">

  <%# Header %>
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
      <h2 style="margin: 0 0 0.35rem;">Import Control Catalog</h2>
      <p class="text-body-tertiary small" style="margin: 0;">
        Load a full catalog from an OSCAL JSON, OSCAL YAML, OSCAL XML, or legacy NIST XML file. Existing controls are updated; new ones are created.
      </p>
    </div>
    <%= link_to "← All Catalogs", control_catalogs_path,
          class: "btn bg-body-secondary text-body-secondary border small", style: "text-decoration: none; white-space: nowrap; flex-shrink: 0;" %>
  </div>

  <%# Upload form %>
  <%= form_with url: import_control_catalogs_path, method: :post,
        html: { enctype: "multipart/form-data" },
        data: { turbo: false } do |f| %>

    <div style="margin-bottom: 1.25rem;">
      <%= render "shared/dropzone",
        form: f,
        field: :catalog_file,
        accept: ".json,.yaml,.yml,.xml",
        hint: "Upload an OSCAL JSON, OSCAL YAML, OSCAL XML, or legacy NIST SCAP XML catalog file." %>
    </div>

    <div class="d-flex gap-2 align-items-center mb-4">
      <%= f.submit "Import Catalog", class: "btn btn-success fw-semibold" %>
      <span class="text-body-tertiary" style="font-size: 0.8rem;">Large catalogs are processed in the background.</span>
    </div>
  <% end %>

  <%# ── Supported Format Reference ── %>
  <div class="border-top" style="padding-top: 1.5rem;">
    <h3 class="fw-bold" style="font-size: 1rem; margin: 0 0 1rem;">Supported Formats</h3>

    <div class="row row-cols-1 row-cols-md-2 g-3" style="margin-bottom: 1.25rem;">

      <%# OSCAL JSON %>
      <div class="col"><div class="bg-body-secondary border rounded" style="border-left: 3px solid var(--sparc-primary) !important; padding: 1rem;">
        <div class="d-flex align-items-center gap-2" style="margin-bottom: 0.5rem;">
          <span class="fw-bold sparc-status sparc-status--info" style="font-size: 0.72rem; font-family: monospace;">.json</span>
          <strong class="small">OSCAL Catalog (JSON)</strong>
        </div>
        <p class="text-body-secondary" style="font-size: 0.82rem; margin: 0 0 0.65rem; line-height: 1.5;">
          NIST OSCAL 1.x catalog schema. Imports families, controls, statements,
          supplemental guidance, and related-control links.
        </p>
        <a href="https://github.com/usnistgov/oscal-content/tree/main/nist.gov/SP800-53"
           target="_blank" rel="noopener"
           class="text-primary" style="font-size: 0.78rem; text-decoration: none;">
          ↗ Download from usnistgov/oscal-content
        </a>
        <div class="rounded" style="margin-top: 0.5rem; background: #1a252f; padding: 0.65rem 0.75rem; font-family: monospace; font-size: 0.72rem; color: rgba(255,255,255,0.75); line-height: 1.6; overflow-x: auto;">
          { "catalog": {<br>
          &nbsp;&nbsp;"metadata": { "title": "…", "version": "…" },<br>
          &nbsp;&nbsp;"groups": [{<br>
          &nbsp;&nbsp;&nbsp;&nbsp;"id": "ac", "title": "Access Control",<br>
          &nbsp;&nbsp;&nbsp;&nbsp;"controls": [{<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"id": "ac-1",<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"props": [{"name":"label","value":"AC-1"}],<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"parts": [<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{"name":"statement","prose":"…"},<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{"name":"guidance","prose":"…"}<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;]<br>
          &nbsp;&nbsp;&nbsp;&nbsp;}]<br>
          &nbsp;&nbsp;}]<br>
          }}
        </div>
      </div></div>

      <%# OSCAL YAML %>
      <div class="col"><div class="bg-body-secondary border rounded" style="border-left: 3px solid #e67e22 !important; padding: 1rem;">
        <div class="d-flex align-items-center gap-2" style="margin-bottom: 0.5rem;">
          <span class="fw-bold sparc-status sparc-status--orange" style="font-size: 0.72rem; font-family: monospace;">.yaml</span>
          <strong class="small">OSCAL Catalog (YAML)</strong>
        </div>
        <p class="text-body-secondary" style="font-size: 0.82rem; margin: 0 0 0.65rem; line-height: 1.5;">
          NIST OSCAL 1.x catalog schema in YAML. Same structure as OSCAL JSON.
          Imports families, controls, statements, parameters, and guidance.
        </p>
        <a href="https://github.com/usnistgov/oscal-content/tree/main/nist.gov/SP800-53"
           target="_blank" rel="noopener"
           class="text-warning" style="font-size: 0.78rem; text-decoration: none;">
          ↗ Download from usnistgov/oscal-content
        </a>
        <div class="rounded" style="margin-top: 0.5rem; background: #1a252f; padding: 0.65rem 0.75rem; font-family: monospace; font-size: 0.72rem; color: rgba(255,255,255,0.75); line-height: 1.6; overflow-x: auto;">
          catalog:<br>
          &nbsp;&nbsp;metadata:<br>
          &nbsp;&nbsp;&nbsp;&nbsp;title: "…"<br>
          &nbsp;&nbsp;&nbsp;&nbsp;version: "…"<br>
          &nbsp;&nbsp;groups:<br>
          &nbsp;&nbsp;&nbsp;&nbsp;- id: ac<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;title: Access Control<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;controls:<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;- id: ac-1<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;title: "…"
        </div>
      </div></div>

      <%# OSCAL XML %>
      <div class="col"><div class="bg-body-secondary border rounded" style="border-left: 3px solid #27ae60 !important; padding: 1rem;">
        <div class="d-flex align-items-center gap-2" style="margin-bottom: 0.5rem;">
          <span class="fw-bold sparc-status sparc-status--success" style="font-size: 0.72rem; font-family: monospace;">.xml</span>
          <strong class="small">OSCAL Catalog (XML)</strong>
        </div>
        <p class="text-body-secondary" style="font-size: 0.82rem; margin: 0 0 0.65rem; line-height: 1.5;">
          NIST OSCAL 1.x catalog schema in XML. Imports families, controls, parameters
          (including select/choice), statements, and supplemental guidance.
        </p>
        <a href="https://github.com/usnistgov/oscal-content/tree/main/nist.gov/SP800-53"
           target="_blank" rel="noopener"
           class="text-success" style="font-size: 0.78rem; text-decoration: none;">
          ↗ Download from usnistgov/oscal-content
        </a>
        <div class="rounded" style="margin-top: 0.5rem; background: #1a252f; padding: 0.65rem 0.75rem; font-family: monospace; font-size: 0.72rem; color: rgba(255,255,255,0.75); line-height: 1.6; overflow-x: auto;">
          &lt;catalog xmlns="…/ns/oscal/1.0"&gt;<br>
          &nbsp;&nbsp;&lt;metadata&gt;&lt;title&gt;…&lt;/title&gt;&lt;/metadata&gt;<br>
          &nbsp;&nbsp;&lt;group id="ac"&gt;<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&lt;control id="ac-1"&gt;<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;param id="ac-01_odp.01"&gt;<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;select&gt;&lt;choice&gt;…&lt;/choice&gt;&lt;/select&gt;<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&lt;/param&gt;<br>
          &nbsp;&nbsp;&nbsp;&nbsp;&lt;/control&gt;<br>
          &nbsp;&nbsp;&lt;/group&gt;<br>
          &lt;/catalog&gt;
        </div>
      </div></div>

      <%# NIST XML (Legacy) %>
      <div class="col"><div class="bg-body-secondary border rounded" style="border-left: 3px solid var(--sparc-purple) !important; padding: 1rem;">
        <div class="d-flex align-items-center gap-2" style="margin-bottom: 0.5rem;">
          <span class="fw-bold sparc-status sparc-status--purple" style="font-size: 0.72rem; font-family: monospace;">.xml</span>
          <strong class="small">NIST SP 800-53 XML Feed (Legacy)</strong>
        </div>
        <p class="text-body-secondary" style="font-size: 0.82rem; margin: 0 0 0.65rem; line-height: 1.5;">
          SCAP SP 800-53 feed schema v2.0. Imports family, control ID, title, baselines,
          statement text, discussion (supplemental guidance), and related controls.
        </p>
        <a href="https://csrc.nist.gov/projects/risk-management/sp800-53-controls/downloads"
           target="_blank" rel="noopener"
           class="link-purple" style="font-size: 0.78rem; text-decoration: none;">
          ↗ Download from NIST CSRC
        </a>
        <div class="rounded" style="margin-top: 0.5rem; background: #1a252f; padding: 0.65rem 0.75rem; font-family: monospace; font-size: 0.72rem; color: rgba(255,255,255,0.75); line-height: 1.6; overflow-x: auto;">
          &lt;controls:control&gt;<br>
          &nbsp;&nbsp;&lt;family&gt;ACCESS CONTROL&lt;/family&gt;<br>
          &nbsp;&nbsp;&lt;number&gt;AC-1&lt;/number&gt;<br>
          &nbsp;&nbsp;&lt;title&gt;POLICY AND PROCEDURES&lt;/title&gt;<br>
          &nbsp;&nbsp;&lt;baseline&gt;LOW&lt;/baseline&gt;<br>
          &nbsp;&nbsp;&lt;statement&gt;…&lt;/statement&gt;<br>
          &nbsp;&nbsp;&lt;discussion&gt;…&lt;/discussion&gt;<br>
          &nbsp;&nbsp;&lt;related&gt;IA-1&lt;/related&gt;<br>
          &lt;/controls:control&gt;
        </div>
      </div></div>
    </div>

    <%# Warning box %>
    <div class="border rounded" style="background: rgba(243,156,18,0.08); border-left: 3px solid #f39c12 !important; padding: 0.85rem 1rem; font-size: 0.84rem; line-height: 1.5;">
      <strong style="color: var(--sparc-warning-fg);">⚠ Format requirement:</strong>
      Files must match one of the OSCAL JSON, OSCAL YAML, OSCAL XML, or NIST SCAP XML schemas above.
      Other file structures are <em>not</em> supported by this importer — use the
      links above to download the official NIST source files.
    </div>
  </div>

  </div>
</div>

