<div class="row justify-content-center my-4">
  <div class="col-lg-8">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 fw-bold mb-0">Edit Control Mapping</h1>
      <%= link_to "Cancel", control_mapping_path(@control_mapping), class: "btn btn-sm btn-outline-secondary" %>
    </div>

    <div class="card">
      <div class="card-body p-4">
        <%= render "form", control_mapping: @control_mapping %>
      </div>
    </div>
  </div>
</div>
