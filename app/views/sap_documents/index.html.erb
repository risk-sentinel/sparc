<%= render "shared/section_summary", tiles: [
  [@total_count, "Assessment Plans"],
  [@controls_count, "Total Controls"],
  [@completed_count, "Completed"]
] %>

<% if @sap_documents.any? { |d| d.processing? || d.pending? } %>
  <meta http-equiv="refresh" content="10">
<% end %>

<div class="card" style="overflow-x: auto;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Assessment Plans (SAP)</h2>
    <div class="d-flex gap-2">
      <%= link_to "Create New", new_sap_document_path, class: "btn btn-success" %>
      <%= link_to "Upload", new_sap_document_path(anchor: "upload-sap"), class: "btn btn-outline-primary" %>
    </div>
  </div>

  <% if @sap_documents.any? %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th style="white-space: nowrap;">Name</th>
          <th style="white-space: nowrap;">Type</th>
          <th style="white-space: nowrap;">SSP</th>
          <th style="white-space: nowrap;">Version</th>
          <th style="white-space: nowrap;">Status</th>
          <th style="white-space: nowrap;">Controls</th>
          <th style="white-space: nowrap;">Schedule</th>
          <th style="white-space: nowrap;">Created</th>
          <th style="white-space: nowrap;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @sap_documents.each do |doc| %>
          <tr>
            <td><strong><%= link_to doc.name, sap_document_path(doc), class: "text-primary", style: "text-decoration: none;" %></strong></td>
            <td>
              <% type_colors = { "initial" => "#3498db", "annual" => "#27ae60", "continuous" => "#8e44ad", "ad-hoc" => "#f39c12" } %>
              <% color = type_colors[doc.assessment_type] || "#7f8c8d" %>
              <span class="rounded fw-semibold" style="padding: 0.2rem 0.6rem; background: <%= color %>22; color: <%= color %>; border: 1px solid <%= color %>44; font-size: 0.78rem; white-space: nowrap;">
                <%= doc.assessment_type&.titleize || "Initial" %>
              </span>
            </td>
            <td class="small text-body-secondary"><%= doc.ssp_document&.name || "—" %></td>
            <td class="small text-body-secondary"><%= doc.sap_version.presence || "—" %></td>
            <td style="white-space: nowrap;">
              <% if doc.processing? || doc.pending? || doc.failed? %>
                <span class="<%= doc.completed? ? 'badge-ok' : doc.failed? ? 'badge-fail' : 'badge-warn' %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.85rem;">
                  <%= doc.status %>
                </span>
                <% if doc.processing? && doc.metadata_extra&.dig("processing_message").present? %>
                  <br><span class="text-body-secondary" style="font-size: 0.72rem; white-space: normal;"><%= doc.metadata_extra["processing_message"] %></span>
                <% end %>
              <% else %>
                <span class="<%= doc.lifecycle_badge_class %> rounded fw-semibold" style="padding: 0.2rem 0.6rem; font-size: 0.85rem;">
                  <%= doc.lifecycle_label %>
                </span>
              <% end %>
            </td>
            <td><%= doc.sap_controls.count %></td>
            <td class="text-body-secondary" style="font-size: 0.82rem; white-space: nowrap;">
              <% if doc.assessment_start.present? %>
                <%= doc.assessment_start.strftime("%Y-%m-%d") %>
                <% if doc.assessment_end.present? %>
                  &rarr; <%= doc.assessment_end.strftime("%Y-%m-%d") %>
                <% end %>
              <% else %>
                —
              <% end %>
            </td>
            <td style="white-space: nowrap;"><%= doc.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td>
              <div class="d-flex flex-wrap gap-1" style="max-width: 280px;">
                <%= link_to "View", sap_document_path(doc), class: "btn btn-primary btn-sm", style: "padding: 0.25rem 0.6rem; font-size: 0.78rem;" %>
                <% if doc.completed? %>
                  <div class="btn-group">
                    <button type="button" class="btn btn-sm dropdown-toggle" style="background: #8e44ad; color: white; padding: 0.25rem 0.6rem; font-size: 0.78rem;" data-bs-toggle="dropdown" aria-expanded="false">
                      Export OSCAL
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                      <li><h6 class="dropdown-header">OSCAL (validated)</h6></li>
                      <li><%= link_to "JSON", download_oscal_sap_document_path(doc), class: "dropdown-item" %></li>
                      <li><%= link_to "YAML", download_yaml_sap_document_path(doc), class: "dropdown-item" %></li>
                      <li><%= link_to "XML", download_xml_sap_document_path(doc), class: "dropdown-item" %></li>
                    </ul>
                  </div>
                <% end %>
                <%= button_to "Delete", sap_document_path(doc), method: :delete,
                      class: "btn btn-danger btn-sm",
                      style: "padding: 0.25rem 0.6rem; font-size: 0.78rem;",
                      form: { data: { turbo_confirm: "Delete '#{doc.name}'? This cannot be undone." }, style: "display: inline;" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-center p-4 text-body-secondary">No assessment plans found. Create your first Security Assessment Plan to get started.</p>
  <% end %>
</div>
