<%# #395 P3: boundary context header %>
<%= render "shared/boundary_header", document: @sap_document %>

<%# ── PROCESSING STATE BANNER ─────────────────────────────────────── %>
<% unless @sap_document.completed? %>
  <%= render "shared/processing_banner",
       document:     @sap_document,
       title:        "Processing Your Assessment Plan",
       back_label:   "Back to Assessment Plans",
       back_path:    sap_documents_path %>

<% else %>
<%
  examine_count = @method_counts["examine"].to_i
  interview_count = @method_counts["interview"].to_i
  test_count = @method_counts["test"].to_i
  none_count = @method_counts[nil].to_i
  multiple_count = @multiple_count.to_i

  planned_count = @status_counts["planned"].to_i
  in_progress_count = @status_counts["in-progress"].to_i
  completed_count = @status_counts["completed"].to_i

  type_colors = { "initial" => "#3498db", "annual" => "#27ae60", "continuous" => "#8e44ad", "ad-hoc" => "#f39c12" }
  type_color = type_colors[@sap_document.assessment_type] || "#7f8c8d"
  type_variants = { "initial" => "info", "annual" => "success", "continuous" => "purple", "ad-hoc" => "warning" }
  type_variant = type_variants[@sap_document.assessment_type] || "neutral"
%>

<div data-controller="doc-meta family-toggle heatmap-chip">

<%# ── HEADER DASHBOARD ──────────────────────────────────────────── %>
<div class="sparc-gradient-header" style="border-radius: 12px; padding: 1.75rem 2rem; margin-bottom: 1.5rem; color: white;">

  <div class="d-flex justify-content-between align-items-start mb-4 gap-3 flex-wrap">
    <div>
      <div class="sparc-header-subtitle">OSCAL Security Assessment Plan</div>

      <%# ── View mode ── %>
      <div id="doc-meta-view" data-doc-meta-target="view">
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <h2 class="sparc-header-title"><%= @sap_document.name %></h2>
          <% if @sap_document.sap_version.present? %>
            <span class="sparc-version-badge">v<%= @sap_document.sap_version %></span>
          <% end %>
          <span class="sparc-tag-outline sparc-status--<%= type_variant %>">
            <%= @sap_document.assessment_type&.titleize || "Initial" %>
          </span>
          <button type="button" data-action="doc-meta#toggle" class="sparc-btn-header-edit">Edit</button>
        </div>
      </div>

      <%# ── Edit mode (hidden) ── %>
      <div id="doc-meta-edit" data-doc-meta-target="edit" style="display: none;">
        <%= form_with url: update_metadata_sap_document_path(@sap_document), method: :patch, local: true do |f| %>
          <div class="d-flex gap-2 align-items-center flex-wrap">
            <%= f.text_field :name, value: @sap_document.name,
                  class: "sparc-input-dark sparc-input-dark-lg" %>
            <%= f.text_field :sap_version, value: @sap_document.sap_version, placeholder: "Version",
                  class: "sparc-input-dark sparc-input-dark-sm" %>
            <%= f.submit "Save", class: "sparc-btn-save" %>
            <button type="button" data-action="doc-meta#toggle" class="sparc-btn-cancel-dark">Cancel</button>
          </div>
        <% end %>
      </div>

      <div class="sparc-header-meta">
        <% if @sap_document.ssp_document.present? %>
          SSP: <span style="color: rgba(255,255,255,0.7);"><%= @sap_document.ssp_document.name %></span>
          &nbsp;&bull;&nbsp;
        <% end %>
        <% if @sap_document.profile_document.present? %>
          Profile: <span style="color: rgba(255,255,255,0.7);"><%= @sap_document.profile_document.name %></span>
          &nbsp;&bull;&nbsp;
        <% end %>
        <%= @total_controls %> controls
        <% if @sap_document.assessment_start.present? %>
          &nbsp;&bull;&nbsp; <%= @sap_document.assessment_start.strftime("%b %d, %Y") %>
          <% if @sap_document.assessment_end.present? %>
            &ndash; <%= @sap_document.assessment_end.strftime("%b %d, %Y") %>
          <% end %>
        <% end %>
      </div>
      <% if @sap_document.description.present? %>
        <div style="font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-top: 0.4rem; max-width: 600px;"><%= truncate(@sap_document.description, length: 200) %></div>
      <% end %>
    </div>
    <div class="d-flex gap-2 flex-shrink-0 flex-wrap">
      <% if signed_in? && @sap_document.draft? %>
        <%= render "shared/publish_button", document: @sap_document,
              publish_path: publish_sap_document_path(@sap_document),
              check_path: publish_check_sap_document_path(@sap_document) %>
      <% end %>
      <%= render "shared/oscal_export_dropdown",
            validate_path: validate_oscal_export_sap_document_path(@sap_document),
            download_json_path: download_oscal_validated_sap_document_path(@sap_document),
            download_yaml_path: download_yaml_sap_document_path(@sap_document),
            download_xml_path: download_xml_sap_document_path(@sap_document),
            fallback_json_path: download_oscal_unvalidated_sap_document_path(@sap_document),
            document_type: "Assessment Plan" %>
      <%= link_to "&#8592; Back".html_safe, sap_documents_path,
            class: "sparc-btn-ghost-muted" %>
    </div>
  </div>

  <%# ── Summary chips ── %>
  <div class="d-flex align-items-center gap-4 flex-wrap">
    <div class="text-center flex-shrink-0" style="min-width: 80px;">
      <div class="sparc-score" style="color: white;"><%= @total_controls %></div>
      <div class="sparc-score-label">Total Controls</div>
    </div>

    <div class="sparc-divider-v"></div>

    <%# ── Method breakdown (counts each method individually; "Multiple" tracks controls with 2+ methods) ── %>
    <div class="d-flex flex-wrap" style="gap: 0.45rem;">
      <% [["Examine", examine_count, "#3498db", "examine"], ["Interview", interview_count, "#f39c12", "interview"], ["Test", test_count, "#e74c3c", "test"], ["Multiple", multiple_count, "#9b59b6", "multiple"], ["Unset", none_count, "#95a5a6", "(none)"]].each do |label, count, color, filter_val| %>
        <% next if count == 0 %>
        <div class="sparc-summary-chip summary-chip"
             data-filter-value="<%= filter_val %>"
             data-action="heatmap-chip#apply"
             data-heatmap-chip-filter-param="<%= filter_val %>"
             role="button"
             tabindex="0"
             title="Click to filter: <%= label %>"
             style="border-left: 3px solid <%= color %>;">
          <div class="sparc-chip-count"><%= count %></div>
          <div class="sparc-chip-label"><%= label %></div>
        </div>
      <% end %>
    </div>

    <div class="sparc-divider-v"></div>

    <%# ── Status breakdown ── %>
    <div class="d-flex flex-wrap" style="gap: 0.45rem;">
      <% [["Planned", planned_count, "#95a5a6"], ["In Progress", in_progress_count, "#f39c12"], ["Completed", completed_count, "#27ae60"]].each do |label, count, color| %>
        <% next if count == 0 %>
        <div class="sparc-summary-chip" style="border-left: 3px solid <%= color %>;">
          <div class="sparc-chip-count"><%= count %></div>
          <div class="sparc-chip-label"><%= label %></div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Progress bar by method (each method counted individually; total may exceed control count) ── %>
  <div class="mt-3">
    <div class="sparc-progress-bar">
      <% total = [examine_count + interview_count + test_count + none_count, 1].max %>
      <% [["examine", examine_count, "#3498db"], ["interview", interview_count, "#f39c12"], ["test", test_count, "#e74c3c"], ["unset", none_count, "#95a5a6"]].each do |m, count, color| %>
        <% next if count == 0 %>
        <div style="width: <%= (count * 100.0 / total).round(3) %>%; background: <%= color %>;" title="<%= m.titleize %>: <%= count %>"></div>
      <% end %>
    </div>
  </div>
</div>

<%# ── ASSESSMENT METHOD HEATMAP BY CONTROL FAMILY ──────────────── %>
<%= render "shared/heatmap",
     heatmap_data: @heatmap_data,
     heatmap_families: @heatmap_families,
     heatmap_statuses: @heatmap_methods,
     title: "Assessment Methods by Control Family",
     variant_helper: :sap_method_variant,
     filter_key: "method",
     show_percentage: false,
     legend_items: [["Examine", "#3498db"], ["Interview", "#f39c12"], ["Test", "#e74c3c"], ["Multiple", "#9b59b6"], ["None", "#95a5a6"]] %>

<%# ── ASSESSMENT STATUS (OBJECTIVE ROLLUP) HEATMAP ──────────────── %>
<% if @status_heatmap_data.present? && @status_heatmap_families.any? %>
  <%= render "shared/heatmap",
       heatmap_data: @status_heatmap_data,
       heatmap_families: @status_heatmap_families,
       heatmap_statuses: @status_heatmap_statuses,
       title: "Assessment Status by Control Family (Objective Rollup)",
       variant_helper: :sap_objective_status_variant,
       filter_key: "objective-status",
       show_percentage: false,
       legend_items: [
         ["Failed", "#e74c3c"], ["In Progress", "#f39c12"],
         ["Pending", "#95a5a6"], ["Passing", "#27ae60"],
         ["N/A", "#7f8c8d"], ["Not Assessed", "#bdc3c7"]
       ] %>
<% end %>

<%# ── NEEDS RE-ASSOCIATION BANNER ──────────────────────────────── %>
<% if @needs_reassociation %>
  <div class="card mt-3" style="border-left: 4px solid #f39c12;">
    <strong class="sparc-text-warning-bold">Per-objective tracking unavailable.</strong>
    <span class="text-body-secondary">
      This SAP isn't linked to a profile, so individual NIST 800-53A determination
      statements (assessment objectives) can't be populated. Use the Associate Source
      controls below to link a profile or SSP and enable per-objective assessment.
    </span>
  </div>
<% end %>

<%# ── ASSOCIATE SOURCE (when 0 controls and SAP uses include-all) ── %>
<% if @total_controls == 0 && @sap_document.draft? %>
  <div class="card mt-3" style="border-left: 4px solid #f39c12;">
    <h3 class="sparc-heading-assessment">No Controls Assigned</h3>
    <p class="text-body-secondary">
      This SAP uses <code>reviewed-controls.include-all</code> but no source profile or SSP
      could be matched automatically. Associate it with an existing profile or SSP below to
      populate the assessed controls list.
    </p>

    <%= form_with url: associate_source_sap_document_path(@sap_document), method: :patch, local: true do |f| %>
      <div class="row row-cols-1 row-cols-md-2 g-3">
        <div class="col">
          <div class="form-group">
            <label for="sap_document_profile_document_id">Baseline Profile</label>
            <%= f.select "sap_document[profile_document_id]",
                  options_for_select(
                    ProfileDocument.where(lifecycle_status: "published")
                                   .order(:name)
                                   .map { |p| ["#{p.name} (#{p.baseline_level || 'Custom'}, #{p.profile_controls.count} controls)", p.id] },
                    @sap_document.profile_document_id
                  ),
                  { include_blank: "— Select profile —" },
                  class: "form-control" %>
          </div>
        </div>
        <div class="col">
          <div class="form-group">
            <label for="sap_document_ssp_document_id">System Security Plan</label>
            <%= f.select "sap_document[ssp_document_id]",
                  options_for_select(
                    SspDocument.order(:name).map { |s| ["#{s.name} (#{s.ssp_controls.count} controls)", s.id] },
                    @sap_document.ssp_document_id
                  ),
                  { include_blank: "— Select SSP —" },
                  class: "form-control" %>
          </div>
        </div>
      </div>
      <p class="text-body-tertiary small mt-2">
        Selecting either or both will re-process the SAP file and assign controls from the matching source.
      </p>
      <div class="d-flex gap-2 mt-3">
        <%= f.submit "Associate & Reprocess", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
<% end %>

<%# ── CONTROL CARDS (grouped by family) ─────────────────────────── %>
<div id="controlsContainer">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <label class="form-label fw-semibold mb-0"><%= @total_controls %> controls</label>
    <div class="d-flex gap-1">
      <button type="button" class="btn btn-sm btn-outline-info" data-action="family-toggle#expandAll">Expand All</button>
      <button type="button" class="btn btn-sm btn-outline-info" data-action="family-toggle#collapseAll">Collapse All</button>
    </div>
  </div>

  <% @sorted_families.each do |fam_code| %>
    <% family_controls = @controls_by_family[fam_code] %>
    <% next if family_controls.blank? %>

    <details class="sparc-family-group" data-family-group="<%= fam_code %>">
      <summary>
        <strong><%= fam_code %></strong> &mdash; <%= @family_names[fam_code.downcase] || fam_code %>
        <span class="badge bg-secondary"><%= family_controls.size %></span>
      </summary>

      <div class="mt-2">
  <% family_controls.sort_by { |c| c.control_id.to_s.gsub(/\d+/) { |n| n.rjust(3, "0") } }.each do |control| %>
    <%
      field_map = control.sap_control_fields.index_by(&:field_name)
      methods = control.assessment_methods
      is_multiple = methods.size > 1
      method_colors_map = { "examine" => "#3498db", "interview" => "#f39c12", "test" => "#e74c3c" }
      # Border color: purple if multi-method, otherwise the single method's color (gray if none)
      border_color = is_multiple ? "#9b59b6" : (method_colors_map[methods.first] || "#95a5a6")
      # data-method drives client-side filtering: "multiple" if 2+ methods so the
      # heatmap "Multiple" filter highlights the same controls
      method_filter_val = if methods.empty? then "(None)"
                          elsif is_multiple then "multiple"
                          else methods.first end
      status_val = control.assessment_status.presence || "planned"
      status_colors_map = { "planned" => "#95a5a6", "in-progress" => "#f39c12", "completed" => "#27ae60" }
      status_color = status_colors_map[status_val] || "#95a5a6"
      status_variants_map = { "planned" => "neutral", "in-progress" => "warning", "completed" => "success" }
      status_variant = status_variants_map[status_val] || "neutral"
      family_code = control.control_family.presence || control.control_id.to_s.split("-").first.upcase
    %>
    <%# data-methods drives chip filtering: a multi-method control matches each of its
        method chips AND the synthetic "multiple" chip (see heatmap_controller.js) %>
    <div class="control-card rounded-3"
         data-family="<%= family_code %>"
         data-method="<%= method_filter_val %>"
         data-methods="<%= methods.join(',') %>"
         data-status="<%= status_val %>"
         style="border-left: 4px solid <%= border_color %>;">

      <%# ── Card header ── %>
      <div class="d-flex justify-content-between align-items-start" style="gap: 1rem;">
        <div style="min-width: 0; flex: 1;">
          <div class="d-flex align-items-center gap-2 flex-wrap" style="margin-bottom: 0.2rem;">
            <span class="sparc-ctrl-id">
              <%= control.control_id.presence || "&mdash;".html_safe %>
            </span>
            <% if methods.empty? %>
              <span class="sparc-status-pill sparc-status--neutral">None</span>
            <% else %>
              <% methods.each do |m| %>
                <span class="sparc-status-pill sparc-status--<%= sap_method_variant(m) %>">
                  <%= m.titleize %>
                </span>
              <% end %>
              <% if is_multiple %>
                <span class="sparc-tag-outline sparc-status--purple" title="This control has multiple assessment methods" style="font-weight: 600;">
                  Multiple
                </span>
              <% end %>
            <% end %>
            <span class="sparc-tag-outline sparc-status--<%= status_variant %>">
              <%= status_val.titleize %>
            </span>
            <% if control.assessor_name.present? %>
              <span class="text-body-secondary" style="font-size: 0.68rem;">&#x1F464; <%= control.assessor_name %></span>
            <% end %>
          </div>
          <% if control.title.present? %>
            <div class="sparc-ctrl-title"><%= control.title %></div>
          <% end %>
        </div>
        <div class="d-flex flex-shrink-0" style="gap: 0.35rem;">
          <%= link_to "Edit", sap_document_path(@sap_document, control_id: control.id),
                class: "btn btn-primary btn-sm" %>
        </div>
      </div>

      <%# ── Card body: collapsed by default ── %>
      <%
        has_objectives = control.sap_control_objectives.any?
        has_details = has_objectives || control.objective.present? || control.test_case.present? || field_map.any?
      %>
      <% if has_details %>
        <details class="card-details" style="margin-top: 0.35rem;" <%= "open" if @editing_objective && @editing_objective.sap_control_id == control.id %>>
          <summary class="sparc-card-detail-toggle d-flex align-items-center gap-1">
            <span class="sparc-card-arrow card-arrow">&#9658;</span>
            <span class="sparc-card-detail-separator"></span>
          </summary>

          <div class="mt-2">
            <% if has_objectives %>
              <%= render "sap_documents/objectives_table", control: control, sap_document: @sap_document %>
            <% elsif control.objective.present? %>
              <div class="sparc-statement-block">
                <div class="sparc-statement-label">Assessment Objective</div>
                <div class="sparc-field-value-padded" style="padding: 0;"><%= control.objective %></div>
              </div>
            <% end %>

            <% if control.test_case.present? %>
              <div class="sparc-statement-block" style="background: rgba(231,76,60,0.07); border-color: rgba(231,76,60,0.2); border-left: 3px solid #e74c3c;">
                <div class="sparc-statement-label sparc-heading-danger">Test Case / Check Content</div>
                <div class="sparc-field-value-padded" style="padding: 0;"><%= control.test_case %></div>
              </div>
            <% end %>

            <% if field_map.any? %>
              <table class="sparc-field-table">
                <% field_map.each do |fname, field| %>
                  <tr>
                    <td class="sparc-field-label">
                      <%= fname.tr("_", " ") %>
                    </td>
                    <td class="sparc-field-value">
                      <%= field.field_value %>
                    </td>
                  </tr>
                <% end %>
              </table>
            <% end %>
          </div>
        </details>
      <% end %>

      <%= render "shared/control_references_readonly", control: control %>
    </div><%# end .control-card %>
  <% end %>
      </div>
    </details>
  <% end %>
</div>

<%# ── Edit control modal (inline) ── %>
<% if @control = @sap_document.sap_controls.find_by(id: params[:control_id]) %>
  <%
    # Pre-populate assessor name from current user if blank
    default_assessor = @control.assessor_name.presence || current_user&.display_label

    # Pre-populate objective from catalog assessment data if blank
    default_objective = @control.objective.presence
    if default_objective.blank? && @control.control_id.present?
      cat_ctrl = CatalogControl.find_by(control_id: @control.control_id)
      if cat_ctrl
        guidance = cat_ctrl.guidance_data.is_a?(Hash) ? cat_ctrl.guidance_data : {}

        # 1. Prefer Rev 5 assessment objectives (labeled sub-items)
        default_objective = guidance["assessment_objective"]

        # 2. Fall back to assessment methods (EXAMINE/INTERVIEW/TEST with objects)
        if default_objective.blank?
          assessment = guidance["assessment"]
          if assessment.is_a?(Array) && assessment.any?
            lines = assessment.map do |a|
              method = a["method"]&.upcase
              objects = a["objects"]
              method && objects ? "#{method}:\n#{objects}" : (objects || method)
            end.compact
            default_objective = lines.join("\n\n")
          end
        end

        # 3. Fall back to statement or supplemental guidance
        default_objective = guidance["statement"] if default_objective.blank?
        default_objective = guidance["supplemental_guidance"] if default_objective.blank?
        default_objective = cat_ctrl.description if default_objective.blank?
      end
    end
  %>
  <div id="editModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; align-items: center; justify-content: center;">
    <div class="bg-body rounded-3" style="padding: 2rem; max-width: 600px; width: 90%; max-height: 80vh; overflow-y: auto; box-shadow: 0 8px 32px rgba(0,0,0,0.3);">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Edit <%= @control.control_id %></h3>
        <%= link_to "&times;".html_safe, sap_document_path(@sap_document),
              class: "text-body-secondary", style: "font-size: 1.5rem; text-decoration: none; line-height: 1;" %>
      </div>

      <%= form_with url: sap_document_path(@sap_document, control_id: @control.id), method: :patch, local: true do |f| %>
        <div class="form-group">
          <label>Assessment Method(s)</label>
          <% selected_methods = @control.assessment_methods %>
          <div class="d-flex gap-3 flex-wrap" style="padding: 0.4rem 0;">
            <% SapControl::ASSESSMENT_METHODS.each do |m| %>
              <div class="form-check">
                <%= check_box_tag "sap_control[assessment_methods][]", m, selected_methods.include?(m),
                      id: "method_#{m}", class: "form-check-input" %>
                <label class="form-check-label" for="method_<%= m %>"><%= m.titleize %></label>
              </div>
            <% end %>
          </div>
          <small class="text-body-secondary">Select all methods used to assess this control. Multiple methods are common (e.g., Examine + Interview, or all three).</small>
        </div>
        <div class="form-group">
          <label>Assessment Status</label>
          <%= f.select :assessment_status,
                options_for_select(SapControl::ASSESSMENT_STATUSES.map { |s| [s.titleize, s] }, @control.assessment_status),
                {}, class: "form-control", name: "sap_control[assessment_status]" %>
        </div>
        <div class="form-group">
          <label>Assessor Name</label>
          <%= f.text_field :assessor_name, value: default_assessor, class: "form-control", name: "sap_control[assessor_name]" %>
        </div>
        <div class="form-group">
          <label>Assessment Objective</label>
          <%= f.text_area :objective, value: default_objective, rows: 3, class: "form-control", name: "sap_control[objective]" %>
        </div>
        <div class="form-group">
          <label>Test Case</label>
          <%= f.text_area :test_case, value: @control.test_case, rows: 3, class: "form-control", name: "sap_control[test_case]" %>
        </div>
        <div class="d-flex gap-2">
          <%= f.submit "Save Changes", class: "btn btn-success" %>
          <%= link_to "Cancel", sap_document_path(@sap_document), class: "btn btn-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# ── Edit objective modal (inline) ── %>
<% if @editing_objective %>
  <% obj = @editing_objective %>
  <% obj_default_assessor = obj.assessor_name.presence || current_user&.display_label %>
  <div id="editObjectiveModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; align-items: center; justify-content: center;">
    <div class="bg-body rounded-3" style="padding: 2rem; max-width: 600px; width: 90%; max-height: 80vh; overflow-y: auto; box-shadow: 0 8px 32px rgba(0,0,0,0.3);">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <div class="text-body-tertiary" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.04em;">Assessment Objective</div>
          <h3 style="margin: 0;"><%= obj.label.presence || obj.objective_id %></h3>
        </div>
        <%= link_to "&times;".html_safe, sap_document_path(@sap_document),
              class: "text-body-secondary", style: "font-size: 1.5rem; text-decoration: none; line-height: 1;" %>
      </div>

      <% if obj.prose.present? %>
        <div class="bg-body-secondary rounded p-2 mb-3" style="font-size: 0.85rem;">
          <%= obj.prose %>
        </div>
      <% end %>

      <%= form_with url: update_objective_sap_document_path(@sap_document), method: :patch, local: true do |f| %>
        <%= hidden_field_tag :objective_id, obj.id %>
        <div class="form-group mb-3">
          <label>Status</label>
          <%= select_tag "sap_control_objective[status]",
                options_for_select(SapControlObjective::OBJECTIVE_STATUSES.map { |s| [s.humanize, s] }, obj.status),
                class: "form-control" %>
        </div>
        <div class="form-group mb-3">
          <label>Assessor Name</label>
          <%= text_field_tag "sap_control_objective[assessor_name]", obj_default_assessor, class: "form-control" %>
        </div>
        <div class="form-group mb-3">
          <label>Assessor Notes</label>
          <%= text_area_tag "sap_control_objective[assessor_notes]", obj.assessor_notes, rows: 4, class: "form-control",
                placeholder: "Findings, evidence references, or notes for this objective" %>
        </div>
        <div class="d-flex gap-2">
          <%= f.submit "Save Objective", class: "btn btn-success" %>
          <%= link_to "Cancel", sap_document_path(@sap_document), class: "btn btn-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%= render "shared/uuid_replaced_warning", document: @sap_document %>

<%= render "shared/oscal_metadata_section",
           document: @sap_document,
           update_path: update_metadata_sap_document_path(@sap_document),
           param_key: :sap_document,
           version_field: :sap_version %>

<%= render "shared/oscal_back_matter_section",
           document: @sap_document,
           resources_path: sap_document_back_matter_resources_path(@sap_document) %>

</div><%# end data-controller wrapper %>

<% end %><%# end unless completed %>
