{
  "format": "ssp_excel",
  "version": "1.0",
  "description": "Mapping schema for SSP (System Security Plan) spreadsheet import/export. Column headers are OSCAL-aligned.",
  "document_type": "SspDocument",
  "control_type": "SspControl",
  "field_type": "SspControlField",
  "fields": [
    {
      "key": "control_id",
      "source_header": "control-id",
      "storage": "control_attribute",
      "data_type": "string",
      "required": true,
      "description": "NIST control identifier (e.g. AC-1, AC-2)"
    },
    {
      "key": "title",
      "source_header": "control-title",
      "storage": "control_attribute",
      "data_type": "string",
      "required": false,
      "description": "Control title"
    },
    {
      "key": "stated_requirement",
      "source_header": "control-statement",
      "storage": "control_field",
      "data_type": "text",
      "editable": false,
      "oscal_mapping": {
        "target": "remarks",
        "prefix": "Stated Requirement"
      },
      "description": "The control statement / stated requirement text"
    },
    {
      "key": "implementation_statement",
      "source_header": "implementation-statement",
      "storage": "control_field",
      "data_type": "text",
      "editable": true,
      "oscal_mapping": {
        "target": "statement",
        "statement_suffix": "_priv"
      },
      "description": "Implementation statement (internal narrative)"
    },
    {
      "key": "implementation_summary",
      "source_header": "implementation-summary",
      "storage": "control_field",
      "data_type": "text",
      "editable": true,
      "oscal_mapping": {
        "target": "statement",
        "statement_suffix": "_pub"
      },
      "description": "Implementation summary (shareable narrative)"
    },
    {
      "key": "notes",
      "source_header": "remarks",
      "storage": "control_field",
      "data_type": "text",
      "editable": true,
      "oscal_mapping": {
        "target": "remarks",
        "prefix": "Notes"
      },
      "description": "Additional remarks about the control implementation"
    },
    {
      "key": "status",
      "source_header": "implementation-status",
      "storage": "control_field",
      "data_type": "string",
      "editable": true,
      "validation": {
        "allowed_values": ["Deferred", "Implemented", "Not Applicable", "Will Not Implement"]
      },
      "oscal_mapping": {
        "target": "prop",
        "prop_name": "implementation-status",
        "transform": "downcase_hyphenate"
      },
      "description": "Implementation status of the control"
    },
    {
      "key": "expected_completion",
      "source_header": "completion-date",
      "storage": "control_field",
      "data_type": "string",
      "editable": true,
      "oscal_mapping": {
        "target": "remarks",
        "prefix": "Expected Completion"
      },
      "description": "Expected completion date for implementation"
    },
    {
      "key": "class",
      "source_header": "control-class",
      "storage": "control_field",
      "data_type": "string",
      "editable": false,
      "description": "Control classification"
    },
    {
      "key": "priority",
      "source_header": "control-priority",
      "storage": "control_field",
      "data_type": "string",
      "editable": false,
      "description": "Control priority"
    },
    {
      "key": "responsible_entities",
      "source_header": "responsible-roles",
      "storage": "control_field",
      "data_type": "string",
      "editable": true,
      "oscal_mapping": {
        "target": "prop",
        "prop_name": "responsible-entities",
        "namespace": "https://sparc.local/ns"
      },
      "description": "Roles/entities responsible for the control"
    },
    {
      "key": "control_owner",
      "source_header": "responsible-party",
      "storage": "control_field",
      "data_type": "string",
      "editable": false,
      "description": "Responsible party / owner of the control"
    },
    {
      "key": "control_application",
      "source_header": "control-application",
      "storage": "control_field",
      "data_type": "string",
      "editable": true,
      "validation": {
        "allowed_values": ["System Specific", "Hybrid", "Inherited", "Provider", "Consumer"]
      },
      "oscal_mapping": {
        "target": "prop",
        "prop_name": "control-type",
        "namespace": "https://sparc.local/ns"
      },
      "description": "How the control applies to the system"
    },
    {
      "key": "inherited_from",
      "source_header": "inherited-from",
      "storage": "control_field",
      "data_type": "string",
      "editable": false,
      "oscal_mapping": {
        "target": "remarks",
        "prefix": "Inherited From"
      },
      "description": "Source system the control is inherited from"
    },
    {
      "key": "coverage_level",
      "source_header": "coverage-level",
      "storage": "control_field",
      "data_type": "string",
      "editable": true,
      "validation": {
        "allowed_values": ["Implemented", "Configured", "Documented", "Not Applicable"]
      },
      "oscal_mapping": {
        "target": "prop",
        "prop_name": "provided-as",
        "namespace": "https://sparc.local/ns"
      },
      "description": "Level at which the control is covered/provided"
    },
    {
      "key": "control_type",
      "source_header": "control-type",
      "storage": "control_field",
      "data_type": "string",
      "editable": true,
      "validation": {
        "allowed_values": ["System Specific", "Hybrid — partially inherited", "Inherited from provider", "Not Applicable"]
      },
      "oscal_mapping": {
        "target": "prop",
        "prop_name": "control-origination",
        "namespace": "https://sparc.local/ns"
      },
      "description": "Control type / origination"
    },
    {
      "key": "history",
      "source_header": "change-history",
      "storage": "control_field",
      "data_type": "text",
      "editable": false,
      "oscal_mapping": {
        "target": "remarks",
        "prefix": "History"
      },
      "description": "Change history for the control"
    }
  ]
}
