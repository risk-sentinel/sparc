# ============================================================================
# SPARC — Environment Variables (Production)
# ============================================================================
# Template for production deployments (ECS Fargate, EC2, EKS, Docker, Kamal).
# Copy and fill in required values. Never commit this file with real secrets.
# See docs/ENVIRONMENT_VARIABLES.md for the full configuration reference.
# ============================================================================

# ── Database (REQUIRED) ────────────────────────────────────────────────────
# Option 1: Full connection URI (preferred)
DATABASE_URL=postgresql://sparc_user:CHANGE_ME@db-host:5432/sparc_production

# Option 2: Individual vars (used when DATABASE_URL is not set)
# SPARC_DB_HOST=db-host
# SPARC_DB_PORT=5432
# SPARC_DB_NAME=sparc_production
# SPARC_DB_USER=sparc_user
# SPARC_DB_PASSWORD=CHANGE_ME
# SPARC_DB_SSLMODE=require

# ── Application (REQUIRED) ─────────────────────────────────────────────────
SPARC_APP_URL=https://sparc.yourdomain.com
SPARC_APP_NAME=SPARC
# SPARC_CONTACT_EMAIL=compliance-team@yourdomain.com
# SPARC_WELCOME_TEXT=Welcome to SPARC
# SPARC_RESOURCES='[{"display_text":"FedRAMP 20x","href":"https://www.fedramp.gov/20x"},{"display_text":"NIST OSCAL","href":"https://pages.nist.gov/OSCAL/"},{"display_text":"MITRE SAF","href":"https://saf.mitre.org/"},{"display_text":"Internal Wiki","href":"https://wiki.yourdomain.com/compliance"}]'

# ── Organization ──────────────────────────────────────────────────────────
# SPARC_ORG_NAME=Your Organization Name
# SPARC_ORG_DESCRIPTION=
# SPARC_ORG_ADDRESS=
# SPARC_ORG_CONTACT_PERSON=
# SPARC_ORG_CONTACT_EMAIL=compliance-team@yourdomain.com

# ── User Lifecycle ────────────────────────────────────────────────────────
# SPARC_INACTIVITY_DAYS=30        # Days of inactivity before auto-deactivation
# SPARC_PASSWORD_EXPIRY_DAYS=30   # Days before password expires (local-auth only)

# ── Consent Banner ──────────────────────────────────────────────────────────
# Show a mandatory consent/warning banner modal before login options appear.
# The banner message is loaded from the file at SPARC_BANNER_MESSAGE.
# Relative paths are resolved against Rails.root (e.g., docs/sample-consent-banner.html).
# A sample file is provided at docs/sample-consent-banner.html.
# SPARC_BANNER_ENABLED=false
# SPARC_BANNER_MESSAGE=docs/sample-consent-banner.html

# ── Roles for Organization and Auth Boundaries ──────────────────────────────
# Default values will exist if not set
# Organization Roles: Org Admin (always), Head of Agency, Senior Accountable
# Official, CIO, CISO, Risk Executive, Chief Acqusition Officer, Senior Agency
# Official for Privacy, Member.
# Auth Boundary Roles: Assessor / 3PAO, Authorizing Official, CISO, ISSO, Team
# Member, System Owner (SO), View Only
# SPARC_ORGANIZATION_ROLES=Head of Agency, Senior Accountable, Official, CIO, CISO, Risk Executive, Chief Acqusition Officer, Senior Agency Official for Privacy, Member, Test
# SPARC_AUTH_BOUNDARY_ROLES=Assessor / 3PAO, Authorizing Official (AO), CISO, ISSO, Team Member, System Owner (SO), View Only

# ── Security (REQUIRED) ────────────────────────────────────────────────────
SECRET_KEY_BASE=CHANGE_ME_generate_with_rails_secret
FORCE_SSL=true
RAILS_SERVE_STATIC_FILES=true

# ── Authentication ──────────────────────────────────────────────────────────
# Enable one or more methods to activate the login page.
# SPARC_ENABLE_LOCAL_LOGIN=true
# SPARC_ENABLE_USER_REGISTRATION=false
# SPARC_SESSION_TIMEOUT_MINUTES=60

# ── API Authentication Mode ───────────────────────────────────────────────
# Controls which auth method the REST API accepts (mutually exclusive):
#   local  — SPARC-issued Bearer tokens only (default)
#   oidc   — OIDC/Okta JWT tokens only (requires SPARC_OIDC_ISSUER_URL)
#   hybrid — JWTs for humans + SPARC tokens for service accounts (recommended)
#
# Recommended for production: hybrid
#   - Humans authenticate via Okta JWT (MFA enforced by IdP)
#   - CI/CD pipelines authenticate via SPARC tokens (service accounts only)
#   - Audit logs distinguish auth_mode: "oidc" vs "service_token"
#
# SPARC_API_AUTH=hybrid
# SPARC_API_OIDC_AUDIENCE=your-api-audience  # Optional, defaults to SPARC_OIDC_CLIENT_ID

# ── OIDC / OAuth2 (e.g., Okta, Entra ID, Keycloak, Auth0) ─────────────────
# SPARC_ENABLE_OIDC=true
# SPARC_OIDC_ISSUER_URL=https://your-idp.okta.com
# SPARC_OIDC_CLIENT_ID=your-client-id
# SPARC_OIDC_CLIENT_SECRET=your-client-secret
# SPARC_OIDC_REDIRECT_URI=https://sparc.yourdomain.com/auth/oidc/callback
# SPARC_OIDC_SCOPES=openid profile email
# SPARC_OIDC_PROVIDER_TITLE=Corporate Login (Okta)
# SPARC_OIDC_FORCE_MFA=true

# ── LDAP ────────────────────────────────────────────────────────────────────
# SPARC_ENABLE_LDAP=true
# SPARC_LDAP_HOST=ldap.yourdomain.com
# SPARC_LDAP_PORT=636
# SPARC_LDAP_ENCRYPTION=simple_tls
# SPARC_LDAP_BIND_DN=cn=sparc-svc,ou=services,dc=yourdomain,dc=com
# SPARC_LDAP_BIND_PASSWORD=CHANGE_ME
# SPARC_LDAP_BASE=ou=people,dc=yourdomain,dc=com
# SPARC_LDAP_ATTRIBUTE=sAMAccountName

# ── Logging ─────────────────────────────────────────────────────────────────
SPARC_LOG_LEVEL=info
SPARC_LOG_TO_STDOUT=true
# SPARC_STRUCTURED_LOGGING=true    # Enable for CloudWatch/ELK/Splunk

# ── Email / SMTP ────────────────────────────────────────────────────────────
# SPARC_ENABLE_SMTP=true
# SPARC_SMTP_ADDRESS=smtp.sendgrid.net
# SPARC_SMTP_PORT=587
# SPARC_SMTP_USERNAME=apikey
# SPARC_SMTP_PASSWORD=CHANGE_ME
# SPARC_SMTP_AUTH=plain
# SPARC_SMTP_STARTTLS_AUTO=true
# SPARC_SMTP_FROM_ADDRESS=no-reply@sparc.yourdomain.com

# ── Docker / Runtime ───────────────────────────────────────────────────────
# SPARC_RUN_SEEDS=false
# SPARC_SEED_MODE=full
# SPARC_SEED_DEMO=false

# ── Background Jobs ───────────────────────────────────────────────────────
# Run Solid Queue inside Puma for single-container ECS deployments.
# Set to true unless running a separate worker container.
SOLID_QUEUE_IN_PUMA=true

# ── AWS / Storage ───────────────────────────────────────────────────────────
ACTIVE_STORAGE_SERVICE=amazon
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=us-east-1
AWS_BUCKET=sparc-uploads

# ── Service Account Lifecycle ─────────────────────────────────────────────
# SPARC_SA_INACTIVITY_DAYS=90  # Days before unused service account is auto-disabled

# ── AWS Secrets Manager (ECS/EC2 deployments) ─────────────────────────────
# Two-secret strategy (aligned with sparc-iac #22):
#   Secret 1: admin-credentials (break-glass password, MFA-gated IAM role)
#   Secret 2: app-config (JSON blob with all other config, injected at boot)
# When enabled, the app reads the JSON blob and injects keys into ENV.
# Existing ENV vars take precedence — they are never overwritten.
# SPARC_AWS_SECRETS_ENABLED=true
# SPARC_APP_CONFIG_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456:secret:sparc-prod/app-config
# SPARC_ADMIN_CREDENTIALS_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456:secret:sparc-prod/admin-credentials

# ── AWS IAM Database Authentication ──────────────────────────────────────
# Use IAM auth tokens instead of static DB passwords. Requires:
#   - RDS with iam_database_authentication_enabled = true
#   - ECS task role with rds-db:connect permission
#   - DB user with rds_iam role granted
# SPARC_AWS_IAM_DB_AUTH=true
# SPARC_AWS_REGION=us-east-1

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── DISA CCI Retrieval ────────────────────────────────────────────────────────────────
SPARC_CCI_REVS=4,5 # (defualts to 4, 5 to get 800-53 Rev4 and Rev5 CCI's)
SPARC_DISA_CCI_URL= # Defaults to https://dl.dod.cyber.mil/wp-content/uploads/stigs/zip/U_CCI_List.zip